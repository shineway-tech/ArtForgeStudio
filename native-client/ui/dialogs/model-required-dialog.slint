import { AppState } from "../app-state.slint";
import { DialogCloseButton } from "../components/dialog-close-button.slint";
import { PillButton } from "../components/pill-button.slint";
import { AppTheme } from "../theme.slint";

export component ModelRequiredDialog {
    if AppState.model-required-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        dialog := Rectangle {
            width: min(330px, root.width - 32px);
            height: min(170px, root.height - 40px);
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.model-required-open = false; } }
            VerticalLayout {
                padding: 22px;
                spacing: 18px;
                Text { text: AppState.en ? "Please add a model first" : "请先添加模型"; color: AppTheme.text; font-size: 18px; font-weight: 500; horizontal-alignment: center; }
                HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Cancel" : "取消"; clicked => { AppState.model-required-open = false; } }
                    PillButton {
                        horizontal-stretch: 1;
                        text: AppState.en ? "View Models" : "查看模型";
                        primary: true;
                        clicked => {
                            AppState.model-required-open = false;
                            AppState.settings-section = "models";
                            AppState.navigate("settings");
                        }
                    }
                }
            }
        }
    }
}
