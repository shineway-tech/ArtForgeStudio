import { AppState } from "../app-state.slint";
import { DialogCloseButton } from "../components/dialog-close-button.slint";
import { AppTheme } from "../theme.slint";

export component AliPayQrDialog {
    if AppState.payment-qr-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 340px) / 2;
            y: (parent.height - 350px) / 2;
            width: 340px;
            height: 350px;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton {
                x: parent.width - 40px;
                y: 10px;
                clicked => { AppState.close-payment-window(); AppState.payment-qr-open = false; }
            }
            VerticalLayout {
                padding: 18px;
                spacing: 16px;
                Text {
                    height: 30px;
                    width: parent.width - 36px;
                    text: AppState.en ? "Alipay QR payment" : "支付宝扫码支付";
                    color: AppTheme.text;
                    font-size: 15px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
                HorizontalLayout {
                    height: 232px;
                    alignment: center;
                    Rectangle {
                        width: 232px;
                        height: 232px;
                        background: #ffffff;
                        border-radius: 6px;
                        Text {
                            x: 6px;
                            y: 6px;
                            width: 220px;
                            height: 220px;
                            text: AppState.en ? "Loading payment QR..." : "正在加载支付二维码...";
                            color: AppTheme.muted;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                HorizontalLayout {
                    height: 20px;
                    alignment: center;
                    spacing: 8px;
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: AppTheme.success;
                    }
                    Text {
                        text: AppState.payment-qr-message == "" ? (AppState.en ? "Waiting for Alipay payment..." : "正在等待支付宝付款结果...") : AppState.payment-qr-message;
                        color: AppTheme.muted;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
