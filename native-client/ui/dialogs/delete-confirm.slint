import { AppState } from "../app-state.slint";
import { DialogCloseButton } from "../components/dialog-close-button.slint";
import { PillButton } from "../components/pill-button.slint";
import { AppTheme } from "../theme.slint";

export component DeleteConfirm {
    function close-dialog() {
        AppState.delete-confirm-open = false;
        AppState.pending-delete-kind = "";
        AppState.pending-delete-id = "";
        AppState.pending-delete-source = "";
    }

    function confirm-pending-delete() {
        if AppState.pending-delete-kind == "custom-prompt" {
            AppState.remove-custom-prompt(AppState.pending-delete-id);
        } else if AppState.pending-delete-kind == "notification" {
            AppState.delete-notification(AppState.pending-delete-id);
        } else if AppState.pending-delete-kind == "notifications-all" {
            AppState.clear-all-notifications();
        } else if AppState.pending-delete-kind == "canvas-group" {
            AppState.remove-canvas-group-with-children(AppState.pending-delete-id);
        } else if AppState.pending-delete-kind == "canvas-note" {
            AppState.remove-canvas-node(AppState.pending-delete-id);
        } else if AppState.pending-delete-kind == "canvas-selection" {
            AppState.remove-canvas-selection();
        } else if AppState.pending-delete-kind == "canvas-link" {
            AppState.remove-canvas-link(AppState.pending-delete-id);
        } else {
            AppState.confirm-delete();
        }
        root.close-dialog();
    }

    if AppState.delete-confirm-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        dialog := Rectangle {
            width: min(330px, root.width - 32px);
            height: min(180px, root.height - 40px);
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { root.close-dialog(); } }
            VerticalLayout {
                padding: 22px;
                spacing: 18px;
                Text {
                    text: AppState.pending-delete-kind == "custom-prompt"
                        ? (AppState.en ? "Delete this prompt?" : "确认删除这条提示词？")
                        : (AppState.pending-delete-kind == "canvas-group"
                            ? (AppState.en ? "Delete this group and all nodes inside it?" : "是否删除当前分组以及组内节点？")
                            : (AppState.pending-delete-kind == "canvas-note"
                            ? (AppState.en ? "Delete this node?" : "确认删除这个节点？")
                            : (AppState.pending-delete-kind == "canvas-selection"
                                ? (AppState.en ? "Delete selected nodes?" : "确认删除所选节点？")
                            : (AppState.pending-delete-kind == "canvas-link"
                                ? (AppState.en ? "Delete this connection?" : "确认删除这条连接？")
                                : (AppState.pending-delete-kind == "notification"
                            ? (AppState.en ? "Delete this notification?" : "确认删除这条通知？")
                            : (AppState.pending-delete-kind == "notifications-all"
                                ? (AppState.en ? "Delete all notifications?" : "确认删除全部通知？")
                                : (AppState.en ? "Delete this asset?" : "确认删除这个资产？")))))));
                    color: AppTheme.text;
                    font-size: 18px;
                    font-weight: 600;
                }
                Text {
                    text: AppState.pending-delete-kind == "notifications-all"
                        ? (AppState.en ? "All notifications will be permanently deleted." : "所有通知都将被删除，且无法恢复。")
                        : (AppState.pending-delete-kind == "canvas-group"
                            ? (AppState.en ? "You can restore it with Undo." : "可通过画布撤销恢复。")
                            : (AppState.pending-delete-kind == "custom-prompt" || AppState.pending-delete-kind == "notification" || AppState.pending-delete-kind == "canvas-note" || AppState.pending-delete-kind == "canvas-selection" || AppState.pending-delete-kind == "canvas-link"
                            ? (AppState.en ? "This action cannot be undone." : "删除后无法恢复。")
                            : (AppState.en ? "It will be removed from My Assets." : "删除后将从我的资产中移除。")));
                    color: AppTheme.muted;
                    font-size: 13px;
                    font-weight: 400;
                }
                HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Cancel" : "取消"; clicked => { root.close-dialog(); } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Delete" : "删除"; danger: true; clicked => { root.confirm-pending-delete(); } }
                }
            }
        }
    }
}
