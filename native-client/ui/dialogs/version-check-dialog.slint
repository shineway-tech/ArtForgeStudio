import { AppState } from "../app-state.slint";
import { DialogCloseButton } from "../components/dialog-close-button.slint";
import { PillButton } from "../components/pill-button.slint";
import { AppTheme } from "../theme.slint";

export component VersionCheckDialog {
    if AppState.update-result-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        dialog := Rectangle {
            width: min(380px, root.width - 32px);
            height: min(220px, root.height - 40px);
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.update-result-open = false; } }
            VerticalLayout {
                padding: 22px;
                spacing: 14px;
                Text {
                    text: AppState.en ? "Version Check" : "版本检查";
                    color: AppTheme.text;
                    font-size: 18px;
                    font-weight: 500;
                    horizontal-alignment: center;
                }
                Text {
                    height: 54px;
                    text: AppState.update-message;
                    color: AppTheme.muted;
                    font-size: 13px;
                    font-weight: 400;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
                PillButton {
                    horizontal-stretch: 1;
                    text: AppState.en ? "OK" : "知道了";
                    primary: true;
                    clicked => { AppState.update-result-open = false; }
                }
            }
        }
    }
}
