import { AppState } from "../app-state.slint";
import { PillButton } from "../components/pill-button.slint";
import { AppTheme } from "../theme.slint";

export component UpdateProgressDialog {
    if AppState.update-progress-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        dialog := Rectangle {
            width: min(420px, root.width - 32px);
            height: min(250px, root.height - 40px);
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text {
                x: 24px;
                y: 24px;
                width: parent.width - 48px;
                height: 26px;
                text: AppState.en ? "Updating ArtForgeStudio" : "正在更新 ArtForgeStudio";
                color: AppTheme.text;
                font-size: 18px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Text {
                x: 24px;
                y: 58px;
                width: parent.width - 48px;
                height: 42px;
                text: AppState.update-ready ? (AppState.en ? "Update is ready. Restart now to apply it." : "更新已准备完成，立即更新后客户端将自动关闭并重启。")
                    : (AppState.en ? "Preparing update..." : "正在准备更新...");
                color: AppTheme.muted;
                font-size: 13px;
                font-weight: 400;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }
            Rectangle {
                x: 34px;
                y: 116px;
                width: parent.width - 68px;
                height: 12px;
                background: AppTheme.panel-soft;
                border-radius: 6px;
                border-width: 1px;
                border-color: AppTheme.border;
                Rectangle {
                    width: (parent.width - 2px) * AppState.update-progress / 100;
                    height: parent.height - 2px;
                    x: 1px;
                    y: 1px;
                    border-radius: 5px;
                    background: AppTheme.accent;
                }
            }
            Text {
                x: 34px;
                y: 136px;
                width: parent.width - 68px;
                height: 20px;
                text: AppState.update-progress + "%";
                color: AppTheme.text;
                font-size: 13px;
                font-weight: 400;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            PillButton {
                x: 34px;
                y: 190px;
                width: parent.width - 68px;
                height: 40px;
                text: AppState.en ? "Restart Now" : "立即更新";
                primary: true;
                disabled: !AppState.update-ready;
                clicked => { AppState.restart-after-update(); }
            }
        }
    }
}
