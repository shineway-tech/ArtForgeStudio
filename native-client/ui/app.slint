    Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: root.primary ? #ffffff : #11151c;
        font-size: 14px;
        font-weight: root.primary ? 500 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.clicked(); } }
}

