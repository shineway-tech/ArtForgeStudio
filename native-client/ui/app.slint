component SettingsPage {
    property <string> active-section: "basic";
    Rectangle {
        background: AppTheme.bg;
        ScrollView {
            width: parent.width;
            height: parent.height;
            Rectangle {
                property <length> left-w: 250px;
                property <length> gap: 28px;
                property <length> content-x: 24px + left-w + gap;
                property <length> content-w: parent.width - content-x - 48px;
                x: 0px;
                y: 0px;
                width: parent.width;
                height: max(960px, parent.height);
                background: transparent;

                Rectangle {
                    x: 24px;
                    y: 30px;
                    width: left-w;
                    height: parent.height - 60px;
                    background: AppTheme.panel;
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: AppTheme.border;
                    Text { x: 18px; y: 24px; text: AppState.en ? "Settings" : "设置"; color: AppTheme.text; font-size: 22px; font-weight: 600; }
                    Rectangle {
                        x: 16px;
                        y: 86px;
                        width: parent.width - 32px;
                        height: 62px;
                        background: root.active-section == "basic" ? AppTheme.panel-soft : transparent;
                        border-radius: 10px;
                        if root.active-section == "basic": Rectangle { x: 0px; y: 14px; width: 3px; height: 24px; border-radius: 2px; background: AppTheme.accent; }
                        Text { x: 18px; y: 10px; text: AppState.en ? "Basic" : "基础设置"; color: root.active-section == "basic" ? AppTheme.text : AppTheme.muted; font-size: 14px; font-weight: 400; }
                        Text { x: 18px; y: 34px; text: AppState.en ? "Theme, font, folders" : "主题、字体、目录"; color: AppTheme.weak; font-size: 12px; font-weight: 400; }
                        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.active-section = "basic"; } }
                    }
                    Rectangle {
                        x: 16px;
                        y: 168px;
                        width: parent.width - 32px;
                        height: 62px;
                        background: root.active-section == "about" ? AppTheme.panel-soft : transparent;
                        border-radius: 10px;
                        if root.active-section == "about": Rectangle { x: 0px; y: 14px; width: 3px; height: 24px; border-radius: 2px; background: AppTheme.accent; }
                        Text { x: 18px; y: 10px; text: AppState.en ? "About" : "关于"; color: root.active-section == "about" ? AppTheme.text : AppTheme.muted; font-size: 14px; font-weight: 400; }
                        Text { x: 18px; y: 34px; text: AppState.en ? "Version and paths" : "版本与配置位置"; color: AppTheme.weak; font-size: 12px; font-weight: 400; }
                        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.active-section = "about"; } }
                    }
                }

                Text {
                    x: content-x;
                    y: 38px;
                    width: content-w;
                    text: root.active-section == "about" ? (AppState.en ? "About" : "关于") : (AppState.en ? "Basic Settings" : "基础设置");
                    color: AppTheme.text;
                    font-size: 24px;
                    font-weight: 600;
                }
                if root.active-section == "basic": Rectangle {
                    x: content-x;
                    y: 96px;
                    width: content-w;
                    height: 270px;
                    background: transparent;
                    Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: AppTheme.border; }
                    Text { x: 0px; y: 0px; text: AppState.en ? "Theme color" : "主题颜色"; color: AppTheme.text; font-size: 14px; font-weight: 400; }
                    ThemeTile { x: 0px; y: 38px; width: (parent.width - 16px) / 3; id: "light"; label: AppState.en ? "Light" : "素白"; color: #ffffff; }
                    ThemeTile { x: ((parent.width - 16px) / 3 + 8px); y: 38px; width: (parent.width - 16px) / 3; id: "deep"; label: AppState.en ? "Deep Purple" : "深紫"; color: #4f46e5; }
                    ThemeTile { x: 2 * ((parent.width - 16px) / 3 + 8px); y: 38px; width: (parent.width - 16px) / 3; id: "ocean"; label: AppState.en ? "Ocean Blue" : "深海蓝"; color: #0ea5e9; }
                    ThemeTile { x: 0px; y: 94px; width: (parent.width - 16px) / 3; id: "forest"; label: AppState.en ? "Forest Green" : "森林绿"; color: #38c172; }
                    ThemeTile { x: ((parent.width - 16px) / 3 + 8px); y: 94px; width: (parent.width - 16px) / 3; id: "warm"; label: AppState.en ? "Warm Ink" : "暖墨棕"; color: #f59e0b; }
                    ThemeTile { x: 2 * ((parent.width - 16px) / 3 + 8px); y: 94px; width: (parent.width - 16px) / 3; id: "rose"; label: AppState.en ? "Rose" : "暗玫瑰"; color: #e11d48; }
                    ThemeTile { x: 0px; y: 150px; width: (parent.width - 16px) / 3; id: "cream"; label: AppState.en ? "Cream" : "奶白"; color: #c96b73; }
                    ThemeTile { x: ((parent.width - 16px) / 3 + 8px); y: 150px; width: (parent.width - 16px) / 3; id: "cyber"; label: AppState.en ? "Cyber Purple" : "赛博紫"; color: #d946ef; }
                    ThemeTile { x: 2 * ((parent.width - 16px) / 3 + 8px); y: 150px; width: (parent.width - 16px) / 3; id: "oled"; label: AppState.en ? "Black" : "纯黑"; color: #000000; }
                    ThemeTile { x: 0px; y: 206px; width: (parent.width - 16px) / 3; id: "system"; label: AppState.en ? "System" : "跟随系统"; color: #5b6472; }
                    ThemeTile { x: ((parent.width - 16px) / 3 + 8px); y: 206px; width: (parent.width - 16px) / 3; id: "user"; label: AppState.en ? "Custom" : "自定义"; color: #5b5fc7; }
                }
                if root.active-section == "basic": Rectangle {
                    x: content-x;
                    y: 386px;
                    width: content-w;
                    height: 142px;
                    background: transparent;
                    Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: AppTheme.border; }
                    Text { x: 0px; y: 0px; text: AppState.en ? "Font" : "字体"; color: AppTheme.text; font-size: 14px; font-weight: 400; }
                    FontPicker { x: 0px; y: 36px; width: parent.width; }
                    HorizontalLayout {
                        x: 0px;
                        y: 94px;
                        width: 240px;
                        height: 36px;
                        spacing: 12px;
                        FontStepButton { horizontal-stretch: 0; text: "-"; clicked => { AppState.settings-font-size = max(10, AppState.settings-font-size - 1); } }
                        Text { width: 28px; horizontal-stretch: 0; text: AppState.settings-font-size; color: AppTheme.accent-dark; font-size: 16px; font-weight: 400; vertical-alignment: center; }
                        FontStepButton { horizontal-stretch: 0; text: "+"; clicked => { AppState.settings-font-size = min(24, AppState.settings-font-size + 1); } }
                        Text { width: 72px; horizontal-stretch: 0; text: "10 - 24"; color: AppTheme.muted; font-size: 13px; font-weight: 400; vertical-alignment: center; }
                    }
                }
                if root.active-section == "basic": Rectangle {
                    x: content-x;
                    y: 550px;
                    width: content-w;
                    height: 142px;
                    background: transparent;
                    Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: AppTheme.border; }
                    Text { x: 0px; y: 0px; text: AppState.en ? "Card style" : "卡片设置"; color: AppTheme.text; font-size: 14px; font-weight: 400; }
                    HorizontalLayout {
                        x: 0px;
                        y: 36px;
                        width: parent.width;
                        height: 46px;
                        spacing: 12px;
                        CardStyleOption { horizontal-stretch: 1; id: "rounded"; label: AppState.en ? "Rounded" : "圆角"; }
                        CardStyleOption { horizontal-stretch: 1; id: "square"; label: AppState.en ? "Square" : "直角"; }
                    }
                }
                if root.active-section == "basic": DirRow { x: content-x; y: 714px; width: content-w; label: AppState.en ? "Input folder" : "输入素材目录"; value: AppState.input-dir; kind: "input"; }
                if root.active-section == "basic": DirRow { x: content-x; y: 792px; width: content-w; label: AppState.en ? "Output folder" : "输出目录"; value: AppState.output-dir; kind: "output"; }
                if root.active-section == "basic": DirRow { x: content-x; y: 870px; width: content-w; label: AppState.en ? "Prompt folder" : "提示词模板目录"; value: AppState.prompt-dir; kind: "prompt"; }
                if root.active-section == "about": Rectangle {
                    x: content-x;
                    y: 96px;
                    width: content-w;
                    height: 270px;
                    background: AppTheme.panel;
                    border-radius: 14px;
                    border-width: 1px;
                    border-color: AppTheme.border;
                    Text { x: 18px; y: 18px; text: AppState.en ? "Version" : "版本信息"; color: AppTheme.text; font-size: 14px; font-weight: 400; }
                    Text { x: 18px; y: 58px; text: "ArtForgeStudio"; color: AppTheme.text; font-size: 18px; font-weight: 500; }
                    Text { x: 18px; y: 88px; text: AppState.en ? ("Version: " + AppState.current-version) : ("版本：" + AppState.current-version); color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                    if AppState.update-available: Rectangle {
                        x: 18px;
                        y: 116px;
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: AppTheme.danger;
                    }
                    Text {
                        visible: AppState.update-available || AppState.update-checking || AppState.update-message != "";
                        x: 34px;
                        y: 110px;
                        width: parent.width - 300px;
                        height: 22px;
                        text: AppState.update-checking ? (AppState.en ? "Checking for updates..." : "正在检查版本...")
                            : (AppState.update-available ? (AppState.en ? ("New version " + AppState.latest-version + " available") : ("发现新版本 " + AppState.latest-version))
                            : AppState.update-message);
                        color: AppState.update-available ? AppTheme.danger : AppTheme.muted;
                        font-size: 13px;
                        font-weight: 400;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    HorizontalLayout {
                        x: parent.width - 246px;
                        y: 78px;
                        width: 220px;
                        height: 36px;
                        spacing: 10px;
                        PillButton {
                            horizontal-stretch: 1;
                            text: AppState.update-checking ? (AppState.en ? "Checking" : "检查中") : (AppState.en ? "Check" : "检查版本");
                            disabled: AppState.update-checking;
                            clicked => { AppState.check-version(); }
                        }
                        PillButton {
                            horizontal-stretch: 1;
                            text: AppState.en ? "Update" : "更新";
                            primary: AppState.update-available;
                            disabled: !AppState.update-available || AppState.update-checking;
                            clicked => { AppState.start-update(); }
                        }
                    }
                    if AppState.update-checking: LoadingDots {
                        x: parent.width - 268px;
                        y: 75px;
                        width: 28px;
                        height: 28px;
                    }
                    Rectangle { x: 18px; y: 150px; width: parent.width - 36px; height: 1px; background: AppTheme.border; }
                    Text { x: 18px; y: 176px; text: AppState.en ? "Config path" : "配置位置"; color: AppTheme.text; font-size: 14px; font-weight: 400; }
                    Text { x: 18px; y: 206px; width: parent.width - 36px; text: AppState.input-dir; color: AppTheme.muted; font-size: 13px; font-weight: 400; overflow: elide; }
                }
            }
        }
    }
}

component ViewerNavButton {
    in property <string> direction: "next";
    callback clicked();
    width: 52px;
    height: 52px;
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: touch.has-hover ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 26px;
        border-width: 1px;
        border-color: touch.has-hover ? AppTheme.accent : AppTheme.border;
        Text {
            width: parent.width;
            height: parent.height;
            text: root.direction == "prev" ? "‹" : "›";
            color: AppTheme.text;
            font-size: 36px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component ViewerContextMenuItem {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked();
    height: 38px;
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: touch.has-hover ? (root.danger ? #fff1f1 : AppTheme.panel-soft) : transparent;
        border-radius: 6px;
        Text {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.text;
            color: root.danger ? AppTheme.danger : AppTheme.text;
            font-size: 14px;
            font-weight: 400;
            vertical-alignment: center;
        }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component ViewerOverlay {
    property <length> viewer-message-width: min(360px, max(220px, root.width - 80px));
    property <length> detail-panel-width: AppState.viewer-source == "reference" ? 0px : 396px;
    property <length> viewer-content-right: root.width - root.detail-panel-width;
    property <length> viewer-padding: 24px;
    property <length> viewer-nav-lane: AppState.viewer-source == "reference" ? 0px : 84px;
    property <length> viewer-nav-size: 52px;
    property <bool> context-menu-open: false;
    property <length> context-menu-x: 0px;
    property <length> context-menu-y: 0px;
    property <length> context-menu-width: 148px;
    property <length> context-menu-height: 170px;
    if AppState.viewer-open: Rectangle {
        background: AppTheme.bg;
        Timer {
            interval: 2200ms;
            running: AppState.viewer-message != "";
            triggered => { AppState.viewer-message = ""; }
        }
        PillButton { x: 24px; y: 24px; width: 88px; text: AppState.en ? "← Back" : "← 返回"; clicked => { AppState.close-viewer(); } }
        Rectangle {
            x: AppState.viewer-source == "reference" ? 128px : root.viewer-padding + root.viewer-nav-lane;
            y: 78px;
            width: AppState.viewer-source == "reference" ? parent.width - 256px : root.viewer-content-right - root.viewer-padding * 2 - root.viewer-nav-lane * 2;
            height: parent.height - 112px;
            background: transparent;
            Image {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                source: AppState.viewer-image;
                image-fit: contain;
            }
            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                pointer-event(event) => {
                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                        root.context-menu-open = true;
                        root.context-menu-x = self.absolute-position.x + self.mouse-x;
                        root.context-menu-y = self.absolute-position.y + self.mouse-y;
                    } else if event.kind == PointerEventKind.down {
                        root.context-menu-open = false;
                    }
                }
            }
            if AppState.viewer-processing: Rectangle {
                width: parent.width;
                height: parent.height;
                background: #00000099;
                ProgressSpinner {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    label: AppState.viewer-processing-label;
                    progress: AppState.viewer-processing-progress;
                }
                TouchArea { width: parent.width; height: parent.height; }
            }
        }
        if AppState.viewer-source != "reference": ViewerNavButton {
            x: root.viewer-padding + (root.viewer-nav-lane - root.viewer-nav-size) / 2;
            y: (parent.height - 52px) / 2;
            direction: "prev";
            clicked => { AppState.viewer-prev(); }
        }
        if AppState.viewer-source != "reference": ViewerNavButton {
            x: root.viewer-content-right - root.viewer-padding - root.viewer-nav-lane + (root.viewer-nav-lane - root.viewer-nav-size) / 2;
            y: (parent.height - 52px) / 2;
            direction: "next";
            clicked => { AppState.viewer-next(); }
        }
        if AppState.viewer-message != "": Rectangle {
            x: (parent.width - root.viewer-message-width) / 2;
            y: parent.height - 74px;
            width: root.viewer-message-width;
            height: 42px;
            background: #111827d8;
            border-radius: 21px;
            Text {
                x: 18px;
                width: parent.width - 36px;
                height: parent.height;
                text: AppState.viewer-message;
                color: #ffffff;
                font-size: 14px;
                font-weight: 400;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }
        if AppState.viewer-source != "reference": Rectangle {
            x: root.viewer-content-right;
            y: 0px;
            width: root.detail-panel-width;
            height: parent.height;
            background: AppTheme.panel;
            border-width: 1px;
            border-color: AppTheme.border;
            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                if AppState.viewer-source == "asset": Rectangle {
                    height: 40px;
                    background: transparent;
                    PillButton { x: 0px; width: 128px; text: AppState.en ? "Open Folder" : "打开文件夹位置"; primary: true; clicked => { AppState.viewer-download-image(); } }
                    PillButton { x: parent.width - 72px; width: 72px; text: "删除"; danger: true; clicked => { AppState.request-delete-asset(AppState.viewer-id); } }
                }
                Text { text: AppState.en ? "Prompt" : "图片提示词"; color: AppTheme.muted; font-size: 14px; font-weight: 400; }
                ScrollView {
                    horizontal-stretch: 1;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    height: min(360px, max(24px, (AppState.viewer-prompt-lines > 20 ? 20 : AppState.viewer-prompt-lines) * 18px));
                    viewport-width: self.width;
                    viewport-height: max(self.height, AppState.viewer-prompt-lines * 18px);
                    Text {
                        width: parent.width;
                        height: parent.viewport-height;
                        text: AppState.viewer-prompt;
                        color: AppTheme.text;
                        font-size: 13px;
                        font-weight: 400;
                        wrap: word-wrap;
                    }
                }
                Text { text: AppState.viewer-time + " · " + AppState.viewer-ratio + " · " + AppState.viewer-quality; color: AppTheme.muted; font-size: 12px; font-weight: 400; }
                Rectangle { height: 1px; background: AppTheme.border; }
                SectionTitle { text: AppState.en ? "Image Info" : "图像信息"; }
                GridLayout {
                    spacing: 10px;
                    Row { InfoCard { label: AppState.en ? "Size" : "尺寸"; value: AppState.viewer-width + " x " + AppState.viewer-height; } InfoCard { label: AppState.en ? "Ratio" : "宽高比"; value: AppState.viewer-ratio; } }
                    Row { InfoCard { label: AppState.en ? "Quality" : "清晰度"; value: AppState.viewer-quality; } InfoCard { label: AppState.en ? "Model" : "模型"; value: AppState.viewer-model; } }
                }
                if AppState.viewer-source != "inspiration": HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Cutout" : "抠图"; primary: true; disabled: AppState.viewer-processing || AppState.viewer-cutout-done; clicked => { AppState.viewer-cutout-image(); } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Remove Black" : "去黑"; primary: true; disabled: AppState.viewer-processing || AppState.viewer-remove-black-done; clicked => { AppState.viewer-remove-black(); } }
                }
                if AppState.viewer-source != "inspiration": PillButton { horizontal-stretch: 1; text: AppState.en ? "Clear Upscale" : "清晰放大"; primary: true; disabled: AppState.viewer-processing || AppState.viewer-upscale-done; clicked => { AppState.open-upscale-dialog(); } }
                Rectangle { vertical-stretch: 1; }
                if AppState.viewer-source != "inspiration": HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Edit Again" : "重新编辑"; primary: true; clicked => { AppState.viewer-edit(); } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Generate Again" : "再次生成"; primary: true; clicked => { AppState.viewer-regenerate(); } }
                }
                if AppState.viewer-source == "inspiration": HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Use Style" : "做同款"; primary: true; clicked => { AppState.viewer-use-same(); } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Use as Ref" : "用作参考图"; primary: true; clicked => { AppState.viewer-use-reference(); } }
                }
            }
        }
        if root.context-menu-open: Rectangle {
            x: max(12px, min(root.context-menu-x, parent.width - root.context-menu-width - 12px));
            y: max(12px, min(root.context-menu-y, parent.height - root.context-menu-height - 12px));
            width: root.context-menu-width;
            height: root.context-menu-height;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            drop-shadow-blur: 18px;
            drop-shadow-color: #0000002d;
            VerticalLayout {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                spacing: 2px;
                ViewerContextMenuItem {
                    text: AppState.en ? "Open Folder" : "打开文件夹位置";
                    clicked => {
                        root.context-menu-open = false;
                        AppState.viewer-download-image();
                    }
                }
                ViewerContextMenuItem {
                    text: AppState.en ? "Copy" : "复制";
                    clicked => {
                        root.context-menu-open = false;
                        AppState.viewer-copy-image();
                    }
                }
                ViewerContextMenuItem {
                    text: AppState.en ? "Use as Ref" : "用作参考图";
                    clicked => {
                        root.context-menu-open = false;
                        AppState.viewer-use-reference();
                    }
                }
                ViewerContextMenuItem {
                    text: AppState.en ? "Delete" : "删除";
                    danger: true;
                    clicked => {
                        root.context-menu-open = false;
                        AppState.request-delete-asset(AppState.viewer-id);
                    }
                }
            }
        }
    }
}

component UpscaleDialog {
    function dialog-width() -> length {
        return min(920px, root.width - 80px);
    }
    function dialog-height() -> length {
        return min(560px, root.height - 80px);
    }
    function frame-size() -> length {
        return 112px * AppState.upscale-scale;
    }
    if AppState.upscale-open: Rectangle {
        background: #00000076;
        TouchArea { width: parent.width; height: parent.height; clicked => { if !AppState.viewer-processing { AppState.close-upscale-dialog(); } } }
        Rectangle {
            x: (parent.width - root.dialog-width()) / 2;
            y: (parent.height - root.dialog-height()) / 2;
            width: root.dialog-width();
            height: root.dialog-height();
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            drop-shadow-blur: 30px;
            drop-shadow-color: #00000036;
            Text {
                x: 24px;
                y: 20px;
                width: parent.width - 92px;
                height: 32px;
                text: AppState.en ? "Clear Upscale" : "清晰放大";
                color: AppTheme.text;
                font-size: 20px;
                font-weight: 600;
                vertical-alignment: center;
            }
            PillButton {
                x: parent.width - 68px;
                y: 18px;
                width: 44px;
                height: 34px;
                text: "×";
                disabled: AppState.viewer-processing;
                clicked => { AppState.close-upscale-dialog(); }
            }
            preview := Rectangle {
                x: 24px;
                y: 70px;
                width: parent.width - 314px;
                height: parent.height - 94px;
                background: #0e1117;
                border-radius: 10px;
                border-width: 1px;
                border-color: #202633;
                clip: true;
                Text {
                    x: 12px;
                    y: 10px;
                    width: 64px;
                    height: 20px;
                    text: AppState.upscale-scale + "x";
                    color: #ffffffa0;
                    font-size: 12px;
                    font-weight: 400;
                }
                frame := Rectangle {
                    x: (parent.width - root.frame-size()) / 2;
                    y: (parent.height - root.frame-size()) / 2;
                    width: root.frame-size();
                    height: root.frame-size();
                    background: #111827;
                    border-width: 2px;
                    border-color: #ffffffd8;
                    clip: true;
                    animate width { duration: 160ms; }
                    animate height { duration: 160ms; }
                    animate x { duration: 160ms; }
                    animate y { duration: 160ms; }
                    Image {
                        x: (parent.width - min(210px, parent.width - 40px)) / 2;
                        y: (parent.height - min(210px, parent.height - 40px)) / 2;
                        width: min(210px, parent.width - 40px);
                        height: min(210px, parent.height - 40px);
                        source: AppState.viewer-image;
                        image-fit: contain;
                    }
                }
            }
            Rectangle {
                x: parent.width - 266px;
                y: 70px;
                width: 242px;
                height: parent.height - 94px;
                background: transparent;
                VerticalLayout {
                    spacing: 18px;
                    Text { text: AppState.en ? "Scale" : "放大倍数"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                    HorizontalLayout {
                        spacing: 8px;
                        PillButton { horizontal-stretch: 1; text: "2X"; active: AppState.upscale-scale == 2; clicked => { AppState.upscale-scale = 2; } }
                        PillButton { horizontal-stretch: 1; text: "3X"; active: AppState.upscale-scale == 3; clicked => { AppState.upscale-scale = 3; } }
                        PillButton { horizontal-stretch: 1; text: "4X"; active: AppState.upscale-scale == 4; clicked => { AppState.upscale-scale = 4; } }
                    }
                    Text { text: AppState.en ? "Quality" : "清晰度"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                    HorizontalLayout {
                        spacing: 8px;
                        PillButton { horizontal-stretch: 1; text: "2K"; active: AppState.upscale-quality == "2K"; clicked => { AppState.upscale-quality = "2K"; } }
                        PillButton { horizontal-stretch: 1; text: "4K"; active: AppState.upscale-quality == "4K"; clicked => { AppState.upscale-quality = "4K"; } }
                    }
                    Rectangle { vertical-stretch: 1; }
                    if AppState.viewer-processing: Text {
                        height: 24px;
                        text: AppState.viewer-processing-label + " " + AppState.viewer-processing-progress + "%";
                        color: AppTheme.accent-dark;
                        font-size: 13px;
                        font-weight: 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    PillButton {
                        height: 44px;
                        horizontal-stretch: 1;
                        text: AppState.en ? "Start" : "开始放大";
                        primary: true;
                        disabled: AppState.viewer-processing || AppState.viewer-upscale-done;
                        clicked => { AppState.start-upscale-image(AppState.upscale-scale, AppState.upscale-quality); }
                    }
                }
            }
        }
    }
}

component WelcomePage {
    in-out property <length> scroll-y: 0px;

    function hero-width() -> length {
        return root.width - 96px;
    }

    function hero-x() -> length {
        return 48px;
    }

    function hero-gap() -> length {
        return 52px;
    }

    function copy-width() -> length {
        return max(420px, root.hero-width() * 40 / 100);
    }

    function mosaic-width() -> length {
        return root.hero-width() - root.copy-width() - root.hero-gap();
    }

    function mosaic-height() -> length {
        return min(root.hero-height() - 76px, root.mosaic-width() * 540 / 606);
    }

    function inspiration-width() -> length {
        return root.width - 96px;
    }

    function inspiration-x() -> length {
        return 48px;
    }

    function inspiration-card-width() -> length {
        return max(267px, (root.inspiration-width() - 72px) / 4);
    }

    function hero-height() -> length {
        return max(520px, root.height - 190px);
    }

    function inspiration-title-y() -> length {
        return root.hero-height() + 72px;
    }

    function inspiration-waterfall-y() -> length {
        return root.inspiration-title-y() + 62px;
    }

    function inspiration-estimated-height() -> length {
        return max(1180px, root.inspiration-card-width() * 46 / 10);
    }

    function cta-y() -> length {
        return root.inspiration-waterfall-y() + root.inspiration-estimated-height() + 56px;
    }

    function content-height() -> length {
        return root.cta-y() + 330px;
    }

    Rectangle {
        width: root.width;
        height: root.height;
        background: AppTheme.bg;
        Flickable {
            x: 0px;
            y: 48px;
            width: parent.width;
            height: parent.height - 48px;
            viewport-width: parent.width;
            viewport-height: root.content-height();
            viewport-y <=> root.scroll-y;
            interactive: true;
            Rectangle {
                width: root.width;
                height: root.content-height();
                background: transparent;

                Rectangle {
                    x: root.hero-x();
                    y: 0px;
                    width: root.hero-width();
                    height: root.hero-height();
                    background: transparent;
                    Rectangle {
                        y: max(38px, (root.hero-height() - root.mosaic-height()) / 2);
                        width: root.hero-width();
                        height: root.mosaic-height();
                        background: transparent;
                        Rectangle {
                            x: 0px;
                            y: 0px;
                            width: root.copy-width();
                            height: parent.height;
                            background: transparent;
                            Rectangle {
                                x: 0px;
                                y: max(42px, (parent.height - 282px) / 2);
                                width: parent.width;
                                height: 282px;
                                background: transparent;
                                Text { x: 0px; y: 0px; width: parent.width; height: 80px; text: "ArtForgeStudio"; color: AppTheme.text; font-size: 60px; font-weight: 600; }
                                Text {
                                    x: 0px;
                                    y: 108px;
                                    width: parent.width;
                                    height: 86px;
                                    text: "利用 ArtForgeStudio，为您的游戏生成：角色、特效、UI、场景、精灵图、影视创作等。";
                                    color: AppTheme.muted;
                                    font-size: 24px;
                                    font-weight: 400;
                                    wrap: word-wrap;
                                }
                                PillButton { x: 0px; y: 216px; width: 168px; height: 50px; text: "立即使用"; primary: true; clicked => { AppState.use-now(); } }
                            }
                        }
                        ShowcaseMosaic { x: root.copy-width() + root.hero-gap(); y: 0px; width: root.mosaic-width(); height: root.mosaic-height(); }
                    }
                }

                SectionTitle {
                    x: root.inspiration-x();
                    y: root.inspiration-title-y();
                    width: root.inspiration-width();
                    text: "作品灵感";
                }
                InspirationWaterfall {
                    x: root.inspiration-x();
                    y: root.inspiration-waterfall-y();
                    width: root.inspiration-width();
                    card-width: root.inspiration-card-width();
                }
                Rectangle {
                    x: root.inspiration-x();
                    y: root.cta-y();
                    width: root.inspiration-width();
                    height: 250px;
                    background: AppTheme.panel-soft;
                    border-radius: 28px;
                    border-width: 1px;
                    border-color: AppTheme.border;
                    Rectangle {
                        x: 0px;
                        y: (parent.height - 156px) / 2;
                        width: parent.width;
                        height: 156px;
                        background: transparent;
                        Text {
                            x: 0px;
                            y: 0px;
                            width: parent.width;
                            height: 54px;
                            text: "登录查看全部灵感";
                            color: AppTheme.text;
                            font-size: 40px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text {
                            x: 0px;
                            y: 66px;
                            width: parent.width;
                            height: 24px;
                            text: "与 AI 一起创作不可思议的作品";
                            color: AppTheme.muted;
                            font-size: 18px;
                            font-weight: 400;
                            letter-spacing: 8px;
                            horizontal-alignment: center;
                        }
                        PillButton {
                            x: (parent.width - 180px) / 2;
                            y: 112px;
                            width: 180px;
                            height: 44px;
                            text: "立即创作";
                            primary: true;
                            clicked => { AppState.use-now(); }
                        }
                    }
                }
            }
        }
        WelcomeMarketingNav {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 48px;
        }
    }
}

component PromptComposer {
    in property <bool> generation: false;
    in property <bool> show-generate-button: true;
    height: AppState.references.length > 0 || AppState.quote-title != "" ? 480px : 430px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 16px;
        border-width: 1px;
        border-color: AppTheme.border;
        clip: false;
        if AppState.quote-title != "": Rectangle {
            x: 112px;
            y: 14px;
            height: 32px;
            width: parent.width - 136px;
            background: AppTheme.panel-soft;
            border-radius: 8px;
            Text { x: 12px; width: parent.width - 54px; height: parent.height; text: (AppState.en ? "Quoted image: " : "引用图片：") + AppState.quote-title; color: AppTheme.muted; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
            Text { x: parent.width - 34px; width: 24px; height: parent.height; text: "×"; color: AppTheme.muted; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { width: parent.width; height: parent.height; clicked => { AppState.quote-title = ""; AppState.quote-prompt = ""; AppState.quote-ratio = ""; AppState.quote-quality = ""; AppState.quote-width = 0; AppState.quote-height = 0; } }
        }
        for ref[index] in AppState.references: ReferenceThumb {
            x: root.reference-x(index);
            y: root.reference-y(index);
            item: ref;
        }
        if AppState.references.length < root.max-reference-count(): UploadCard {
            x: root.reference-x(AppState.references.length) + 4px;
            y: root.reference-y(AppState.references.length) + 4px;
            width: 56px;
            height: 64px;
            clicked => { AppState.add-reference(); }
        }
        PillButton {
            x: 24px;
            y: 14px;
            width: 78px;
            height: 28px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing..." : "正在优化...") : (AppState.en ? "AI Optimize" : "AI优化");
            primary: true;
            disabled: AppState.reasoning-model == "" || AppState.optimizing-prompt;
            clicked => { AppState.optimize-current-prompt(); }
        }
        PillButton {
            x: 110px;
            y: 14px;
            width: 88px;
            height: 28px;
            text: AppState.en ? "Image+Text" : "图文优化";
            primary: true;
            disabled: AppState.reasoning-model == "" || AppState.optimizing-prompt || AppState.references.length == 0;
            clicked => { AppState.visual-optimize-current-prompt(); }
        }
        if AppState.optimizing-prompt: LoadingDots {
            x: 204px;
            y: 7px;
            width: 30px;
            height: 30px;
        }
        Text {
            visible: AppState.optimizing-prompt || AppState.translating-prompt;
            x: 240px;
            y: 20px;
            width: parent.width - 264px;
            height: 18px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing prompt..." : "正在优化提示词...")
                : (AppState.en ? "Translating prompt..." : "正在翻译提示词...");
            color: AppTheme.text;
            font-size: 13px;
            font-weight: 400;
            overflow: elide;
        }
        prompt-input := TextInput {
            x: 24px;
            y: root.prompt-input-y();
            width: parent.width - 48px;
            height: root.prompt-input-height();
            text <=> AppState.prompt;
            single-line: false;
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            wrap: word-wrap;
            key-pressed(event) => {
                if event.modifiers.control && (event.text == "v" || event.text == "V") {
                    if AppState.paste-reference() {
                        return accept;
                    }
                }
                return reject;
            }
        }
        Text {
            visible: prompt-input.text == "" && !prompt-input.has-focus;
            x: 24px;
            y: root.prompt-input-y();
            width: parent.width - 48px;
            height: root.prompt-input-height();
            text: root.prompt-placeholder();
            color: AppTheme.weak;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            wrap: word-wrap;
        }
        HorizontalLayout {
            x: 24px;
            y: parent.height - 70px;
            spacing: 10px;
            CreationModeChip {}
            if AppState.asset-type != "action-sequence": StyleModeChip {}
            if AppState.asset-type != "action-sequence": AdvancedControlChip {}
        }
        GenerateActionButton {
            x: root.width < 560px ? parent.width - 190px : parent.width - 178px;
            y: parent.height - 78px;
            width: root.width < 560px ? 166px : 154px;
            height: 54px;
            visible: root.show-generate-button;
            disabled: !AppState.generating && AppState.reasoning-model == "";
            clicked => {
                if AppState.generating {
                    AppState.stop-generation();
                } else {
                    AppState.generate();
                }
            }
        }
        Text {
            visible: root.show-generate-button && (AppState.optimizing-prompt || AppState.translating-prompt || AppState.generating || AppState.generation-status != "");
            x: 24px;
            y: parent.height - 24px;
            width: parent.width - 48px;
            height: 16px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing prompt..." : "正在优化提示词...")
                : (AppState.translating-prompt ? (AppState.en ? "Translating prompt..." : "正在翻译提示词...")
                : (AppState.generating ? (AppState.en ? "Generating..." : "正在生成中...")
                : AppState.generation-status));
            color: AppTheme.text;
            font-size: 13px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        reference-drop := DropArea {
            width: parent.width;
            height: parent.height;
            can-drop(event) => {
                return event.mime-type == "text/uri-list" || event.mime-type == "text/plain" || event.mime-type == "application/x-artforge-image-path";
            }
            dropped(event) => {
                AppState.add-reference-from-drag(event.mime-type, event.data);
            }
        }
        if reference-drop.contains-drag: Rectangle {
            x: 8px;
            y: 8px;
            width: parent.width - 16px;
            height: parent.height - 16px;
            background: #00d98218;
            border-radius: 14px;
            border-width: 2px;
            border-color: AppTheme.accent;
            Text {
                width: parent.width;
                height: parent.height;
                text: AppState.en ? "Drop to add reference" : "松开添加为参考图";
                color: AppTheme.accent;
                font-size: 16px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    function reference-visible-count() -> int {
        return AppState.references.length + (AppState.references.length < root.max-reference-count() ? 1 : 0);
    }

    function max-reference-count() -> int {
        if AppState.asset-type == "action-sequence" { return 1; }
        return 8;
    }

    function reference-columns() -> int {
        return max(1, min(8, floor((root.width - 48px) / 72px)));
    }

    function reference-row-count() -> int {
        return max(1, (root.reference-visible-count() + root.reference-columns() - 1) / root.reference-columns());
    }

    function reference-tray-y() -> length {
        return root.height - 80px - root.reference-row-count() * 74px;
    }

    function reference-x(index: int) -> length {
        return 24px + Math.mod(index, root.reference-columns()) * 72px;
    }

    function reference-y(index: int) -> length {
        return root.reference-tray-y() + floor(index / root.reference-columns()) * 74px;
    }

    function prompt-input-y() -> length {
        return AppState.quote-title != "" ? 62px : 58px;
    }

    function prompt-input-height() -> length {
        return max(96px, root.reference-tray-y() - root.prompt-input-y() - 12px);
    }

    function prompt-placeholder() -> string {
        if AppState.mode == "film" { return AppState.en ? "Describe the script, characters, scenes, storyboard, or video" : "描述你想创作的剧本、角色、场景、分镜或视频"; }
        if AppState.en {
            if AppState.asset-type == "scene" { return "Describe the scene you want to create...\nExample: a wasteland market at dusk, steam-powered mechanical stalls, cinematic lighting, game concept art style"; }
            if AppState.asset-type == "character" { return "Describe the character you want to create...\nExample: a female knight holding a flaming longsword, full armor, dark fantasy style, complete full-body illustration design"; }
            if AppState.asset-type == "ui" { return "Describe the UI screen you want to create...\nExample: dark control-console home page, modular card layout, cyan-blue highlights, hybrid game HUD and data dashboard style"; }
            if AppState.asset-type == "effect" { return "Describe the VFX, enchantment, skill release, or sprite-sheet animation effect you want...\nExample: blue-white lightning enchantment around a sword, 8-direction continuous flicker, suitable for pixel-style RPG battle skill VFX sprite sheet"; }
            return "Describe the character, scene, UI, or effect you want";
        }
        if AppState.asset-type == "scene" { return "描述你想要创作的场景...\n例如：黄昏中的废土集市，蒸汽机械摊位，电影感光影，游戏概念图风格"; }
        if AppState.asset-type == "character" { return "描述你想要创建的角色...\n例如：一位手持火焰长剑的女骑士，全身铠甲，暗黑奇幻风格，完整立绘设计"; }
        if AppState.asset-type == "ui" { return "描述你想要创建的 UI 界面...\n例如：暗黑风控制台首页，模块化卡片布局，蓝青色高亮，游戏 HUD + 数据看板混合风格"; }
        if AppState.asset-type == "effect" { return "描述你想生成的特效、附魔、技能释放或精灵图集动态效果...\n例如：蓝白雷电附魔环绕剑身，8方向连续闪烁，适合像素风 RPG 战斗技能特效精灵图集"; }
        return "描述你想生成的角色、场景、UI 或特效";
    }
}

component StudioWorkPanel {
    in property <bool> generation: false;
    Rectangle {
        background: AppTheme.panel;
        border-width: 0px;
        border-color: transparent;
        Text {
            x: 22px;
            y: 20px;
            text: root.title-text();
            color: AppTheme.text;
            font-size: 18px;
            font-weight: 500;
        }
        Rectangle {
            x: parent.width - 198px;
            y: 21px;
            width: 176px;
            height: 22px;
            Text { x: 0px; width: 78px; height: parent.height; text: AppState.en ? "Translate" : "翻译提示词"; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
            Text { x: 78px; width: 16px; height: parent.height; text: "?"; color: AppTheme.muted; font-size: 12px; font-weight: 400; horizontal-alignment: center; vertical-alignment: center; }
            TranslateTipArea {
                x: 0px;
                y: 0px;
                width: 96px;
                height: parent.height;
                text: AppState.en ? "When enabled, your input will be translated into English to help English-only models understand it better." : "开启后，我们会将你的输入自动翻译成英文，帮助仅支持英文的模型更好理解你的需求";
            }
            SmallToggle {
                x: parent.width - 44px;
                y: (parent.height - 22px) / 2;
                checked: AppState.translate-prompt;
                toggled => {
                    AppState.translate-prompt = !AppState.translate-prompt;
                    if AppState.translate-prompt && AppState.prompt != "" {
                        AppState.translate-current-prompt();
                    }
                }
            }
        }
        composer := PromptComposer {
            x: 22px;
            y: 66px;
            width: parent.width - 44px;
            generation: root.generation;
            show-generate-button: false;
        }
        ScrollView {
            x: 22px;
            y: composer.y + composer.height + 14px;
            width: parent.width - 44px;
            height: max(80px, parent.height - (composer.y + composer.height + 132px));
            viewport-width: parent.width - 44px;
            viewport-height: AppState.ratio-more-open ? 344px : 244px;
            InlineCardChooser {
                width: parent.viewport-width;
                height: AppState.ratio-more-open ? 344px : 244px;
            }
        }
        GenerateActionButton {
            x: 22px;
            y: parent.height - 118px;
            width: parent.width - 44px;
            height: 56px;
            disabled: !AppState.generating && AppState.reasoning-model == "";
            clicked => {
                if AppState.generating {
                    AppState.stop-generation();
                } else {
                    AppState.generate();
                }
            }
        }
        Text {
            visible: AppState.optimizing-prompt || AppState.translating-prompt || AppState.generating || AppState.generation-status != "";
            x: 22px;
            y: parent.height - 48px;
            width: parent.width - 44px;
            height: 18px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing prompt..." : "正在优化提示词...")
                : (AppState.translating-prompt ? (AppState.en ? "Translating prompt..." : "正在翻译提示词...")
                : (AppState.generating ? (AppState.en ? "Generating..." : "正在生成中...")
                : AppState.generation-status));
            color: AppTheme.text;
            font-size: 13px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    function title-text() -> string {
        if AppState.asset-type == "scene" { return AppState.en ? "Workspace · Scene" : "工作台 · 场景"; }
        if AppState.asset-type == "ui" { return AppState.en ? "Workspace · UI" : "工作台 · UI"; }
        if AppState.asset-type == "effect" { return AppState.en ? "Workspace · Effect" : "工作台 · 特效"; }
        if AppState.asset-type == "action-sequence" { return AppState.en ? "Workspace · Action Sequence" : "工作台 · 动作序列"; }
        return AppState.en ? "Workspace · Character" : "工作台 · 角色";
    }
}

component StudioSplitPage {
    in property <bool> generation: false;
    Rectangle {
        background: AppTheme.bg;
        StudioWorkPanel {
            x: 0px;
            y: 0px;
            width: 420px;
            height: parent.height;
            generation: root.generation;
        }
        Rectangle { x: 420px; y: 0px; width: 1px; height: parent.height; background: AppTheme.border; }
        GenerationResultPanel {
            x: 421px;
            y: 0px;
            width: parent.width - 421px;
            height: parent.height;
        }
    }
}

export component AppWindow inherits Window {
    title: "ArtForgeStudio";
    preferred-width: 1440px;
    preferred-height: 900px;
    min-width: 1180px;
    min-height: 760px;
    icon: AppState.app-logo;
    background: AppTheme.bg;
    default-font-family: AppState.settings-font-family;
    default-font-size: AppState.settings-font-size * 1px;

    if AppState.page == "welcome": WelcomePage {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
    }

    if AppState.page != "welcome": HorizontalLayout {
        if AppState.logged-in: Sidebar {}
        VerticalLayout {
            TopBar {}
            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                if AppState.page == "generation": StudioSplitPage { width: parent.width; height: parent.height; generation: true; }
                if AppState.page == "assets": AssetsPage { width: parent.width; height: parent.height; }
                if AppState.page == "inspiration": InspirationPage { width: parent.width; height: parent.height; }
                if AppState.page == "notifications": NotificationsPage { width: parent.width; height: parent.height; }
                if AppState.page == "credits": CreditsPage { width: parent.width; height: parent.height; }
                if AppState.page == "models": ModelsPage { width: parent.width; height: parent.height; }
                if AppState.page == "rebate": InviteRebatePage { width: parent.width; height: parent.height; }
                if AppState.page == "settings": SettingsPage { width: parent.width; height: parent.height; }
            }
        }
    }

    AuthDialog { width: root.width; height: root.height; }
    ProviderEditorDialog { width: root.width; height: root.height; }
    ProfileDialog { width: root.width; height: root.height; }
    AliPayQrDialog { width: root.width; height: root.height; }
    CreditRuleDialog { width: root.width; height: root.height; }
    VersionCheckDialog { width: root.width; height: root.height; }
    UpdateProgressDialog { width: root.width; height: root.height; }
    ViewerOverlay { width: root.width; height: root.height; }
    UpscaleDialog { width: root.width; height: root.height; }
    if AppState.thumbnail-drag-preview-visible: Rectangle {
        x: max(0px, min(AppState.thumbnail-drag-preview-x - AppState.thumbnail-drag-preview-size / 2, root.width - AppState.thumbnail-drag-preview-size));
        y: max(0px, min(AppState.thumbnail-drag-preview-y - AppState.thumbnail-drag-preview-size / 2, root.height - AppState.thumbnail-drag-preview-size));
        width: AppState.thumbnail-drag-preview-size;
        height: AppState.thumbnail-drag-preview-size;
        background: transparent;
        border-radius: 8px;
        border-width: 1px;
        border-color: #ffffffaa;
        opacity: 0.62;
        clip: true;
        Image {
            width: parent.width;
            height: parent.height;
            source: AppState.thumbnail-drag-preview-image;
            image-fit: cover;
        }
    }
    DeleteConfirm { width: root.width; height: root.height; }
    ModelRequiredDialog { width: root.width; height: root.height; }
    CreditInsufficientDialog { width: root.width; height: root.height; }
}

