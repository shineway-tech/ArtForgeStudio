}

component InfoCard {
    in property <string> label;
    in property <string> value;
    height: 70px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 10px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text { x: 12px; y: 10px; text: root.label; color: AppTheme.muted; font-size: 14px; font-weight: 400; }
        Text { x: 12px; y: 36px; width: parent.width - 24px; text: root.value; color: AppTheme.text; font-size: 16px; font-weight: 400; overflow: elide; }
    }
}

component DeleteConfirm {
    if AppState.delete-confirm-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 330px) / 2;
            y: (parent.height - 180px) / 2;
            width: 330px;
            height: 180px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.delete-confirm-open = false; } }
            VerticalLayout {
                padding: 22px;
                spacing: 18px;
                Text { text: AppState.en ? "Delete this asset?" : "确认删除这个资产？"; color: AppTheme.text; font-size: 18px; font-weight: 600; }
                Text { text: AppState.en ? "It will be removed from My Assets." : "删除后将从我的资产中移除。"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Cancel" : "取消"; clicked => { AppState.delete-confirm-open = false; } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Delete" : "删除"; danger: true; clicked => { AppState.confirm-delete(); } }
                }
            }
        }
    }
}

component ModelRequiredDialog {
    if AppState.model-required-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 330px) / 2;
            y: (parent.height - 170px) / 2;
            width: 330px;
            height: 170px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.model-required-open = false; } }
            VerticalLayout {
                padding: 22px;
                spacing: 18px;
                Text { text: AppState.en ? "Please add a model first" : "请先添加模型"; color: AppTheme.text; font-size: 18px; font-weight: 500; horizontal-alignment: center; }
                HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Cancel" : "取消"; clicked => { AppState.model-required-open = false; } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Add Now" : "立即添加"; primary: true; clicked => { AppState.model-required-open = false; AppState.navigate("models"); } }
                }
            }
        }
    }
}

component VersionCheckDialog {
    if AppState.update-result-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 360px) / 2;
            y: (parent.height - 190px) / 2;
            width: 360px;
            height: 190px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.update-result-open = false; } }
            VerticalLayout {
                padding: 22px;
                spacing: 18px;
                Text {
                    text: AppState.en ? "Version Check" : "版本检查";
                    color: AppTheme.text;
                    font-size: 18px;
                    font-weight: 500;
                    horizontal-alignment: center;
                }
                Text {
                    text: AppState.update-message;
                    color: AppTheme.muted;
                    font-size: 13px;
                    font-weight: 400;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                PillButton {
                    horizontal-stretch: 1;
                    text: AppState.en ? "OK" : "知道了";
                    primary: true;
                    clicked => { AppState.update-result-open = false; }
                }
            }
        }
    }
}

component UpdateProgressDialog {
    if AppState.update-progress-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 420px) / 2;
            y: (parent.height - 230px) / 2;
            width: 420px;
            height: 230px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text {
                x: 24px;
                y: 24px;
                width: parent.width - 48px;
                height: 26px;
                text: AppState.en ? "Updating ArtForgeStudio" : "正在更新 ArtForgeStudio";
                color: AppTheme.text;
                font-size: 18px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Text {
                x: 24px;
                y: 62px;
                width: parent.width - 48px;
                height: 22px;
                text: AppState.update-ready ? (AppState.en ? "Update is ready. Restart now to apply it." : "更新已准备完成，立即更新后客户端将自动关闭并重启。")
                    : (AppState.en ? "Preparing update..." : "正在准备更新...");
                color: AppTheme.muted;
                font-size: 13px;
                font-weight: 400;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }
            Rectangle {
                x: 34px;
                y: 112px;
                width: parent.width - 68px;
                height: 12px;
                background: AppTheme.panel-soft;
                border-radius: 6px;
                border-width: 1px;
                border-color: AppTheme.border;
                Rectangle {
                    width: (parent.width - 2px) * AppState.update-progress / 100;
                    height: parent.height - 2px;
                    x: 1px;
                    y: 1px;
                    border-radius: 5px;
                    background: AppTheme.accent;
                }
            }
            Text {
                x: 34px;
                y: 132px;
                width: parent.width - 68px;
                height: 20px;
                text: AppState.update-progress + "%";
                color: AppTheme.text;
                font-size: 13px;
                font-weight: 400;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            PillButton {
                x: 34px;
                y: 174px;
                width: parent.width - 68px;
                height: 40px;
                text: AppState.en ? "Restart Now" : "立即更新";
                primary: true;
                disabled: !AppState.update-ready;
                clicked => { AppState.restart-after-update(); }
            }
        }
    }
}

component CreditInsufficientDialog {
    if AppState.credit-insufficient-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 360px) / 2;
            y: (parent.height - 190px) / 2;
            width: 360px;
            height: 190px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.credit-insufficient-open = false; } }
            VerticalLayout {
                padding: 22px;
                spacing: 18px;
                Text {
                    text: AppState.en ? "Insufficient credits" : "积分不足";
                    color: AppTheme.text;
                    font-size: 18px;
                    font-weight: 500;
                    horizontal-alignment: center;
                }
                Text {
                    text: AppState.en ? "Your credits are insufficient. Please recharge." : AppState.credit-insufficient-message;
                    color: AppTheme.muted;
                    font-size: 13px;
                    font-weight: 400;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                PillButton {
                    horizontal-stretch: 1;
                    text: AppState.en ? "Go to Recharge" : "前往充值";
                    primary: true;
                    clicked => {
                        AppState.credit-insufficient-open = false;
                        AppState.navigate("credits");
                    }
                }
            }
        }
    }
}

component TopBar {
    height: 58px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: AppTheme.bg;
        border-width: 1px;
        border-color: AppTheme.border;
        Rectangle {
            x: 18px;
            y: 0px;
            width: 94px;
            height: parent.height;
            background: transparent;
            if AppState.page != "welcome" && AppState.page != "generation": PillButton {
                x: 0px;
                y: (parent.height - 36px) / 2;
                width: 88px;
                text: AppState.en ? "← Back" : "← 返回";
                clicked => { AppState.back(); }
            }
        }
        Rectangle {
            x: 118px;
            y: 0px;
            width: max(360px, parent.width - 118px - root.actions-width() - 32px);
            height: parent.height;
            background: transparent;
            clip: true;
            if AppState.page == "generation": Rectangle {
                width: parent.width;
                height: parent.height;
                background: transparent;
                ModelPicker {
                    x: max(0px, (parent.width - root.models-width()) / 2);
                    y: 6px;
                    kind: "image";
                    label: AppState.en ? "Image Model" : "生图模型";
                    picker-width: root.model-picker-width();
                    select-model(provider-id, model) => { AppState.select-image-model(provider-id, model); }
                }
                ModelPicker {
                    x: max(0px, (parent.width - root.models-width()) / 2) + root.model-picker-width() + 18px;
                    y: 6px;
                    kind: "reasoning";
                    label: AppState.en ? "Reasoning Model" : "推理模型";
                    picker-width: root.model-picker-width();
                    select-model(provider-id, model) => { AppState.select-reasoning-model(provider-id, model); }
                }
            }
        }
        Rectangle {
            x: parent.width - root.actions-width() - 18px;
            y: 0px;
            width: root.actions-width();
            height: parent.height;
            background: transparent;
            HorizontalLayout {
                width: parent.width;
                y: (parent.height - 36px) / 2;
                height: 36px;
                spacing: 8px;
                alignment: center;
                PillButton { width: 94px; text: AppState.language == "zh" ? "中文" : "English"; clicked => { AppState.set-language(AppState.language == "zh" ? "en" : "zh"); } }
                ThemeMenuButton { width: 94px; }
                if AppState.logged-in: PillButton { width: 104px; text: AppState.en ? ("Credits " + AppState.credit-balance) : ("积分 " + AppState.credit-balance); clicked => { AppState.navigate("credits"); } }
                if AppState.logged-in: PillButton { width: 128px; text: AppState.nickname != "" ? AppState.nickname : AppState.phone-mask; clicked => { AppState.profile-open = true; AppState.profile-name = AppState.nickname; } }
                if !AppState.logged-in && AppState.page != "welcome": PillButton { width: 112px; text: AppState.en ? "Login" : "登录/注册"; primary: true; clicked => { AppState.auth-open = true; } }
            }
        }
    }
    function actions-width() -> length {
        return AppState.logged-in ? 446px : 318px;
    }
    function model-picker-width() -> length {
        return min(330px, max(180px, (root.width - 118px - root.actions-width() - 70px) / 2));
    }
    function models-width() -> length {
        return root.model-picker-width() * 2 + 18px;
    }
}

component Sidebar {
    width: 204px;
    Rectangle {
        background: AppTheme.panel;
        border-color: AppTheme.border;
        border-width: 1px;
        VerticalLayout {
            padding: 14px;
            spacing: 10px;
            Rectangle {
                height: 56px;
                HorizontalLayout {
                    spacing: 10px;
                    Image { width: 36px; height: 36px; source: AppState.app-logo; image-fit: contain; }
                    VerticalLayout {
                        Text { text: "ArtForgeStudio"; color: AppTheme.text; font-size: 18px; font-weight: 600; }
                        Text { text: "AI Art Studio"; color: AppTheme.muted; font-size: 12px; font-weight: 400; }
                    }
                }
            }
            Rectangle { height: 1px; background: AppTheme.border; }
            CategoryWorkspaceMenu {}
            NavItem { icon: "assets"; label: AppState.en ? "My Assets" : "我的资产"; page: "assets"; }
            NavItem { icon: "inspiration"; label: AppState.en ? "Inspiration" : "灵感广场"; page: "inspiration"; }
            NavItem { icon: "notifications"; label: AppState.en ? "Notifications" : "通知"; page: "notifications"; show-dot: AppState.has-unread; }
            NavItem { icon: "models"; label: AppState.en ? "Model Management" : "模型管理"; page: "models"; }
            NavItem { icon: "rebate"; label: AppState.en ? "Invite Rebate" : "邀请返利"; page: "rebate"; }
            Rectangle { vertical-stretch: 1; }
            NavItem { icon: "settings"; label: AppState.en ? "Settings" : "设置"; page: "settings"; }
        }
    }
}

component ShowcaseMosaic inherits Rectangle {
    background: transparent;
    clip: false;

    function tile-x(n: int) -> length {
        if n == 0 { return 0px; }
        return root.width * 346 / 606;
    }

    function tile-y(n: int) -> length {
        if n == 0 { return 0px; }
        if n == 1 { return 0px; }
        if n == 2 { return root.width * 188 / 606; }
        return root.width * 384 / 606;
    }

    ShowcaseTile { x: root.tile-x(0); y: root.tile-y(0); width: root.width * 322 / 606; height: root.width * 360 / 606; source: AppState.showcase-character; title: "角色设定"; subtitle: "完整立绘"; }
    ShowcaseTile { x: root.tile-x(1); y: root.tile-y(1); width: root.width * 260 / 606; height: root.width * 172 / 606; source: AppState.showcase-scene; title: "场景概念"; subtitle: "环境参考"; }
    ShowcaseTile { x: root.tile-x(1); y: root.tile-y(2); width: root.width * 260 / 606; height: root.width * 172 / 606; source: AppState.showcase-ui; title: "游戏 UI"; subtitle: "界面方案"; }
    ShowcaseTile { x: root.tile-x(0); y: root.tile-y(3); width: root.width * 346 / 606; height: root.width * 142 / 606; source: AppState.showcase-vfx; title: "特效设计"; subtitle: "技能表现"; }
}

component SelectChip {
    in property <string> kind;
    property <bool> open: false;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: open ? AppTheme.accent : AppTheme.border;
        Text { x: 16px; width: parent.width - 46px; height: parent.height; text: label(); color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: -options-height() - 6px;
        width: options-width();
        height: options-height();
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 6px;
                spacing: 4px;
                if root.kind == "type": TypeOption { id: "character"; label: AppState.en ? "Character" : "角色"; close => { root.open = false; popup.close(); } }
                if root.kind == "type": TypeOption { id: "scene"; label: AppState.en ? "Scene" : "场景"; close => { root.open = false; popup.close(); } }
                if root.kind == "type": TypeOption { id: "ui"; label: "UI"; close => { root.open = false; popup.close(); } }
                if root.kind == "type": TypeOption { id: "effect"; label: AppState.en ? "Effect" : "特效"; close => { root.open = false; popup.close(); } }
                if root.kind == "count": CountOption { count: 1; close => { root.open = false; popup.close(); } }
                if root.kind == "count": CountOption { count: 2; close => { root.open = false; popup.close(); } }
                if root.kind == "count": CountOption { count: 4; close => { root.open = false; popup.close(); } }
            }
        }
    }
    function label() -> string {
        if root.kind == "count" { return "\{AppState.count}" + (AppState.en ? " img" : " 张"); }
        if AppState.asset-type == "character" { return AppState.en ? "Character" : "角色"; }
        if AppState.asset-type == "scene" { return AppState.en ? "Scene" : "场景"; }
        if AppState.asset-type == "ui" { return "UI"; }
        if AppState.asset-type == "effect" { return AppState.en ? "Effect" : "特效"; }
        if AppState.asset-type == "action-sequence" { return AppState.en ? "Action Sequence" : "动作序列"; }
        return AppState.en ? "Character" : "角色";
    }
    function options-height() -> length {
        return root.kind == "count" ? 138px : 218px;
    }
    function options-width() -> length {
        return root.kind == "count" ? 118px : 152px;
    }
}

component CanvasChip {
    property <bool> open: false;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: open ? AppTheme.accent : AppTheme.border;
        Text { x: 16px; width: parent.width - 46px; height: parent.height; text: ratio-label() + " · " + AppState.quality; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: -358px;
        width: 440px;
        height: 354px;
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 12px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 14px;
                spacing: 14px;
                Text { text: AppState.en ? "Aspect ratio" : "选择比例"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                GridLayout {
                    spacing: 10px;
                    Row { RatioButton { id: "1:1"; label: "1:1"; } RatioButton { id: "3:2"; label: "3:2"; } RatioButton { id: "2:3"; label: "2:3"; } RatioButton { id: "4:3"; label: "4:3"; } }
                    Row { RatioButton { id: "3:4"; label: "3:4"; } RatioButton { id: "5:4"; label: "5:4"; } RatioButton { id: "4:5"; label: "4:5"; } RatioButton { id: "16:9"; label: "16:9"; } }
                    Row { RatioButton { id: "16:9"; label: "16:9"; } RatioButton { id: "9:16"; label: "9:16"; } RatioButton { id: "2:1"; label: "2:1"; } RatioButton { id: "1:2"; label: "1:2"; } }
                    Row { RatioButton { id: "21:9"; label: "21:9"; } RatioButton { id: "9:21"; label: "9:21"; } }
                }
                Text { text: AppState.en ? "Resolution" : "选择分辨率"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                HorizontalLayout {
                    spacing: 12px;
                    QualityButton { label: "1K"; }
                    QualityButton { label: AppState.en ? "HD 2K" : "高清 2K"; value: "2K"; }
                    QualityButton { label: AppState.en ? "Ultra 4K" : "超清 4K"; value: "4K"; }
                }
            }
        }
    }
    function ratio-label() -> string { return AppState.ratio; }
}

component TextOption {
    in property <string> left;
    in property <string> right: "";
    in property <bool> active: false;
    callback clicked();
    height: 30px;
    Rectangle {
        background: root.active ? AppTheme.panel-soft : transparent;
        border-radius: 6px;
        Text {
            x: 10px;
            width: parent.width - 86px;
            height: parent.height;
            text: root.left;
            color: root.active ? AppTheme.accent-dark : AppTheme.text;
            font-size: 12px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        Text {
            x: parent.width - 72px;
            width: 58px;
            height: parent.height;
            text: root.right;
            color: AppTheme.muted;
            font-size: 12px;
            font-weight: 400;
            horizontal-alignment: TextHorizontalAlignment.right;
            vertical-alignment: center;
            overflow: elide;
        }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.clicked(); } }
    }
}

component CreationModeChip {
    property <bool> open: false;
    width: 108px;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: AppTheme.accent;
        Text { x: 14px; width: parent.width - 44px; height: parent.height; text: label(); color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 28px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: 42px;
        width: 170px;
        height: root.options-height();
        close-policy: close-on-click-outside;
        Rectangle {
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 6px;
                spacing: 3px;
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "Free Create" : "自由创作"; right: ""; active: AppState.creation-mode == "free"; clicked => { AppState.creation-mode = "free"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "Character Full Body" : "角色立绘"; right: AppState.en ? "Full" : "立绘"; active: AppState.creation-mode == "character-standee"; clicked => { AppState.creation-mode = "character-standee"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "Three Views" : "三视图"; right: AppState.en ? "Sheet" : "设定"; active: AppState.creation-mode == "character-turnaround"; clicked => { AppState.creation-mode = "character-turnaround"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "8 Directions" : "8方向"; right: AppState.en ? "Action" : "动作"; active: AppState.creation-mode == "character-8dir"; clicked => { AppState.creation-mode = "character-8dir"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: "SpriteSheet"; right: AppState.en ? "Frames" : "帧"; active: AppState.creation-mode == "character-spritesheet"; clicked => { AppState.creation-mode = "character-spritesheet"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "Spine Parts" : "Spine拆件"; right: AppState.en ? "Parts" : "拆件"; active: AppState.creation-mode == "character-spine-parts"; clicked => { AppState.creation-mode = "character-spine-parts"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "NPC Portrait" : "NPC头像"; right: AppState.en ? "Head" : "头像"; active: AppState.creation-mode == "character-portrait"; clicked => { AppState.creation-mode = "character-portrait"; root.open = false; popup.close(); } }
                if AppState.asset-type == "character": TextOption { left: AppState.en ? "Promo Poster" : "宣传海报"; right: AppState.en ? "Poster" : "海报"; active: AppState.creation-mode == "character-poster"; clicked => { AppState.creation-mode = "character-poster"; root.open = false; popup.close(); } }

                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Free Create" : "自由创作"; right: ""; active: AppState.creation-mode == "free"; clicked => { AppState.creation-mode = "free"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Scene concept" : "场景概念图"; right: AppState.en ? "Explore" : "探索"; active: AppState.creation-mode == "scene-concept"; clicked => { AppState.creation-mode = "scene-concept"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: "TileSet"; right: AppState.en ? "Tiles" : "地块"; active: AppState.creation-mode == "tileset"; clicked => { AppState.creation-mode = "tileset"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Map Reference" : "地编参考"; right: AppState.en ? "Layout" : "布局"; active: AppState.creation-mode == "map-ref"; clicked => { AppState.creation-mode = "map-ref"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Key Visual" : "宣传图"; right: AppState.en ? "Marketing" : "营销"; active: AppState.creation-mode == "poster"; clicked => { AppState.creation-mode = "poster"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Loading Image" : "Loading 图"; right: AppState.en ? "Load" : "载入"; active: AppState.creation-mode == "loading"; clicked => { AppState.creation-mode = "loading"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Mini Map" : "小地图"; right: AppState.en ? "Top" : "俯视"; active: AppState.creation-mode == "minimap"; clicked => { AppState.creation-mode = "minimap"; root.open = false; popup.close(); } }
                if AppState.asset-type == "scene": TextOption { left: AppState.en ? "Building Kit" : "建筑套件"; right: AppState.en ? "Module" : "模块"; active: AppState.creation-mode == "building-kit"; clicked => { AppState.creation-mode = "building-kit"; root.open = false; popup.close(); } }

                if AppState.asset-type == "ui": TextOption { left: AppState.en ? "Free Create" : "自由创作"; right: ""; active: AppState.creation-mode == "free"; clicked => { AppState.creation-mode = "free"; root.open = false; popup.close(); } }
                if AppState.asset-type == "ui": TextOption { left: "HUD"; right: AppState.en ? "Battle" : "战斗"; active: AppState.creation-mode == "ui-hud"; clicked => { AppState.creation-mode = "ui-hud"; root.open = false; popup.close(); } }
