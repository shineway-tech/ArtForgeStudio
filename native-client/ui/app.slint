    }
    function column-count() -> int {
        return max(1, min(root.items.length, min(8, floor((root.grid-width() + root.grid-gap()) / (root.card-width + root.grid-gap())))));
    }
    function item-width() -> length {
        return min(root.card-width, max(118px, (root.grid-width() - (root.column-count() - 1) * root.grid-gap()) / root.column-count()));
    }
    function row-height() -> length {
        return root.item-width() + root.grid-gap();
    }
    function row-count() -> int {
        return (root.items.length + root.column-count() - 1) / root.column-count();
    }
