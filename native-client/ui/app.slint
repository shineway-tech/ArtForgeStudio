import { ScrollView } from "std-widgets.slint";

component LoadingDots {
    in-out property <int> step: 0;
    width: 42px;
    height: 42px;
    Timer {
        interval: 420ms;
        running: true;
        triggered => { root.step = Math.mod(root.step + 1, 3); }
    }
    Text {
        width: parent.width;
        height: parent.height;
        text: root.step == 0 ? "." : (root.step == 1 ? ".." : "...");
        color: AppTheme.accent;
        font-size: 18px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ProgressSpinner {
    in property <string> label: "";
    in property <int> progress: 0;
    in-out property <int> step: 0;
    width: 220px;
    height: 118px;
    Timer {
        interval: 95ms;
        running: true;
        triggered => { root.step = Math.mod(root.step + 1, 8); }
    }
    Rectangle {
        x: (parent.width - 62px) / 2;
        y: 0px;
        width: 62px;
        height: 62px;
        background: transparent;
        Rectangle { x: 27px; y: 0px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(0); }
        Rectangle { x: 45px; y: 8px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(1); }
        Rectangle { x: 54px; y: 27px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(2); }
        Rectangle { x: 45px; y: 46px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(3); }
        Rectangle { x: 27px; y: 54px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(4); }
        Rectangle { x: 8px; y: 46px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(5); }
        Rectangle { x: 0px; y: 27px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(6); }
        Rectangle { x: 8px; y: 8px; width: 8px; height: 8px; border-radius: 4px; background: #ffffff; opacity: root.dot-opacity(7); }
    }
    Text {
        x: 0px;
        y: 76px;
        width: parent.width;
        height: 28px;
        text: root.label + " " + root.progress + "%";
        color: #ffffff;
        font-size: 18px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
    function dot-opacity(index: int) -> float {
        let age = Math.mod(root.step + 8 - index, 8);
        if age == 0 { return 1.0; }
        if age == 1 { return 0.82; }
        if age == 2 { return 0.64; }
        if age == 3 { return 0.48; }
        if age == 4 { return 0.34; }
        return 0.22;
    }
}

export struct ModelProvider {
    id: string,
    name: string,
    endpoint: string,
    remark: string,
    website: string,
    api-key: string,
    models: [string],
    used-models: [string],
    selected-model: string,
}

export struct ProviderModelOption {
    name: string,
    used: bool,
}

export struct AssetItem {
    id: string,
    title: string,
    category: string,
    kind: string,
    time: string,
    prompt: string,
    ratio: string,
    quality: string,
    model: string,
    width: int,
    height: int,
    image: image,
    source-path: string,
    drag-uri: string,
    cutout-done: bool,
    remove-black-done: bool,
    upscale-done: bool,
}

export struct AssetGroup {
    title: string,
    items: [AssetItem],
}

export struct ConversationItem {
    id: string,
    title: string,
    image: image,
    loading: bool,
}

export struct NotificationItem {
    id: string,
    title: string,
    model: string,
    time: string,
    reason: string,
    success: bool,
    read: bool,
}

export struct CreditRecord {
    title: string,
    amount: string,
    time: string,
    note: string,
    positive: bool,
}

export struct InvitedUser {
    email: string,
    username: string,
    rebate-points: int,
    register-time: string,
}

export struct ReferenceItem {
    id: string,
    image: image,
    source-path: string,
}

