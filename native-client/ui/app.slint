        if AppState.creation-mode == "anim-skill" { return AppState.en ? "Skill Move" : "技能动作"; }
        return AppState.en ? "Free Create" : "自由创作";
    }
}

component StyleModeChip {
    property <bool> open: false;
    width: 108px;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: AppTheme.accent;
        Text { x: 14px; width: parent.width - 44px; height: parent.height; text: label(); color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 28px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: 42px;
        width: 170px;
        height: 282px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 6px;
                spacing: 3px;
                TextOption { left: AppState.en ? "Free Style" : "自由风格"; right: ""; active: AppState.style-mode == "free"; clicked => { AppState.style-mode = "free"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Warm Healing" : "温暖治愈"; right: AppState.en ? "Warm" : "暖"; active: AppState.style-mode == "warm"; clicked => { AppState.style-mode = "warm"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Cool Pressure" : "冷峻压抑"; right: AppState.en ? "Cold" : "冷"; active: AppState.style-mode == "cold"; clicked => { AppState.style-mode = "cold"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "High Saturation" : "高饱和"; right: AppState.en ? "Vivid" : "艳"; active: AppState.style-mode == "vivid"; clicked => { AppState.style-mode = "vivid"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Low Saturation" : "低饱和"; right: AppState.en ? "Soft" : "淡"; active: AppState.style-mode == "soft"; clicked => { AppState.style-mode = "soft"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Dark Style" : "暗黑风"; right: AppState.en ? "Dark" : "暗"; active: AppState.style-mode == "dark"; clicked => { AppState.style-mode = "dark"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Cyber Neon" : "赛博朋克"; right: AppState.en ? "Neon" : "霓虹"; active: AppState.style-mode == "cyber"; clicked => { AppState.style-mode = "cyber"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Fantasy" : "日系幻想"; right: AppState.en ? "Fantasy" : "幻想"; active: AppState.style-mode == "fantasy"; clicked => { AppState.style-mode = "fantasy"; root.open = false; popup.close(); } }
                TextOption { left: AppState.en ? "Cartoon" : "吉卜力风"; right: AppState.en ? "Paint" : "绘本"; active: AppState.style-mode == "ghibli"; clicked => { AppState.style-mode = "ghibli"; root.open = false; popup.close(); } }
            }
        }
    }
    function label() -> string {
        if AppState.style-mode == "warm" { return AppState.en ? "Warm Healing" : "温暖治愈"; }
        if AppState.style-mode == "cold" { return AppState.en ? "Cool Pressure" : "冷峻压抑"; }
        if AppState.style-mode == "vivid" { return AppState.en ? "High Saturation" : "高饱和"; }
        if AppState.style-mode == "soft" { return AppState.en ? "Low Saturation" : "低饱和"; }
        if AppState.style-mode == "dark" { return AppState.en ? "Dark Style" : "暗黑风"; }
        if AppState.style-mode == "cyber" { return AppState.en ? "Cyber Neon" : "赛博朋克"; }
        if AppState.style-mode == "fantasy" { return AppState.en ? "Fantasy" : "日系幻想"; }
        if AppState.style-mode == "ghibli" { return AppState.en ? "Cartoon" : "吉卜力风"; }
        return AppState.en ? "Free Style" : "自由风格";
    }
}

component SimpleSelectLine {
    in property <string> label;
    height: 34px;
    Rectangle {
        background: AppTheme.bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text { x: 10px; width: parent.width - 38px; height: parent.height; text: root.label; color: AppTheme.text; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 26px; y: (parent.height - 12px) / 2; }
    }
}

component AdvancedSelectLine {
    in property <string> kind;
    property <bool> open: false;
    height: 34px;
    Rectangle {
        background: AppTheme.bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.accent;
        Text { x: 10px; width: parent.width - 38px; height: parent.height; text: root.label(); color: AppTheme.text; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 26px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: 38px;
        width: root.width;
        height: root.options-height();
        close-policy: close-on-click-outside;
        Rectangle {
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 6px;
                spacing: 3px;
                if root.kind == "view": TextOption { left: AppState.en ? "Free Camera" : "自由视角"; right: ""; active: AppState.view-mode == "free"; clicked => { AppState.view-mode = "free"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "Top Down"; right: AppState.en ? "Top" : "俯视"; active: AppState.view-mode == "top-down"; clicked => { AppState.view-mode = "top-down"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "2.5D"; right: AppState.en ? "Angle" : "斜视"; active: AppState.view-mode == "2.5d"; clicked => { AppState.view-mode = "2.5d"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "Isometric"; right: AppState.en ? "Iso" : "等距"; active: AppState.view-mode == "isometric"; clicked => { AppState.view-mode = "isometric"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "Side View"; right: AppState.en ? "Side" : "横版"; active: AppState.view-mode == "side-view"; clicked => { AppState.view-mode = "side-view"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "Third Person"; right: AppState.en ? "3rd" : "三人称"; active: AppState.view-mode == "third-person"; clicked => { AppState.view-mode = "third-person"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "First Person"; right: AppState.en ? "1st" : "第一人称"; active: AppState.view-mode == "first-person"; clicked => { AppState.view-mode = "first-person"; root.open = false; popup.close(); } }
                if root.kind == "view": TextOption { left: "Orthographic"; right: AppState.en ? "Ortho" : "正交"; active: AppState.view-mode == "orthographic"; clicked => { AppState.view-mode = "orthographic"; root.open = false; popup.close(); } }

                if root.kind == "weather": TextOption { left: AppState.en ? "Natural Weather" : "自然天气"; right: ""; active: AppState.weather-mode == "natural"; clicked => { AppState.weather-mode = "natural"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Sunny" : "晴天"; right: AppState.en ? "Sun" : "晴"; active: AppState.weather-mode == "sunny"; clicked => { AppState.weather-mode = "sunny"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Cloudy" : "阴天"; right: AppState.en ? "Cloud" : "阴"; active: AppState.weather-mode == "cloudy"; clicked => { AppState.weather-mode = "cloudy"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Rainy" : "雨天"; right: AppState.en ? "Rain" : "雨"; active: AppState.weather-mode == "rainy"; clicked => { AppState.weather-mode = "rainy"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Storm" : "暴风雨"; right: AppState.en ? "Storm" : "暴"; active: AppState.weather-mode == "storm"; clicked => { AppState.weather-mode = "storm"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Snow" : "雪天"; right: AppState.en ? "Snow" : "雪"; active: AppState.weather-mode == "snow"; clicked => { AppState.weather-mode = "snow"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Fog" : "雾天"; right: AppState.en ? "Fog" : "雾"; active: AppState.weather-mode == "fog"; clicked => { AppState.weather-mode = "fog"; root.open = false; popup.close(); } }
                if root.kind == "weather": TextOption { left: AppState.en ? "Dust" : "沙尘"; right: AppState.en ? "Dust" : "尘"; active: AppState.weather-mode == "dust"; clicked => { AppState.weather-mode = "dust"; root.open = false; popup.close(); } }

                if root.kind == "time": TextOption { left: AppState.en ? "Natural Time" : "自然时间"; right: ""; active: AppState.time-mode == "natural"; clicked => { AppState.time-mode = "natural"; root.open = false; popup.close(); } }
                if root.kind == "time": TextOption { left: AppState.en ? "Morning" : "清晨"; right: AppState.en ? "AM" : "晨"; active: AppState.time-mode == "morning"; clicked => { AppState.time-mode = "morning"; root.open = false; popup.close(); } }
                if root.kind == "time": TextOption { left: AppState.en ? "Noon" : "正午"; right: AppState.en ? "Noon" : "昼"; active: AppState.time-mode == "noon"; clicked => { AppState.time-mode = "noon"; root.open = false; popup.close(); } }
                if root.kind == "time": TextOption { left: AppState.en ? "Dusk" : "黄昏"; right: AppState.en ? "Dusk" : "昏"; active: AppState.time-mode == "dusk"; clicked => { AppState.time-mode = "dusk"; root.open = false; popup.close(); } }
                if root.kind == "time": TextOption { left: AppState.en ? "Blue Hour" : "蓝调时刻"; right: AppState.en ? "Blue" : "蓝"; active: AppState.time-mode == "blue-hour"; clicked => { AppState.time-mode = "blue-hour"; root.open = false; popup.close(); } }
                if root.kind == "time": TextOption { left: AppState.en ? "Deep Night" : "深夜"; right: AppState.en ? "Night" : "夜"; active: AppState.time-mode == "night"; clicked => { AppState.time-mode = "night"; root.open = false; popup.close(); } }

                if root.kind == "light": TextOption { left: AppState.en ? "Natural Light" : "自然光照"; right: ""; active: AppState.light-mode == "natural"; clicked => { AppState.light-mode = "natural"; root.open = false; popup.close(); } }
                if root.kind == "light": TextOption { left: AppState.en ? "Soft Natural Light" : "柔和自然光"; right: AppState.en ? "Soft" : "自然"; active: AppState.light-mode == "soft"; clicked => { AppState.light-mode = "soft"; root.open = false; popup.close(); } }
                if root.kind == "light": TextOption { left: AppState.en ? "Cinematic" : "电影感"; right: AppState.en ? "Film" : "电影"; active: AppState.light-mode == "cinematic"; clicked => { AppState.light-mode = "cinematic"; root.open = false; popup.close(); } }
                if root.kind == "light": TextOption { left: AppState.en ? "Dream Glow" : "梦幻发光"; right: AppState.en ? "Glow" : "发光"; active: AppState.light-mode == "glow"; clicked => { AppState.light-mode = "glow"; root.open = false; popup.close(); } }
                if root.kind == "light": TextOption { left: AppState.en ? "High Contrast" : "高对比"; right: AppState.en ? "Contrast" : "对比"; active: AppState.light-mode == "contrast"; clicked => { AppState.light-mode = "contrast"; root.open = false; popup.close(); } }
                if root.kind == "light": TextOption { left: AppState.en ? "Volumetric Light" : "体积光"; right: AppState.en ? "Beam" : "光束"; active: AppState.light-mode == "volumetric"; clicked => { AppState.light-mode = "volumetric"; root.open = false; popup.close(); } }
                if root.kind == "light": TextOption { left: AppState.en ? "Neon Light" : "霓虹灯"; right: AppState.en ? "Neon" : "霓虹"; active: AppState.light-mode == "neon"; clicked => { AppState.light-mode = "neon"; root.open = false; popup.close(); } }
            }
        }
    }

    function options-height() -> length {
        if root.kind == "time" { return 198px; }
        if root.kind == "light" { return 230px; }
        return 294px;
    }

    function label() -> string {
        if root.kind == "view" {
            if AppState.view-mode == "top-down" { return "Top Down"; }
            if AppState.view-mode == "2.5d" { return "2.5D"; }
            if AppState.view-mode == "isometric" { return "Isometric"; }
            if AppState.view-mode == "side-view" { return "Side View"; }
            if AppState.view-mode == "third-person" { return "Third Person"; }
            if AppState.view-mode == "first-person" { return "First Person"; }
            if AppState.view-mode == "orthographic" { return "Orthographic"; }
            return AppState.en ? "Free Camera" : "自由视角";
        }
        if root.kind == "weather" {
            if AppState.weather-mode == "sunny" { return AppState.en ? "Sunny" : "晴天"; }
            if AppState.weather-mode == "cloudy" { return AppState.en ? "Cloudy" : "阴天"; }
            if AppState.weather-mode == "rainy" { return AppState.en ? "Rainy" : "雨天"; }
            if AppState.weather-mode == "storm" { return AppState.en ? "Storm" : "暴风雨"; }
            if AppState.weather-mode == "snow" { return AppState.en ? "Snow" : "雪天"; }
            if AppState.weather-mode == "fog" { return AppState.en ? "Fog" : "雾天"; }
            if AppState.weather-mode == "dust" { return AppState.en ? "Dust" : "沙尘"; }
            return AppState.en ? "Natural Weather" : "自然天气";
        }
        if root.kind == "time" {
            if AppState.time-mode == "morning" { return AppState.en ? "Morning" : "清晨"; }
            if AppState.time-mode == "noon" { return AppState.en ? "Noon" : "正午"; }
            if AppState.time-mode == "dusk" { return AppState.en ? "Dusk" : "黄昏"; }
            if AppState.time-mode == "blue-hour" { return AppState.en ? "Blue Hour" : "蓝调时刻"; }
            if AppState.time-mode == "night" { return AppState.en ? "Deep Night" : "深夜"; }
            return AppState.en ? "Natural Time" : "自然时间";
        }
        if AppState.light-mode == "soft" { return AppState.en ? "Soft Natural Light" : "柔和自然光"; }
        if AppState.light-mode == "cinematic" { return AppState.en ? "Cinematic" : "电影感"; }
        if AppState.light-mode == "glow" { return AppState.en ? "Dream Glow" : "梦幻发光"; }
        if AppState.light-mode == "contrast" { return AppState.en ? "High Contrast" : "高对比"; }
        if AppState.light-mode == "volumetric" { return AppState.en ? "Volumetric Light" : "体积光"; }
        if AppState.light-mode == "neon" { return AppState.en ? "Neon Light" : "霓虹灯"; }
        return AppState.en ? "Natural Light" : "自然光照";
    }
}

component AdvancedControlChip {
    property <bool> open: false;
    width: 108px;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: root.open ? AppTheme.accent : AppTheme.border;
        Text { x: 14px; width: parent.width - 44px; height: parent.height; text: AppState.en ? "Advanced" : "高级控制"; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 28px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: -228px;
        y: 42px;
        width: 336px;
        height: root.popup-height();
        close-policy: close-on-click-outside;
        Rectangle {
            background: AppTheme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text { x: 14px; y: 12px; text: AppState.en ? "Advanced Control" : "高级控制"; color: AppTheme.text; font-size: 13px; font-weight: 500; }
            Text { x: parent.width - 52px; y: 12px; width: 36px; text: AppState.en ? "Limit" : "约束"; color: AppTheme.muted; font-size: 12px; font-weight: 400; horizontal-alignment: TextHorizontalAlignment.right; }
            Rectangle { x: 0px; y: 43px; width: parent.width; height: 1px; background: AppTheme.border; }
            if root.show-view(): AdvancedSelectLine { x: 14px; y: 58px; width: parent.width - 28px; kind: "view"; }
            if AppState.asset-type == "scene": AdvancedSelectLine { x: 14px; y: 102px; width: (parent.width - 38px) / 2; kind: "weather"; }
            if AppState.asset-type == "scene": AdvancedSelectLine { x: 24px + (parent.width - 38px) / 2; y: 102px; width: (parent.width - 38px) / 2; kind: "time"; }
            AdvancedSelectLine { x: 14px; y: root.light-y(); width: parent.width - 28px; kind: "light"; }
            Rectangle {
                x: 14px; y: root.preview-y(); width: parent.width - 28px; height: AppState.advanced-preview-open ? 178px : 34px;
                background: AppTheme.bg;
                border-radius: 8px;
                border-width: 1px;
                border-color: AppTheme.border;
                Text { x: 10px; y: 0px; width: parent.width - 112px; height: 34px; text: AppState.en ? "Advanced Prompt Preview" : "高级设置 Prompt 预览"; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
                PillButton {
                    x: parent.width - 98px;
                    y: 5px;
                    width: 42px;
                    height: 24px;
                    text: AppState.advanced-preview-open ? (AppState.en ? "Hide" : "收起") : (AppState.en ? "View" : "查看");
                    clicked => {
                        AppState.advanced-preview-open = !AppState.advanced-preview-open;
                        if AppState.advanced-preview-open {
                            AppState.refresh-advanced-prompt-preview();
                        }
                    }
                }
                PillButton { x: parent.width - 50px; y: 5px; width: 42px; height: 24px; text: AppState.en ? "Refresh" : "刷新"; clicked => { AppState.advanced-preview-open = true; AppState.refresh-advanced-prompt-preview(); } }
                if AppState.advanced-preview-open: Rectangle {
                    x: 10px;
                    y: 42px;
                    width: parent.width - 20px;
                    height: 122px;
                    background: AppTheme.panel;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: AppTheme.border;
                    Text {
                        x: 10px;
                        y: 8px;
                        width: parent.width - 20px;
                        height: parent.height - 16px;
                        text: AppState.advanced-prompt-preview;
                        color: AppTheme.text;
                        font-size: 12px;
                        font-weight: 400;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }
            }
        }
    }

    function popup-height() -> length {
        if AppState.asset-type == "scene" {
            return AppState.advanced-preview-open ? 392px : 246px;
        }
        if AppState.asset-type == "character" {
            return AppState.advanced-preview-open ? 338px : 202px;
        }
        return AppState.advanced-preview-open ? 338px : 202px;
    }

    function show-view() -> bool {
        return AppState.asset-type == "scene" || AppState.asset-type == "character";
    }

    function light-y() -> length {
        if AppState.asset-type == "scene" { return 146px; }
        if AppState.asset-type == "character" { return 102px; }
        return 58px;
    }

    function preview-y() -> length {
        if AppState.asset-type == "scene" { return 190px; }
        if AppState.asset-type == "character" { return 146px; }
        return 102px;
    }
}

component AssetsPage {
    function content-width() -> length {
        return root.width - 40px;
    }
    function content-x() -> length {
        return 20px;
    }
    function card-width() -> length {
        return 200px;
    }
    Rectangle {
        background: AppTheme.bg;
        Rectangle {
            x: root.content-x();
            y: 0px;
            width: root.content-width();
            height: parent.height;
            background: transparent;
            CategoryTabs {
                x: 0px;
                y: 20px;
                width: parent.width;
                height: 64px;
                for-assets: true;
            }
            AssetGallery {
                x: 0px;
                y: 116px;
                width: parent.width;
                height: parent.height - 116px;
                items: AppState.assets;
                groups: AppState.asset-groups;
                source: "asset";
                card-width: root.card-width();
            }
        }
    }
}

component InspirationPage {
    function content-width() -> length {
        return root.width - 40px;
    }
    function content-x() -> length {
        return 20px;
    }
    function card-width() -> length {
        return 200px;
    }
    function gallery-y() -> length {
        return 124px;
    }
    function gallery-top-gap() -> length {
        return 18px;
    }
    function gallery-height() -> length {
        return max(root.height - root.gallery-y(), max(820px, root.gallery-top-gap() + 32px + root.row-count() * root.row-height()));
    }
    Rectangle {
        background: AppTheme.bg;
        Rectangle {
            y: root.gallery-y();
            width: parent.width;
            height: max(0px, parent.height - root.gallery-y());
            clip: true;
            background: transparent;
            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-width: parent.width;
                viewport-height: root.gallery-height();
                interactive: true;
                Rectangle {
                    width: root.width;
                    height: root.gallery-height();
                    background: transparent;

                    if root.is-empty(): EmptyState {
                        x: root.content-x();
                        y: 0px;
                        width: root.content-width();
                        height: max(360px, root.height - 106px);
                    }

                    if !root.is-empty(): SquareGalleryGrid {
                        x: root.content-x();
                        y: root.gallery-top-gap();
                        width: root.content-width();
                        items: AppState.inspiration;
                        card-width: root.card-width();
                        source: "inspiration";
                    }
                }
            }
        }
        Rectangle {
            y: 0px;
            width: parent.width;
            height: root.gallery-y();
            background: AppTheme.bg;
        }
        CategoryTabs {
            x: root.content-x();
            y: 14px;
            width: root.content-width();
            for-assets: false;
        }
    }
    function is-empty() -> bool {
        return AppState.inspiration.length == 0;
    }
    function column-count() -> int {
        return max(1, min(AppState.inspiration.length, min(8, floor((root.content-width() + 18px) / (root.card-width() + 18px)))));
    }
    function item-width() -> length {
        return min(root.card-width(), max(139px, (root.content-width() - (root.column-count() - 1) * 18px) / root.column-count()));
    }
    function row-height() -> length {
        return root.item-width() + 48px;
    }
    function row-count() -> int {
        return (AppState.inspiration.length + root.column-count() - 1) / root.column-count();
    }
}

component MarketingNavButton inherits Rectangle {
