import { AppState } from "app-state.slint";
import { AppTheme } from "theme.slint";
import { AccountSession, AssetGroup, AssetItem, CanvasNote, ConversationItem, CreditRecord, CustomPromptItem, InvoiceOrderView, ModelGroup, ModelOption, NotificationItem, ReferenceItem } from "types.slint";
import { Sidebar } from "components/sidebar.slint";
import { TopBar } from "components/top-bar.slint";
import { AliPayQrDialog } from "dialogs/ali-pay-qr-dialog.slint";
import { AuthDialog } from "dialogs/auth-dialog.slint";
import { CreditInsufficientDialog } from "dialogs/credit-insufficient-dialog.slint";
import { CustomPromptDialog } from "dialogs/custom-prompt-dialog.slint";
import { InvoiceDialog } from "dialogs/invoice-dialog.slint";
import { InvoiceOrderDialog } from "dialogs/invoice-order-dialog.slint";
import { DeleteConfirm } from "dialogs/delete-confirm.slint";
import { ModelRequiredDialog } from "dialogs/model-required-dialog.slint";
import { QualityRestrictedDialog } from "dialogs/quality-restricted-dialog.slint";
import { ProfileDialog } from "dialogs/profile-dialog.slint";
import { AgreementUpdateDialog } from "dialogs/agreement-update-dialog.slint";
import { AgreementViewerDialog } from "dialogs/agreement-viewer-dialog.slint";
import { UpdateProgressDialog } from "dialogs/update-progress-dialog.slint";
import { UpscaleDialog } from "dialogs/upscale-dialog.slint";
import { VersionCheckDialog } from "dialogs/version-check-dialog.slint";
import { ViewerOverlay } from "dialogs/viewer-overlay.slint";
import { AssetsPage } from "pages/assets-page.slint";
import { CreditsPage } from "pages/credits-page.slint";
import { InspirationPage } from "pages/inspiration-page.slint";
import { InfiniteCanvasPage } from "pages/infinite-canvas-page.slint";
import { NotificationsPage } from "pages/notifications-page.slint";
import { SettingsPage } from "pages/settings-page.slint";
import { StudioSplitPage } from "pages/studio-split-page.slint";
import { WelcomePage } from "pages/welcome-page.slint";

export { AppState, AppTheme, AccountSession, ModelGroup, ModelOption, AssetItem, AssetGroup, CanvasNote, ConversationItem, NotificationItem, CreditRecord, CustomPromptItem, InvoiceOrderView, ReferenceItem }

export component AppWindow inherits Window {
    property <bool> invoice-open: false;
    property <bool> invoice-orders-open: false;
    property <string> invoice-order-id: "";
    property <string> invoice-order-title: "";
    property <string> invoice-order-amount: "";
    property <string> invoice-order-time: "";

    title: "ArtForgeStudio";
    preferred-width: 1440px;
    preferred-height: 900px;
    min-width: 1180px;
    min-height: 760px;
    icon: AppState.app-logo;
    background: AppTheme.bg;
    default-font-family: AppState.settings-font-family;
    default-font-size: AppState.settings-font-size * 1px;

    if AppState.page == "welcome": WelcomePage {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
    }

    if AppState.page != "welcome": HorizontalLayout {
        if AppState.logged-in: Sidebar {}
        VerticalLayout {
            TopBar {}
            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                if AppState.page == "generation": StudioSplitPage { width: parent.width; height: parent.height; generation: true; }
                if AppState.page == "canvas": InfiniteCanvasPage { width: parent.width; height: parent.height; }
                if AppState.page == "assets": AssetsPage { width: parent.width; height: parent.height; }
                if AppState.page == "inspiration": InspirationPage { width: parent.width; height: parent.height; }
                if AppState.page == "notifications": NotificationsPage { width: parent.width; height: parent.height; }
                if AppState.page == "credits": CreditsPage {
                    width: parent.width;
                    height: parent.height;
                    open-invoice-orders => { root.invoice-orders-open = true; }
                }
                if AppState.page == "settings": SettingsPage { width: parent.width; height: parent.height; }
            }
        }
    }

    AuthDialog { width: root.width; height: root.height; }
    ProfileDialog { width: root.width; height: root.height; }
    AgreementUpdateDialog { width: root.width; height: root.height; }
    AliPayQrDialog { width: root.width; height: root.height; }
    VersionCheckDialog { width: root.width; height: root.height; }
    UpdateProgressDialog { width: root.width; height: root.height; }
    ViewerOverlay { width: root.width; height: root.height; }
    UpscaleDialog { width: root.width; height: root.height; }
    if AppState.thumbnail-drag-preview-visible: Rectangle {
        x: max(0px, min(AppState.thumbnail-drag-preview-x - AppState.thumbnail-drag-preview-size / 2, root.width - AppState.thumbnail-drag-preview-size));
        y: max(0px, min(AppState.thumbnail-drag-preview-y - AppState.thumbnail-drag-preview-size / 2, root.height - AppState.thumbnail-drag-preview-size));
        width: AppState.thumbnail-drag-preview-size;
        height: AppState.thumbnail-drag-preview-size;
        background: transparent;
        border-radius: 8px;
        border-width: 1px;
        border-color: #ffffffaa;
        opacity: 0.62;
        clip: true;
        Image {
            width: parent.width;
            height: parent.height;
            source: AppState.thumbnail-drag-preview-image;
            image-fit: cover;
        }
    }
    DeleteConfirm { width: root.width; height: root.height; }
    ModelRequiredDialog { width: root.width; height: root.height; }
    CreditInsufficientDialog { width: root.width; height: root.height; }
    QualityRestrictedDialog { width: root.width; height: root.height; }
    CustomPromptDialog { width: root.width; height: root.height; }
    InvoiceOrderDialog {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        open <=> root.invoice-orders-open;
        select-order(order-id, order-title, order-amount, order-time) => {
            root.invoice-order-id = order-id;
            root.invoice-order-title = order-title;
            root.invoice-order-amount = order-amount;
            root.invoice-order-time = order-time;
            root.invoice-orders-open = false;
            root.invoice-open = true;
        }
    }
    InvoiceDialog {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        open <=> root.invoice-open;
        selected-order-id: root.invoice-order-id;
        selected-order-title: root.invoice-order-title;
        selected-order-amount: root.invoice-order-amount;
        selected-order-time: root.invoice-order-time;
    }
    AgreementViewerDialog { width: root.width; height: root.height; }
}
