    }
}

component CategoryTabs {
    in property <bool> for-assets: true;
    VerticalLayout {
        spacing: 9px;
        HorizontalLayout {
            visible: false;
            spacing: 10px;
            PillButton { width: 98px; text: AppState.en ? "Game Art" : "游戏美术"; active: root.for-assets ? AppState.asset-kind-filter == "game" : AppState.inspiration-kind-filter == "game"; clicked => { if root.for-assets { AppState.asset-kind-filter = "game"; AppState.refresh-assets(); } else { AppState.inspiration-kind-filter = "game"; AppState.refresh-inspiration(); } } }
            PillButton { width: 98px; text: AppState.en ? "Film" : "影视创作"; active: root.for-assets ? AppState.asset-kind-filter == "film" : AppState.inspiration-kind-filter == "film"; clicked => { if root.for-assets { AppState.asset-kind-filter = "film"; AppState.refresh-assets(); } else { AppState.inspiration-kind-filter = "film"; AppState.refresh-inspiration(); } } }
        }
        HorizontalLayout {
            spacing: 8px;
            if root.for-assets: PillButton { width: 78px; text: (AppState.en ? "All " : "全部 ") + AppState.asset-all-count; active: AppState.asset-category-filter == "all"; clicked => { AppState.asset-category-filter = "all"; AppState.refresh-assets(); } }
            if !root.for-assets: PillButton { width: 78px; text: AppState.en ? "All" : "全部"; active: AppState.inspiration-category-filter == "all"; clicked => { AppState.inspiration-category-filter = "all"; AppState.refresh-inspiration(); } }
            PillButton { width: 78px; text: root.for-assets ? (AppState.en ? "Char " : "角色 ") + AppState.asset-character-count : (AppState.en ? "Char" : "角色"); active: root.for-assets ? AppState.asset-category-filter == "character" : AppState.inspiration-category-filter == "character"; clicked => { if root.for-assets { AppState.asset-category-filter = "character"; AppState.refresh-assets(); } else { AppState.inspiration-category-filter = "character"; AppState.refresh-inspiration(); } } }
            PillButton { width: 78px; text: root.for-assets ? (AppState.en ? "Scene " : "场景 ") + AppState.asset-scene-count : (AppState.en ? "Scene" : "场景"); active: root.for-assets ? AppState.asset-category-filter == "scene" : AppState.inspiration-category-filter == "scene"; clicked => { if root.for-assets { AppState.asset-category-filter = "scene"; AppState.refresh-assets(); } else { AppState.inspiration-category-filter = "scene"; AppState.refresh-inspiration(); } } }
            PillButton { width: 68px; text: root.for-assets ? "UI " + AppState.asset-ui-count : "UI"; active: root.for-assets ? AppState.asset-category-filter == "ui" : AppState.inspiration-category-filter == "ui"; clicked => { if root.for-assets { AppState.asset-category-filter = "ui"; AppState.refresh-assets(); } else { AppState.inspiration-category-filter = "ui"; AppState.refresh-inspiration(); } } }
            PillButton { width: 78px; text: root.for-assets ? (AppState.en ? "FX " : "特效 ") + AppState.asset-effect-count : (AppState.en ? "FX" : "特效"); active: root.for-assets ? AppState.asset-category-filter == "effect" : AppState.inspiration-category-filter == "effect"; clicked => { if root.for-assets { AppState.asset-category-filter = "effect"; AppState.refresh-assets(); } else { AppState.inspiration-category-filter = "effect"; AppState.refresh-inspiration(); } } }
            PillButton { width: 78px; text: root.for-assets ? (AppState.en ? "Other " : "其他 ") + AppState.asset-other-count : (AppState.en ? "Other" : "其他"); active: root.for-assets ? AppState.asset-category-filter == "other" : AppState.inspiration-category-filter == "other"; clicked => { if root.for-assets { AppState.asset-category-filter = "other"; AppState.refresh-assets(); } else { AppState.inspiration-category-filter = "other"; AppState.refresh-inspiration(); } } }
        }
    }
}

component AssetGallery {
    in property <[AssetItem]> items;
    in property <[AssetGroup]> groups;
    in property <string> source;
    in property <length> card-width: 220px;
    Rectangle {
        width: root.width;
        height: root.height;
        clip: true;
        background: transparent;
        Flickable {
            width: parent.width;
            height: parent.height;
            viewport-width: parent.width;
            viewport-height: root.content-height();
            interactive: true;
            Rectangle {
                width: parent.viewport-width;
                height: root.content-height();
                background: transparent;
                if root.is-empty(): EmptyState {
                    width: parent.width;
                    height: max(360px, root.height);
                }
                if !root.is-empty(): TimeGroupedGallery {
                    width: parent.width;
                    height: root.content-height();
                    groups: root.groups;
                    card-width: root.card-width;
                    source: root.source;
                }
            }
        }
    }
    function is-empty() -> bool {
        return root.items.length == 0;
    }
    function content-height() -> length {
        return max(root.height, 34px + root.groups.length * 66px + root.row-count() * root.row-height());
    }
    function column-count() -> int {
        return max(1, min(root.items.length, min(8, floor((root.grid-width() + 18px) / root.item-slot-width()))));
    }
    function grid-width() -> length {
        return max(1px, root.width);
    }
    function item-slot-width() -> length {
        return root.card-width + 18px;
    }
    function item-width() -> length {
        return min(root.card-width, max(139px, (root.grid-width() - (root.column-count() - 1) * 18px) / root.column-count()));
    }
    function row-height() -> length {
        return root.item-width() + 48px;
    }
    function row-count() -> int {
        return (root.items.length + root.column-count() - 1) / root.column-count();
    }
}

component ModelsPage {
    function content-width() -> length {
        return root.width - 48px;
    }
    Rectangle {
        background: AppTheme.bg;
        ScrollView {
            width: parent.width;
            height: parent.height;
            Rectangle {
                x: 24px;
                y: 24px;
                width: root.content-width();
                height: max(680px, parent.height - 48px);
                background: transparent;
                VerticalLayout {
                    spacing: 16px;
                    HorizontalLayout {
                        spacing: 12px;
                        SectionTitle { horizontal-stretch: 1; text: AppState.en ? "Model List" : "模型列表"; }
                        Rectangle {
                            width: 62px;
                            height: 58px;
                            background: add-provider-hover.has-hover ? AppTheme.accent-dark : AppTheme.accent;
                            border-radius: 18px;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: "+";
                                color: #ffffff;
                                font-size: 24px;
                                font-weight: 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            add-provider-hover := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => { AppState.open-provider-editor(""); }
                            }
                        }
                    }
                    if AppState.provider-message != "": Rectangle {
                        height: 40px;
                        background: AppTheme.panel-soft;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        Text {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: AppState.provider-message;
                            color: AppTheme.muted;
                            font-size: 13px;
                            font-weight: 400;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                    if AppState.providers.length == 0: EmptyState {}
                    for provider in AppState.providers: Rectangle {
                        height: 104px;
                        background: AppTheme.panel;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        HorizontalLayout {
                            padding: 18px;
                            spacing: 14px;
                            Rectangle { width: 46px; height: 46px; border-radius: 12px; background: AppTheme.panel-soft; Text { width: parent.width; height: parent.height; text: "M"; color: AppTheme.accent-dark; horizontal-alignment: center; vertical-alignment: center; font-weight: 500; } }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 6px;
                                Text { text: provider.name; color: AppTheme.text; font-size: 17px; font-weight: 500; }
                                Text { text: provider.endpoint; color: AppTheme.accent-dark; font-size: 14px; font-weight: 400; overflow: elide; }
                                Text { text: provider.models.length + (AppState.en ? " models" : " 个模型"); color: AppTheme.muted; font-size: 12px; font-weight: 400; }
                            }
                            PillButton { width: 82px; text: AppState.en ? "Test" : "测速"; clicked => { AppState.test-provider(provider.id); } }
                            PillButton { width: 82px; text: AppState.en ? "Edit" : "编辑"; clicked => { AppState.edit-provider(provider.id); } }
                            PillButton { width: 82px; text: AppState.en ? "Delete" : "删除"; clicked => { AppState.delete-provider(provider.id); } }
                        }
                    }
                }
            }
        }
    }
}

component NotificationsPage {
    Rectangle {
        background: AppTheme.bg;
        Rectangle {
            x: 24px;
            y: 24px;
            width: parent.width - 48px;
            height: parent.height - 48px;
            background: transparent;
            VerticalLayout {
                spacing: 12px;
                Rectangle {
                    height: 44px;
                    background: transparent;
                    SectionTitle { x: 0px; y: 0px; width: parent.width - 280px; text: AppState.en ? "Notifications" : "通知"; }
                    PillButton {
                        x: parent.width - 264px;
                        y: 0px;
                        width: 124px;
                        height: 40px;
                        text: AppState.en ? "Clear all" : "一键清空";
                        primary: false;
                        danger: true;
                        disabled: AppState.notifications.length == 0;
                        clicked => { AppState.clear-all-notifications(); }
                    }
                    PillButton {
                        x: parent.width - 128px;
                        y: 0px;
                        width: 128px;
                        height: 40px;
                        text: AppState.en ? "Mark all read" : "一键已读";
                        primary: true;
                        disabled: !AppState.has-unread;
                        clicked => { AppState.mark-all-notifications-read(); }
                    }
                }
                ScrollView {
                    vertical-stretch: 1;
                    if AppState.notifications.length == 0: EmptyState { width: parent.width; height: parent.height; }
                    if AppState.notifications.length > 0: VerticalLayout {
                        spacing: 10px;
                        for item in AppState.notifications: Rectangle {
                            height: item.reason == "" ? 72px : 96px;
                            background: AppTheme.panel;
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: AppTheme.border;
                            Rectangle { x: 14px; y: 22px; width: 9px; height: 9px; border-radius: 5px; background: item.read ? transparent : (item.success ? AppTheme.success : AppTheme.danger); }
                            Text { x: 42px; y: 14px; width: parent.width - 64px; text: item.title; color: item.success ? AppTheme.text : AppTheme.danger; font-size: 14px; font-weight: 400; overflow: elide; }
                            Text { x: 42px; y: 38px; width: parent.width - 64px; text: AppState.en ? ("Model: " + item.model) : ("模型：" + item.model); color: AppTheme.muted; font-size: 12px; font-weight: 400; overflow: elide; }
                            if item.reason != "": Text { x: 42px; y: 64px; width: parent.width - 64px; text: AppState.en ? ("Reason: " + item.reason) : ("失败原因：" + item.reason); color: AppTheme.danger; font-size: 12px; font-weight: 400; overflow: elide; }
                            TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.mark-notification-read(item.id); } }
                        }
                    }
                }
            }
        }
    }
}

component CreditPlan {
    in property <int> amount;
    in property <string> price;
    in property <string> title;
    in property <string> note;
    width: 210px;
    height: 128px;
    Rectangle {
        background: AppState.selected-credit-amount == root.amount ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 12px;
        border-width: 1px;
        border-color: AppState.selected-credit-amount == root.amount ? AppTheme.accent : AppTheme.border;
        Text { x: 12px; y: 12px; width: parent.width - 24px; height: 22px; text: root.title; color: AppTheme.text; font-size: 15px; font-weight: 500; overflow: elide; }
        Text { x: 12px; y: 38px; width: parent.width - 24px; height: 18px; text: root.note; color: AppTheme.muted; font-size: 12px; font-weight: 400; overflow: elide; }
        Text {
            x: 12px;
            y: 60px;
            width: parent.width - 24px;
            height: 34px;
            text: AppState.en ? ("About " + root.estimated-images() + " images (minimum cost)") : ("预计能生成 " + root.estimated-images() + " 张图（以最小消耗计算）");
            color: AppTheme.muted;
            font-size: 11px;
            font-weight: 400;
            wrap: word-wrap;
        }
        Text { x: 12px; y: 96px; width: 82px; height: 22px; text: root.price; color: AppTheme.accent-dark; font-size: 17px; font-weight: 500; }
        Text {
            x: parent.width - 74px;
            y: 96px;
            width: 62px;
            height: 22px;
            text: AppState.selected-credit-amount == root.amount ? (AppState.en ? "Selected" : "已选择") : (AppState.en ? "Select" : "选择");
            color: AppState.selected-credit-amount == root.amount ? AppTheme.accent-dark : AppTheme.muted;
            font-size: 12px;
            font-weight: 400;
            horizontal-alignment: right;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.selected-credit-amount = root.amount;
                AppState.selected-credit-price = root.price;
            }
        }
    }
    function estimated-images() -> int {
        return root.amount / 50;
    }
}

component CreditRecordRow {
    in property <CreditRecord> item;
    height: 76px;
    Rectangle {
        background: AppTheme.panel;
        border-radius: 12px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text { x: 16px; y: 12px; width: parent.width - 140px; height: 22px; text: root.item.title; color: AppTheme.text; font-size: 15px; font-weight: 400; overflow: elide; }
        Text { x: 16px; y: 38px; width: parent.width - 140px; height: 20px; text: root.item.time + " · " + root.item.note; color: AppTheme.muted; font-size: 12px; font-weight: 400; overflow: elide; }
        Text {
            x: parent.width - 112px;
            y: 0px;
            width: 96px;
            height: parent.height;
            text: root.item.amount;
            color: root.item.positive ? AppTheme.success : AppTheme.danger;
            font-size: 16px;
            font-weight: 500;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }
}

component AliPayQrDialog {
    if AppState.credit-pay-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 380px) / 2;
            y: (parent.height - 470px) / 2;
            width: 380px;
            height: 470px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.credit-pay-open = false; } }
            VerticalLayout {
                padding: 24px;
                spacing: 14px;
                SectionTitle { text: AppState.en ? "Alipay Payment" : "支付宝扫码付款"; }
                Text {
                    height: 22px;
                    text: AppState.en ? ("Pay " + AppState.selected-credit-price + " for " + AppState.selected-credit-amount + " credits") : ("支付 " + AppState.selected-credit-price + "，充值 " + AppState.selected-credit-amount + " 积分");
                    color: AppTheme.text;
                    font-size: 14px;
                    font-weight: 400;
                    horizontal-alignment: center;
                    overflow: elide;
                }
                Rectangle {
                    height: 250px;
                    background: #ffffff;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: AppTheme.border;
                    Rectangle { x: 28px; y: 28px; width: 52px; height: 52px; background: #111111; }
                    Rectangle { x: parent.width - 80px; y: 28px; width: 52px; height: 52px; background: #111111; }
                    Rectangle { x: 28px; y: parent.height - 80px; width: 52px; height: 52px; background: #111111; }
                    Rectangle { x: 96px; y: 34px; width: 18px; height: 18px; background: #111111; }
                    Rectangle { x: 134px; y: 34px; width: 36px; height: 18px; background: #111111; }
                    Rectangle { x: 190px; y: 54px; width: 18px; height: 18px; background: #111111; }
                    Rectangle { x: 112px; y: 92px; width: 92px; height: 18px; background: #111111; }
                    Rectangle { x: 222px; y: 96px; width: 18px; height: 54px; background: #111111; }
                    Rectangle { x: 96px; y: 132px; width: 28px; height: 46px; background: #111111; }
                    Rectangle { x: 146px; y: 142px; width: 74px; height: 18px; background: #111111; }
                    Rectangle { x: 246px; y: 166px; width: 44px; height: 18px; background: #111111; }
                    Rectangle { x: 94px; y: 204px; width: 110px; height: 18px; background: #111111; }
                    Rectangle { x: 224px; y: 198px; width: 18px; height: 30px; background: #111111; }
                    Text { width: parent.width; height: parent.height; text: AppState.en ? "Alipay" : "支付宝"; color: #1677ff; font-size: 18px; font-weight: 500; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => {
                            AppState.credit-pay-open = false;
                            AppState.recharge-credits(AppState.selected-credit-amount);
                        }
                    }
                }
                Text {
                    height: 44px;
                    text: AppState.en ? "Test mode: click the QR code area to simulate a successful scan and payment." : "测试阶段：点击二维码区域，即视为扫码并支付成功。";
                    color: AppTheme.muted;
                    font-size: 13px;
                    font-weight: 400;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                PillButton { horizontal-stretch: 1; text: AppState.en ? "Cancel" : "取消"; clicked => { AppState.credit-pay-open = false; } }
            }
        }
    }
}

component CreditRuleDialog {
    if AppState.credit-rule-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 620px) / 2;
            y: (parent.height - 560px) / 2;
            width: 620px;
            height: 560px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.credit-rule-open = false; } }
            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                SectionTitle { text: "积分规则"; }
                ScrollView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    viewport-width: parent.width;
                    viewport-height: 650px;
                    Rectangle {
                        width: parent.viewport-width;
                        height: 650px;
                        background: transparent;
                        VerticalLayout {
                            spacing: 14px;
                            Text { text: "1、积分是什么？"; color: AppTheme.text; font-size: 15px; font-weight: 500; }
                            Text { text: "用户可通过消耗积分来使用AI平台提供的AI生成功能，每日来AI平台即可获得免费积分。"; color: AppTheme.muted; font-size: 13px; font-weight: 400; wrap: word-wrap; }
                            Text { text: "2、积分消耗顺序？"; color: AppTheme.text; font-size: 15px; font-weight: 500; }
                            Text { text: "按照积分有效期，先消耗即将过期的积分，默认的积分消耗顺序依次为每日免费积分、充值积分"; color: AppTheme.muted; font-size: 13px; font-weight: 400; wrap: word-wrap; }
                            Text { text: "3、积分充值"; color: AppTheme.text; font-size: 15px; font-weight: 500; }
                            Text { text: "会员用户可以通过充值获得积分，如您选择通过人民币充值获得积分，需要提示您积分充值服务为收费服务，积分为虚拟商品采用先收费后服务的方式。请您仔细阅读以下字段，并在理解和同意的前提下继续使用本产品：积分充值成功后，将不支持退款或反向兑换为人民币。积分不可兑换、不可转赠，也不可提现."; color: AppTheme.muted; font-size: 13px; font-weight: 400; wrap: word-wrap; }
                            Text { text: "4、充值渠道选择"; color: AppTheme.text; font-size: 15px; font-weight: 500; }
                            Text { text: "进行积分充值操作前，请务必仔细了解并谨慎选择适合的操作系统与渠道进行充值。"; color: AppTheme.muted; font-size: 13px; font-weight: 400; wrap: word-wrap; }
                        }
                    }
                }
                PillButton { horizontal-stretch: 1; text: "我知道了"; primary: true; clicked => { AppState.credit-rule-open = false; } }
            }
        }
    }
}

component CreditsPage {
    function content-width() -> length {
        return root.width - 48px;
    }
    function content-height() -> length {
        return max(root.height + 80px, 720px + max(1, AppState.credit-records.length) * 96px);
    }
    Rectangle {
        background: AppTheme.bg;
        ScrollView {
            width: parent.width;
            height: parent.height;
            viewport-width: parent.width;
            viewport-height: root.content-height() + 48px;
            Rectangle {
                x: 24px;
                y: 24px;
                width: root.content-width();
                height: root.content-height();
                background: transparent;
                VerticalLayout {
                    spacing: 16px;
                    Rectangle {
                        height: 32px;
                        background: transparent;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: AppState.en ? "Credits" : "积分";
                            color: AppTheme.text;
                            font-size: 22px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Text {
                            x: parent.width - 90px;
                            width: 90px;
                            height: parent.height;
                            text: "积分规则";
                            color: rule-touch.has-hover ? AppTheme.accent : AppTheme.muted;
                            font-size: 12px;
                            font-weight: 400;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                        rule-touch := TouchArea {
                            x: parent.width - 90px;
                            width: 90px;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => { AppState.credit-rule-open = true; }
                        }
                    }
                    Rectangle {
                        height: 132px;
                        background: AppTheme.panel;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        Text { x: 22px; y: 20px; text: AppState.en ? "Remaining Credits" : "剩余积分"; color: AppTheme.muted; font-size: 14px; font-weight: 400; }
                        Text { x: 22px; y: 48px; width: parent.width - 44px; height: 48px; text: AppState.credit-balance; color: AppTheme.text; font-size: 40px; font-weight: 600; }
                        Text { x: 22px; y: 98px; width: parent.width - 44px; height: 20px; text: AppState.en ? "Credits are used for image generation and prompt services." : "积分用于图片生成、提示词优化等服务。"; color: AppTheme.muted; font-size: 13px; font-weight: 400; overflow: elide; }
                    }
                    SectionTitle { text: AppState.en ? "Recharge" : "充值积分"; }
                    HorizontalLayout {
                        height: 128px;
                        spacing: 12px;
                        CreditPlan { amount: 1000; title: AppState.en ? "Starter Pack" : "基础包"; note: AppState.en ? "10 CNY = 1000 credits" : "10元兑换1000积分"; price: "¥ 10"; }
                        CreditPlan { amount: 5000; title: AppState.en ? "Creator Pack" : "创作包"; note: AppState.en ? "50 CNY = 5000 credits" : "50元兑换5000积分"; price: "¥ 50"; }
                        CreditPlan { amount: 10000; title: AppState.en ? "Studio Pack" : "工作室包"; note: AppState.en ? "100 CNY = 10000 credits" : "100元兑换10000积分"; price: "¥ 100"; }
                        CreditPlan { amount: 30000; title: AppState.en ? "Pro Pack" : "专业包"; note: AppState.en ? "300 CNY = 30000 credits" : "300元兑换30000积分"; price: "¥ 300"; }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                    }
                    Rectangle {
                        height: 54px;
                        background: transparent;
                        Text {
                            x: 0px;
                            width: parent.width - 150px;
                            height: parent.height;
                            text: AppState.en ? ("Selected: " + AppState.selected-credit-amount + " credits · " + AppState.selected-credit-price) : ("已选择：" + AppState.selected-credit-amount + " 积分 · " + AppState.selected-credit-price);
                            color: AppTheme.text;
                            font-size: 14px;
                            font-weight: 400;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        PillButton {
                            x: parent.width - 132px;
                            y: 8px;
                            width: 132px;
                            text: AppState.en ? "Recharge" : "充值";
                            primary: true;
                            clicked => { AppState.credit-pay-open = true; }
                        }
                    }
                    Rectangle {
                        height: 58px;
                        background: AppTheme.panel-soft;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        Text {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: AppState.en ? "Usage: GPT Image 2 generation costs 50 credits for 1K, 120 for 2K, 300 for 4K per image. GPT-5.5 prompt optimization or translation costs 5 credits each." : "消耗规则：GPT Image 2 每张图 1K 扣 50 积分，2K 扣 120 积分，4K 扣 300 积分；GPT-5.5 优化或翻译提示词每次扣 5 积分。";
                            color: AppTheme.muted;
                            font-size: 13px;
                            font-weight: 400;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                    HorizontalLayout {
                        spacing: 12px;
                        SectionTitle { horizontal-stretch: 1; text: AppState.en ? "Credit Details" : "积分明细"; }
                    }
                    if AppState.credit-records.length == 0: EmptyState {}
                    if AppState.credit-records.length > 0: VerticalLayout {
                        spacing: 10px;
                        for record in AppState.credit-records: CreditRecordRow { item: record; }
                    }
                }
            }
        }
    }
}

component RebateStatCard {
    in property <string> title;
    in property <string> value;
    in property <string> note;
    in property <bool> accent: false;
    height: 94px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: AppTheme.panel;
        border-radius: 12px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text {
            x: 18px;
            y: 16px;
            width: parent.width - 36px;
            height: 18px;
            text: root.title;
            color: AppTheme.muted;
            font-size: 12px;
            font-weight: 400;
            overflow: elide;
        }
        Text {
            x: 18px;
            y: 40px;
            width: parent.width - 36px;
            height: 34px;
            text: root.value;
            color: root.accent ? AppTheme.success : AppTheme.text;
            font-size: 24px;
            font-weight: 600;
            overflow: elide;
        }
        if root.note != "": Text {
            x: 18px;
            y: 72px;
            width: parent.width - 36px;
            height: 16px;
            text: root.note;
            color: AppTheme.weak;
            font-size: 11px;
            font-weight: 400;
            overflow: elide;
        }
    }
}

component RebateDisplayField {
    in property <string> label;
    in property <string> value;
    in property <string> button-text;
    height: 58px;
    Rectangle {
        background: transparent;
        Text {
            y: 0px;
            width: parent.width;
            height: 18px;
            text: root.label;
            color: AppTheme.muted;
            font-size: 12px;
            font-weight: 400;
            overflow: elide;
        }
        Rectangle {
            y: 22px;
            width: parent.width;
            height: 36px;
            background: AppTheme.panel-soft;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text {
                x: 12px;
                width: parent.width - 132px;
                height: parent.height;
                text: root.value == "" ? (AppState.en ? "Waiting for backend" : "待后端返回") : root.value;
                color: root.value == "" ? AppTheme.weak : AppTheme.text;
                font-size: 12px;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }
            PillButton {
                x: parent.width - 112px;
                y: 5px;
                width: 104px;
                height: 26px;
                text: root.button-text;
                disabled: root.value == "";
                clicked => {}
            }
        }
    }
}

component InviteUserRow {
    in property <string> email;
    in property <string> username;
    in property <int> rebate-points;
    in property <string> time;
    height: 38px;
    Rectangle {
        background: transparent;
        Text { x: 12px; width: parent.width * 34 / 100; height: parent.height; text: root.email; color: AppTheme.text; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        Text { x: parent.width * 34 / 100; width: parent.width * 24 / 100; height: parent.height; text: root.username == "" ? "-" : root.username; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        Text { x: parent.width * 58 / 100; width: parent.width * 18 / 100; height: parent.height; text: root.rebate-points + " 积分"; color: AppTheme.success; font-size: 12px; font-weight: 500; vertical-alignment: center; overflow: elide; }
        Text { x: parent.width * 76 / 100; width: parent.width * 22 / 100; height: parent.height; text: root.time; color: AppTheme.text; font-size: 12px; font-weight: 400; vertical-alignment: center; overflow: elide; }
    }
}

component InviteRebatePage {
    function content-width() -> length {
        return root.width - 48px;
    }
    function content-height() -> length {
        return max(root.height + 80px, 560px);
    }
    Rectangle {
        background: AppTheme.bg;
        ScrollView {
            width: parent.width;
            height: parent.height;
            viewport-width: parent.width;
            viewport-height: root.content-height() + 48px;
            Rectangle {
                x: 24px;
                y: 24px;
                width: root.content-width();
                height: root.content-height();
                background: transparent;
                VerticalLayout {
                    spacing: 16px;
                    HorizontalLayout {
                        height: 94px;
                        spacing: 12px;
                        RebateStatCard { horizontal-stretch: 1; title: AppState.en ? "My Rebate Rate" : "我的返现比例"; value: "10%"; note: AppState.en ? "Rebate points earned from invited users' recharge." : "被邀请用户充值积分后你可获得的返现比例"; accent: true; }
                        RebateStatCard { horizontal-stretch: 1; title: AppState.en ? "Invited Users" : "邀请人数"; value: "\{AppState.invited-users.length}"; }
                        RebateStatCard { horizontal-stretch: 1; title: AppState.en ? "Historical Rebate Points" : "历史返现积分"; value: AppState.invite-history-points + " 积分"; accent: true; }
                    }
                    Rectangle {
                        height: 268px;
                        background: AppTheme.panel;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        Text { x: 18px; y: 18px; width: parent.width - 36px; height: 24px; text: AppState.en ? "Invite Rebate" : "邀请返利"; color: AppTheme.text; font-size: 16px; font-weight: 600; overflow: elide; }
                        Text { x: 18px; y: 44px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Invite new users to register and earn rebate points from their recharge." : "邀请新用户注册，并按被邀请用户充值积分计算返现积分"; color: AppTheme.muted; font-size: 12px; font-weight: 400; overflow: elide; }
                        HorizontalLayout {
                            x: 18px;
                            y: 82px;
                            width: parent.width - 36px;
                            height: 58px;
                            spacing: 12px;
                            RebateDisplayField { horizontal-stretch: 1; label: AppState.en ? "My Invite Code" : "我的邀请码"; value: AppState.invite-code; button-text: AppState.en ? "Copy Code" : "复制邀请码"; }
                            RebateDisplayField { horizontal-stretch: 1; label: AppState.en ? "Invite Link" : "邀请链接"; value: AppState.invite-link; button-text: AppState.en ? "Copy Link" : "复制链接"; }
                        }
                        Rectangle {
                            x: 18px;
                            y: 160px;
                            width: parent.width - 36px;
                            height: 84px;
                            background: AppTheme.panel-soft;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: AppTheme.border;
                            Text {
                                x: 16px;
                                y: 12px;
                                width: parent.width - 32px;
                                height: parent.height - 24px;
                                text: AppState.en ? "Usage\n1. Share your invite code or invite link with new users.\n2. After invited users recharge credits, you receive 10% rebate points." : "使用说明\n1. 将邀请码或邀请链接分享给新用户。\n2. 被邀请用户充值积分后，你可获得 10% 的返利积分。";
                                color: AppTheme.accent-dark;
                                font-size: 12px;
                                font-weight: 500;
                                wrap: word-wrap;
                            }
                        }
                    }
                    Rectangle {
                        height: min(360px, max(150px, 98px + max(1, AppState.invited-users.length) * 40px));
                        background: AppTheme.panel;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        Text { x: 18px; y: 18px; width: parent.width - 36px; height: 24px; text: AppState.en ? "Invited Users" : "已邀请用户"; color: AppTheme.text; font-size: 16px; font-weight: 600; overflow: elide; }
                        Rectangle {
                            x: 18px;
                            y: 58px;
                            width: parent.width - 36px;
                            height: 1px;
                            background: AppTheme.border;
                        }
                        Text { x: 30px; y: 64px; width: (parent.width - 36px) * 34 / 100; height: 26px; text: AppState.en ? "Email" : "邮箱"; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; }
                        Text { x: 18px + (parent.width - 36px) * 34 / 100; y: 64px; width: (parent.width - 36px) * 24 / 100; height: 26px; text: AppState.en ? "Username" : "用户名"; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; }
                        Text { x: 18px + (parent.width - 36px) * 58 / 100; y: 64px; width: (parent.width - 36px) * 18 / 100; height: 26px; text: AppState.en ? "Rebate Points" : "返现积分"; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; }
                        Text { x: 18px + (parent.width - 36px) * 76 / 100; y: 64px; width: (parent.width - 36px) * 22 / 100; height: 26px; text: AppState.en ? "Register Time" : "注册时间"; color: AppTheme.muted; font-size: 12px; font-weight: 400; vertical-alignment: center; }
                        Rectangle { x: 18px; y: 92px; width: parent.width - 36px; height: 1px; background: AppTheme.border; }
                        if AppState.invited-users.length == 0: Text {
                            x: 18px;
                            y: 104px;
                            width: parent.width - 36px;
                            height: 32px;
                            text: AppState.en ? "No invited users yet." : "暂无邀请用户";
                            color: AppTheme.muted;
                            font-size: 13px;
                            font-weight: 400;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        if AppState.invited-users.length > 0: ScrollView {
                            x: 18px;
                            y: 94px;
                            width: parent.width - 36px;
                            height: parent.height - 106px;
                            viewport-width: parent.width - 36px;
                            viewport-height: AppState.invited-users.length * 40px;
                            Rectangle {
                                width: parent.viewport-width;
                                height: parent.viewport-height;
                                background: transparent;
                                for user[index] in AppState.invited-users: Rectangle {
                                    y: index * 40px;
                                    width: parent.width;
                                    height: 40px;
                                    InviteUserRow { x: 0px; y: 0px; width: parent.width; email: user.email; username: user.username; rebate-points: user.rebate-points; time: user.register-time; }
                                    Rectangle { x: 0px; y: 38px; width: parent.width; height: 1px; background: AppTheme.border; }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component ThemeTile {
    in property <string> id;
    in property <string> label;
    in property <color> color;
    height: 46px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: AppState.theme-id == root.id ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: AppState.theme-id == root.id ? AppTheme.accent : AppTheme.border;
        Rectangle { x: 12px; y: 16px; width: 14px; height: 14px; border-radius: 7px; background: root.color; }
        Text { x: 34px; width: parent.width - 42px; height: parent.height; text: root.label; color: AppTheme.text; font-size: 13px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.set-theme(root.id); } }
    }
}

component FontStepButton {
    in property <string> text;
    callback clicked();
    width: 36px;
    height: 36px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: touch.has-hover ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 18px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text {
            width: parent.width;
            height: parent.height;
            text: root.text;
            color: AppTheme.text;
            font-size: 15px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.clicked(); } }
    }
}

component ThemeOption {
    in property <string> id;
    in property <string> label;
    in property <color> color;
    callback close();
    width: 172px;
    height: 34px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: AppState.theme-id == root.id ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : AppTheme.panel);
        border-radius: 8px;
        border-width: 1px;
        border-color: AppState.theme-id == root.id ? AppTheme.accent : transparent;
        Rectangle { x: 12px; y: 10px; width: 12px; height: 12px; border-radius: 6px; background: root.color; }
        Text { x: 34px; width: parent.width - 46px; height: parent.height; text: root.label; color: AppTheme.text; font-size: 13px; font-weight: 400; vertical-alignment: center; }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.set-theme(root.id);
                root.close();
            }
        }
    }
}

component ThemeMenuButton {
    in property <bool> marketing: false;
    property <bool> open: false;
    callback clicked();
    height: 36px;
    Rectangle {
        background: root.marketing ? #ffffffcc : AppTheme.panel;
        border-radius: 18px;
        border-width: 1px;
        border-color: AppTheme.border;
        Rectangle { x: 17px; y: 12px; width: 12px; height: 12px; border-radius: 6px; background: AppTheme.accent; }
        Text { x: 36px; width: parent.width - 66px; height: parent.height; text: AppState.en ? "Theme" : "主题"; color: root.marketing ? #111827 : AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; }
        DropdownIcon { x: parent.width - 28px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; AppState.theme-menu-open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: -84px;
        y: 42px;
        width: 188px;
        height: 402px;
        close-policy: close-on-click-outside;
        Rectangle {
            visible: AppState.theme-menu-open;
            background: AppTheme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: AppTheme.border;
            VerticalLayout {
                padding: 8px;
                spacing: 4px;
                ThemeOption { id: "light"; label: AppState.en ? "Light" : "素白"; color: #ffffff; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "deep"; label: AppState.en ? "Deep Purple" : "深紫"; color: #4f46e5; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "ocean"; label: AppState.en ? "Ocean Blue" : "深海蓝"; color: #0ea5e9; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "forest"; label: AppState.en ? "Forest Green" : "森林绿"; color: #22c55e; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "warm"; label: AppState.en ? "Warm Ink" : "暖墨棕"; color: #f59e0b; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "rose"; label: AppState.en ? "Rose" : "暗玫瑰"; color: #f43f5e; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "cream"; label: AppState.en ? "Cream" : "奶白"; color: #c96b73; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "cyber"; label: AppState.en ? "Cyber Purple" : "赛博紫"; color: #d946ef; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "oled"; label: AppState.en ? "Black" : "纯黑"; color: #000000; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "system"; label: AppState.en ? "System" : "跟随系统"; color: #5b6472; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
                ThemeOption { id: "user"; label: AppState.en ? "Custom" : "自定义"; color: #5b5fc7; close => { root.open = false; AppState.theme-menu-open = false; popup.close(); } }
            }
        }
    }
}

component DirRow {
    in property <string> label;
    in property <string> value;
    in property <string> kind;
    height: 68px;
    Rectangle {
        background: transparent;
        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: AppTheme.border; }
        Text { x: 0px; y: 12px; text: root.label; color: AppTheme.text; font-size: 14px; font-weight: 400; }
        Text { x: 0px; y: 35px; width: parent.width - 112px; text: root.value; color: AppTheme.muted; font-size: 13px; font-weight: 400; overflow: elide; }
        PillButton { x: parent.width - 80px; y: 16px; width: 72px; text: AppState.en ? "Choose" : "选择"; clicked => { AppState.pick-dir(root.kind); } }
    }
}

component AuthDialog {
    if AppState.auth-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 420px) / 2;
            y: (parent.height - 330px) / 2;
            width: 420px;
            height: 330px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.auth-open = false; } }
            VerticalLayout {
                padding: 24px;
                spacing: 12px;
                SectionTitle { text: AppState.en ? "Login / Sign Up" : "登录/注册"; }
                Field { label: AppState.en ? "Phone" : "手机号"; placeholder: AppState.en ? "Enter phone number" : "请输入手机号"; value <=> AppState.auth-phone; }
                Rectangle {
                    height: 78px;
                    background: transparent;
                    Text { x: 0px; y: 0px; text: AppState.en ? "Code" : "验证码"; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; }
                    Rectangle {
                        x: 0px;
                        y: 32px;
                        width: parent.width - 130px;
                        height: 46px;
                        background: AppTheme.panel;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: code-input.has-focus ? AppTheme.accent : AppTheme.border;
                        code-input := TextInput {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text <=> AppState.auth-code;
                            single-line: true;
                            color: AppTheme.text;
                            font-size: AppState.settings-font-size * 1px;
                            font-weight: 400;
                            vertical-alignment: center;
                        }
                        if (AppState.auth-code == "") && (!code-input.has-focus): Text {
                            x: 14px;
                            width: parent.width - 28px;
                            height: parent.height;
                            text: AppState.en ? "Enter code" : "请输入验证码";
                            color: AppTheme.weak;
                            font-size: AppState.settings-font-size * 1px;
                            font-weight: 400;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                    PillButton {
                        x: parent.width - 120px;
                        y: 37px;
                        width: 120px;
                        text: AppState.auth-countdown > 0 ? (AppState.en ? "\{AppState.auth-countdown}s" : "\{AppState.auth-countdown}秒") : (AppState.en ? "Get Code" : "获取验证码");
                        clicked => { AppState.request-code(); }
                    }
                }
                Text {
                    height: 18px;
                    text: AppState.auth-error;
                    color: AppState.auth-error == "" ? transparent : AppTheme.danger;
                    font-size: 13px;
                    font-weight: 400;
                    vertical-alignment: center;
                    overflow: elide;
                }
                HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Cancel" : "取消"; clicked => { AppState.auth-open = false; } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Login / Sign Up" : "登录/注册"; primary: true; clicked => { AppState.login-or-register(); } }
                }
            }
        }
    }
}

component ProviderEditorDialog {
    property <length> dialog-width: min(760px, root.width - 48px);
    property <length> dialog-height: min(760px, root.height - 24px);

    if AppState.provider-editor-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - root.dialog-width) / 2;
            y: (parent.height - root.dialog-height) / 2;
            width: root.dialog-width;
            height: root.dialog-height;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.close-provider-editor(); } }
            SectionTitle {
                x: 24px;
                y: 24px;
                width: parent.width - 48px;
                text: AppState.edit-provider-id == "" ? (AppState.en ? "Add Model" : "添加模型") : (AppState.en ? "Edit Model" : "编辑模型");
            }
            Field { x: 24px; y: 72px; width: parent.width - 48px; label: AppState.en ? "Provider Name" : "供应商名称"; placeholder: AppState.en ? "Example: deepseek" : "例如：deepseek"; value <=> AppState.provider-name; required: true; }
            Field { x: 24px; y: 162px; width: parent.width - 48px; label: "API Key"; placeholder: AppState.en ? "Enter API key" : "请输入APIkey"; value <=> AppState.provider-api-key; secret: true; required: true; }
            Field { x: 24px; y: 252px; width: parent.width - 48px; label: AppState.en ? "API Endpoint" : "API 请求地址"; placeholder: "https://api.example.com/v1"; value <=> AppState.provider-endpoint; required: true; }
            Rectangle {
                x: 24px;
                y: 346px;
                width: parent.width - 48px;
                height: AppState.provider-model-options.length == 0 ? 92px : max(116px, parent.height - 346px - (AppState.provider-message != "" ? 116px : 92px));
                background: transparent;
                Text { x: 0px; y: 6px; text: AppState.en ? "Model Name" : "模型名称"; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; }
                PillButton { x: parent.width - 204px; y: 0px; width: 112px; text: AppState.en ? "Fetch" : "获取模型"; clicked => { AppState.fetch-models(); } }
                PillButton { x: parent.width - 82px; y: 0px; width: 82px; text: AppState.en ? "Test" : "测速"; clicked => { AppState.test-provider(AppState.edit-provider-id); } }
                if AppState.provider-model-options.length == 0: Rectangle {
                    x: 0px;
                    y: 46px;
                    width: parent.width;
                    height: 46px;
                    background: AppTheme.panel;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: AppTheme.border;
                    Text {
                        x: 14px;
                        width: parent.width - 28px;
                        height: parent.height;
                        text: AppState.provider-model-name == "" ? (AppState.en ? "Fetch models first" : "请获取模型") : AppState.provider-model-name;
                        color: AppState.provider-model-name == "" ? AppTheme.weak : AppTheme.text;
                        font-size: AppState.settings-font-size * 1px;
                        font-weight: 400;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
                if AppState.provider-model-options.length > 0: ScrollView {
                    x: 0px;
                    y: 60px;
                    width: parent.width;
                    height: parent.height - 60px;
                    viewport-width: parent.width;
                    viewport-height: max(parent.height - 60px, AppState.provider-model-options.length * 52px + 8px);
                    Rectangle {
                        width: parent.viewport-width;
                        height: parent.viewport-height;
                        background: transparent;
                        for model[index] in AppState.provider-model-options: Rectangle {
                            y: index * 52px;
                            height: 44px;
                            width: parent.width;
                            background: AppTheme.panel-soft;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: AppTheme.border;
                            Text {
                                x: 14px;
                                width: parent.width - 362px;
                                height: parent.height;
                                text: model.name;
                                color: AppTheme.text;
                                font-size: AppState.settings-font-size * 1px;
                                font-weight: 400;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            PillButton { x: parent.width - 340px; y: 5px; width: 88px; height: 34px; text: model.used ? (AppState.en ? "Used" : "已使用") : (AppState.en ? "Use" : "使用"); primary: model.used; clicked => { AppState.toggle-provider-model-used(model.name); } }
                            PillButton { x: parent.width - 238px; y: 5px; width: 108px; height: 34px; text: AppState.pending-reasoning-model == model.name ? (AppState.en ? "Reasoning Set" : "已设为推理") : (AppState.en ? "Reasoning" : "设为推理"); primary: AppState.pending-reasoning-model == model.name; clicked => { AppState.set-provider-model-role("reasoning", model.name); } }
                            PillButton { x: parent.width - 120px; y: 5px; width: 108px; height: 34px; text: AppState.pending-image-model == model.name ? (AppState.en ? "Image Set" : "已设为生图") : (AppState.en ? "Image" : "设为生图"); primary: AppState.pending-image-model == model.name; clicked => { AppState.set-provider-model-role("image", model.name); } }
                        }
                    }
                }
            }
            if AppState.provider-message != "": Text {
                x: 24px;
                y: parent.height - 96px;
                width: parent.width - 48px;
                height: 20px;
                text: AppState.provider-message;
                color: AppTheme.muted;
                font-size: 13px;
                font-weight: 400;
                overflow: elide;
            }
            HorizontalLayout {
                x: 24px;
                y: parent.height - 70px;
                width: parent.width - 48px;
                height: 46px;
                spacing: 16px;
                PillButton { horizontal-stretch: 1; height: 46px; text: AppState.en ? "Cancel" : "取消"; clicked => { AppState.close-provider-editor(); } }
                PillButton { horizontal-stretch: 1; height: 46px; text: AppState.en ? "Save Model" : "保存模型"; primary: true; clicked => { AppState.save-provider(); } }
            }
        }
    }
}

component CardStyleOption {
    in property <string> id;
    in property <string> label;
    height: 46px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: AppState.card-style == root.id ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: AppState.card-style == root.id ? AppTheme.accent : AppTheme.border;
        Rectangle {
            x: 12px;
            y: 15px;
            width: 16px;
            height: 16px;
            border-radius: root.id == "rounded" ? 5px : 0px;
            border-width: 1px;
            border-color: AppState.card-style == root.id ? AppTheme.accent : AppTheme.weak;
            background: transparent;
            if AppState.card-style == root.id: Rectangle {
                x: 4px;
                y: 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: AppTheme.accent;
            }
        }
        Text { x: 38px; width: parent.width - 48px; height: parent.height; text: root.label; color: AppTheme.text; font-size: 13px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.set-card-style(root.id); } }
    }
}

component ProfileDialog {
    if AppState.profile-open: Rectangle {
        background: #00000055;
        TouchArea { width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 380px) / 2;
            y: (parent.height - 260px) / 2;
            width: 380px;
            height: 260px;
            background: AppTheme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.border;
            DialogCloseButton { x: parent.width - 42px; y: 12px; clicked => { AppState.profile-open = false; } }
            VerticalLayout {
                padding: 24px;
                spacing: 12px;
                SectionTitle { text: AppState.en ? "Profile" : "修改资料"; }
                Field { label: AppState.en ? "Nickname" : "昵称"; placeholder: AppState.phone-mask; value <=> AppState.profile-name; }
                HorizontalLayout {
                    spacing: 10px;
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Logout" : "退出登录"; danger: true; clicked => { AppState.logout(); } }
                    PillButton { horizontal-stretch: 1; text: AppState.en ? "Save" : "保存"; primary: true; clicked => { AppState.save-profile(); } }
                }
            }
        }
