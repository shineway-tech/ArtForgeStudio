export global AppTheme {
    in-out property <color> bg: #ecfbf4;
    in-out property <color> panel: #ffffff;
    in-out property <color> panel-soft: #e9f8f0;
    in-out property <color> border: #ccebdd;
    in-out property <color> text: #07130f;
    in-out property <color> muted: #50625b;
    in-out property <color> weak: #8da096;
    in-out property <color> accent: #00d982;
    in-out property <color> accent-dark: #06b96f;
    in-out property <color> danger: #ef6969;
    in-out property <color> warning: #f5a524;
    in-out property <color> success: #00c878;
}

component IconButton {
    in property <string> text;
    in property <bool> active: false;
    in property <bool> danger: false;
    callback clicked();
    width: 120px;
    height: 38px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: root.active ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 8px;
        border-width: 1px;
        border-color: root.active ? AppTheme.accent : transparent;
        Text {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.text;
            color: root.active ? AppTheme.accent-dark : (root.danger ? AppTheme.danger : AppTheme.text);
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.clicked(); } }
    }
}

component PillButton {
    in property <string> text;
    in property <bool> active: false;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> disabled: false;
    callback clicked();
    min-width: 72px;
    height: 36px;
    Rectangle {
        width: root.width;
        height: root.height;
        opacity: root.disabled ? 0.45 : 1.0;
        background: root.primary || root.active ? AppTheme.accent : (touch.has-hover && !root.disabled ? AppTheme.panel-soft : AppTheme.panel);
        border-radius: 18px;
        border-width: root.primary || root.active ? 0px : 1px;
        border-color: root.danger ? AppTheme.danger : (touch.has-hover && !root.disabled ? AppTheme.accent : AppTheme.border);
        Text {
            x: 0px;
            width: parent.width;
            height: parent.height;
            text: root.text;
            color: root.primary || root.active ? #ffffff : (root.danger ? AppTheme.danger : AppTheme.text);
            font-size: AppState.settings-font-size * 1px;
            font-weight: root.primary ? 500 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => {
                if !root.disabled {
                    root.clicked();
                }
            }
        }
    }
}

component GenerateActionButton {
    in property <bool> disabled: false;
    callback clicked();
    height: 56px;
    Rectangle {
        width: root.width;
        height: root.height;
        opacity: root.disabled ? 0.45 : 1.0;
        background: AppTheme.accent;
        border-radius: root.height / 2;
        Text {
            x: 14px;
            y: AppState.generating ? 0px : 8px;
            width: parent.width - 28px;
            height: AppState.generating ? parent.height : 20px;
            text: AppState.generating ? (AppState.en ? "Stop" : "停止生成") : (AppState.en ? "Generate" : "生成");
            color: #ffffff;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        if !AppState.generating: Text {
            x: 14px;
            y: parent.height - 24px;
            width: parent.width - 28px;
            height: 16px;
            text: AppState.en ? ("Estimated cost: " + AppState.generation-estimated-credit-cost + " credits") : ("本次预计消耗 " + AppState.generation-estimated-credit-cost + " 积分");
            color: #ffffffcc;
            font-size: 11px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => {
                if !root.disabled {
                    root.clicked();
                }
            }
        }
    }
}

component SmallToggle {
    in property <bool> checked: false;
    callback toggled();
    width: 36px;
    height: 20px;
    Rectangle {
        background: root.checked ? AppTheme.accent : AppTheme.panel-soft;
        border-radius: 10px;
        border-width: 1px;
        border-color: root.checked ? AppTheme.accent : AppTheme.border;
        Rectangle {
            x: root.checked ? parent.width - 18px : 2px;
            y: 2px;
            width: 16px;
            height: 16px;
            border-radius: 8px;
            background: #ffffff;
            animate x { duration: 120ms; }
        }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.toggled(); } }
    }
}

component HelpBubble {
    in property <string> text;
    property <bool> open: false;
    width: 18px;
    height: 18px;
    Timer {
        interval: 80ms;
        running: true;
        triggered => {
            if helper.has-hover && !root.open {
                root.open = true;
                popup.show();
            }
            if !helper.has-hover && root.open {
                root.open = false;
                popup.close();
            }
        }
    }
    Rectangle {
        background: helper.has-hover ? AppTheme.panel-soft : transparent;
        border-radius: 9px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text {
            width: parent.width;
            height: parent.height;
            text: "?";
            color: AppTheme.muted;
            font-size: 12px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        helper := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: help;
        }
    }
    popup := PopupWindow {
        x: -242px;
        y: 24px;
        width: 260px;
        height: 82px;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                height: parent.height - 20px;
                text: root.text;
                color: AppTheme.text;
                font-size: 12px;
                font-weight: 400;
                wrap: word-wrap;
            }
        }
    }
}

component TranslateTipArea {
    in property <string> text;
    property <bool> open: false;
    Timer {
        interval: 80ms;
        running: true;
        triggered => {
            if hover.has-hover && !root.open {
                root.open = true;
                popup.show();
            }
            if !hover.has-hover && root.open {
                root.open = false;
                popup.close();
            }
        }
    }
    hover := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: help;
    }
    popup := PopupWindow {
        x: -84px;
        y: 28px;
        width: 260px;
        height: 82px;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                height: parent.height - 20px;
                text: root.text;
                color: AppTheme.text;
                font-size: 12px;
                font-weight: 400;
                wrap: word-wrap;
            }
        }
    }
}

component DialogCloseButton {
    callback clicked();
    width: 30px;
    height: 30px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: touch.has-hover ? AppTheme.panel-soft : transparent;
        border-radius: 15px;
        Text {
            width: parent.width;
            height: parent.height;
                text: "x";
            color: AppTheme.muted;
            font-size: 18px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.clicked(); } }
    }
}

component DropdownIcon {
    width: 12px;
    height: 12px;
    Image {
        width: parent.width;
        height: parent.height;
        source: AppState.icon-dropdown;
        colorize: AppTheme.muted;
        image-fit: contain;
    }
}

component Field {
    in property <string> label;
    in property <string> placeholder;
    in-out property <string> value;
    in property <bool> secret: false;
    in property <bool> required: false;
    height: 78px;
    VerticalLayout {
        spacing: 7px;
        HorizontalLayout {
            height: 20px;
            spacing: 3px;
            alignment: start;
            Text { height: parent.height; text: root.label; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; }
            if root.required: Text { width: 8px; height: parent.height; text: "*"; color: AppTheme.danger; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; }
            Rectangle { horizontal-stretch: 1; background: transparent; }
        }
        Rectangle {
            height: 46px;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: input.has-focus ? AppTheme.accent : AppTheme.border;
            input := TextInput {
                x: 14px;
                width: parent.width - 28px;
                height: parent.height;
                text <=> root.value;
                input-type: root.secret ? password : text;
                single-line: true;
                color: AppTheme.text;
                font-size: AppState.settings-font-size * 1px;
                font-weight: 400;
                vertical-alignment: center;
            }
            if root.value == "" && !input.has-focus: Text {
                x: 14px;
                width: parent.width - 28px;
                height: parent.height;
                text: root.placeholder;
                color: AppTheme.weak;
                font-size: AppState.settings-font-size * 1px;
                font-weight: 400;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }
}

component ProviderModelPicker {
    property <bool> open: false;
    height: 46px;
    Rectangle {
        height: 46px;
        background: AppTheme.panel;
        border-radius: 8px;
        border-width: 1px;
        border-color: AppTheme.accent;
        Text {
            x: 14px;
            width: parent.width - 48px;
            height: parent.height;
            text: AppState.provider-model-name == "" ? (AppState.en ? "Select a model" : "请选择模型") : AppState.provider-model-name;
            color: AppState.provider-model-name == "" ? AppTheme.weak : AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: 50px;
        width: root.width;
        height: min(240px, AppState.fetched-models.length * 42px + 12px);
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            ScrollView {
                width: parent.width;
                height: parent.height;
                VerticalLayout {
                    padding: 6px;
                    spacing: 4px;
                    for model in AppState.fetched-models: IconButton {
                        width: root.width - 12px;
                        text: model;
                        active: AppState.provider-model-name == model;
                        clicked => {
                            AppState.provider-model-name = model;
                            root.open = false;
                            popup.close();
                        }
                    }
                }
            }
        }
    }
}

component FontPicker {
    property <bool> open: false;
    height: 46px;
    Rectangle {
        background: AppTheme.panel;
        border-radius: 8px;
        border-width: 1px;
        border-color: root.open ? AppTheme.accent : AppTheme.border;
        Text {
            x: 14px;
            width: parent.width - 48px;
            height: parent.height;
            text: AppState.settings-font-family;
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.load-fonts();
                root.open = true;
                popup.show();
            }
        }
    }
    popup := PopupWindow {
        x: 0px;
        y: 50px;
        width: root.width;
        height: 260px;
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            ScrollView {
                width: parent.width;
                height: parent.height;
                VerticalLayout {
                    padding: 6px;
                    spacing: 4px;
                    for font in AppState.font-list: IconButton {
                        width: root.width - 12px;
                        text: font;
                        active: AppState.settings-font-family == font;
                        clicked => {
                            AppState.settings-font-family = font;
                            root.open = false;
                            popup.close();
                        }
                    }
                }
            }
        }
    }
}

component SectionTitle {
    in property <string> text;
    height: 36px;
    Text {
        text: root.text;
        color: AppTheme.text;
        font-size: (AppState.settings-font-size + 8) * 1px;
        font-weight: 600;
        vertical-alignment: center;
    }
}

component ModelPicker {
    in property <string> kind;
    in property <string> label;
    in property <length> picker-width: 320px;
    callback select-model(string, string);
    property <bool> open: false;
    width: root.picker-width;
    height: 46px;
    Rectangle {
        background: AppTheme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: open ? AppTheme.accent : AppTheme.border;
        Text {
            x: 14px;
            width: 62px;
            height: parent.height;
            text: root.label;
            color: AppTheme.muted;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        Rectangle { x: 82px; y: (parent.height - 8px) / 2; width: 8px; height: 8px; border-radius: 4px; background: AppTheme.accent; }
        Text {
            x: 100px;
            width: parent.width - 134px;
            height: parent.height;
            text: display-text();
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: 50px;
        width: root.width;
        height: 320px;
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            ScrollView {
                width: parent.width;
                height: parent.height;
                VerticalLayout {
                    padding: 6px;
                    spacing: 4px;
                    if AppState.providers.length == 0: IconButton {
                        width: root.width - 12px;
                        text: AppState.en ? "Add a model first" : "请先添加模型";
                        clicked => { root.open = false; popup.close(); AppState.navigate("models"); }
                    }
                    if !AppState.provider-used-filter-active: VerticalLayout {
                        spacing: 4px;
                        for provider in AppState.providers: VerticalLayout {
                            spacing: 4px;
                            if provider.models.length == 0: IconButton {
                                width: root.width - 12px;
                                text: provider.name + " / " + (provider.selected-model == "" ? (AppState.en ? "No models fetched" : "未获取模型") : provider.selected-model);
                                active: root.kind == "image"
                                    ? AppState.image-provider-id == provider.id && AppState.image-model == provider.selected-model
                                    : AppState.reasoning-provider-id == provider.id && AppState.reasoning-model == provider.selected-model;
                                clicked => {
                                    root.select-model(provider.id, provider.selected-model);
                                    root.open = false;
                                    popup.close();
                                }
                            }
                            for model in provider.models: IconButton {
                                width: root.width - 12px;
                                text: provider.name + " / " + model;
                                active: root.kind == "image"
                                    ? AppState.image-provider-id == provider.id && AppState.image-model == model
                                    : AppState.reasoning-provider-id == provider.id && AppState.reasoning-model == model;
                                clicked => {
                                    root.select-model(provider.id, model);
                                    root.open = false;
                                    popup.close();
                                }
                            }
                        }
                    }
                    if AppState.provider-used-filter-active: VerticalLayout {
                        spacing: 4px;
                        for provider in AppState.providers: VerticalLayout {
                            spacing: 4px;
                            for model in provider.used-models: IconButton {
                                width: root.width - 12px;
                                text: provider.name + " / " + model;
                                active: root.kind == "image"
                                    ? AppState.image-provider-id == provider.id && AppState.image-model == model
                                    : AppState.reasoning-provider-id == provider.id && AppState.reasoning-model == model;
                                clicked => {
                                    root.select-model(provider.id, model);
                                    root.open = false;
                                    popup.close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    function display-text() -> string {
        if root.kind == "image" {
            return AppState.image-model == "" ? (AppState.en ? "Not selected" : "未选择") : AppState.image-model;
        }
        return AppState.reasoning-model == "" ? (AppState.en ? "Not selected" : "未选择") : AppState.reasoning-model;
    }
}

component NavGlyph {
    in property <string> kind;
    in property <color> glyph-color;
    width: 22px;
    height: 22px;
    if root.kind == "assets": Image { width: parent.width; height: parent.height; source: AppState.icon-assets; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "generation": Image { width: parent.width; height: parent.height; source: AppState.icon-generation; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "workspace": Image { width: parent.width; height: parent.height; source: AppState.icon-workspace; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "inspiration": Image { width: parent.width; height: parent.height; source: AppState.icon-inspiration; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "notifications": Image { width: parent.width; height: parent.height; source: AppState.icon-notifications; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "settings": Image { width: parent.width; height: parent.height; source: AppState.icon-settings; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "models": Image { width: parent.width; height: parent.height; source: AppState.icon-models; colorize: root.glyph-color; image-fit: contain; }
    if root.kind == "credits": Text { width: parent.width; height: parent.height; text: "¥"; color: root.glyph-color; font-size: 14px; font-weight: 500; horizontal-alignment: center; vertical-alignment: center; }
    if root.kind == "rebate": Text { width: parent.width; height: parent.height; text: "%"; color: root.glyph-color; font-size: 14px; font-weight: 500; horizontal-alignment: center; vertical-alignment: center; }
}

component NavItem {
    in property <string> icon;
    in property <string> label;
    in property <string> page;
    in property <bool> show-dot: false;
    width: 176px;
    height: 38px;
    Rectangle {
        background: AppState.page == root.page ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 7px;
        border-width: AppState.page == root.page ? 1px : 0px;
        border-color: AppTheme.accent;
        Rectangle {
            x: 9px;
            y: 8px;
            width: 22px;
            height: 22px;
            border-radius: 6px;
            background: AppTheme.panel-soft;
            NavGlyph {
                kind: root.icon;
                glyph-color: AppTheme.accent-dark;
                width: parent.width;
                height: parent.height;
            }
        }
        Text {
            x: 42px;
            width: parent.width - 52px;
            height: parent.height;
            text: root.label;
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
        }
        if root.show-dot: Rectangle {
            x: parent.width - 18px;
            y: 7px;
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: AppTheme.danger;
        }
        touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.navigate(root.page); } }
    }
}

component CategoryWorkspaceOption {
    in property <string> category;
    in property <string> label;
    callback picked();
    width: 176px;
    height: 32px;
    Rectangle {
        x: 8px;
        width: parent.width - 8px;
        height: parent.height;
        background: AppState.page == "generation" && AppState.asset-type == root.category ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 7px;
        border-width: AppState.page == "generation" && AppState.asset-type == root.category ? 1px : 0px;
        border-color: AppTheme.accent;
        Rectangle {
            x: 14px;
            y: (parent.height - 16px) / 2;
            width: 16px;
            height: 16px;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppState.asset-type == root.category ? AppTheme.accent : AppTheme.weak;
            background: transparent;
            if AppState.asset-type == root.category: Rectangle {
                x: 4px;
                y: 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: AppTheme.accent;
            }
        }
        Text {
            x: 42px;
            width: parent.width - 52px;
            height: parent.height;
            text: root.label;
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.select-workspace-category(root.category);
                root.picked();
                AppState.navigate("generation");
            }
        }
    }
}

component CategoryWorkspaceMenu {
    property <bool> open: true;
    width: 176px;
    height: root.open ? 182px : 38px;
    VerticalLayout {
        spacing: 4px;
        Rectangle {
            width: root.width;
            height: 38px;
            background: AppState.page == "generation" ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : transparent);
            border-radius: 7px;
            border-width: AppState.page == "generation" ? 1px : 0px;
            border-color: AppTheme.accent;
            Rectangle {
                x: 9px;
                y: 8px;
                width: 22px;
                height: 22px;
                border-radius: 6px;
                background: AppTheme.panel-soft;
                NavGlyph {
                    kind: "generation";
                    glyph-color: AppTheme.accent-dark;
                    width: parent.width;
                    height: parent.height;
                }
            }
            Text {
                x: 42px;
                width: parent.width - 74px;
                height: parent.height;
                text: AppState.en ? "Workspace" : "工作台";
                color: AppTheme.text;
                font-size: AppState.settings-font-size * 1px;
                font-weight: 400;
                vertical-alignment: center;
                overflow: elide;
            }
            DropdownIcon { x: parent.width - 28px; y: (parent.height - 12px) / 2; }
            touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = !root.open; } }
        }
        if root.open: CategoryWorkspaceOption { category: "character"; label: AppState.en ? "Character" : "角色"; }
        if root.open: CategoryWorkspaceOption { category: "scene"; label: AppState.en ? "Scene" : "场景"; }
        if root.open: CategoryWorkspaceOption { category: "ui"; label: "UI"; }
        if root.open: CategoryWorkspaceOption { category: "effect"; label: AppState.en ? "Effect" : "特效"; }
    }

    function current-label() -> string {
        if AppState.asset-type == "scene" { return AppState.en ? "Scene" : "场景"; }
        if AppState.asset-type == "ui" { return "UI"; }
        if AppState.asset-type == "effect" { return AppState.en ? "Effect" : "特效"; }
        if AppState.asset-type == "action-sequence" { return AppState.en ? "Action Sequence" : "动作序列"; }
        return AppState.en ? "Character" : "角色";
    }
}

component ShowcaseTile inherits Rectangle {
    in property <image> source;
    in property <string> title;
    in property <string> subtitle;
    border-radius: 20px;
    clip: true;
    background: #1d1d1f;
    Image {
        x: hover.has-hover ? -12px : 0px;
        y: hover.has-hover ? -12px : 0px;
        width: parent.width + (hover.has-hover ? 24px : 0px);
        height: parent.height + (hover.has-hover ? 24px : 0px);
        source: root.source;
        image-fit: cover;
        animate x, y, width, height { duration: 180ms; }
    }
    Rectangle { y: parent.height - 92px; height: 92px; background: @linear-gradient(0deg, #000000b8, #00000000); }
    Text { x: 20px; y: parent.height - 62px; text: root.title; color: #ffffff; font-size: 24px; font-weight: 600; }
    Text { x: 20px; y: parent.height - 32px; text: root.subtitle; color: #ffffffe0; font-size: 16px; font-weight: 400; }
    hover := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; }
}
component UploadCard {
    callback clicked();
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 3px;
        border-width: 1px;
        border-color: AppTheme.accent;
        Text { width: parent.width; height: parent.height; text: "+"; color: AppTheme.muted; font-size: 22px; font-weight: 300; horizontal-alignment: center; vertical-alignment: center; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.clicked(); } }
    }
}

component ReferenceThumb {
    in property <ReferenceItem> item;
    width: 60px;
    height: 70px;
    Rectangle {
        background: transparent;
        clip: false;
        Image { x: 4px; y: 8px; width: 48px; height: 58px; source: root.item.image; image-fit: contain; }
        TouchArea { x: 0px; y: 8px; width: 52px; height: 58px; mouse-cursor: pointer; clicked => { AppState.open-reference(root.item.id); } }
        Rectangle {
            x: 38px; y: 0px; width: 20px; height: 20px; border-radius: 10px; background: AppTheme.danger;
            Text { width: parent.width; height: parent.height; text: "x"; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; font-size: 12px; }
            TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.remove-reference(root.item.id); } }
        }
    }
}

component TypeOption {
    in property <string> id;
    in property <string> label;
    callback close();
    width: 138px;
    height: 38px;
    IconButton { width: root.width; height: root.height; text: root.label; active: AppState.asset-type == root.id; clicked => { AppState.asset-type = root.id; root.close(); } }
}

component CountOption {
    in property <int> count;
    callback close();
    width: 104px;
    height: 38px;
    IconButton { width: root.width; height: root.height; text: root.count + (AppState.en ? " img" : " 张"); active: AppState.count == root.count; clicked => { AppState.count = root.count; root.close(); } }
}

component RatioButton {
    in property <string> id;
    in property <string> label;
    width: 94px;
    height: 40px;
    PillButton { width: root.width; height: root.height; text: root.label; active: AppState.ratio == root.id; clicked => { AppState.ratio = root.id; } }
}

component QualityButton {
    in property <string> label;
    in property <string> value: label;
    width: 130px;
    height: 40px;
    PillButton { width: root.width; height: root.height; text: root.label; active: AppState.quality == root.value; clicked => { AppState.quality = root.value; } }
}

component InlineChoiceCard {
    in property <string> label;
    in property <string> value;
    in property <string> group;
    width: 54px;
    height: 42px;
    Rectangle {
        background: root.active() ? AppTheme.accent : AppTheme.panel-soft;
        border-radius: 6px;
        border-width: 1px;
        border-color: root.active() ? AppTheme.accent : AppTheme.border;
        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.label;
            color: root.active() ? #ffffff : AppTheme.text;
            font-size: max(10px, (AppState.settings-font-size - 1) * 1px);
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.pick(); }
        }
    }

    function active() -> bool {
        if root.group == "type" { return AppState.asset-type == root.value; }
        if root.group == "ratio" { return AppState.ratio == root.value; }
        if root.group == "quality" { return AppState.quality == root.value; }
        return root.group == "count" && AppState.count == root.count-value();
    }

    function count-value() -> int {
        if root.value == "2" { return 2; }
        if root.value == "4" { return 4; }
        return 1;
    }

    function pick() {
        if root.group == "type" { AppState.asset-type = root.value; }
        if root.group == "ratio" { AppState.ratio = root.value; }
        if root.group == "quality" { AppState.quality = root.value; }
        if root.group == "count" { AppState.count = root.count-value(); }
    }
}

component InlineToggleCard {
    in property <string> label;
    callback clicked();
    width: 54px;
    height: 42px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 6px;
        border-width: 1px;
        border-color: AppTheme.border;
        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.label;
            color: AppTheme.text;
            font-size: max(10px, (AppState.settings-font-size - 1) * 1px);
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component InlineCardChooser {
    height: root.content-height();
    Rectangle {
        background: transparent;
        Text { x: 0px; y: 0px; width: parent.width; height: 18px; text: AppState.en ? "Canvas" : "画布"; color: AppTheme.muted; font-size: 12px; font-weight: 400; }
        GridLayout {
            x: 0px;
            y: 20px;
            spacing: 8px;
            if AppState.asset-type == "action-sequence": Row {
                InlineChoiceCard { group: "ratio"; value: "1:1"; label: "1:1"; }
                InlineChoiceCard { group: "ratio"; value: "9:16"; label: "9:16"; }
                InlineChoiceCard { group: "ratio"; value: "16:9"; label: "16:9"; }
            }
            if AppState.asset-type != "action-sequence" && !AppState.ratio-more-open: Row {
                InlineChoiceCard { group: "ratio"; value: "1:1"; label: "1:1"; }
                InlineChoiceCard { group: "ratio"; value: "3:2"; label: "3:2"; }
                InlineChoiceCard { group: "ratio"; value: "5:4"; label: "5:4"; }
                InlineChoiceCard { group: "ratio"; value: "16:9"; label: "16:9"; }
                InlineChoiceCard { group: "ratio"; value: "2:1"; label: "2:1"; }
                InlineToggleCard { label: AppState.en ? "More" : "更多"; clicked => { AppState.ratio-more-open = true; } }
            }
            if AppState.asset-type != "action-sequence" && AppState.ratio-more-open: Row {
                InlineChoiceCard { group: "ratio"; value: "1:1"; label: "1:1"; }
                InlineChoiceCard { group: "ratio"; value: "3:2"; label: "3:2"; }
                InlineChoiceCard { group: "ratio"; value: "2:3"; label: "2:3"; }
                InlineChoiceCard { group: "ratio"; value: "4:3"; label: "4:3"; }
                InlineChoiceCard { group: "ratio"; value: "3:4"; label: "3:4"; }
                InlineChoiceCard { group: "ratio"; value: "5:4"; label: "5:4"; }
            }
            if AppState.asset-type != "action-sequence" && AppState.ratio-more-open: Row {
                InlineChoiceCard { group: "ratio"; value: "4:5"; label: "4:5"; }
                InlineChoiceCard { group: "ratio"; value: "16:9"; label: "16:9"; }
                InlineChoiceCard { group: "ratio"; value: "9:16"; label: "9:16"; }
                InlineChoiceCard { group: "ratio"; value: "2:1"; label: "2:1"; }
                InlineChoiceCard { group: "ratio"; value: "1:2"; label: "1:2"; }
                InlineChoiceCard { group: "ratio"; value: "21:9"; label: "21:9"; }
            }
            if AppState.asset-type != "action-sequence" && AppState.ratio-more-open: Row {
                InlineChoiceCard { group: "ratio"; value: "9:21"; label: "9:21"; }
                InlineToggleCard { label: AppState.en ? "Less" : "收起"; clicked => { AppState.ratio-more-open = false; } }
            }
        }

        Text { x: 0px; y: root.quality-y(); width: parent.width; height: 18px; text: AppState.en ? "Resolution" : "清晰度"; color: AppTheme.muted; font-size: 12px; font-weight: 400; }
        GridLayout {
            x: 0px;
            y: root.quality-y() + 20px;
            spacing: 8px;
            Row {
                InlineChoiceCard { group: "quality"; value: "1K"; label: "1K"; }
                InlineChoiceCard { group: "quality"; value: "2K"; label: "2K"; }
                InlineChoiceCard { group: "quality"; value: "4K"; label: "4K"; }
            }
        }

        if AppState.asset-type != "action-sequence": Text { x: 0px; y: root.count-y(); width: parent.width; height: 18px; text: AppState.en ? "Count" : "张数"; color: AppTheme.muted; font-size: 12px; font-weight: 400; }
        if AppState.asset-type != "action-sequence": GridLayout {
            x: 0px;
            y: root.count-y() + 20px;
            spacing: 8px;
            Row {
                InlineChoiceCard { group: "count"; value: "1"; label: AppState.en ? "1 img" : "1张"; }
                InlineChoiceCard { group: "count"; value: "2"; label: AppState.en ? "2 imgs" : "2张"; }
                InlineChoiceCard { group: "count"; value: "4"; label: AppState.en ? "4 imgs" : "4张"; }
            }
        }
    }

    function ratio-rows-height() -> length {
        if AppState.asset-type == "action-sequence" { return 42px; }
        return AppState.ratio-more-open ? 142px : 42px;
    }
    function quality-y() -> length {
        return 20px + root.ratio-rows-height() + 22px;
    }
    function count-y() -> length {
        return root.quality-y() + 84px;
    }
    function content-height() -> length {
        if AppState.asset-type == "action-sequence" { return root.quality-y() + 64px; }
        return root.count-y() + 64px;
    }
}

component StudioToolCard {
    in property <string> title;
    in property <string> subtitle;
    in property <string> page;
    in property <string> mode: "";
    height: 124px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: touch.has-hover ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: touch.has-hover ? AppTheme.accent : AppTheme.border;
        Text { x: 18px; y: 18px; width: parent.width - 62px; text: root.title; color: AppTheme.text; font-size: 16px; font-weight: 500; overflow: elide; }
        Text { x: 18px; y: 48px; width: parent.width - 36px; text: root.subtitle; color: AppTheme.muted; font-size: 12px; font-weight: 400; wrap: word-wrap; }
        Text { x: parent.width - 36px; y: 16px; width: 18px; height: 24px; text: "→"; color: AppTheme.accent-dark; font-size: 18px; font-weight: 400; horizontal-alignment: center; vertical-alignment: center; }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.mode = root.mode == "" ? AppState.mode : root.mode;
                AppState.navigate(root.page);
            }
        }
    }
}

component EmptyState {
    height: 220px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: transparent;
        Image {
            x: (parent.width - 96px) / 2;
            y: max(0px, (parent.height - 146px) / 2);
            width: 96px;
            height: 96px;
            source: AppState.icon-empty;
            image-fit: contain;
            colorize: AppTheme.accent;
        }
        Text {
            x: 0px;
            y: max(0px, (parent.height - 146px) / 2) + 112px;
            width: parent.width;
            height: 24px;
            text: AppState.en ? "No data" : "暂无数据";
            color: AppTheme.accent-dark;
            font-size: 14px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component ConversationSide {
    width: 236px;
    Rectangle {
        background: AppTheme.panel;
        border-width: 1px;
        border-color: AppTheme.border;
        VerticalLayout {
            padding: 14px;
            spacing: 12px;
            alignment: start;
            Text { vertical-stretch: 0; text: AppState.en ? "Conversations" : "对话记录"; color: AppTheme.text; font-size: 15px; font-weight: 400; }
            Rectangle { height: 1px; vertical-stretch: 0; background: AppTheme.border; }
            if AppState.conversations.length == 0: EmptyState { height: 180px; vertical-stretch: 0; }
            for item in AppState.conversations: Rectangle {
                height: 58px;
                vertical-stretch: 0;
                background: item.id == AppState.current-conversation-id || touch.has-hover ? AppTheme.panel-soft : AppTheme.panel;
                border-radius: 8px;
                border-width: 1px;
                border-color: item.id == AppState.current-conversation-id || touch.has-hover ? AppTheme.accent : AppTheme.border;
                HorizontalLayout {
                    padding: 8px;
                    spacing: 10px;
                    Rectangle {
                        width: 42px; height: 42px; border-radius: 8px; background: AppTheme.panel; clip: true;
                        if item.loading: LoadingDots { width: parent.width; height: parent.height; }
                        if !item.loading: Image { source: item.image; width: parent.width; height: parent.height; image-fit: cover; }
                    }
                    Text { text: item.title; color: AppTheme.text; font-size: 13px; font-weight: 400; vertical-alignment: center; overflow: elide; }
                }
                touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.open-conversation(item.id); } }
            }
        }
    }
}

component GenerationRecord {
    in property <AssetItem> item;
    in property <length> record-width: 820px;
    VerticalLayout {
        spacing: 12px;
        width: root.record-width;
        HorizontalLayout {
            width: root.record-width;
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: min(460px, root.record-width * 54 / 100);
                height: 48px;
                background: AppTheme.panel;
                border-radius: 16px;
                border-width: 1px;
                border-color: AppTheme.border;
                Text { x: 16px; width: parent.width - 32px; height: parent.height; text: root.item.title; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
            }
        }
        VerticalLayout {
            spacing: 10px;
            alignment: start;
            if root.item.source-path != "failed": Rectangle {
                width: thumb-width(root.item.ratio) * 1px;
                height: thumb-height(root.item.ratio) * 1px;
                background: transparent;
                Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.item.image;
                    image-fit: cover;
                    TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.open-viewer(root.item.id, "generation"); } }
                }
            }
            if root.item.source-path == "failed": Rectangle {
                width: min(520px, root.record-width * 62 / 100);
                height: 54px;
                background: AppTheme.panel-soft;
                border-radius: 12px;
                border-width: 1px;
                border-color: AppTheme.danger;
                Text {
                    x: 14px;
                    width: parent.width - 28px;
                    height: parent.height;
                    text: root.item.prompt;
                    color: AppTheme.danger;
                    font-size: AppState.settings-font-size * 1px;
                    font-weight: 400;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            Text { text: root.item.time; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
            HorizontalLayout {
                spacing: 8px;
                PillButton { width: 104px; text: AppState.en ? "Regenerate" : "重新生成"; primary: true; clicked => { AppState.regenerate(root.item.id); } }
                if root.item.source-path != "failed": PillButton { width: 44px; text: "引用"; primary: true; clicked => { AppState.quote-generation(root.item.id); } }
            }
        }
    }
    function thumb-width(ratio: string) -> int {
        if ratio == "9:16" { return 205; }
        if ratio == "3:4" { return 250; }
        if ratio == "2:3" { return 240; }
        if ratio == "4:5" { return 250; }
        if ratio == "1:2" { return 205; }
        if ratio == "9:21" { return 190; }
        if ratio == "16:9" { return 360; }
        if ratio == "21:9" { return 400; }
        if ratio == "2:1" { return 380; }
        if ratio == "3:2" { return 330; }
        if ratio == "4:3" { return 320; }
        if ratio == "5:4" { return 300; }
        return 250;
    }
    function thumb-height(ratio: string) -> int {
        if ratio == "9:16" { return 450; }
        if ratio == "3:4" { return 336; }
        if ratio == "2:3" { return 360; }
        if ratio == "4:5" { return 312; }
        if ratio == "1:2" { return 410; }
        if ratio == "9:21" { return 444; }
        if ratio == "16:9" { return 203; }
        if ratio == "21:9" { return 171; }
        if ratio == "2:1" { return 190; }
        if ratio == "3:2" { return 220; }
        if ratio == "4:3" { return 240; }
        if ratio == "5:4" { return 240; }
        return 250;
    }
}

component ThumbnailCard {
    in property <AssetItem> item;
    in property <length> card-width: 188px;
    in property <length> card-gap: 18px;
    in property <string> source: "asset";
    in property <bool> active: true;
    property <length> outline-pad: 4px;
    property <bool> drag-armed: false;
    property <bool> system-drag-preview-started: false;
    width: root.card-width;
    height: root.active ? root.card-width + root.card-gap : 0px;
    DragArea {
        width: root.card-width;
        height: root.card-width;
        visible: root.item.source-path != "failed";
        enabled: root.can-drag-preview();
        mime-type: "application/x-artforge-image-path";
        data: root.item.source-path;
        Rectangle {
            width: root.card-width;
            height: root.card-width;
            visible: root.active;
            background: transparent;
            if root.item.source-path != "failed" && hover.has-hover: Rectangle {
                width: parent.width;
                height: parent.height;
                background: transparent;
                border-radius: AppState.card-style == "rounded" ? 10px : 0px;
                border-width: 2px;
                border-color: AppTheme.accent;
            }
            content := Rectangle {
                x: root.outline-pad;
                y: root.outline-pad;
                width: root.visual-card-width();
                height: root.visual-card-width();
                background: root.item.source-path == "failed" || hover.has-hover ? AppTheme.panel-soft : transparent;
                border-radius: AppState.card-style == "rounded" ? 8px : 0px;
                border-width: root.item.source-path == "failed" ? 1px : 0px;
                border-color: AppTheme.border;
                clip: true;
                if root.item.source-path != "failed": Image {
                    x: hover.has-hover ? -parent.width * 0.05 : 0px;
                    y: hover.has-hover ? -parent.height * 0.05 : 0px;
                    width: hover.has-hover ? parent.width * 1.10 : parent.width;
                    height: hover.has-hover ? parent.height * 1.10 : parent.height;
                    source: root.item.image;
                    image-fit: cover;
                    animate x, y, width, height { duration: 140ms; }
                }
                if root.item.source-path == "failed": Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: AppTheme.panel-soft;
                    Text {
                        x: 12px;
                        y: parent.height / 2 - 30px;
                        width: parent.width - 24px;
                        height: 24px;
                        text: AppState.en ? "Failed" : "生成失败";
                        color: AppTheme.danger;
                        font-size: 13px;
                        font-weight: 400;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }
                if root.item.source-path == "failed": PillButton {
                    x: (parent.width - 74px) / 2;
                    y: parent.height / 2 + 2px;
                    width: 74px;
                    height: 32px;
                    text: AppState.en ? "Retry" : "重试";
                    primary: true;
                    disabled: AppState.generating && AppState.generation-active-category == root.item.category;
                    clicked => { AppState.retry-generation(root.item.id); }
                }
                if root.item.source-path != "failed" && root.source != "generation": Rectangle {
                    y: parent.height - 86px;
                    width: parent.width;
                    height: 86px;
                    background: @linear-gradient(0deg, #000000b8, #00000000);
                }
                if root.item.source-path != "failed" && root.source != "generation": Text {
                    x: 13px;
                    y: parent.height - 46px;
                    width: parent.width - 26px;
                    text: root.item.title;
                    color: #ffffff;
                    font-size: 14px;
                    font-weight: 500;
                    overflow: elide;
                }
                if root.item.source-path != "failed" && root.source != "generation": Text {
                    x: 13px;
                    y: parent.height - 24px;
                    width: parent.width - 26px;
                    text: category-label(root.item.category);
                    color: #ffffffc8;
                    font-size: 12px;
                    font-weight: 400;
                    overflow: elide;
                }
                if root.item.source-path != "failed" && hover.has-hover: Rectangle {
                    y: parent.height - 42px;
                    width: parent.width;
                    height: 42px;
                    background: #000000a8;
                    Text {
                        x: 12px;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: root.meta-label();
                        color: #ffffff;
                        font-size: 12px;
                        font-weight: 400;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
            hover := TouchArea {
                width: parent.width;
                height: parent.height;
                visible: root.item.source-path != "failed";
                mouse-cursor: pointer;
                pointer-event(event) => {
                    if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                        root.drag-armed = true;
                        root.system-drag-preview-started = false;
                        root.update-drag-preview();
                    } else if event.kind == PointerEventKind.move {
                        root.update-drag-preview();
                        root.start-system-drag-preview();
                    } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                        root.hide-drag-preview();
                    }
                }
                moved => {
                    if root.drag-armed {
                        root.update-drag-preview();
                        root.start-system-drag-preview();
                    } else {
                        root.hide-drag-preview();
                    }
                }
                clicked => {
                    root.hide-drag-preview();
                    if root.item.source-path != "failed" {
                        AppState.open-viewer(root.item.id, root.source);
                    }
                }
            }
        }
    }
    if root.item.source-path == "failed": Rectangle {
        width: root.card-width;
        height: root.card-width;
        visible: root.active;
        background: transparent;
        Rectangle {
            x: root.outline-pad;
            y: root.outline-pad;
            width: root.visual-card-width();
            height: root.visual-card-width();
            background: AppTheme.panel-soft;
            border-radius: AppState.card-style == "rounded" ? 8px : 0px;
            border-width: 1px;
            border-color: AppTheme.border;
            Text {
                x: 12px;
                y: parent.height / 2 - 30px;
                width: parent.width - 24px;
                height: 24px;
                text: AppState.en ? "Failed" : "生成失败";
                color: AppTheme.danger;
                font-size: 13px;
                font-weight: 400;
                vertical-alignment: center;
                horizontal-alignment: center;
                overflow: elide;
            }
            PillButton {
                x: (parent.width - 74px) / 2;
                y: parent.height / 2 + 2px;
                width: 74px;
                height: 32px;
                text: AppState.en ? "Retry" : "重试";
                primary: true;
                disabled: AppState.generating && AppState.generation-active-category == root.item.category;
                clicked => { AppState.retry-generation(root.item.id); }
            }
        }
    }
    function image-height() -> length {
        return root.card-width;
    }
    function image-width() -> length {
        return root.card-width;
    }
    function visual-height() -> length {
        return root.card-width;
    }
    function visual-card-width() -> length {
        return max(1px, root.card-width - root.outline-pad * 2);
    }
    function can-drag-preview() -> bool {
        return root.active && root.item.source-path != "" && root.item.source-path != "failed";
    }
    function update-drag-preview() {
        if !root.can-drag-preview() || !root.drag-armed {
            return;
        }
        AppState.thumbnail-drag-preview-visible = true;
        AppState.thumbnail-drag-preview-image = root.item.image;
        AppState.thumbnail-drag-preview-size = root.card-width * 0.82;
        AppState.thumbnail-drag-preview-x = hover.absolute-position.x + hover.mouse-x;
        AppState.thumbnail-drag-preview-y = hover.absolute-position.y + hover.mouse-y;
    }
    function hide-drag-preview() {
        root.drag-armed = false;
        AppState.thumbnail-drag-preview-visible = false;
        root.system-drag-preview-started = false;
    }
    function start-system-drag-preview() {
        if !root.can-drag-preview() || !root.drag-armed || root.system-drag-preview-started {
            return;
        }
        root.system-drag-preview-started = true;
        let drag-data = root.item.drag-uri != "" ? root.item.drag-uri : root.item.source-path;
        AppState.start-thumbnail-drag-preview(drag-data);
        AppState.thumbnail-drag-preview-visible = false;
        AppState.start-thumbnail-file-drag(drag-data);
    }
    function category-label(id: string) -> string {
        if id == "character" { return AppState.en ? "Character" : "角色"; }
        if id == "scene" { return AppState.en ? "Scene" : "场景"; }
        if id == "ui" { return AppState.en ? "UI" : "UI"; }
        if id == "effect" { return AppState.en ? "Effect" : "特效"; }
        return AppState.en ? "Other" : "其他";
    }
    function meta-label() -> string {
        if root.item.quality != "" && root.item.model != "" { return root.item.quality + " · " + root.item.model; }
        if root.item.quality != "" { return root.item.quality; }
        return root.item.model;
    }
}

component GenerationLoadingCard {
    in property <length> card-width: 188px;
    in property <length> card-gap: 10px;
    width: root.card-width;
    height: root.card-width + root.card-gap;
    Rectangle {
        width: root.width;
        height: root.card-width;
        background: AppTheme.panel-soft;
        border-radius: 12px;
        border-width: 1px;
        border-color: AppTheme.border;
        LoadingDots {
            x: (parent.width - 64px) / 2;
            y: parent.height / 2 - 48px;
            width: 64px;
            height: 46px;
        }
        Text {
            x: 0px;
            y: parent.height / 2 + 6px;
            width: parent.width;
            height: 24px;
            text: AppState.en ? "Generating..." : "生成中...";
            color: AppTheme.accent-dark;
            font-size: 13px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component GenerationMasonryColumn {
    in property <[AssetItem]> items;
    in property <length> card-width: 188px;
    in property <int> column-index: 0;
    in property <int> column-count: 1;
    in property <int> loading-count: 0;
    horizontal-stretch: 0;
    width: root.column-width();
    VerticalLayout {
        x: 0px;
        width: root.width;
        spacing: 0px;
        alignment: start;
        if root.loading-count > 0 && Math.mod(0, root.column-count) == root.column-index: GenerationLoadingCard {
            card-width: root.card-width;
            card-gap: 10px;
        }
        if root.loading-count > 1 && Math.mod(1, root.column-count) == root.column-index: GenerationLoadingCard {
            card-width: root.card-width;
            card-gap: 10px;
        }
        if root.loading-count > 2 && Math.mod(2, root.column-count) == root.column-index: GenerationLoadingCard {
            card-width: root.card-width;
            card-gap: 10px;
        }
        if root.loading-count > 3 && Math.mod(3, root.column-count) == root.column-index: GenerationLoadingCard {
            card-width: root.card-width;
            card-gap: 10px;
        }
        for item[index] in root.items: ThumbnailCard {
            active: Math.mod(index + root.loading-count, root.column-count) == root.column-index;
            item: item;
            card-width: root.card-width;
            card-gap: 10px;
            source: "generation";
        }
    }
    function column-width() -> length {
        return root.card-width;
    }
}

component GenerationWaterfall {
    in property <[AssetItem]> items;
    in property <length> card-width: 120px;
    in property <int> column-count: 1;
    in property <int> loading-count: 0;
    width: root.column-count * root.column-width() + max(0, root.column-count - 1) * 10px;
    HorizontalLayout {
        x: 0px;
        width: root.used-width();
        height: root.height;
        spacing: 10px;
        alignment: start;
        if root.column-count >= 1: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 0; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 2: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 1; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 3: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 2; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 4: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 3; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 5: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 4; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 6: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 5; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 7: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 6; column-count: root.column-count; loading-count: root.loading-count; }
        if root.column-count >= 8: GenerationMasonryColumn { items: root.items; card-width: root.card-width; column-index: 7; column-count: root.column-count; loading-count: root.loading-count; }
    }
    function column-width() -> length {
        return root.card-width;
    }
    function used-width() -> length {
        return root.column-count * root.column-width() + max(0, root.column-count - 1) * 10px;
    }
}

component TimeGroupSection {
    in property <AssetGroup> group;
    in property <length> card-width: 200px;
    in property <string> source: "asset";
    height: root.content-height();
    Rectangle {
        width: root.width;
        height: root.height;
        background: transparent;
        Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: root.header-height();
            text: root.group.title;
            color: AppTheme.text;
            font-size: 20px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }
        for item[index] in root.group.items: ThumbnailCard {
            x: root.item-x(index);
            y: root.item-y(index);
            item: item;
            card-width: root.item-width();
            card-gap: 0px;
            source: root.source;
        }
    }
    function grid-gap() -> length {
        return 8px;
    }
    function header-height() -> length {
        return 32px;
    }
    function section-gap() -> length {
        return 26px;
    }
    function grid-y() -> length {
        return root.header-height() + 8px;
    }
    function grid-width() -> length {
        return max(1px, root.width);
    }
    function column-count() -> int {
        return max(1, min(root.group.items.length, min(8, floor((root.grid-width() + root.grid-gap()) / (root.card-width + root.grid-gap())))));
    }
    function item-width() -> length {
        return min(root.card-width, max(118px, (root.grid-width() - (root.column-count() - 1) * root.grid-gap()) / root.column-count()));
    }
    function row-height() -> length {
        return root.item-width() + root.grid-gap();
    }
    function row-count() -> int {
        return (root.group.items.length + root.column-count() - 1) / root.column-count();
    }
    function item-x(index: int) -> length {
        return Math.mod(index, root.column-count()) * (root.item-width() + root.grid-gap());
    }
    function item-y(index: int) -> length {
        return root.grid-y() + floor(index / root.column-count()) * root.row-height();
    }
    function content-height() -> length {
        if root.group.items.length == 0 {
            return 0px;
        }
        return root.grid-y() + root.row-count() * root.row-height() + root.section-gap();
    }
}

component TimeGroupedGallery inherits VerticalLayout {
    in property <[AssetGroup]> groups;
    in property <length> card-width: 200px;
    in property <string> source: "asset";
    spacing: 0px;
    for group in root.groups: TimeGroupSection {
        width: root.width;
        group: group;
        card-width: root.card-width;
        source: root.source;
    }
}

component GenerationResultPanel {
    Rectangle {
        background: AppTheme.panel;
        border-width: 1px;
        border-color: AppTheme.border;
        Text {
            x: 20px;
            y: 18px;
            width: parent.width - 40px;
            text: AppState.en ? "Generated Images" : "生成结果";
            color: AppTheme.text;
            font-size: 16px;
            font-weight: 500;
        }
        Rectangle { x: 20px; y: 52px; width: parent.width - 40px; height: 1px; background: AppTheme.border; }
        Rectangle {
            x: 20px;
            y: 70px;
            width: parent.width - 40px;
            height: parent.height - 90px;
            clip: true;
            background: transparent;
            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-width: parent.width;
                viewport-height: root.content-height();
                interactive: true;
                Rectangle {
                    width: parent.viewport-width;
                    height: root.content-height();
                    background: transparent;
                    if AppState.generations.length == 0 && !root.active-generating(): EmptyState {
                        width: parent.width;
                        height: max(360px, root.height - 90px);
                    }
                    if root.active-generating(): GenerationWaterfall {
                        width: parent.width;
                        height: root.content-height();
                        items: AppState.generations;
                        card-width: root.item-width();
                        column-count: root.column-count();
                        loading-count: root.loading-count();
                    }
                    if AppState.generations.length > 0 && !root.active-generating(): TimeGroupedGallery {
                        width: parent.width;
                        height: root.content-height();
                        groups: AppState.generation-groups;
                        card-width: root.item-width();
                        source: "generation";
                    }
                }
            }
        }
    }
    function column-count() -> int {
        return max(1, min(root.visible-count(), min(8, floor((root.grid-width() + root.grid-gap()) / root.item-slot-width()))));
    }
    function grid-width() -> length {
        return max(1px, root.width - 40px);
    }
    function grid-gap() -> length {
        return 10px;
    }
    function base-thumb-width() -> length {
        return 160px;
    }
    function item-slot-width() -> length {
        return root.base-thumb-width() + root.grid-gap();
    }
    function item-width() -> length {
        return min(root.base-thumb-width(), max(91px, (root.grid-width() - (root.column-count() - 1) * root.grid-gap()) / root.column-count()));
    }
    function row-height() -> length {
        return root.item-width() + 30px;
    }
    function content-height() -> length {
        return max(360px, max(root.height - 90px, 34px + AppState.generation-groups.length * 66px + root.row-count() * root.row-height()));
    }
    function row-count() -> int {
        return (AppState.generations.length + root.loading-count() + root.column-count() - 1) / root.column-count();
    }
    function loading-count() -> int {
        return root.active-generating() ? AppState.generation-loading-count : 0;
    }
    function visible-count() -> int {
        return AppState.generations.length + root.loading-count();
    }
    function active-generating() -> bool {
        return AppState.generating && AppState.generation-active-category == AppState.asset-type;
    }
}

component WaterfallColumn {
    in property <[AssetItem]> items;
    in property <length> card-width: 220px;
    in property <string> source: "inspiration";
    in property <int> column-index: 0;
    in property <int> column-count: 1;
    horizontal-stretch: 0;
    width: root.column-width();
    VerticalLayout {
        x: 0px;
        width: root.width;
        spacing: 0px;
        alignment: start;
        for item[index] in root.items: ThumbnailCard {
            active: Math.mod(index, root.column-count) == root.column-index;
            item: item;
            card-width: root.card-width;
            card-gap: 18px;
            source: root.source;
        }
    }
    function column-width() -> length {
        return root.card-width;
    }
}

component InspirationWaterfall {
    in property <length> card-width: 220px;
    HorizontalLayout {
        spacing: 18px;
        WaterfallColumn { items: AppState.inspiration-col-0; card-width: root.card-width; }
        WaterfallColumn { items: AppState.inspiration-col-1; card-width: root.card-width; }
        WaterfallColumn { items: AppState.inspiration-col-2; card-width: root.card-width; }
        WaterfallColumn { items: AppState.inspiration-col-3; card-width: root.card-width; }
        WaterfallColumn { items: AppState.inspiration-col-4; card-width: root.card-width; }
    }
}

component GalleryWaterfall {
    in property <[AssetItem]> items;
    in property <length> card-width: 220px;
    in property <string> source: "asset";
    Rectangle {
        width: root.width;
        height: root.content-height();
        background: transparent;
        HorizontalLayout {
            x: 0px;
            width: root.used-width();
            height: parent.height;
            spacing: root.grid-gap();
            alignment: start;
            if root.column-count() >= 1: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 0; column-count: root.column-count(); }
            if root.column-count() >= 2: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 1; column-count: root.column-count(); }
            if root.column-count() >= 3: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 2; column-count: root.column-count(); }
            if root.column-count() >= 4: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 3; column-count: root.column-count(); }
            if root.column-count() >= 5: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 4; column-count: root.column-count(); }
            if root.column-count() >= 6: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 5; column-count: root.column-count(); }
            if root.column-count() >= 7: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 6; column-count: root.column-count(); }
            if root.column-count() >= 8: WaterfallColumn { items: root.items; card-width: root.item-width(); source: root.source; column-index: 7; column-count: root.column-count(); }
        }
    }
    function column-count() -> int {
        return max(1, min(root.items.length, min(8, floor((root.grid-width() + root.grid-gap()) / root.item-slot-width()))));
    }
    function grid-width() -> length {
        return max(1px, root.width);
    }
    function grid-gap() -> length {
        return 18px;
    }
    function item-slot-width() -> length {
        return root.card-width + root.grid-gap();
    }
    function item-width() -> length {
        return min(root.card-width, max(139px, (root.grid-width() - (root.column-count() - 1) * root.grid-gap()) / root.column-count()));
    }
    function used-width() -> length {
        return root.column-count() * root.item-width() + max(0, root.column-count() - 1) * root.grid-gap();
    }
    function row-height() -> length {
        return root.item-width() + 48px;
    }
    function row-count() -> int {
        return (root.items.length + root.column-count() - 1) / root.column-count();
    }
    function content-height() -> length {
        return max(1px, root.row-count() * root.row-height());
    }
}

