import { AppState } from "../app-state.slint";
import { CanvasLink, CanvasNote } from "../types.slint";
import { AppTheme } from "../theme.slint";

component CanvasToolButton {
    in property <image> icon;
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> disabled: false;
    in property <bool> compact: false;
    callback clicked();
    width: root.compact ? 32px : 44px;
    height: root.compact ? 36px : 44px;

    node-frame := Rectangle {
        clip: false;
        opacity: root.disabled ? 0.42 : 1;
        background: root.selected ? AppTheme.accent.with-alpha(0.16) : (button-touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 6px;
        border-width: root.selected ? 1px : 0px;
        border-color: AppTheme.accent;
        Image {
            x: (parent.width - 20px) / 2;
            y: (parent.height - 20px) / 2;
            width: 20px;
            height: 20px;
            source: root.icon;
            colorize: root.selected ? AppTheme.accent : AppTheme.text;
            image-fit: contain;
        }
        if button-touch.has-hover: Rectangle {
            x: (parent.width - max(72px, tooltip-text.preferred-width + 18px)) / 2;
            y: -34px;
            width: max(72px, tooltip-text.preferred-width + 18px);
            height: 28px;
            background: AppTheme.text;
            border-radius: 5px;
            tooltip-text := Text {
                width: parent.width;
                height: parent.height;
                text: root.label;
                color: AppTheme.panel;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: no-wrap;
            }
        }
        button-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => {
                if !root.disabled { root.clicked(); }
            }
        }
    }
}

component CanvasZoomButton {
    in property <image> icon;
    in property <string> label;
    in property <bool> selected: false;
    callback clicked();
    width: 30px;
    height: 30px;

    button-frame := Rectangle {
        clip: false;
        background: root.selected ? #393532 : (button-touch.has-hover ? #302c29 : transparent);
        border-radius: 6px;
        Image {
            x: 7px;
            y: 7px;
            width: 16px;
            height: 16px;
            source: root.icon;
            colorize: #f2eee9;
            image-fit: contain;
        }
        if button-touch.has-hover: Rectangle {
            x: (parent.width - max(68px, tooltip-text.preferred-width + 16px)) / 2;
            y: -32px;
            width: max(68px, tooltip-text.preferred-width + 16px);
            height: 26px;
            background: #f7f6f4;
            border-radius: 5px;
            tooltip-text := Text {
                width: parent.width;
                height: parent.height;
                text: root.label;
                color: #25211f;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: no-wrap;
            }
        }
        button-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component CanvasChoiceButton {
    in property <string> text;
    in property <bool> selected: false;
    callback clicked();
    height: 30px;
    Rectangle {
        background: root.selected ? AppTheme.accent.with-alpha(0.14) : (choice-touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 5px;
        border-width: 1px;
        border-color: root.selected ? AppTheme.accent : AppTheme.border;
        Text {
            width: parent.width;
            height: parent.height;
            text: root.text;
            color: root.selected ? AppTheme.accent : AppTheme.text;
            font-size: 12px;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
        choice-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component CanvasToggle {
    in property <string> text;
    in property <bool> checked: false;
    callback toggled();
    height: 30px;
    Text {
        x: 0px;
        width: parent.width - 44px;
        height: parent.height;
        text: root.text;
        color: AppTheme.text;
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
    }
    Rectangle {
        x: parent.width - 38px;
        y: 5px;
        width: 38px;
        height: 20px;
        background: root.checked ? AppTheme.accent : AppTheme.border;
        border-radius: 10px;
        Rectangle {
            x: root.checked ? 20px : 2px;
            y: 2px;
            width: 16px;
            height: 16px;
            background: #ffffff;
            border-radius: 8px;
        }
    }
    toggle-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.toggled(); }
    }
}

component CanvasMediaAction {
    in property <image> icon;
    in property <string> text;
    in property <bool> danger: false;
    in property <float> scale-factor: 1;
    callback clicked();
    height: 38px * root.scale-factor;
    Rectangle {
        background: action-touch.has-hover ? (root.danger ? #fee9e7 : #ebe9e7) : transparent;
        border-radius: 6px * root.scale-factor;
        Image {
            x: 8px * root.scale-factor;
            y: (parent.height - 16px * root.scale-factor) / 2;
            width: 16px * root.scale-factor;
            height: self.width;
            source: root.icon;
            colorize: root.danger ? #d7473f : #302c29;
            image-fit: contain;
        }
        Text {
            x: 30px * root.scale-factor;
            width: parent.width - 36px * root.scale-factor;
            height: parent.height;
            text: root.text;
            color: root.danger ? #d7473f : #302c29;
            font-size: 13px * root.scale-factor;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
        action-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component CanvasMediaChip {
    in property <image> icon;
    in property <string> text;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <float> scale-factor: 1;
    callback clicked();
    height: 38px * root.scale-factor;
    Rectangle {
        opacity: root.disabled ? 0.48 : 1;
        background: chip-touch.has-hover && !root.disabled ? #34302d : #292624;
        border-radius: 19px * root.scale-factor;
        border-width: 1px * root.scale-factor;
        border-color: root.active ? #ddd7d1 : #4c4743;
        Image {
            x: 12px * root.scale-factor;
            y: (parent.height - 16px * root.scale-factor) / 2;
            width: 16px * root.scale-factor;
            height: self.width;
            source: root.icon;
            colorize: #eee9e4;
            image-fit: contain;
        }
        Text {
            x: 36px * root.scale-factor;
            width: parent.width - 58px * root.scale-factor;
            height: parent.height;
            text: root.text;
            color: #eee9e4;
            font-size: 13px * root.scale-factor;
            font-weight: 500;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
        Image {
            x: parent.width - 22px * root.scale-factor;
            y: (parent.height - 12px * root.scale-factor) / 2;
            width: 12px * root.scale-factor;
            height: self.width;
            source: @image-url("../../assets/icons/dropdown.svg");
            colorize: #a9a29c;
            image-fit: contain;
        }
        chip-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => { if !root.disabled { root.clicked(); } }
        }
    }
}

component CanvasOptionPill {
    in property <string> text;
    in property <bool> selected: false;
    callback clicked();
    height: 36px;
    Rectangle {
        background: option-touch.has-hover ? #393532 : transparent;
        border-radius: 18px;
        border-width: root.selected ? 2px : 1px;
        border-color: root.selected ? #f2eee9 : #514c48;
        Text {
            width: parent.width;
            height: parent.height;
            text: root.text;
            color: #f0ebe7;
            font-size: 13px;
            font-weight: root.selected ? 600 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
        option-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component CanvasRatioOption {
    in property <string> value;
    in property <string> label;
    in property <string> detail: "";
    in property <bool> selected: false;
    callback clicked();
    height: 66px;
    Rectangle {
        background: ratio-touch.has-hover ? #393532 : transparent;
        border-radius: 8px;
        border-width: root.selected ? 2px : 1px;
        border-color: root.selected ? #f2eee9 : #514c48;
        Rectangle {
            x: (parent.width - root.preview-width()) / 2;
            y: 10px;
            width: root.preview-width();
            height: root.preview-height();
            background: transparent;
            border-width: 2px;
            border-color: #f2eee9;
        }
        Text {
            x: 4px;
            y: 34px;
            width: parent.width - 8px;
            height: root.detail == "" ? 25px : 17px;
            text: root.label;
            color: #f0ebe7;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
        if root.detail != "": Text {
            x: 4px;
            y: 50px;
            width: parent.width - 8px;
            height: 13px;
            text: root.detail;
            color: #8f8882;
            font-size: 9px;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }
        ratio-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
    function preview-width() -> length {
        if root.value == "2:3" || root.value == "3:4" || root.value == "9:16" || root.value == "portrait" || root.value == "tall" { return 12px; }
        if root.value == "3:2" || root.value == "4:3" || root.value == "16:9" || root.value == "landscape" || root.value == "wide" { return 24px; }
        return 18px;
    }
    function preview-height() -> length {
        if root.value == "2:3" || root.value == "3:4" || root.value == "9:16" || root.value == "portrait" || root.value == "tall" { return 20px; }
        if root.value == "3:2" || root.value == "4:3" || root.value == "16:9" || root.value == "landscape" || root.value == "wide" { return 14px; }
        return 18px;
    }
}

component CanvasConnectionCurve {
    in property <CanvasLink> link;
    in property <length> canvas-width;
    in property <length> canvas-height;
    in property <length> start-x;
    in property <length> start-y;
    in property <length> end-x;
    in property <length> end-y;
    in property <bool> preview: false;
    in property <bool> dark-background: true;
    property <bool> selected: !root.preview && AppState.canvas-selected-link-id == root.link.id;
    callback link-selected(string);

    function control-offset() -> length {
        return max(72px, Math.abs((root.end-x - root.start-x) / 1px) * 0.42px);
    }

    function curve-x(t: float) -> length {
        let remaining = 1 - t;
        let control-1 = root.start-x + root.control-offset();
        let control-2 = root.end-x - root.control-offset();
        return remaining * remaining * remaining * root.start-x
            + 3 * remaining * remaining * t * control-1
            + 3 * remaining * t * t * control-2
            + t * t * t * root.end-x;
    }

    function curve-y(t: float) -> length {
        let remaining = 1 - t;
        return remaining * remaining * remaining * root.start-y
            + 3 * remaining * remaining * t * root.start-y
            + 3 * remaining * t * t * root.end-y
            + t * t * t * root.end-y;
    }

    width: root.canvas-width;
    height: root.canvas-height;

    for dash-index in 42: Rectangle {
        property <float> t: (dash-index + 1) / 43;
        visible: Math.mod(dash-index, 2) == 0;
        x: root.curve-x(self.t) - (root.selected ? 4px : 3px);
        y: root.curve-y(self.t) - (root.selected ? 2px : 1.5px);
        width: root.preview ? 5px : (root.selected ? 8px : 6px);
        height: root.selected ? 4px : 3px;
        background: root.preview
            ? (root.dark-background ? #f7f7f7 : AppTheme.text)
            : (root.selected ? AppTheme.accent : (root.dark-background ? #d6d9df : AppTheme.muted));
        border-radius: 2px;
        opacity: root.preview || root.selected ? 1 : 0.78;
    }

    if !root.preview: Rectangle {
        background: transparent;
        for hit-index in 42: Rectangle {
            property <float> t: (hit-index + 1) / 43;
            x: root.curve-x(self.t) - 9px;
            y: root.curve-y(self.t) - 9px;
            width: 18px;
            height: 18px;
            background: transparent;
            hit-touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.link-selected(root.link.id); }
            }
        }
    }

    if !root.preview: Rectangle {
        x: root.curve-x(0.5) - 13px;
        y: root.curve-y(0.5) - 13px;
        width: 26px;
        height: 26px;
        background: root.selected
            ? AppTheme.panel.with-alpha(0.98)
            : (link-touch.has-hover ? AppTheme.panel.with-alpha(0.92) : transparent);
        border-radius: 13px;
        border-width: root.selected ? 2px : 0px;
        border-color: AppTheme.accent;
        if root.selected: Rectangle {
            x: 8px;
            y: 8px;
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: AppTheme.accent;
        }
        if !root.selected && link-touch.has-hover: Rectangle {
            x: 10px;
            y: 10px;
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: AppTheme.accent;
        }
        link-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => { root.link-selected(root.link.id); }
        }
    }
}

component CanvasNodeCard {
    in property <CanvasNote> note;
    in property <int> zoom-percent;
    in property <length> pan-x;
    in property <length> pan-y;
    in property <bool> show-image-info;
    in property <bool> dark-background;
    in property <length> viewport-width;
    in property <length> viewport-height;
    in property <string> connection-source-id;
    in property <string> connection-target-id;
    callback connection-started(string, length, length);
    callback connection-moved(length, length);
    callback connection-finished(string, length, length);
    callback reconnect-started(string, length, length);
    callback reconnect-finished(string, length, length);
    callback selection-focused();
    in-out property <length> drag-offset-x: 0px;
    in-out property <length> drag-offset-y: 0px;
    in-out property <length> resize-preview-width: 0px;
    in-out property <length> resize-preview-height: 0px;
    in-out property <string> current-content: root.note.content;
    in-out property <bool> editing: false;
    in-out property <bool> media-model-open: false;
    in-out property <bool> media-settings-open: false;
    in-out property <string> video-quality: "720p";
    in-out property <string> video-layout: "square";
    in-out property <string> video-duration: "6s";
    in-out property <string> audio-voice: "Alloy";
    in-out property <string> audio-format: "MP3";
    in-out property <string> audio-speed: "1x";
    in-out property <string> audio-instruction: "";

    x: root.pan-x + (root.note.x + (root.note.selected ? AppState.canvas-drag-delta-x : 0)) * 1px * root.zoom-percent / 100;
    y: root.pan-y + (root.note.y + (root.note.selected ? AppState.canvas-drag-delta-y : 0)) * 1px * root.zoom-percent / 100;
    width: root.resize-preview-width > 0px ? root.resize-preview-width : root.note.width * 1px * root.zoom-percent / 100;
    height: root.resize-preview-height > 0px ? root.resize-preview-height : root.note.height * 1px * root.zoom-percent / 100;

    function node-scale() -> float {
        return root.zoom-percent / 100;
    }

    function node-title() -> string {
        if root.note.kind == "image" { return AppState.en ? "Image" : "图片"; }
        if root.note.kind == "video" { return AppState.en ? "Video" : "视频"; }
        if root.note.kind == "audio" { return AppState.en ? "Audio" : "音频"; }
        if root.note.kind == "group" { return AppState.en ? "Group" : "分组"; }
        return AppState.en ? "Text" : "文本";
    }

    function is-visual-media() -> bool {
        return root.note.kind == "image" || root.note.kind == "video" || root.note.kind == "audio";
    }

    function is-default-media-prompt() -> bool {
        return root.current-content == "描述要生成的图片内容"
            || root.current-content == "描述要生成的视频内容"
            || root.current-content == "描述要生成的音频内容"
            || root.current-content == "Describe the image you want to generate"
            || root.current-content == "Describe the video you want to generate"
            || root.current-content == "Describe the audio you want to generate";
    }

    function is-default-text-prompt() -> bool {
        return root.current-content == "点击编辑按钮修改文字"
            || root.current-content == "Use the edit button to change text"
            || root.current-content == "双击编辑文字"
            || root.current-content == "Double-click to edit text";
    }

    function local-prompt() -> string {
        return root.is-default-media-prompt() || root.is-default-text-prompt() ? "" : root.current-content;
    }

    function effective-prompt() -> string {
        if root.note.linked-input == "" { return root.local-prompt(); }
        if root.local-prompt() == "" { return root.note.linked-input; }
        return root.note.linked-input + "\n" + root.local-prompt();
    }

    function text-display-content() -> string {
        if root.effective-prompt() != "" { return root.effective-prompt(); }
        return AppState.en ? "Double-click to edit text" : "双击编辑文字";
    }

    function generate-from-text() {
        if root.effective-prompt() == "" {
            AppState.generation-status = AppState.en ? "Enter text before generating an image" : "请先输入文字内容";
            return;
        }
        if AppState.image-model == "" {
            AppState.generation-status = AppState.en ? "Select an image model first" : "请先选择生图模型";
            return;
        }
        if !AppState.generating {
            root.save-content();
            AppState.prompt = root.effective-prompt();
            AppState.generate();
        }
    }

    function empty-media-label() -> string {
        if root.note.kind == "image" { return AppState.en ? "Empty image node" : "空图片节点"; }
        if root.note.kind == "video" { return AppState.en ? "Empty video node" : "空视频节点"; }
        return AppState.en ? "Empty audio node" : "空音频节点";
    }

    function media-prompt-placeholder() -> string {
        if root.note.kind == "image" { return AppState.en ? "Describe the image to generate" : "描述要生成的图片内容"; }
        if root.note.kind == "video" { return AppState.en ? "Describe the video to generate" : "描述要生成的视频内容"; }
        return AppState.en ? "Describe the audio to generate" : "描述要生成的音频内容";
    }

    function media-editor-width() -> length {
        return max(root.width, (root.note.kind == "image" ? 540px : 580px) * root.node-scale());
    }

    function media-editor-height() -> length {
        return 180px * root.node-scale();
    }

    function media-editor-y() -> length {
        return root.height + 20px * root.node-scale();
    }

    function action-bar-y() -> length {
        return -76px * root.node-scale();
    }

    function dropdown-popup-x(popup-width: length) -> length {
        let preferred = (root.width - root.media-editor-width()) / 2 + 64px * root.node-scale();
        return max(8px - root.x, min(preferred, root.viewport-width - popup-width - root.x - 8px));
    }

    function dropdown-popup-y(popup-height: length) -> length {
        let preferred = root.media-editor-y() + root.media-editor-height() + 16px * root.node-scale();
        return max(8px - root.y, min(preferred, root.viewport-height - popup-height - root.y - 8px));
    }

    function settings-popup-x(popup-width: length) -> length {
        return max(8px - root.x, min(root.width + 16px, root.viewport-width - popup-width - root.x - 8px));
    }

    function settings-popup-y(popup-height: length) -> length {
        return max(8px - root.y, min(-32px, root.viewport-height - popup-height - root.y - 8px));
    }

    function media-model-text() -> string {
        if root.note.kind == "image" {
            return AppState.image-model-name == "" ? (AppState.en ? "Select image model" : "选择图片模型") : AppState.image-model-name;
        }
        if root.note.kind == "video" { return AppState.en ? "Video model not configured" : "未配置视频模型"; }
        return AppState.en ? "Audio model not configured" : "未配置音频模型";
    }

    function media-settings-text() -> string {
        if root.note.kind == "image" { return (AppState.en ? "Auto" : "自动") + " · " + AppState.ratio + " · " + AppState.count + (AppState.en ? " images" : "张"); }
        if root.note.kind == "video" { return root.video-quality + " · " + root.video-layout-label() + " · " + root.video-duration; }
        return root.audio-voice + " · " + root.audio-format + " · " + root.audio-speed;
    }

    function video-layout-label() -> string {
        if root.video-layout == "landscape" { return AppState.en ? "Landscape" : "横屏"; }
        if root.video-layout == "portrait" { return AppState.en ? "Portrait" : "竖屏"; }
        if root.video-layout == "wide" { return AppState.en ? "Wide" : "宽屏"; }
        if root.video-layout == "tall" { return AppState.en ? "Tall" : "长图"; }
        if root.video-layout == "auto" { return "auto"; }
        return AppState.en ? "Square" : "方形";
    }

    function image-width-text() -> string {
        if AppState.ratio == "2:3" { return "680"; }
        if AppState.ratio == "3:4" { return "768"; }
        if AppState.ratio == "4:5" { return "816"; }
        if AppState.ratio == "9:16" { return "576"; }
        if AppState.ratio == "1:2" { return "512"; }
        if AppState.ratio == "9:21" { return "440"; }
        return "1024";
    }

    function image-height-text() -> string {
        if AppState.ratio == "3:2" { return "680"; }
        if AppState.ratio == "4:3" { return "768"; }
        if AppState.ratio == "5:4" { return "816"; }
        if AppState.ratio == "16:9" { return "576"; }
        if AppState.ratio == "2:1" { return "512"; }
        if AppState.ratio == "21:9" { return "440"; }
        return "1024";
    }

    function video-width-text() -> string {
        if root.video-layout == "portrait" { return "720"; }
        if root.video-layout == "square" { return "1024"; }
        if root.video-layout == "wide" { return "1792"; }
        if root.video-layout == "tall" { return "1024"; }
        return "1280";
    }

    function video-height-text() -> string {
        if root.video-layout == "portrait" { return "1280"; }
        if root.video-layout == "square" { return "1024"; }
        if root.video-layout == "wide" { return "1024"; }
        if root.video-layout == "tall" { return "1792"; }
        return "720";
    }

    function commit-position() {
        let dx = root.drag-offset-x / 1px * 100 / root.zoom-percent;
        let dy = root.drag-offset-y / 1px * 100 / root.zoom-percent;
        if dx != 0 || dy != 0 {
            AppState.move-canvas-selection(dx, dy);
        }
        root.drag-offset-x = 0px;
        root.drag-offset-y = 0px;
        AppState.canvas-drag-preview-id = "";
        AppState.canvas-drag-delta-x = 0;
        AppState.canvas-drag-delta-y = 0;
    }

    function save-content() {
        AppState.update-canvas-node(root.note.id, root.current-content, root.note.x, root.note.y);
    }

    Rectangle {
        clip: false;
        background: root.note.kind == "group"
            ? AppTheme.accent.with-alpha(root.note.selected ? 0.10 : 0.045)
            : (root.dark-background ? #292522 : AppTheme.panel);
        border-radius: (root.note.kind == "group" ? 4px : 20px) * root.node-scale();
        border-width: (root.note.selected || node-drag-touch.has-hover || input-connector-touch.has-hover || output-connector-touch.has-hover ? 2px : 1px) * root.node-scale();
        border-color: root.note.selected
            ? AppTheme.accent
            : (node-drag-touch.has-hover || input-connector-touch.has-hover || output-connector-touch.has-hover
                ? AppTheme.accent.with-alpha(0.78)
                : (root.note.kind == "group" ? AppTheme.accent.with-alpha(0.55) : #514c48));

        if root.note.kind != "group" && (node-drag-touch.has-hover || input-connector-touch.has-hover || output-connector-touch.has-hover || AppState.canvas-selected-id == root.note.id || root.connection-source-id != ""): Rectangle {
            x: -5px * root.node-scale();
            y: (parent.height - 10px * root.node-scale()) / 2;
            width: 10px * root.node-scale();
            height: self.width;
            background: AppTheme.panel;
            border-radius: self.width / 2;
            border-width: 2px * root.node-scale();
            border-color: AppState.canvas-link-hover-target-id == root.note.id
                ? (AppState.canvas-link-hover-valid ? AppTheme.accent : #e5484d)
                : (root.connection-source-id != "" && root.connection-source-id != root.note.id ? AppTheme.accent.with-alpha(0.72) : AppTheme.accent);
        }
        if root.note.kind != "group" && (node-drag-touch.has-hover || input-connector-touch.has-hover || output-connector-touch.has-hover || AppState.canvas-selected-id == root.note.id || root.connection-source-id == root.note.id || root.connection-target-id != ""): Rectangle {
            x: parent.width - 5px * root.node-scale();
            y: (parent.height - 10px * root.node-scale()) / 2;
            width: 10px * root.node-scale();
            height: self.width;
            background: AppTheme.panel;
            border-radius: self.width / 2;
            border-width: 2px * root.node-scale();
            border-color: AppTheme.accent;
        }

        node-drag-touch := TouchArea {
            property <length> start-pointer-x: 0px;
            property <length> start-pointer-y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.editing ? default : move;
            pointer-event(event) => {
                if !root.editing && event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                    AppState.select-canvas-node(root.note.id, event.modifiers.control);
                    root.selection-focused();
                    self.start-pointer-x = self.absolute-position.x + self.mouse-x;
                    self.start-pointer-y = self.absolute-position.y + self.mouse-y;
                } else if !root.editing && event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                    root.commit-position();
                }
            }
            moved => {
                if self.pressed && !root.editing {
                    root.drag-offset-x = self.absolute-position.x + self.mouse-x - self.start-pointer-x;
                    root.drag-offset-y = self.absolute-position.y + self.mouse-y - self.start-pointer-y;
                    AppState.canvas-drag-preview-id = root.note.id;
                    AppState.canvas-drag-delta-x = root.drag-offset-x / 1px * 100 / root.zoom-percent;
                    AppState.canvas-drag-delta-y = root.drag-offset-y / 1px * 100 / root.zoom-percent;
                }
            }
            double-clicked => {
                if root.note.kind == "text" {
                    AppState.select-canvas-node(root.note.id, false);
                    root.selection-focused();
                    root.current-content = root.is-default-text-prompt() ? "" : root.note.content;
                    root.editing = true;
                    text-editor.focus();
                }
            }
        }

        header := Rectangle {
            visible: root.note.kind == "group" && root.zoom-percent >= 30;
            height: root.note.kind == "group" ? 36px * root.node-scale() : 0px;
            background: transparent;
            border-radius: 0px;
            Text {
                x: 12px * root.node-scale();
                width: parent.width - 88px * root.node-scale();
                height: parent.height;
                text: root.node-title();
                color: root.note.kind == "group" ? AppTheme.accent : (root.dark-background ? #dce7f8 : AppTheme.text);
                font-size: (AppState.settings-font-size - 1) * 1px * root.node-scale();
                font-weight: 500;
                vertical-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
            if root.zoom-percent >= 35: Rectangle {
                x: parent.width - 64px * root.node-scale();
                y: (parent.height - 26px * root.node-scale()) / 2;
                width: 26px * root.node-scale();
                height: self.width;
                background: edit-touch.has-hover ? AppTheme.accent.with-alpha(0.16) : transparent;
                border-radius: 5px * root.node-scale();
                Image {
                    x: (parent.width - 14px * root.node-scale()) / 2;
                    y: self.x;
                    width: 14px * root.node-scale();
                    height: self.width;
                    source: @image-url("../../assets/icons/edit.svg");
                    colorize: AppTheme.accent;
                    image-fit: contain;
                }
                edit-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => {
                        AppState.canvas-selected-id = root.note.id;
                        root.current-content = root.note.content;
                        root.editing = true;
                    }
                }
            }
            if root.zoom-percent >= 35: Rectangle {
                x: parent.width - 32px * root.node-scale();
                y: (parent.height - 26px * root.node-scale()) / 2;
                width: 26px * root.node-scale();
                height: self.width;
                background: delete-touch.has-hover ? AppTheme.danger.with-alpha(0.16) : transparent;
                border-radius: 5px * root.node-scale();
                Image {
                    x: (parent.width - 14px * root.node-scale()) / 2;
                    y: self.x;
                    width: 14px * root.node-scale();
                    height: self.width;
                    source: @image-url("../../assets/icons/trash.svg");
                    colorize: AppTheme.danger;
                    image-fit: contain;
                }
                delete-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => {
                        AppState.canvas-selected-id = root.note.id;
                        AppState.pending-delete-kind = "canvas-note";
                        AppState.pending-delete-id = root.note.id;
                        AppState.pending-delete-source = "canvas";
                        AppState.delete-confirm-open = true;
                    }
                }
            }
        }

        if root.zoom-percent >= 30 && root.note.kind == "text" && !root.editing: Text {
            x: 18px * root.node-scale();
            y: 50px * root.node-scale();
            width: parent.width - 2 * self.x;
            height: parent.height - self.y - 18px * root.node-scale();
            text: root.text-display-content();
            wrap: word-wrap;
            overflow: elide;
            color: root.dark-background ? #ddd7d1 : AppTheme.text;
            font-size: AppState.settings-font-size * 1px * root.node-scale();
        }

        text-editor := TextInput {
            visible: root.zoom-percent >= 30 && root.note.kind == "text" && root.editing;
            x: 18px * root.node-scale();
            y: 50px * root.node-scale();
            width: parent.width - 2 * self.x;
            height: parent.height - self.y - 18px * root.node-scale();
            text <=> root.current-content;
            single-line: false;
            wrap: word-wrap;
            color: root.dark-background ? #ddd7d1 : AppTheme.text;
            font-size: AppState.settings-font-size * 1px * root.node-scale();
            key-pressed(event) => {
                AppState.canvas-selected-id = root.note.id;
                if event.text == Key.Return {
                    if event.modifiers.alt { return reject; }
                    root.save-content();
                    root.editing = false;
                    return accept;
                }
                return reject;
            }
        }

        if root.zoom-percent >= 30 && root.note.kind == "group" && !root.editing: Text {
            x: 12px * root.node-scale();
            y: header.height + 8px * root.node-scale();
            width: min(parent.width - 2 * self.x, 280px * root.node-scale());
            height: 36px * root.node-scale();
            text: root.current-content;
            wrap: no-wrap;
            overflow: elide;
            vertical-alignment: center;
            color: root.dark-background ? #dce7f8 : AppTheme.text;
            font-size: AppState.settings-font-size * 1px * root.node-scale();
        }

        if root.zoom-percent >= 30 && root.note.kind == "group" && root.editing: TextInput {
            x: 12px * root.node-scale();
            y: header.height + 8px * root.node-scale();
            width: min(parent.width - 2 * self.x, 280px * root.node-scale());
            height: 36px * root.node-scale();
            text <=> root.current-content;
            single-line: true;
            color: root.dark-background ? #dce7f8 : AppTheme.text;
            font-size: AppState.settings-font-size * 1px * root.node-scale();
            key-pressed(event) => {
                AppState.canvas-selected-id = root.note.id;
                if event.text == Key.Return {
                    root.save-content();
                    root.editing = false;
                    return accept;
                }
                return reject;
            }
        }

        if root.note.kind == "text" && root.zoom-percent >= 45 && !root.editing: Rectangle {
            x: parent.width - 84px * root.node-scale();
            y: 14px * root.node-scale();
            width: 72px * root.node-scale();
            height: 30px * root.node-scale();
            background: text-generate-touch.has-hover ? AppTheme.accent.with-alpha(0.18) : transparent;
            border-radius: self.height / 2;
            border-width: 1px;
            border-color: root.dark-background ? #514c48 : AppTheme.border;
            Image {
                x: 9px * root.node-scale();
                y: (parent.height - 14px * root.node-scale()) / 2;
                width: 14px * root.node-scale();
                height: self.width;
                source: @image-url("../../assets/icons/image.svg");
                colorize: root.dark-background ? #eee9e4 : AppTheme.text;
                image-fit: contain;
            }
            Text {
                x: 28px * root.node-scale();
                width: parent.width - self.x - 8px * root.node-scale();
                height: parent.height;
                text: AppState.en ? "Generate" : "生图";
                color: root.dark-background ? #eee9e4 : AppTheme.text;
                font-size: 12px * root.node-scale();
                font-weight: 500;
                vertical-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
            text-generate-touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { root.generate-from-text(); }
            }
        }

        if (root.note.kind == "text" || root.is-visual-media()) && root.zoom-percent >= 30: Text {
            x: 12px * root.node-scale();
            y: root.y < 40px * root.node-scale() ? 12px * root.node-scale() : -34px * root.node-scale();
            width: parent.width - 2 * self.x;
            height: 28px * root.node-scale();
            text: root.node-title();
            color: root.dark-background ? #ddd7d1 : AppTheme.text;
            font-size: 15px * root.node-scale();
            font-weight: 600;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        if root.is-visual-media() && root.zoom-percent >= 30: Rectangle {
            x: (parent.width - 64px * root.node-scale()) / 2;
            y: (parent.height - 104px * root.node-scale()) / 2;
            width: 64px * root.node-scale();
            height: self.width;
            background: root.dark-background ? #393532 : AppTheme.panel-soft;
            border-radius: 18px * root.node-scale();
            Image {
                x: (parent.width - 28px * root.node-scale()) / 2;
                y: (parent.height - self.height) / 2;
                width: 28px * root.node-scale();
                height: self.width;
                source: root.note.kind == "image" ? @image-url("../../assets/icons/image.svg")
                    : (root.note.kind == "video" ? @image-url("../../assets/icons/video.svg") : @image-url("../../assets/icons/audio.svg"));
                colorize: root.dark-background ? #716a64 : AppTheme.muted;
                image-fit: contain;
            }
        }

        if root.is-visual-media() && root.zoom-percent >= 30: Text {
            x: 12px * root.node-scale();
            y: parent.height / 2 + 28px * root.node-scale();
            width: parent.width - 24px * root.node-scale();
            height: 30px * root.node-scale();
            text: root.empty-media-label();
            color: root.dark-background ? #8b847e : AppTheme.muted;
            font-size: 13px * root.node-scale();
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        if root.note.kind == "text" && AppState.canvas-selected-id == root.note.id && root.zoom-percent >= 45: text-action-bar := Rectangle {
            width: 320px * root.node-scale();
            height: 46px * root.node-scale();
            x: (parent.width - self.width) / 2;
            y: root.action-bar-y();
            background: #f7f6f4;
            border-radius: self.height / 2;
            border-width: 1px * root.node-scale();
            border-color: #e2dfdc;
            HorizontalLayout {
                padding-left: 8px * root.node-scale();
                padding-right: 8px * root.node-scale();
                padding-top: 4px * root.node-scale();
                padding-bottom: 4px * root.node-scale();
                spacing: 2px * root.node-scale();
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/info.svg"); text: AppState.en ? "Info" : "信息"; clicked => { AppState.canvas-show-image-info = !AppState.canvas-show-image-info; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/trash.svg"); text: AppState.en ? "Delete" : "删除"; danger: true; clicked => { AppState.pending-delete-kind = "canvas-note"; AppState.pending-delete-id = root.note.id; AppState.pending-delete-source = "canvas"; AppState.delete-confirm-open = true; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/edit.svg"); text: AppState.en ? "Edit" : "编辑"; clicked => { root.current-content = root.is-default-text-prompt() ? "" : root.note.content; root.editing = true; text-editor.focus(); } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/image.svg"); text: AppState.en ? "Generate" : "生图"; clicked => { root.generate-from-text(); } }
            }
        }

        if root.is-visual-media() && AppState.canvas-selected-id == root.note.id && root.zoom-percent >= 30: media-action-bar := Rectangle {
            width: (root.note.kind == "video" ? 380px : 312px) * root.node-scale();
            height: 46px * root.node-scale();
            x: (parent.width - self.width) / 2;
            y: root.action-bar-y();
            background: #f7f6f4;
            border-radius: self.height / 2;
            border-width: 1px * root.node-scale();
            border-color: #e2dfdc;
            if root.note.kind == "video": HorizontalLayout {
                padding-left: 8px * root.node-scale();
                padding-right: 8px * root.node-scale();
                padding-top: 4px * root.node-scale();
                padding-bottom: 4px * root.node-scale();
                spacing: 2px * root.node-scale();
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/info.svg"); text: AppState.en ? "Info" : "信息"; clicked => { AppState.canvas-show-image-info = !AppState.canvas-show-image-info; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/trash.svg"); text: AppState.en ? "Delete" : "删除"; danger: true; clicked => { AppState.pending-delete-kind = "canvas-note"; AppState.pending-delete-id = root.note.id; AppState.pending-delete-source = "canvas"; AppState.delete-confirm-open = true; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/edit.svg"); text: AppState.en ? "Edit" : "编辑"; clicked => { root.editing = true; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/upload.svg"); text: AppState.en ? "Upload video" : "上传视频"; clicked => { AppState.generation-status = AppState.en ? "Video upload requires a configured video provider" : "请先配置视频生成服务"; } }
            }
            if root.note.kind != "video": HorizontalLayout {
                padding-left: 8px * root.node-scale();
                padding-right: 8px * root.node-scale();
                padding-top: 4px * root.node-scale();
                padding-bottom: 4px * root.node-scale();
                spacing: 2px * root.node-scale();
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/info.svg"); text: AppState.en ? "Info" : "信息"; clicked => { AppState.canvas-show-image-info = !AppState.canvas-show-image-info; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/trash.svg"); text: AppState.en ? "Delete" : "删除"; danger: true; clicked => { AppState.pending-delete-kind = "canvas-note"; AppState.pending-delete-id = root.note.id; AppState.pending-delete-source = "canvas"; AppState.delete-confirm-open = true; } }
                CanvasMediaAction { horizontal-stretch: 1; scale-factor: root.node-scale(); icon: @image-url("../../assets/icons/upload.svg"); text: root.note.kind == "image" ? (AppState.en ? "Upload image" : "上传图片") : (AppState.en ? "Upload audio" : "上传音频"); clicked => { if root.note.kind == "image" { AppState.add-reference(); } else { AppState.generation-status = AppState.en ? "Audio upload requires a configured audio provider" : "请先配置音频生成服务"; } } }
            }
        }

        if root.is-visual-media() && AppState.canvas-selected-id == root.note.id && root.zoom-percent >= 30: media-editor-panel := Rectangle {
            x: (parent.width - root.media-editor-width()) / 2;
            y: root.media-editor-y();
            width: root.media-editor-width();
            height: root.media-editor-height();
            background: root.dark-background ? #211e1c : AppTheme.panel;
            border-radius: 16px * root.node-scale();
            border-width: 1px * root.node-scale();
            border-color: root.dark-background ? #4d4844 : AppTheme.border;

            if root.note.linked-input != "": Rectangle {
                x: 14px * root.node-scale();
                y: self.x;
                width: parent.width - 2 * self.x;
                height: 28px * root.node-scale();
                background: AppTheme.accent.with-alpha(root.dark-background ? 0.14 : 0.10);
                border-radius: 6px * root.node-scale();
                Text {
                    x: 9px * root.node-scale();
                    width: parent.width - 18px * root.node-scale();
                    height: parent.height;
                    text: (AppState.en ? "Connected input: " : "已连接输入：") + root.note.linked-input;
                    color: root.dark-background ? #d8e6ff : AppTheme.accent-dark;
                    font-size: 11px * root.node-scale();
                    vertical-alignment: center;
                    wrap: no-wrap;
                    overflow: elide;
                }
            }

            prompt-frame := Rectangle {
                x: 14px * root.node-scale();
                y: root.note.linked-input == "" ? self.x : 48px * root.node-scale();
                width: parent.width - 2 * self.x;
                height: (root.note.linked-input == "" ? 104px : 70px) * root.node-scale();
                background: root.dark-background ? #292522 : AppTheme.panel-soft;
                border-radius: 12px * root.node-scale();
                border-width: 1px * root.node-scale();
                border-color: root.dark-background ? #514c48 : AppTheme.border;
                media-prompt := TextInput {
                    x: 12px * root.node-scale();
                    y: 10px * root.node-scale();
                    width: parent.width - 24px * root.node-scale();
                    height: parent.height - 20px * root.node-scale();
                    text <=> root.current-content;
                    single-line: false;
                    wrap: word-wrap;
                    color: root.dark-background ? #eee9e4 : AppTheme.text;
                    font-size: 13px * root.node-scale();
                    key-pressed(event) => {
                        if event.text == Key.Return {
                            if event.modifiers.alt { return reject; }
                            root.save-content();
                            return accept;
                        }
                        return reject;
                    }
                }
                if root.current-content == "" && !media-prompt.has-focus: Text {
                    x: 12px * root.node-scale();
                    y: 10px * root.node-scale();
                    width: parent.width - 24px * root.node-scale();
                    height: 24px * root.node-scale();
                    text: root.media-prompt-placeholder();
                    color: root.dark-background ? #8f8882 : AppTheme.muted;
                    font-size: 13px * root.node-scale();
                    vertical-alignment: center;
                }
            }

            Rectangle {
                x: 16px * root.node-scale();
                y: parent.height - 52px * root.node-scale();
                width: 38px * root.node-scale();
                height: self.width;
                background: prompt-library-touch.has-hover ? #34302d : transparent;
                border-radius: self.height / 2;
                Image {
                    x: (parent.width - 17px * root.node-scale()) / 2;
                    y: (parent.height - 17px * root.node-scale()) / 2;
                    width: 17px * root.node-scale();
                    height: self.width;
                    source: @image-url("../../assets/icons/book.svg");
                    colorize: root.dark-background ? #eee9e4 : AppTheme.text;
                    image-fit: contain;
                }
                prompt-library-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => { AppState.settings-section = "prompts"; AppState.navigate("settings"); }
                }
            }

            media-model-chip := CanvasMediaChip {
                scale-factor: root.node-scale();
                x: 64px * root.node-scale();
                y: parent.height - 50px * root.node-scale();
                width: (parent.width - self.x - 72px * root.node-scale()) / 2;
                icon: root.note.kind == "image" ? @image-url("../../assets/icons/image.svg") : (root.note.kind == "video" ? @image-url("../../assets/icons/video.svg") : @image-url("../../assets/icons/audio.svg"));
                text: root.media-model-text();
                active: root.media-model-open;
                clicked => { root.media-model-open = true; image-model-popup.show(); }
            }

            CanvasMediaChip {
                scale-factor: root.node-scale();
                x: media-model-chip.x + media-model-chip.width + 8px * root.node-scale();
                y: parent.height - 50px * root.node-scale();
                width: parent.width - self.x - 64px * root.node-scale();
                icon: @image-url("../../assets/icons/controls.svg");
                text: root.media-settings-text();
                active: root.media-settings-open;
                clicked => {
                    root.media-settings-open = true;
                    if root.note.kind == "image" { image-settings-popup.show(); }
                    else if root.note.kind == "video" { video-settings-popup.show(); }
                    else { audio-settings-popup.show(); }
                }
            }

            Rectangle {
                x: parent.width - 56px * root.node-scale();
                y: parent.height - 51px * root.node-scale();
                width: 44px * root.node-scale();
                height: self.width;
                opacity: root.note.kind == "image" && root.effective-prompt() != "" && AppState.image-model != "" && !AppState.generating ? 1 : 0.42;
                background: generate-touch.has-hover && root.note.kind == "image" && root.effective-prompt() != "" && AppState.image-model != "" && !AppState.generating ? AppTheme.accent : #4a4642;
                border-radius: self.height / 2;
                border-width: 1px * root.node-scale();
                border-color: root.dark-background ? #5a5550 : AppTheme.border;
                Image {
                    x: (parent.width - 18px * root.node-scale()) / 2;
                    y: (parent.height - 18px * root.node-scale()) / 2;
                    width: 18px * root.node-scale();
                    height: self.width;
                    source: @image-url("../../assets/icons/arrow-up.svg");
                    colorize: #f5f2ee;
                    image-fit: contain;
                }
                generate-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: root.note.kind == "image" && root.effective-prompt() != "" && AppState.image-model != "" && !AppState.generating ? pointer : default;
                    clicked => {
                        if root.note.kind == "image" && root.effective-prompt() != "" && AppState.image-model != "" && !AppState.generating {
                            root.save-content();
                            AppState.prompt = root.effective-prompt();
                            AppState.generate();
                        }
                    }
                }
            }
        }

        input-connector-touch := TouchArea {
            visible: root.note.kind != "group" && root.zoom-percent >= 30;
            width: max(18px, 26px * root.node-scale());
            height: self.width;
            x: -self.width / 2;
            y: (parent.height - self.height) / 2;
            mouse-cursor: crosshair;
            pointer-event(event) => {
                if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                    AppState.select-canvas-node(root.note.id, false);
                    root.reconnect-started(root.note.id, root.x, root.y + root.height / 2);
                } else if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                    root.connection-moved(root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
                    root.reconnect-finished(root.note.id, root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
                }
            }
            moved => {
                if self.pressed {
                    root.connection-moved(root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
                }
            }
        }

        output-connector-touch := TouchArea {
            visible: root.note.kind != "group" && root.zoom-percent >= 30;
            width: max(18px, 26px * root.node-scale());
            height: self.width;
            x: parent.width - self.width / 2;
            y: (parent.height - self.height) / 2;
            mouse-cursor: crosshair;
            pointer-event(event) => {
                if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                    AppState.canvas-selected-id = root.note.id;
                    AppState.canvas-selected-link-id = "";
                    root.connection-started(root.note.id, root.x + root.width, root.y + root.height / 2);
                } else if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                    root.connection-moved(root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
                    root.connection-finished(root.note.id, root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
                }
            }
            moved => {
                if self.pressed {
                    root.connection-moved(root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
                }
            }
        }

        group-resize-touch := TouchArea {
            in-out property <length> start-width: 0px;
            in-out property <length> start-height: 0px;
            in-out property <length> start-pointer-x: 0px;
            in-out property <length> start-pointer-y: 0px;
            visible: root.note.kind == "group" && root.note.selected && root.zoom-percent >= 30;
            width: max(18px, 24px * root.node-scale());
            height: self.width;
            x: parent.width - self.width / 2;
            y: parent.height - self.height / 2;
            mouse-cursor: nwse-resize;
            pointer-event(event) => {
                if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                    self.start-width = root.width;
                    self.start-height = root.height;
                    self.start-pointer-x = self.absolute-position.x + self.mouse-x;
                    self.start-pointer-y = self.absolute-position.y + self.mouse-y;
                } else if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                    let next-width = (root.resize-preview-width > 0px ? root.resize-preview-width : root.width) / 1px * 100 / root.zoom-percent;
                    let next-height = (root.resize-preview-height > 0px ? root.resize-preview-height : root.height) / 1px * 100 / root.zoom-percent;
                    AppState.resize-canvas-group(root.note.id, next-width, next-height);
                    root.resize-preview-width = 0px;
                    root.resize-preview-height = 0px;
                }
            }
            moved => {
                if self.pressed {
                    root.resize-preview-width = max(160px * root.node-scale(), self.start-width + self.absolute-position.x + self.mouse-x - self.start-pointer-x);
                    root.resize-preview-height = max(120px * root.node-scale(), self.start-height + self.absolute-position.y + self.mouse-y - self.start-pointer-y);
                }
            }
        }

        image-model-popup := PopupWindow {
            width: max(230px, min(320px, 280px * root.zoom-percent / 100));
            height: root.note.kind == "image" ? min(270px, max(58px, 12px + AppState.model-image-options.length * 42px)) : 74px;
            x: root.dropdown-popup-x(self.width);
            y: root.dropdown-popup-y(self.height);
            close-policy: close-on-click-outside;
            Rectangle {
                background: #211e1c;
                border-radius: 10px;
                border-width: 1px;
                border-color: #4f4a46;
                clip: true;
                if root.note.kind == "image" && AppState.model-image-options.length > 0: VerticalLayout {
                    padding: 6px;
                    spacing: 4px;
                    for model in AppState.model-image-options: Rectangle {
                        height: 38px;
                        background: model-touch.has-hover ? #35312e : (AppState.image-model == model.code ? #302c29 : transparent);
                        border-radius: 7px;
                        Image {
                            x: 10px;
                            y: (parent.height - 16px) / 2;
                            width: 16px;
                            height: 16px;
                            source: @image-url("../../assets/icons/image.svg");
                            colorize: #eee9e4;
                        }
                        Text {
                            x: 34px;
                            width: parent.width - 64px;
                            height: parent.height;
                            text: model.name;
                            color: #eee9e4;
                            font-size: 12px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        if AppState.image-model == model.code: Image {
                            x: parent.width - 24px;
                            y: (parent.height - 14px) / 2;
                            width: 14px;
                            height: 14px;
                            source: @image-url("../../assets/icons/check.svg");
                            colorize: #eee9e4;
                        }
                        model-touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => { AppState.select-image-model(model.code); root.media-model-open = false; image-model-popup.close(); }
                        }
                    }
                }
                if root.note.kind != "image" || AppState.model-image-options.length == 0: Rectangle {
                    x: 6px;
                    y: 6px;
                    width: parent.width - 12px;
                    height: parent.height - 12px;
                    background: empty-model-touch.has-hover ? #35312e : transparent;
                    border-radius: 7px;
                    Text {
                        x: 12px;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: AppState.en ? "Configure a compatible model" : "前往模型管理配置";
                        color: #eee9e4;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                    empty-model-touch := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => { root.media-model-open = false; image-model-popup.close(); AppState.settings-section = "models"; AppState.navigate("settings"); }
                    }
                }
            }
        }

        image-settings-popup := PopupWindow {
            width: 378px;
            height: 418px;
            x: root.settings-popup-x(self.width);
            y: root.settings-popup-y(self.height);
            close-policy: close-on-click-outside;
            Rectangle {
                background: #211e1c;
                border-radius: 12px;
                border-width: 1px;
                border-color: #4f4a46;
                Text { x: 18px; y: 10px; width: parent.width - 36px; height: 28px; text: AppState.en ? "Image settings" : "图片设置"; color: #f0ebe7; font-size: 16px; font-weight: 600; vertical-alignment: center; }
                Rectangle { x: 18px; y: 44px; width: 154px; height: 36px; background: #2d2926; border-radius: 10px; Text { x: 12px; width: 26px; height: parent.height; text: "W"; color: #aaa39d; font-size: 12px; vertical-alignment: center; } Text { x: 48px; width: parent.width - 60px; height: parent.height; text: root.image-width-text(); color: #eee9e4; font-size: 13px; vertical-alignment: center; } }
                Text { x: 177px; y: 44px; width: 24px; height: 36px; text: "↔"; color: #8d8680; font-size: 15px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle { x: 206px; y: 44px; width: 154px; height: 36px; background: #2d2926; border-radius: 10px; Text { x: 12px; width: 26px; height: parent.height; text: "H"; color: #aaa39d; font-size: 12px; vertical-alignment: center; } Text { x: 48px; width: parent.width - 60px; height: parent.height; text: root.image-height-text(); color: #eee9e4; font-size: 13px; vertical-alignment: center; } }
                Text { x: 18px; y: 88px; width: parent.width - 36px; height: 22px; text: AppState.en ? "Aspect ratio" : "宽高比"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                GridLayout {
                    x: 18px;
                    y: 114px;
                    width: parent.width - 36px;
                    height: 208px;
                    spacing: 8px;
                    Row {
                        CanvasRatioOption { width: 78px; value: "1:1"; label: "1:1"; selected: AppState.ratio == "1:1"; clicked => { AppState.ratio = "1:1"; } }
                        CanvasRatioOption { width: 78px; value: "3:2"; label: "3:2"; selected: AppState.ratio == "3:2"; clicked => { AppState.ratio = "3:2"; } }
                        CanvasRatioOption { width: 78px; value: "2:3"; label: "2:3"; selected: AppState.ratio == "2:3"; clicked => { AppState.ratio = "2:3"; } }
                        CanvasRatioOption { width: 78px; value: "4:3"; label: "4:3"; selected: AppState.ratio == "4:3"; clicked => { AppState.ratio = "4:3"; } }
                    }
                    Row {
                        CanvasRatioOption { width: 78px; value: "3:4"; label: "3:4"; selected: AppState.ratio == "3:4"; clicked => { AppState.ratio = "3:4"; } }
                        CanvasRatioOption { width: 78px; value: "16:9"; label: "16:9"; selected: AppState.ratio == "16:9"; clicked => { AppState.ratio = "16:9"; } }
                        CanvasRatioOption { width: 78px; value: "9:16"; label: "9:16"; selected: AppState.ratio == "9:16"; clicked => { AppState.ratio = "9:16"; } }
                        CanvasRatioOption { width: 78px; value: "2:1"; label: "2:1"; selected: AppState.ratio == "2:1"; clicked => { AppState.ratio = "2:1"; } }
                    }
                    Row {
                        CanvasRatioOption { width: 78px; value: "1:2"; label: "1:2"; selected: AppState.ratio == "1:2"; clicked => { AppState.ratio = "1:2"; } }
                        CanvasRatioOption { width: 78px; value: "21:9"; label: "21:9"; selected: AppState.ratio == "21:9"; clicked => { AppState.ratio = "21:9"; } }
                        CanvasRatioOption { width: 78px; value: "9:21"; label: "9:21"; selected: AppState.ratio == "9:21"; clicked => { AppState.ratio = "9:21"; } }
                    }
                }
                Text { x: 18px; y: 332px; width: parent.width - 36px; height: 22px; text: AppState.en ? "Generation count" : "生成张数"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                HorizontalLayout {
                    x: 18px;
                    y: 360px;
                    width: parent.width - 36px;
                    height: 36px;
                    spacing: 10px;
                    CanvasOptionPill { text: AppState.en ? "1 image" : "1张"; selected: AppState.count == 1; clicked => { AppState.count = 1; } }
                    CanvasOptionPill { text: AppState.en ? "2 images" : "2张"; selected: AppState.count == 2; clicked => { AppState.count = 2; } }
                    CanvasOptionPill { text: AppState.en ? "3 images" : "3张"; selected: AppState.count == 3; clicked => { AppState.count = 3; } }
                    CanvasOptionPill { text: AppState.en ? "4 images" : "4张"; selected: AppState.count == 4; clicked => { AppState.count = 4; } }
                }
            }
        }

        video-settings-popup := PopupWindow {
            width: 366px;
            height: 430px;
            x: root.settings-popup-x(self.width);
            y: root.settings-popup-y(self.height);
            close-policy: close-on-click-outside;
            Rectangle {
                background: #211e1c;
                border-radius: 12px;
                border-width: 1px;
                border-color: #4f4a46;
                Text { x: 18px; y: 10px; width: parent.width - 36px; height: 28px; text: AppState.en ? "Video settings" : "视频设置"; color: #f0ebe7; font-size: 16px; font-weight: 600; vertical-alignment: center; }
                Text { x: 18px; y: 44px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Quality" : "清晰度"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                HorizontalLayout { x: 18px; y: 68px; width: parent.width - 36px; height: 36px; spacing: 10px; CanvasOptionPill { text: "720p"; selected: root.video-quality == "720p"; clicked => { root.video-quality = "720p"; } } CanvasOptionPill { text: "480p"; selected: root.video-quality == "480p"; clicked => { root.video-quality = "480p"; } } }
                Text { x: 18px; y: 112px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Size" : "尺寸"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                Rectangle { x: 18px; y: 136px; width: 145px; height: 36px; background: #2d2926; border-radius: 10px; Text { x: 12px; width: 24px; height: parent.height; text: "W"; color: #aaa39d; font-size: 12px; vertical-alignment: center; } Text { x: 45px; width: parent.width - 55px; height: parent.height; text: root.video-width-text(); color: #eee9e4; font-size: 13px; vertical-alignment: center; } }
                Text { x: 168px; y: 136px; width: 24px; height: 36px; text: "↔"; color: #8d8680; font-size: 15px; horizontal-alignment: center; vertical-alignment: center; }
                Rectangle { x: 197px; y: 136px; width: 151px; height: 36px; background: #2d2926; border-radius: 10px; Text { x: 12px; width: 24px; height: parent.height; text: "H"; color: #aaa39d; font-size: 12px; vertical-alignment: center; } Text { x: 45px; width: parent.width - 55px; height: parent.height; text: root.video-height-text(); color: #eee9e4; font-size: 13px; vertical-alignment: center; } }
                GridLayout {
                    x: 18px;
                    y: 182px;
                    width: parent.width - 36px;
                    height: 142px;
                    spacing: 8px;
                    Row {
                        CanvasRatioOption { width: 104px; value: "landscape"; label: AppState.en ? "Landscape" : "横屏"; detail: "1280x720"; selected: root.video-layout == "landscape"; clicked => { root.video-layout = "landscape"; } }
                        CanvasRatioOption { width: 104px; value: "portrait"; label: AppState.en ? "Portrait" : "竖屏"; detail: "720x1280"; selected: root.video-layout == "portrait"; clicked => { root.video-layout = "portrait"; } }
                        CanvasRatioOption { width: 104px; value: "square"; label: AppState.en ? "Square" : "方形"; detail: "1024x1024"; selected: root.video-layout == "square"; clicked => { root.video-layout = "square"; } }
                    }
                    Row {
                        CanvasRatioOption { width: 104px; value: "wide"; label: AppState.en ? "Wide" : "宽屏"; detail: "1792x1024"; selected: root.video-layout == "wide"; clicked => { root.video-layout = "wide"; } }
                        CanvasRatioOption { width: 104px; value: "tall"; label: AppState.en ? "Tall" : "长图"; detail: "1024x1792"; selected: root.video-layout == "tall"; clicked => { root.video-layout = "tall"; } }
                        CanvasRatioOption { width: 104px; value: "auto"; label: "auto"; selected: root.video-layout == "auto"; clicked => { root.video-layout = "auto"; } }
                    }
                }
                Text { x: 18px; y: 332px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Duration" : "秒数"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                GridLayout {
                    x: 18px;
                    y: 358px;
                    width: parent.width - 36px;
                    height: 36px;
                    spacing: 8px;
                    Row {
                        CanvasOptionPill { width: 58px; text: "6s"; selected: root.video-duration == "6s"; clicked => { root.video-duration = "6s"; } }
                        CanvasOptionPill { width: 58px; text: "10s"; selected: root.video-duration == "10s"; clicked => { root.video-duration = "10s"; } }
                        CanvasOptionPill { width: 58px; text: "12s"; selected: root.video-duration == "12s"; clicked => { root.video-duration = "12s"; } }
                        CanvasOptionPill { width: 58px; text: "16s"; selected: root.video-duration == "16s"; clicked => { root.video-duration = "16s"; } }
                        CanvasOptionPill { width: 58px; text: "20s"; selected: root.video-duration == "20s"; clicked => { root.video-duration = "20s"; } }
                    }
                }
            }
        }

        audio-settings-popup := PopupWindow {
            width: 372px;
            height: min(520px, max(280px, root.viewport-height - 16px));
            x: root.settings-popup-x(self.width);
            y: root.settings-popup-y(self.height);
            close-policy: close-on-click-outside;
            Rectangle {
                background: #211e1c;
                border-radius: 12px;
                border-width: 1px;
                border-color: #4f4a46;
                clip: true;
                audio-settings-scroll := Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-width: parent.width;
                    viewport-height: 520px;
                    interactive: true;
                    Rectangle {
                        width: audio-settings-scroll.width;
                        height: 520px;
                        Text { x: 18px; y: 10px; width: parent.width - 36px; height: 28px; text: AppState.en ? "Audio settings" : "音频设置"; color: #f0ebe7; font-size: 16px; font-weight: 600; vertical-alignment: center; }
                        Text { x: 18px; y: 44px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Voice" : "声音"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                        GridLayout {
                            x: 18px;
                            y: 68px;
                            width: parent.width - 36px;
                            height: 152px;
                            spacing: 8px;
                            Row { CanvasOptionPill { width: 104px; text: "Alloy"; selected: root.audio-voice == "Alloy"; clicked => { root.audio-voice = "Alloy"; } } CanvasOptionPill { width: 104px; text: "Ash"; selected: root.audio-voice == "Ash"; clicked => { root.audio-voice = "Ash"; } } CanvasOptionPill { width: 104px; text: "Ballad"; selected: root.audio-voice == "Ballad"; clicked => { root.audio-voice = "Ballad"; } } }
                            Row { CanvasOptionPill { width: 104px; text: "Coral"; selected: root.audio-voice == "Coral"; clicked => { root.audio-voice = "Coral"; } } CanvasOptionPill { width: 104px; text: "Echo"; selected: root.audio-voice == "Echo"; clicked => { root.audio-voice = "Echo"; } } CanvasOptionPill { width: 104px; text: "Fable"; selected: root.audio-voice == "Fable"; clicked => { root.audio-voice = "Fable"; } } }
                            Row { CanvasOptionPill { width: 104px; text: "Nova"; selected: root.audio-voice == "Nova"; clicked => { root.audio-voice = "Nova"; } } CanvasOptionPill { width: 104px; text: "Onyx"; selected: root.audio-voice == "Onyx"; clicked => { root.audio-voice = "Onyx"; } } CanvasOptionPill { width: 104px; text: "Sage"; selected: root.audio-voice == "Sage"; clicked => { root.audio-voice = "Sage"; } } }
                            Row { CanvasOptionPill { width: 104px; text: "Shimmer"; selected: root.audio-voice == "Shimmer"; clicked => { root.audio-voice = "Shimmer"; } } CanvasOptionPill { width: 104px; text: "Verse"; selected: root.audio-voice == "Verse"; clicked => { root.audio-voice = "Verse"; } } CanvasOptionPill { width: 104px; text: "Marin"; selected: root.audio-voice == "Marin"; clicked => { root.audio-voice = "Marin"; } } }
                        }
                        Text { x: 18px; y: 230px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Format" : "格式"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                        GridLayout {
                            x: 18px;
                            y: 254px;
                            width: parent.width - 36px;
                            height: 80px;
                            spacing: 8px;
                            Row { CanvasOptionPill { width: 104px; text: "MP3"; selected: root.audio-format == "MP3"; clicked => { root.audio-format = "MP3"; } } CanvasOptionPill { width: 104px; text: "WAV"; selected: root.audio-format == "WAV"; clicked => { root.audio-format = "WAV"; } } CanvasOptionPill { width: 104px; text: "Opus"; selected: root.audio-format == "Opus"; clicked => { root.audio-format = "Opus"; } } }
                            Row { CanvasOptionPill { width: 104px; text: "AAC"; selected: root.audio-format == "AAC"; clicked => { root.audio-format = "AAC"; } } CanvasOptionPill { width: 104px; text: "FLAC"; selected: root.audio-format == "FLAC"; clicked => { root.audio-format = "FLAC"; } } CanvasOptionPill { width: 104px; text: "PCM"; selected: root.audio-format == "PCM"; clicked => { root.audio-format = "PCM"; } } }
                        }
                        Text { x: 18px; y: 344px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Speed" : "语速"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                        HorizontalLayout { x: 18px; y: 368px; width: parent.width - 36px; height: 36px; spacing: 8px; CanvasOptionPill { text: "0.75x"; selected: root.audio-speed == "0.75x"; clicked => { root.audio-speed = "0.75x"; } } CanvasOptionPill { text: "1x"; selected: root.audio-speed == "1x"; clicked => { root.audio-speed = "1x"; } } CanvasOptionPill { text: "1.25x"; selected: root.audio-speed == "1.25x"; clicked => { root.audio-speed = "1.25x"; } } CanvasOptionPill { text: "1.5x"; selected: root.audio-speed == "1.5x"; clicked => { root.audio-speed = "1.5x"; } } }
                        Text { x: 18px; y: 414px; width: parent.width - 36px; height: 20px; text: AppState.en ? "Voice instruction" : "声音指令"; color: #d7d1cb; font-size: 12px; vertical-alignment: center; }
                        Rectangle {
                            x: 18px;
                            y: 438px;
                            width: parent.width - 36px;
                            height: 66px;
                            background: #292522;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: #514c48;
                            audio-instruction-input := TextInput { x: 10px; y: 8px; width: parent.width - 20px; height: parent.height - 16px; text <=> root.audio-instruction; single-line: false; wrap: word-wrap; color: #eee9e4; font-size: 12px; key-pressed(event) => { if event.text == Key.Return && !event.modifiers.alt { return accept; } return reject; } }
                            if root.audio-instruction == "" && !audio-instruction-input.has-focus: Text { x: 10px; y: 8px; width: parent.width - 20px; height: 22px; text: AppState.en ? "e.g. Natural, warm, suitable for narration." : "例如：自然、温暖、适合旁白。"; color: #8f8882; font-size: 12px; vertical-alignment: center; }
                        }
                    }
                }
                if parent.height < 520px: Rectangle {
                    x: parent.width - 6px;
                    y: 8px + (-audio-settings-scroll.viewport-y / 1px) / max(1, (520px - audio-settings-scroll.height) / 1px) * (parent.height - 16px - self.height);
                    width: 3px;
                    height: max(32px, (parent.height - 16px) * parent.height / 520px);
                    background: #8f8882;
                    border-radius: 2px;
                }
            }
        }
    }
}

export component InfiniteCanvasPage {
    in-out property <length> pan-x: 120px;
    in-out property <length> pan-y: 92px;
    in-out property <int> zoom-percent: 100;
    in-out property <bool> appearance-open: false;
    in-out property <bool> connection-dragging: false;
    in-out property <string> connection-mode: "";
    in-out property <string> connection-source-id: "";
    in-out property <string> connection-target-id: "";
    in-out property <string> connection-replacing-link-id: "";
    in-out property <length> connection-start-x: 0px;
    in-out property <length> connection-start-y: 0px;
    in-out property <length> connection-end-x: 0px;
    in-out property <length> connection-end-y: 0px;
    in-out property <bool> marquee-active: false;
    in-out property <length> marquee-start-x: 0px;
    in-out property <length> marquee-start-y: 0px;
    in-out property <length> marquee-end-x: 0px;
    in-out property <length> marquee-end-y: 0px;
    in-out property <bool> marquee-additive: false;
    in-out property <bool> space-pan-active: false;
    in-out property <bool> temporary-pan-active: false;
    in-out property <bool> node-search-open: false;
    in-out property <string> node-search-query: "";
    in-out property <string> node-search-source-id: "";
    in-out property <float> node-search-world-x: 0;
    in-out property <float> node-search-world-y: 0;
    in-out property <int> node-search-index: 0;

    function grid-spacing() -> length {
        return max(12px, 40px * root.zoom-percent / 100);
    }

    function grid-offset-x() -> length {
        let offset = Math.mod(root.pan-x / 1px, root.grid-spacing() / 1px) * 1px;
        return offset < 0px ? offset + root.grid-spacing() : offset;
    }

    function grid-offset-y() -> length {
        let offset = Math.mod(root.pan-y / 1px, root.grid-spacing() / 1px) * 1px;
        return offset < 0px ? offset + root.grid-spacing() : offset;
    }

    function set-zoom(next: int, anchor-x: length, anchor-y: length) {
        let target = max(5, min(500, next));
        let world-x = (anchor-x - root.pan-x) * 100 / root.zoom-percent;
        let world-y = (anchor-y - root.pan-y) * 100 / root.zoom-percent;
        root.pan-x = anchor-x - world-x * target / 100;
        root.pan-y = anchor-y - world-y * target / 100;
        root.zoom-percent = target;
    }

    function reset-view() {
        root.pan-x = 120px;
        root.pan-y = 92px;
        root.zoom-percent = 100;
    }

    function focus-selection() {
        let target = AppState.prepare-canvas-focus(canvas.width / 1px * 0.84, canvas.height / 1px * 0.84);
        if AppState.canvas-focus-width <= 0 || AppState.canvas-focus-height <= 0 {
            return;
        }
        root.zoom-percent = max(5, min(500, target));
        root.pan-x = canvas.width / 2 - (AppState.canvas-focus-x + AppState.canvas-focus-width / 2) * 1px * root.zoom-percent / 100;
        root.pan-y = canvas.height / 2 - (AppState.canvas-focus-y + AppState.canvas-focus-height / 2) * 1px * root.zoom-percent / 100;
    }

    function node-type-label(kind: string) -> string {
        if kind == "image" { return AppState.en ? "Image node" : "图片节点"; }
        if kind == "video" { return AppState.en ? "Video node" : "视频节点"; }
        if kind == "audio" { return AppState.en ? "Audio node" : "音频节点"; }
        return AppState.en ? "Text node" : "文本节点";
    }

    function create-searched-node(kind: string) {
        if kind == "" {
            return;
        }
        AppState.add-connected-canvas-node(
            kind,
            root.node-search-source-id,
            root.node-search-world-x,
            root.node-search-world-y
        );
        root.node-search-open = false;
        root.node-search-query = "";
        root.node-search-source-id = "";
        canvas-keyboard.focus();
    }

    function add-node(kind: string) {
        let world-x = (canvas.width / 2 - root.pan-x) * 100 / root.zoom-percent;
        let world-y = (canvas.height / 2 - root.pan-y) * 100 / root.zoom-percent;
        AppState.add-canvas-node(kind, world-x / 1px, world-y / 1px);
        AppState.canvas-tool = "select";
    }

    function begin-connection(source-id: string, start-x: length, start-y: length) {
        root.connection-mode = "output";
        root.connection-source-id = source-id;
        root.connection-target-id = "";
        root.connection-replacing-link-id = "";
        root.connection-start-x = start-x;
        root.connection-start-y = start-y;
        root.connection-end-x = start-x;
        root.connection-end-y = start-y;
        root.connection-dragging = true;
        AppState.canvas-link-hover-target-id = "";
        AppState.canvas-link-hover-valid = false;
        AppState.canvas-tool = "select";
    }

    function begin-reconnect(target-id: string, start-x: length, start-y: length) {
        root.connection-mode = "input";
        root.connection-source-id = "";
        root.connection-target-id = target-id;
        root.connection-replacing-link-id = AppState.canvas-input-link(target-id);
        root.connection-start-x = start-x;
        root.connection-start-y = start-y;
        root.connection-end-x = start-x;
        root.connection-end-y = start-y;
        root.connection-dragging = true;
        AppState.canvas-link-hover-target-id = "";
        AppState.canvas-link-hover-valid = false;
        AppState.canvas-tool = "select";
    }

    function move-connection(end-x: length, end-y: length) {
        if root.connection-dragging {
            root.connection-end-x = end-x;
            root.connection-end-y = end-y;
            if root.connection-mode == "output" {
                let world-x = (end-x - root.pan-x) * 100 / root.zoom-percent;
                let world-y = (end-y - root.pan-y) * 100 / root.zoom-percent;
                let tolerance = max(18, 30 * 100 / root.zoom-percent);
                AppState.preview-canvas-link-target(root.connection-source-id, world-x / 1px, world-y / 1px, tolerance);
            }
        }
    }

    function finish-connection(source-id: string, end-x: length, end-y: length) {
        if !root.connection-dragging || root.connection-source-id != source-id {
            return;
        }
        let world-x = (end-x - root.pan-x) * 100 / root.zoom-percent;
        let world-y = (end-y - root.pan-y) * 100 / root.zoom-percent;
        let tolerance = max(18, 30 * 100 / root.zoom-percent);
        root.connection-dragging = false;
        root.connection-source-id = "";
        let result = AppState.finish-canvas-link(source-id, world-x / 1px, world-y / 1px, tolerance);
        if result == "empty" {
            root.node-search-source-id = source-id;
            root.node-search-world-x = world-x / 1px;
            root.node-search-world-y = world-y / 1px;
            root.node-search-query = "";
            root.node-search-index = 0;
            AppState.search-canvas-node-types("");
            root.node-search-open = true;
            node-search-input.focus();
        }
        root.connection-mode = "";
        root.connection-target-id = "";
        root.connection-replacing-link-id = "";
        AppState.canvas-link-hover-target-id = "";
        AppState.canvas-link-hover-valid = false;
    }

    function finish-reconnect(target-id: string, end-x: length, end-y: length) {
        if !root.connection-dragging || root.connection-target-id != target-id {
            return;
        }
        let world-x = (end-x - root.pan-x) * 100 / root.zoom-percent;
        let world-y = (end-y - root.pan-y) * 100 / root.zoom-percent;
        let tolerance = max(18, 30 * 100 / root.zoom-percent);
        root.connection-dragging = false;
        AppState.finish-canvas-reconnect(target-id, world-x / 1px, world-y / 1px, tolerance);
        root.connection-mode = "";
        root.connection-source-id = "";
        root.connection-target-id = "";
        root.connection-replacing-link-id = "";
        AppState.canvas-link-hover-target-id = "";
        AppState.canvas-link-hover-valid = false;
    }

    function request-selected-delete() {
        if AppState.canvas-selected-count > 1 {
            AppState.pending-delete-kind = "canvas-selection";
            AppState.pending-delete-id = "";
            AppState.pending-delete-source = "canvas";
            AppState.delete-confirm-open = true;
        } else if AppState.canvas-selected-id != "" {
            AppState.pending-delete-kind = "canvas-note";
            AppState.pending-delete-id = AppState.canvas-selected-id;
            AppState.pending-delete-source = "canvas";
            AppState.delete-confirm-open = true;
        } else if AppState.canvas-selected-link-id != "" {
            AppState.pending-delete-kind = "canvas-link";
            AppState.pending-delete-id = AppState.canvas-selected-link-id;
            AppState.pending-delete-source = "canvas";
            AppState.delete-confirm-open = true;
        }
    }

    Rectangle {
        background: AppTheme.bg;
        Text {
            x: 20px;
            y: 0px;
            width: parent.width - 40px;
            height: 58px;
            text: AppState.en ? "Infinite Canvas" : "无限画布";
            color: AppTheme.text;
            font-size: 22px;
            font-weight: 600;
            vertical-alignment: center;
        }

        canvas := Rectangle {
            x: 20px;
            y: 58px;
            width: parent.width - 40px;
            height: parent.height - 78px;
            background: AppState.canvas-dark-background ? #090e17 : AppTheme.panel-soft;
            border-width: 1px;
            border-color: AppTheme.border;
            border-radius: 7px;
            clip: true;

            if AppState.canvas-grid-style == "line": Rectangle {
                background: transparent;
                for column in 120: Rectangle {
                    x: root.grid-offset-x() + column * root.grid-spacing();
                    width: 1px;
                    height: parent.height;
                    background: AppState.canvas-dark-background ? #ffffff12 : AppTheme.border.with-alpha(0.55);
                }
                for row in 80: Rectangle {
                    y: root.grid-offset-y() + row * root.grid-spacing();
                    width: parent.width;
                    height: 1px;
                    background: AppState.canvas-dark-background ? #ffffff12 : AppTheme.border.with-alpha(0.55);
                }
            }

            if AppState.canvas-grid-style == "dot": Rectangle {
                background: transparent;
                for row in 44: Rectangle {
                    y: root.grid-offset-y() + row * root.grid-spacing();
                    width: parent.width;
                    height: 2px;
                    background: transparent;
                    for column in 70: Rectangle {
                        x: root.grid-offset-x() + column * root.grid-spacing();
                        width: 2px;
                        height: 2px;
                        background: AppState.canvas-dark-background ? #ffffff28 : AppTheme.muted.with-alpha(0.5);
                        border-radius: 1px;
                    }
                }
            }

            canvas-touch := TouchArea {
                in-out property <length> start-pan-x: 0px;
                in-out property <length> start-pan-y: 0px;
                in-out property <length> start-pointer-x: 0px;
                in-out property <length> start-pointer-y: 0px;
                width: parent.width;
                height: parent.height;
                mouse-cursor: AppState.canvas-tool == "pan" || root.space-pan-active ? move : crosshair;
                pointer-event(event) => {
                    if event.kind == PointerEventKind.down && (event.button == PointerEventButton.left || event.button == PointerEventButton.middle) {
                        root.appearance-open = false;
                        canvas-keyboard.focus();
                        if event.button == PointerEventButton.middle || AppState.canvas-tool == "pan" || root.space-pan-active {
                            root.temporary-pan-active = true;
                            self.start-pan-x = root.pan-x;
                            self.start-pan-y = root.pan-y;
                            self.start-pointer-x = self.mouse-x;
                            self.start-pointer-y = self.mouse-y;
                        } else {
                            root.marquee-active = true;
                            root.marquee-additive = event.modifiers.control;
                            root.marquee-start-x = self.mouse-x;
                            root.marquee-start-y = self.mouse-y;
                            root.marquee-end-x = self.mouse-x;
                            root.marquee-end-y = self.mouse-y;
                        }
                    } else if event.kind == PointerEventKind.up {
                        if root.marquee-active {
                            let world-start-x = (root.marquee-start-x - root.pan-x) * 100 / root.zoom-percent;
                            let world-start-y = (root.marquee-start-y - root.pan-y) * 100 / root.zoom-percent;
                            let world-end-x = (root.marquee-end-x - root.pan-x) * 100 / root.zoom-percent;
                            let world-end-y = (root.marquee-end-y - root.pan-y) * 100 / root.zoom-percent;
                            AppState.select-canvas-rect(
                                world-start-x / 1px,
                                world-start-y / 1px,
                                world-end-x / 1px,
                                world-end-y / 1px,
                                root.marquee-additive
                            );
                            root.marquee-active = false;
                        }
                        root.temporary-pan-active = false;
                    }
                }
                moved => {
                    if root.temporary-pan-active {
                        root.pan-x = self.start-pan-x + self.mouse-x - self.start-pointer-x;
                        root.pan-y = self.start-pan-y + self.mouse-y - self.start-pointer-y;
                    } else if root.marquee-active {
                        root.marquee-end-x = self.mouse-x;
                        root.marquee-end-y = self.mouse-y;
                    }
                }
                scroll-event(event) => {
                    if event.delta-y != 0 {
                        root.set-zoom(root.zoom-percent + (event.delta-y > 0 ? 10 : -10), self.mouse-x, self.mouse-y);
                        return accept;
                    }
                    return reject;
                }
            }

            canvas-keyboard := FocusScope {
                width: 1px;
                height: 1px;
                focus-on-click: false;
                key-pressed(event) => {
                    if event.text == Key.Space {
                        root.space-pan-active = true;
                        return accept;
                    }
                    if event.text == Key.Escape {
                        if root.node-search-open {
                            root.node-search-open = false;
                            root.node-search-query = "";
                            root.node-search-source-id = "";
                            return accept;
                        }
                        root.marquee-active = false;
                        root.temporary-pan-active = false;
                        root.connection-dragging = false;
                        root.connection-mode = "";
                        root.connection-source-id = "";
                        root.connection-target-id = "";
                        root.connection-replacing-link-id = "";
                        AppState.canvas-link-hover-target-id = "";
                        AppState.canvas-link-hover-valid = false;
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "a" || event.text == "A") {
                        AppState.select-all-canvas-nodes();
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "c" || event.text == "C") {
                        AppState.copy-canvas-selection();
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "v" || event.text == "V") {
                        AppState.paste-canvas-selection(24, 24);
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "d" || event.text == "D") {
                        AppState.duplicate-canvas-selection();
                        return accept;
                    }
                    if event.modifiers.control && event.modifiers.shift && (event.text == "g" || event.text == "G") {
                        AppState.ungroup-canvas-selection();
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "g" || event.text == "G") {
                        let world-x = (canvas.width / 2 - root.pan-x) * 100 / root.zoom-percent;
                        let world-y = (canvas.height / 2 - root.pan-y) * 100 / root.zoom-percent;
                        AppState.group-canvas-selection(world-x / 1px, world-y / 1px);
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "z" || event.text == "Z") {
                        AppState.undo-canvas();
                        return accept;
                    }
                    if event.modifiers.control && (event.text == "y" || event.text == "Y") {
                        AppState.redo-canvas();
                        return accept;
                    }
                    if event.text == "f" || event.text == "F" {
                        root.focus-selection();
                        return accept;
                    }
                    if (AppState.canvas-selected-count > 0 || AppState.canvas-selected-link-id != "") && (event.text == Key.Backspace || event.text == Key.Delete) {
                        root.request-selected-delete();
                        return accept;
                    }
                    return reject;
                }
                key-released(event) => {
                    if event.text == Key.Space {
                        root.space-pan-active = false;
                        root.temporary-pan-active = false;
                        return accept;
                    }
                    return reject;
                }
            }

            for link in AppState.canvas-links: CanvasConnectionCurve {
                visible: link.id != root.connection-replacing-link-id;
                link: link;
                canvas-width: canvas.width;
                canvas-height: canvas.height;
                start-x: root.pan-x + (link.start-x + (link.source-selected ? AppState.canvas-drag-delta-x : 0)) * 1px * root.zoom-percent / 100;
                start-y: root.pan-y + (link.start-y + (link.source-selected ? AppState.canvas-drag-delta-y : 0)) * 1px * root.zoom-percent / 100;
                end-x: root.pan-x + (link.end-x + (link.target-selected ? AppState.canvas-drag-delta-x : 0)) * 1px * root.zoom-percent / 100;
                end-y: root.pan-y + (link.end-y + (link.target-selected ? AppState.canvas-drag-delta-y : 0)) * 1px * root.zoom-percent / 100;
                dark-background: AppState.canvas-dark-background;
                link-selected(link-id) => {
                    AppState.canvas-selected-id = "";
                    AppState.canvas-selected-link-id = link-id;
                    canvas-keyboard.focus();
                }
            }

            if root.connection-dragging: CanvasConnectionCurve {
                preview: true;
                canvas-width: canvas.width;
                canvas-height: canvas.height;
                start-x: root.connection-start-x;
                start-y: root.connection-start-y;
                end-x: root.connection-end-x;
                end-y: root.connection-end-y;
                dark-background: AppState.canvas-dark-background;
            }

            if AppState.canvas-notes.length == 0: Rectangle {
                x: (parent.width - min(320px, parent.width - 32px)) / 2;
                y: (parent.height - 136px) / 2;
                width: min(320px, parent.width - 32px);
                height: 136px;
                background: AppTheme.panel;
                border-radius: 7px;
                border-width: 1px;
                border-color: AppTheme.border;
                Image {
                    x: (parent.width - 30px) / 2;
                    y: 18px;
                    width: 30px;
                    height: 30px;
                    source: @image-url("../../assets/icons/canvas.svg");
                    colorize: AppTheme.accent;
                }
                Text {
                    x: 16px;
                    y: 55px;
                    width: parent.width - 32px;
                    height: 28px;
                    text: AppState.en ? "Create the first node" : "创建第一个节点";
                    color: AppTheme.text;
                    font-size: 17px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                CanvasChoiceButton {
                    x: (parent.width - 112px) / 2;
                    y: 94px;
                    width: 112px;
                    text: AppState.en ? "Add text" : "添加文本";
                    clicked => { root.add-node("text"); }
                }
            }

            for note in AppState.canvas-notes: CanvasNodeCard {
                visible: note.kind == "group";
                note: note;
                zoom-percent: root.zoom-percent;
                pan-x: root.pan-x;
                pan-y: root.pan-y;
                show-image-info: AppState.canvas-show-image-info;
                dark-background: AppState.canvas-dark-background;
                viewport-width: canvas.width;
                viewport-height: canvas.height;
                connection-source-id: root.connection-source-id;
                connection-target-id: root.connection-target-id;
                connection-started(source-id, start-x, start-y) => { root.begin-connection(source-id, start-x, start-y); }
                connection-moved(end-x, end-y) => { root.move-connection(end-x, end-y); }
                connection-finished(source-id, end-x, end-y) => { root.finish-connection(source-id, end-x, end-y); }
                reconnect-started(target-id, start-x, start-y) => { root.begin-reconnect(target-id, start-x, start-y); }
                reconnect-finished(target-id, end-x, end-y) => { root.finish-reconnect(target-id, end-x, end-y); }
                selection-focused => { canvas-keyboard.focus(); }
            }

            for note in AppState.canvas-notes: CanvasNodeCard {
                visible: note.kind != "group";
                note: note;
                zoom-percent: root.zoom-percent;
                pan-x: root.pan-x;
                pan-y: root.pan-y;
                show-image-info: AppState.canvas-show-image-info;
                dark-background: AppState.canvas-dark-background;
                viewport-width: canvas.width;
                viewport-height: canvas.height;
                connection-source-id: root.connection-source-id;
                connection-target-id: root.connection-target-id;
                connection-started(source-id, start-x, start-y) => { root.begin-connection(source-id, start-x, start-y); }
                connection-moved(end-x, end-y) => { root.move-connection(end-x, end-y); }
                connection-finished(source-id, end-x, end-y) => { root.finish-connection(source-id, end-x, end-y); }
                reconnect-started(target-id, start-x, start-y) => { root.begin-reconnect(target-id, start-x, start-y); }
                reconnect-finished(target-id, end-x, end-y) => { root.finish-reconnect(target-id, end-x, end-y); }
                selection-focused => { canvas-keyboard.focus(); }
            }

            if root.marquee-active: Rectangle {
                x: min(root.marquee-start-x, root.marquee-end-x);
                y: min(root.marquee-start-y, root.marquee-end-y);
                width: abs(root.marquee-end-x - root.marquee-start-x);
                height: abs(root.marquee-end-y - root.marquee-start-y);
                background: AppTheme.accent.with-alpha(0.12);
                border-width: 1px;
                border-color: AppTheme.accent;
                border-radius: 2px;
            }

            if AppState.canvas-selected-count > 1: Rectangle {
                x: root.pan-x + (AppState.canvas-focus-x + AppState.canvas-focus-width / 2) * 1px * root.zoom-percent / 100 - self.width / 2;
                y: root.pan-y + AppState.canvas-focus-y * 1px * root.zoom-percent / 100 - 54px;
                width: 216px;
                height: 42px;
                background: AppTheme.panel.with-alpha(0.98);
                border-radius: 21px;
                border-width: 1px;
                border-color: AppTheme.border;
                HorizontalLayout {
                    padding: 3px;
                    spacing: 3px;
                    CanvasToolButton {
                        horizontal-stretch: 1;
                        compact: true;
                        icon: @image-url("../../assets/icons/assets.svg");
                        label: AppState.en ? "Copy" : "复制";
                        clicked => { AppState.copy-canvas-selection(); }
                    }
                    CanvasToolButton {
                        horizontal-stretch: 1;
                        compact: true;
                        icon: @image-url("../../assets/icons/group.svg");
                        label: AppState.en ? "Group" : "分组";
                        clicked => {
                            let world-x = (canvas.width / 2 - root.pan-x) * 100 / root.zoom-percent;
                            let world-y = (canvas.height / 2 - root.pan-y) * 100 / root.zoom-percent;
                            AppState.group-canvas-selection(world-x / 1px, world-y / 1px);
                        }
                    }
                    CanvasToolButton {
                        horizontal-stretch: 1;
                        compact: true;
                        icon: @image-url("../../assets/icons/trash.svg");
                        label: AppState.en ? "Delete" : "删除";
                        clicked => { root.request-selected-delete(); }
                    }
                }
            }

            if AppState.canvas-minimap-open: Rectangle {
                x: 16px;
                y: max(16px, parent.height - (parent.width < 900px ? 258px : 202px));
                width: min(220px, parent.width - 32px);
                height: 126px;
                background: AppTheme.panel.with-alpha(0.96);
                border-radius: 6px;
                border-width: 1px;
                border-color: AppTheme.border;
                clip: true;
                Text {
                    x: 10px;
                    y: 4px;
                    width: parent.width - 20px;
                    height: 22px;
                    text: AppState.en ? "Minimap" : "小地图";
                    color: AppTheme.muted;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                for note in AppState.canvas-notes: Rectangle {
                    x: min(parent.width - 12px, max(8px, parent.width / 2 + note.x * 0.035px));
                    y: min(parent.height - 12px, max(30px, parent.height / 2 + note.y * 0.035px));
                    width: min(42px, max(5px, note.width * 0.035px));
                    height: min(24px, max(4px, note.height * 0.035px));
                    background: note.kind == "group" ? AppTheme.accent.with-alpha(0.16) : AppTheme.accent.with-alpha(0.72);
                    border-width: note.id == AppState.canvas-selected-id ? 1px : 0px;
                    border-color: AppTheme.accent-dark;
                }
                Rectangle {
                    x: parent.width / 2 - 30px;
                    y: parent.height / 2 - 18px;
                    width: 60px;
                    height: 36px;
                    background: transparent;
                    border-width: 1px;
                    border-color: AppTheme.warning;
                }
            }

            zoom-panel := Rectangle {
                x: 16px;
                y: parent.height - (parent.width < 900px ? 118px : 60px);
                width: min(250px, parent.width - 32px);
                height: 48px;
                background: AppState.canvas-dark-background ? #211e1c : AppTheme.panel.with-alpha(0.98);
                border-radius: 10px;
                border-width: 1px;
                border-color: AppState.canvas-dark-background ? #4d4844 : AppTheme.border;
                CanvasZoomButton {
                    x: 6px;
                    y: 9px;
                    icon: @image-url("../../assets/icons/compass.svg");
                    label: AppState.en ? "Minimap" : "小地图";
                    selected: AppState.canvas-minimap-open;
                    clicked => { AppState.canvas-minimap-open = !AppState.canvas-minimap-open; }
                }
                CanvasZoomButton {
                    x: 40px;
                    y: 9px;
                    icon: @image-url("../../assets/icons/focus.svg");
                    label: AppState.en ? "Reset view" : "重置视图";
                    clicked => { root.reset-view(); }
                }
                zoom-track := Rectangle {
                    property <float> zoom-progress: max(0, min(1, (root.zoom-percent - 5) / 495));
                    property <length> thumb-center-x: 7px + (self.width - 14px) * self.zoom-progress;
                    x: 80px;
                    y: 22px;
                    width: 82px;
                    height: 4px;
                    background: #6b6661;
                    border-radius: 2px;
                    Rectangle {
                        x: 0px;
                        width: zoom-track.thumb-center-x;
                        height: parent.height;
                        background: #f2eee9;
                        border-radius: 2px;
                    }
                    Rectangle {
                        x: zoom-track.thumb-center-x - 7px;
                        y: -5px;
                        width: 14px;
                        height: 14px;
                        background: #f2eee9;
                        border-radius: 7px;
                        border-width: 1px;
                        border-color: #ffffff;
                    }
                    zoom-touch := TouchArea {
                        width: parent.width;
                        height: 24px;
                        y: -10px;
                        mouse-cursor: pointer;
                        clicked => {
                            root.set-zoom(5 + floor(self.mouse-x / self.width * 495), canvas.width / 2, canvas.height / 2);
                        }
                        moved => {
                            if self.pressed {
                                root.set-zoom(5 + floor(max(0px, min(self.width, self.mouse-x)) / self.width * 495), canvas.width / 2, canvas.height / 2);
                            }
                        }
                    }
                }
                Text {
                    x: 166px;
                    width: 42px;
                    height: parent.height;
                    text: root.zoom-percent + "%";
                    color: AppState.canvas-dark-background ? #f2eee9 : AppTheme.text;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                CanvasZoomButton {
                    x: 212px;
                    y: 9px;
                    icon: @image-url("../../assets/icons/help.svg");
                    label: AppState.en ? "Canvas zoom" : "画布缩放";
                }
            }

            toolbar := Rectangle {
                x: max(16px, (parent.width - self.width) / 2);
                y: parent.height - 62px;
                width: min(parent.width - 32px, parent.width < 620px ? 332px : 436px);
                height: parent.width < 620px ? 44px : 52px;
                background: AppTheme.panel.with-alpha(0.98);
                border-radius: 7px;
                border-width: 1px;
                border-color: AppTheme.border;
                HorizontalLayout {
                    padding: 4px;
                    spacing: 4px;
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/canvas.svg"); label: AppState.en ? "Select" : "选择"; selected: AppState.canvas-tool == "select"; clicked => { AppState.canvas-tool = "select"; } }
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/move.svg"); label: AppState.en ? "Pan" : "移动画布"; selected: AppState.canvas-tool == "pan"; clicked => { AppState.canvas-tool = "pan"; } }
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/undo.svg"); label: AppState.en ? "Undo" : "撤销"; disabled: !AppState.canvas-can-undo; clicked => { AppState.undo-canvas(); } }
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/redo.svg"); label: AppState.en ? "Redo" : "重做"; disabled: !AppState.canvas-can-redo; clicked => { AppState.redo-canvas(); } }
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/text.svg"); label: AppState.en ? "Text node" : "文本节点"; clicked => { root.add-node("text"); } }
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/image.svg"); label: AppState.en ? "Image node" : "图片节点"; clicked => { root.add-node("image"); } }
                    CanvasToolButton {
                        compact: canvas.width < 620px;
                        icon: @image-url("../../assets/icons/group.svg");
                        label: AppState.en ? "Group" : "分组";
                        clicked => {
                            let world-x = (canvas.width / 2 - root.pan-x) * 100 / root.zoom-percent;
                            let world-y = (canvas.height / 2 - root.pan-y) * 100 / root.zoom-percent;
                            AppState.group-canvas-selection(world-x / 1px, world-y / 1px);
                        }
                    }
                    appearance-button := CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/palette.svg"); label: AppState.en ? "Canvas appearance" : "画布外观"; selected: root.appearance-open; clicked => { root.appearance-open = !root.appearance-open; } }
                    CanvasToolButton { compact: canvas.width < 620px; icon: @image-url("../../assets/icons/trash.svg"); label: AppState.en ? "Delete selected" : "删除所选"; disabled: AppState.canvas-selected-count == 0 && AppState.canvas-selected-link-id == ""; clicked => { root.request-selected-delete(); } }
                }
            }

            if root.appearance-open: Rectangle {
                x: max(16px, min(toolbar.x + appearance-button.x + (appearance-button.width - self.width) / 2, parent.width - self.width - 16px));
                y: max(16px, toolbar.y - self.height - 10px);
                width: min(280px, parent.width - 32px);
                height: 214px;
                background: AppTheme.panel.with-alpha(0.99);
                border-radius: 7px;
                border-width: 1px;
                border-color: AppTheme.border;
                Text { x: 14px; y: 8px; width: parent.width - 28px; height: 28px; text: AppState.en ? "Canvas appearance" : "画布外观"; color: AppTheme.text; font-size: 14px; font-weight: 600; vertical-alignment: center; }
                Text { x: 14px; y: 42px; width: 70px; height: 30px; text: AppState.en ? "Theme" : "背景"; color: AppTheme.muted; font-size: 12px; vertical-alignment: center; }
                CanvasChoiceButton { x: 84px; y: 42px; width: 82px; text: AppState.en ? "Dark" : "深色"; selected: AppState.canvas-dark-background; clicked => { AppState.canvas-dark-background = true; } }
                CanvasChoiceButton { x: 174px; y: 42px; width: parent.width - 188px; text: AppState.en ? "Light" : "浅色"; selected: !AppState.canvas-dark-background; clicked => { AppState.canvas-dark-background = false; } }
                Text { x: 14px; y: 82px; width: 70px; height: 30px; text: AppState.en ? "Grid" : "网格"; color: AppTheme.muted; font-size: 12px; vertical-alignment: center; }
                CanvasChoiceButton { x: 84px; y: 82px; width: 54px; text: AppState.en ? "Line" : "线"; selected: AppState.canvas-grid-style == "line"; clicked => { AppState.canvas-grid-style = "line"; } }
                CanvasChoiceButton { x: 144px; y: 82px; width: 54px; text: AppState.en ? "Dot" : "点"; selected: AppState.canvas-grid-style == "dot"; clicked => { AppState.canvas-grid-style = "dot"; } }
                CanvasChoiceButton { x: 204px; y: 82px; width: parent.width - 218px; text: AppState.en ? "None" : "无"; selected: AppState.canvas-grid-style == "blank"; clicked => { AppState.canvas-grid-style = "blank"; } }
                CanvasToggle { x: 14px; y: 126px; width: parent.width - 28px; text: AppState.en ? "Show media configuration" : "显示媒体配置信息"; checked: AppState.canvas-show-image-info; toggled => { AppState.canvas-show-image-info = !AppState.canvas-show-image-info; } }
                CanvasToggle { x: 14px; y: 164px; width: parent.width - 28px; text: AppState.en ? "Show minimap" : "显示小地图"; checked: AppState.canvas-minimap-open; toggled => { AppState.canvas-minimap-open = !AppState.canvas-minimap-open; } }
            }
        }

        node-search-popup := Rectangle {
            visible: root.node-search-open;
            x: canvas.x + root.pan-x + root.node-search-world-x * 1px * root.zoom-percent / 100;
            y: canvas.y + root.pan-y + root.node-search-world-y * 1px * root.zoom-percent / 100;
            width: 248px;
            height: 58px + max(1, AppState.canvas-node-search-results.length) * 42px;
            background: AppTheme.panel.with-alpha(0.99);
            border-radius: 10px;
            border-width: 1px;
            border-color: AppTheme.border;

            Rectangle {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: 38px;
                background: AppTheme.panel-soft;
                border-radius: 7px;
                border-width: 1px;
                border-color: node-search-input.has-focus ? AppTheme.accent : AppTheme.border;
                node-search-input := TextInput {
                    x: 10px;
                    y: 7px;
                    width: parent.width - 20px;
                    height: parent.height - 14px;
                    text <=> root.node-search-query;
                    single-line: true;
                    color: AppTheme.text;
                    font-size: 13px;
                    edited => {
                        AppState.search-canvas-node-types(self.text);
                        root.node-search-index = 0;
                    }
                    key-pressed(event) => {
                        if event.text == Key.DownArrow && AppState.canvas-node-search-results.length > 0 {
                            root.node-search-index = min(AppState.canvas-node-search-results.length - 1, root.node-search-index + 1);
                            return accept;
                        }
                        if event.text == Key.UpArrow && AppState.canvas-node-search-results.length > 0 {
                            root.node-search-index = max(0, root.node-search-index - 1);
                            return accept;
                        }
                        if event.text == Key.Return && AppState.canvas-node-search-results.length > 0 {
                            root.create-searched-node(AppState.canvas-node-search-results[root.node-search-index]);
                            return accept;
                        }
                        if event.text == Key.Escape {
                            root.node-search-open = false;
                            root.node-search-query = "";
                            root.node-search-source-id = "";
                            canvas-keyboard.focus();
                            return accept;
                        }
                        return reject;
                    }
                }
                if root.node-search-query == "" && !node-search-input.has-focus: Text {
                    x: 10px;
                    y: 7px;
                    width: parent.width - 20px;
                    height: parent.height - 14px;
                    text: AppState.en ? "Search nodes..." : "搜索节点...";
                    color: AppTheme.muted;
                    font-size: 13px;
                    vertical-alignment: center;
                }
            }

            if AppState.canvas-node-search-results.length == 0: Text {
                x: 12px;
                y: 50px;
                width: parent.width - 24px;
                height: 40px;
                text: AppState.en ? "No matching nodes" : "没有匹配节点";
                color: AppTheme.muted;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            for kind[index] in AppState.canvas-node-search-results: Rectangle {
                x: 8px;
                y: 50px + index * 42px;
                width: parent.width - 16px;
                height: 38px;
                background: index == root.node-search-index || node-type-touch.has-hover ? AppTheme.accent.with-alpha(0.14) : transparent;
                border-radius: 7px;
                Image {
                    x: 10px;
                    y: 9px;
                    width: 20px;
                    height: 20px;
                    source: kind == "image"
                        ? @image-url("../../assets/icons/image.svg")
                        : (kind == "video"
                            ? @image-url("../../assets/icons/video.svg")
                            : (kind == "audio"
                                ? @image-url("../../assets/icons/audio.svg")
                                : @image-url("../../assets/icons/text.svg")));
                    colorize: AppTheme.accent;
                }
                Text {
                    x: 40px;
                    width: parent.width - 50px;
                    height: parent.height;
                    text: root.node-type-label(kind);
                    color: AppTheme.text;
                    font-size: 13px;
                    vertical-alignment: center;
                }
                node-type-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => {
                        root.node-search-index = index;
                        root.create-searched-node(kind);
                    }
                }
            }
        }
    }
}
