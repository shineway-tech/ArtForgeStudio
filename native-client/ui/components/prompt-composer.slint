import { ScrollView } from "std-widgets.slint";
import { AppState } from "../app-state.slint";
import { AdvancedControlChip } from "advanced-control-chip.slint";
import { CreationModeChip } from "creation-mode-chip.slint";
import { GenerateActionButton } from "generate-action-button.slint";
import { LoadingDots } from "loading-dots.slint";
import { PillButton } from "pill-button.slint";
import { ReferenceThumb } from "reference-thumb.slint";
import { StyleModeChip } from "style-mode-chip.slint";
import { UploadCard } from "upload-card.slint";
import { AppTheme } from "../theme.slint";

export component PromptComposer {
    in property <bool> generation: false;
    in property <bool> show-generate-button: true;
    property <int> prompt-history-selected-index: 0;
    property <int> custom-prompt-selected-index: 0;
    property <length> prompt-history-scroll-y: 0px;
    property <length> custom-prompt-scroll-y: 0px;
    height: AppState.references.length > 0 || AppState.quote-title != "" ? 480px : 430px;

    function apply-selected-prompt(value: string) {
        AppState.prompt-history-open = false;
        AppState.custom-prompt-open = false;
        history-popup.close();
        custom-prompt-popup.close();
        prompt-input.focus();
        prompt-input.text = value;
        AppState.prompt = value;
    }

    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 16px;
        border-width: 1px;
        border-color: AppTheme.border;
        clip: false;
        if AppState.quote-title != "": Rectangle {
            x: 24px;
            y: root.action-status-wraps() ? 76px : 50px;
            height: 34px;
            width: parent.width - 48px;
            background: AppTheme.panel-soft;
            border-radius: 8px;
            Text { x: 12px; width: parent.width - 54px; height: parent.height; text: (AppState.en ? "Quoted image: " : "引用图片：") + AppState.quote-title; color: AppTheme.muted; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
            Text { x: parent.width - 34px; width: 24px; height: parent.height; text: "×"; color: AppTheme.muted; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { width: parent.width; height: parent.height; clicked => { AppState.quote-title = ""; AppState.quote-prompt = ""; AppState.quote-ratio = ""; AppState.quote-quality = ""; AppState.quote-width = 0; AppState.quote-height = 0; } }
        }
        for ref[index] in AppState.references: ReferenceThumb {
            x: root.reference-x(index);
            y: root.reference-y(index);
            item: ref;
        }
        if AppState.references.length < root.max-reference-count(): UploadCard {
            x: root.reference-x(AppState.references.length) + 4px;
            y: root.reference-y(AppState.references.length) + 4px;
            width: 56px;
            height: 64px;
            clicked => { AppState.add-reference(); }
        }
        PillButton {
            x: 24px;
            y: 14px;
            width: 96px;
            height: 28px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing..." : "正在优化...") : (AppState.en ? "AI Optimize" : "AI优化");
            primary: true;
            disabled: AppState.reasoning-model == "" || AppState.optimizing-prompt;
            clicked => { AppState.optimize-current-prompt(); }
        }
        PillButton {
            x: 128px;
            y: 14px;
            width: 104px;
            height: 28px;
            text: AppState.en ? "Image+Text" : "图文优化";
            primary: true;
            disabled: AppState.reasoning-model == "" || AppState.optimizing-prompt || AppState.references.length == 0;
            clicked => { AppState.visual-optimize-current-prompt(); }
        }
        if AppState.optimizing-prompt: LoadingDots {
            x: 238px;
            y: 7px;
            width: 30px;
            height: 30px;
        }
        Text {
            visible: AppState.optimizing-prompt || AppState.translating-prompt;
            x: root.action-status-wraps() ? 24px : 274px;
            y: root.action-status-wraps() ? 48px : 20px;
            width: root.action-status-wraps() ? parent.width - 48px : parent.width - 298px;
            height: 18px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing prompt..." : "正在优化提示词...")
                : (AppState.en ? "Translating prompt..." : "正在翻译提示词...");
            color: AppTheme.text;
            font-size: 13px;
            font-weight: 400;
            overflow: elide;
        }
        prompt-scroll := ScrollView {
            x: 24px;
            y: root.prompt-input-y();
            width: parent.width - 48px;
            height: root.prompt-input-height();
            viewport-width: self.visible-width;
            viewport-height: max(self.visible-height, prompt-input.preferred-height);
            prompt-input := TextInput {
                text <=> AppState.prompt;
                single-line: false;
                color: AppTheme.text;
                font-size: AppState.settings-font-size * 1px;
                font-weight: 400;
                wrap: word-wrap;
                page-height: prompt-scroll.visible-height;
                cursor-position-changed(position) => {
                    if position.y + prompt-scroll.viewport-y < 8px {
                        prompt-scroll.viewport-y = min(0px, max(prompt-scroll.visible-height - self.height, -position.y + 8px));
                    } else if position.y + prompt-scroll.viewport-y > prompt-scroll.visible-height - 28px {
                        prompt-scroll.viewport-y = min(0px, max(prompt-scroll.visible-height - self.height, prompt-scroll.visible-height - position.y - 28px));
                    }
                }
                edited => {
                    if AppState.prompt-history-open && self.text != "/" {
                        AppState.prompt-history-open = false;
                        history-popup.close();
                    }
                    if AppState.custom-prompt-open && self.text != "//" {
                        AppState.custom-prompt-open = false;
                        custom-prompt-popup.close();
                    }
                }
                key-pressed(event) => {
                    if event.text == "/" && AppState.prompt == "/" {
                        AppState.prompt = "//";
                        prompt-input.set-selection-offsets(2, 2);
                        AppState.prompt-history-open = false;
                        history-popup.close();
                        root.custom-prompt-selected-index = 0;
                        root.custom-prompt-scroll-y = 0px;
                        AppState.custom-prompt-open = true;
                        custom-prompt-popup.show();
                        prompt-input.focus();
                        return accept;
                    }
                    if AppState.prompt-history-open && AppState.prompt-history.length > 0 {
                        if event.text == Key.DownArrow {
                            root.prompt-history-selected-index = min(
                                AppState.prompt-history.length - 1,
                                root.prompt-history-selected-index + 1,
                            );
                            root.scroll-prompt-history-selection-into-view();
                            return accept;
                        }
                        if event.text == Key.UpArrow {
                            root.prompt-history-selected-index = max(0, root.prompt-history-selected-index - 1);
                            root.scroll-prompt-history-selection-into-view();
                            return accept;
                        }
                        if event.text == Key.Return && !event.modifiers.alt {
                            root.apply-selected-prompt(
                                AppState.prompt-history[root.prompt-history-selected-index],
                            );
                            return accept;
                        }
                        if event.text == Key.Escape {
                            AppState.prompt-history-open = false;
                            history-popup.close();
                            return accept;
                        }
                    }
                    if AppState.custom-prompt-open && AppState.custom-prompts.length > 0 {
                        if event.text == Key.DownArrow {
                            root.custom-prompt-selected-index = min(
                                AppState.custom-prompts.length - 1,
                                root.custom-prompt-selected-index + 1,
                            );
                            root.scroll-custom-prompt-selection-into-view();
                            return accept;
                        }
                        if event.text == Key.UpArrow {
                            root.custom-prompt-selected-index = max(0, root.custom-prompt-selected-index - 1);
                            root.scroll-custom-prompt-selection-into-view();
                            return accept;
                        }
                        if event.text == Key.Return && !event.modifiers.alt {
                            root.apply-selected-prompt(
                                AppState.custom-prompts[root.custom-prompt-selected-index],
                            );
                            return accept;
                        }
                        if event.text == Key.Escape {
                            AppState.custom-prompt-open = false;
                            custom-prompt-popup.close();
                            return accept;
                        }
                    }
                    if event.text == Key.Return {
                        if event.modifiers.alt {
                            return reject;
                        }
                        if root.show-generate-button && !AppState.generating && AppState.reasoning-model != "" {
                            AppState.generate();
                        }
                        return accept;
                    }
                    if event.text == "/" && AppState.prompt == "" && AppState.prompt-history.length > 0 {
                        root.prompt-history-selected-index = 0;
                        root.prompt-history-scroll-y = 0px;
                        AppState.prompt-history-open = true;
                        history-popup.show();
                        prompt-input.focus();
                    }
                    if event.modifiers.control && (event.text == "v" || event.text == "V") {
                        if AppState.paste-reference() {
                            return accept;
                        }
                    }
                    return reject;
                }
            }
        }
        Text {
            visible: prompt-input.text == "" && !prompt-input.has-focus;
            x: 24px;
            y: root.prompt-input-y();
            width: parent.width - 48px;
            height: root.prompt-input-height();
            text: root.prompt-placeholder();
            color: AppTheme.weak;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            wrap: word-wrap;
        }
        HorizontalLayout {
            x: 24px;
            y: parent.height - 70px;
            spacing: 10px;
            CreationModeChip {}
            if AppState.asset-type != "action-sequence": StyleModeChip {}
            if AppState.asset-type != "action-sequence": AdvancedControlChip {}
        }
        GenerateActionButton {
            x: root.width < 560px ? parent.width - 190px : parent.width - 178px;
            y: parent.height - 78px;
            width: root.width < 560px ? 166px : 154px;
            height: 54px;
            visible: root.show-generate-button;
            disabled: !AppState.generating && AppState.reasoning-model == "";
            clicked => {
                if AppState.generating {
                    AppState.stop-generation();
                } else {
                    AppState.generate();
                }
            }
        }
        Text {
            visible: root.show-generate-button && (AppState.optimizing-prompt || AppState.translating-prompt || AppState.generating || AppState.generation-status != "");
            x: 24px;
            y: parent.height - 24px;
            width: parent.width - 48px;
            height: 16px;
            text: AppState.optimizing-prompt ? (AppState.en ? "Optimizing prompt..." : "正在优化提示词...")
                : (AppState.translating-prompt ? (AppState.en ? "Translating prompt..." : "正在翻译提示词...")
                : (AppState.generating ? (AppState.en ? "Generating..." : "正在生成中...")
                : AppState.generation-status));
            color: AppTheme.text;
            font-size: 13px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        reference-drop := DropArea {
            width: parent.width;
            height: parent.height;
            can-drop(event) => {
                return event.mime-type == "text/uri-list" || event.mime-type == "text/plain" || event.mime-type == "application/x-artforge-image-path";
            }
            dropped(event) => {
                AppState.add-reference-from-drag(event.mime-type, event.data);
            }
        }
        if reference-drop.contains-drag: Rectangle {
            x: 8px;
            y: 8px;
            width: parent.width - 16px;
            height: parent.height - 16px;
            background: #00d98218;
            border-radius: 14px;
            border-width: 2px;
            border-color: AppTheme.accent;
            Text {
                width: parent.width;
                height: parent.height;
                text: AppState.en ? "Drop to add reference" : "松开添加为参考图";
                color: AppTheme.accent;
                font-size: 16px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    history-popup := PopupWindow {
        x: 24px;
        y: root.prompt-input-y() + 32px;
        width: root.width - 48px;
        height: 16px + min(10, AppState.prompt-history.length) * 32px;
        close-policy: close-on-click-outside;
        Rectangle {
            visible: AppState.prompt-history-open && AppState.prompt-history.length > 0;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            history-scroll := ScrollView {
                viewport-y <=> root.prompt-history-scroll-y;
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                viewport-width: self.width;
                viewport-height: AppState.prompt-history.length * 32px;
                VerticalLayout {
                    width: parent.width;
                    height: AppState.prompt-history.length * 32px;
                    for preview[index] in AppState.prompt-history-previews: Rectangle {
                        height: 32px;
                        background: history-row.has-hover || index == root.prompt-history-selected-index
                            ? AppTheme.panel-soft
                            : transparent;
                        border-radius: 6px;
                        Text {
                            x: 10px;
                            width: parent.width - 20px;
                            height: parent.height;
                            text: preview;
                            color: index == root.prompt-history-selected-index ? AppTheme.accent : AppTheme.text;
                            font-size: AppState.settings-font-size * 1px;
                            font-weight: 400;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        history-row := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => {
                                root.apply-selected-prompt(AppState.prompt-history[index]);
                            }
                        }
                    }
                }
            }
        }
    }

    custom-prompt-popup := PopupWindow {
        x: 24px;
        y: root.prompt-input-y() + 32px;
        width: root.width - 48px;
        height: max(54px, 16px + min(10, AppState.custom-prompts.length) * 32px);
        close-policy: close-on-click-outside;
        Rectangle {
            visible: AppState.custom-prompt-open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.border;
            if AppState.custom-prompts.length == 0: Rectangle {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                background: create-prompt-touch.has-hover ? AppTheme.panel-soft : transparent;
                border-radius: 6px;
                Text {
                    x: 10px;
                    width: parent.width - 20px;
                    height: parent.height;
                    text: AppState.en ? "No custom prompts. Click to create one" : "暂无自定义提示词，点击创建";
                    color: AppTheme.accent;
                    font-size: AppState.settings-font-size * 1px;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    wrap: no-wrap;
                    overflow: elide;
                }
                create-prompt-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => {
                        AppState.custom-prompt-open = false;
                        custom-prompt-popup.close();
                        AppState.settings-section = "prompts";
                        AppState.navigate("settings");
                    }
                }
            }
            custom-prompt-scroll := ScrollView {
                visible: AppState.custom-prompts.length > 0;
                viewport-y <=> root.custom-prompt-scroll-y;
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                viewport-width: self.width;
                viewport-height: AppState.custom-prompts.length * 32px;
                VerticalLayout {
                    width: parent.viewport-width;
                    height: parent.viewport-height;
                    for preview[index] in AppState.custom-prompt-previews: Rectangle {
                        height: 32px;
                        background: custom-row.has-hover || index == root.custom-prompt-selected-index
                            ? AppTheme.panel-soft
                            : transparent;
                        border-radius: 6px;
                        Text {
                            x: 10px;
                            width: parent.width - 20px;
                            height: parent.height;
                            text: preview;
                            color: index == root.custom-prompt-selected-index ? AppTheme.accent : AppTheme.text;
                            font-size: AppState.settings-font-size * 1px;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        custom-row := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            mouse-cursor: pointer;
                            clicked => {
                                root.apply-selected-prompt(AppState.custom-prompts[index]);
                            }
                        }
                    }
                }
            }
        }
    }

    function scroll-prompt-history-selection-into-view() {
        let selected-top = root.prompt-history-selected-index * 32px;
        let selected-bottom = selected-top + 32px;
        let visible-height = min(10, AppState.prompt-history.length) * 32px;
        if selected-top + root.prompt-history-scroll-y < 0px {
            root.prompt-history-scroll-y = -selected-top;
        } else if selected-bottom + root.prompt-history-scroll-y > visible-height {
            root.prompt-history-scroll-y = visible-height - selected-bottom;
        }
    }

    function scroll-custom-prompt-selection-into-view() {
        let selected-top = root.custom-prompt-selected-index * 32px;
        let selected-bottom = selected-top + 32px;
        let visible-height = min(10, AppState.custom-prompts.length) * 32px;
        if selected-top + root.custom-prompt-scroll-y < 0px {
            root.custom-prompt-scroll-y = -selected-top;
        } else if selected-bottom + root.custom-prompt-scroll-y > visible-height {
            root.custom-prompt-scroll-y = visible-height - selected-bottom;
        }
    }

    function reference-visible-count() -> int {
        return AppState.references.length + (AppState.references.length < root.max-reference-count() ? 1 : 0);
    }

    function max-reference-count() -> int {
        if AppState.asset-type == "action-sequence" { return 1; }
        return 8;
    }

    function reference-columns() -> int {
        return max(1, min(8, floor((root.width - 48px) / 72px)));
    }

    function reference-row-count() -> int {
        return max(1, (root.reference-visible-count() + root.reference-columns() - 1) / root.reference-columns());
    }

    function reference-tray-y() -> length {
        return root.height - 80px - root.reference-row-count() * 74px;
    }

    function reference-x(index: int) -> length {
        return 24px + Math.mod(index, root.reference-columns()) * 72px;
    }

    function reference-y(index: int) -> length {
        return root.reference-tray-y() + floor(index / root.reference-columns()) * 74px;
    }

    function prompt-input-y() -> length {
        if AppState.quote-title != "" {
            return root.action-status-wraps() ? 118px : 92px;
        }
        return root.action-status-wraps() ? 84px : 58px;
    }

    function action-status-wraps() -> bool {
        return (AppState.optimizing-prompt || AppState.translating-prompt)
            && (root.width < 680px || AppState.settings-font-size > 16);
    }

    function prompt-input-height() -> length {
        return max(96px, root.reference-tray-y() - root.prompt-input-y() - 12px);
    }

    function prompt-placeholder() -> string {
        if AppState.mode == "film" { return AppState.en ? "Describe the script, characters, scenes, storyboard, or video" : "描述你想创作的剧本、角色、场景、分镜或视频"; }
        if AppState.en {
            if AppState.asset-type == "scene" { return "Describe the scene you want to create...\nExample: a wasteland market at dusk, steam-powered mechanical stalls, cinematic lighting, game concept art style"; }
            if AppState.asset-type == "character" { return "Describe the character you want to create...\nExample: a female knight holding a flaming longsword, full armor, dark fantasy style, complete full-body illustration design"; }
            if AppState.asset-type == "ui" { return "Describe the UI screen you want to create...\nExample: dark control-console home page, modular card layout, cyan-blue highlights, hybrid game HUD and data dashboard style"; }
            if AppState.asset-type == "effect" { return "Describe the VFX, enchantment, skill release, or sprite-sheet animation effect you want...\nExample: blue-white lightning enchantment around a sword, 8-direction continuous flicker, suitable for pixel-style RPG battle skill VFX sprite sheet"; }
            return "Describe the character, scene, UI, or effect you want";
        }
        if AppState.asset-type == "scene" { return "描述你想要创作的场景...\n例如：黄昏中的废土集市，蒸汽机械摊位，电影感光影，游戏概念图风格"; }
        if AppState.asset-type == "character" { return "描述你想要创建的角色...\n例如：一位手持火焰长剑的女骑士，全身铠甲，暗黑奇幻风格，完整立绘设计"; }
        if AppState.asset-type == "ui" { return "描述你想要创建的 UI 界面...\n例如：暗黑风控制台首页，模块化卡片布局，蓝青色高亮，游戏 HUD + 数据看板混合风格"; }
        if AppState.asset-type == "effect" { return "描述你想生成的特效、附魔、技能释放或精灵图集动态效果...\n例如：蓝白雷电附魔环绕剑身，8方向连续闪烁，适合像素风 RPG 战斗技能特效精灵图集"; }
        return "描述你想生成的角色、场景、UI 或特效";
    }
}
