import { ScrollView } from "std-widgets.slint";
import { AppState } from "../app-state.slint";
import { PillButton } from "pill-button.slint";
import { AppTheme } from "../theme.slint";

export component CustomPromptSettings {
    Rectangle {
        background: transparent;
        Text {
            x: 0px;
            y: 0px;
            width: parent.width - 128px;
            height: 36px;
            text: (AppState.en ? "Saved prompts " : "已保存提示词 ") + AppState.custom-prompts.length;
            color: AppTheme.text;
            font-size: 14px;
            font-weight: 500;
            vertical-alignment: center;
        }
        PillButton {
            x: parent.width - 104px;
            y: 0px;
            width: 104px;
            height: 36px;
            text: AppState.en ? "Add" : "新增";
            primary: true;
            clicked => {
                AppState.begin-new-custom-prompt();
            }
        }
        Rectangle {
            x: 0px;
            y: 48px;
            width: parent.width;
            height: parent.height - 48px;
            background: transparent;
            clip: true;
            if AppState.custom-prompt-items.length == 0: Text {
                x: 20px;
                width: parent.width - 40px;
                height: parent.height;
                text: AppState.en ? "No custom prompts" : "暂无自定义提示词";
                color: AppTheme.muted;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            if AppState.custom-prompt-items.length > 0: ScrollView {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: max(self.height, AppState.custom-prompt-items.length * 76px);
                VerticalLayout {
                    width: parent.viewport-width;
                    height: parent.viewport-height;
                    spacing: 8px;
                    for item in AppState.custom-prompt-items: Rectangle {
                        height: 68px;
                        background: row-touch.has-hover ? AppTheme.panel-soft : AppTheme.panel;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: AppTheme.border;
                        clip: true;
                        Text {
                            x: 16px;
                            y: 8px;
                            width: parent.width - 436px;
                            height: 20px;
                            text: item.name;
                            color: AppTheme.text;
                            font-size: 13px;
                            font-weight: 500;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Rectangle {
                            x: parent.width - 412px;
                            y: 8px;
                            width: 52px;
                            height: 20px;
                            background: AppTheme.accent.with-alpha(0.10);
                            border-radius: 10px;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: item.format == "json" ? "JSON" : "TXT";
                                color: AppTheme.accent-dark;
                                font-size: 10px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            x: parent.width - 352px;
                            y: 8px;
                            width: 76px;
                            height: 20px;
                            background: AppTheme.panel-soft;
                            border-radius: 10px;
                            Text {
                                width: parent.width;
                                height: parent.height;
                                text: root.category-label(item.category);
                                color: AppTheme.muted;
                                font-size: 10px;
                                font-weight: 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                        Text {
                            x: 16px;
                            y: 36px;
                            width: parent.width - 120px;
                            height: 18px;
                            text: item.preview;
                            color: AppTheme.muted;
                            font-size: 12px;
                            font-weight: 400;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Text {
                            x: parent.width - 284px;
                            y: 9px;
                            width: 184px;
                            height: 18px;
                            text: item.time;
                            color: AppTheme.weak;
                            font-size: 11px;
                            font-weight: 400;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                            horizontal-alignment: right;
                        }
                        row-touch := TouchArea {
                            width: parent.width - 92px;
                            height: parent.height;
                        }
                        Rectangle {
                            x: parent.width - 84px;
                            y: 17px;
                            width: 34px;
                            height: 34px;
                            background: edit-touch.has-hover ? AppTheme.accent.with-alpha(0.12) : transparent;
                            border-radius: 6px;
                            Image {
                                x: 9px;
                                y: 9px;
                                width: 16px;
                                height: 16px;
                                source: @image-url("../../assets/icons/edit.svg");
                                colorize: AppTheme.accent;
                            }
                            edit-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => {
                                    AppState.begin-edit-custom-prompt(item.content);
                                }
                            }
                        }
                        Rectangle {
                            x: parent.width - 42px;
                            y: 17px;
                            width: 34px;
                            height: 34px;
                            background: delete-touch.has-hover ? AppTheme.danger.with-alpha(0.12) : transparent;
                            border-radius: 6px;
                            Image {
                                x: 9px;
                                y: 9px;
                                width: 16px;
                                height: 16px;
                                source: @image-url("../../assets/icons/trash.svg");
                                colorize: AppTheme.danger;
                            }
                            delete-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => {
                                    AppState.pending-delete-kind = "custom-prompt";
                                    AppState.pending-delete-id = item.content;
                                    AppState.pending-delete-source = "";
                                    AppState.delete-confirm-open = true;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    function category-label(category: string) -> string {
        if category == "character" { return AppState.en ? "Character" : "角色"; }
        if category == "scene" { return AppState.en ? "Scene" : "场景"; }
        if category == "ui" { return "UI"; }
        if category == "effect" { return AppState.en ? "Effect" : "特效"; }
        return AppState.en ? "Default" : "默认";
    }
}
