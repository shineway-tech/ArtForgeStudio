import { ScrollView } from "std-widgets.slint";
import { AppState } from "../app-state.slint";
import { PillButton } from "pill-button.slint";
import { AppTheme } from "../theme.slint";

export component CustomPromptSettings {
    Rectangle {
        background: transparent;
        Text {
            x: 0px;
            y: 0px;
            width: parent.width - 128px;
            height: 36px;
            text: (AppState.en ? "Saved prompts " : "已保存提示词 ") + AppState.custom-prompts.length;
            color: AppTheme.text;
            font-size: 14px;
            font-weight: 500;
            vertical-alignment: center;
        }
        PillButton {
            x: parent.width - 104px;
            y: 0px;
            width: 104px;
            height: 36px;
            text: AppState.en ? "Add" : "新增";
            primary: true;
            clicked => {
                AppState.custom-prompt-input = "";
                AppState.custom-prompt-message = "";
                AppState.custom-prompt-editing-original = "";
                AppState.custom-prompt-editor-open = true;
            }
        }
        Rectangle {
            x: 0px;
            y: 48px;
            width: parent.width;
            height: parent.height - 48px;
            background: AppTheme.panel;
            border-radius: 12px;
            border-width: 1px;
            border-color: AppTheme.border;
            clip: true;
            if AppState.custom-prompt-items.length == 0: Text {
                x: 20px;
                width: parent.width - 40px;
                height: parent.height;
                text: AppState.en ? "No custom prompts" : "暂无自定义提示词";
                color: AppTheme.muted;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            if AppState.custom-prompt-items.length > 0: ScrollView {
                x: 8px;
                y: 8px;
                width: parent.width - 16px;
                height: parent.height - 16px;
                viewport-width: self.width;
                viewport-height: max(self.height, AppState.custom-prompt-items.length * 78px);
                VerticalLayout {
                    width: parent.viewport-width;
                    height: parent.viewport-height;
                    spacing: 6px;
                    for item in AppState.custom-prompt-items: Rectangle {
                        height: 72px;
                        background: row-touch.has-hover ? AppTheme.panel-soft : transparent;
                        border-radius: 8px;
                        Text {
                            x: 12px;
                            y: 10px;
                            width: parent.width - 104px;
                            height: 24px;
                            text: item.content;
                            color: AppTheme.text;
                            font-size: 13px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        Text {
                            x: 12px;
                            y: 38px;
                            width: parent.width - 104px;
                            height: 20px;
                            text: item.time;
                            color: AppTheme.muted;
                            font-size: 12px;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                        row-touch := TouchArea {
                            width: parent.width - 92px;
                            height: parent.height;
                        }
                        Rectangle {
                            x: parent.width - 84px;
                            y: 19px;
                            width: 34px;
                            height: 34px;
                            background: edit-touch.has-hover ? AppTheme.accent.with-alpha(0.12) : transparent;
                            border-radius: 6px;
                            Image {
                                x: 9px;
                                y: 9px;
                                width: 16px;
                                height: 16px;
                                source: @image-url("../../assets/icons/edit.svg");
                                colorize: AppTheme.accent;
                            }
                            edit-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => {
                                    AppState.custom-prompt-input = item.content;
                                    AppState.custom-prompt-editing-original = item.content;
                                    AppState.custom-prompt-message = "";
                                    AppState.custom-prompt-editor-open = true;
                                }
                            }
                        }
                        Rectangle {
                            x: parent.width - 42px;
                            y: 19px;
                            width: 34px;
                            height: 34px;
                            background: delete-touch.has-hover ? AppTheme.danger.with-alpha(0.12) : transparent;
                            border-radius: 6px;
                            Image {
                                x: 9px;
                                y: 9px;
                                width: 16px;
                                height: 16px;
                                source: @image-url("../../assets/icons/trash.svg");
                                colorize: AppTheme.danger;
                            }
                            delete-touch := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                mouse-cursor: pointer;
                                clicked => { AppState.remove-custom-prompt(item.content); }
                            }
                        }
                    }
                }
            }
        }
    }
}
