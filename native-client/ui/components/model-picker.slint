import { ScrollView } from "std-widgets.slint";
import { AppState } from "../app-state.slint";
import { DropdownIcon } from "dropdown-icon.slint";
import { IconButton } from "icon-button.slint";
import { AppTheme } from "../theme.slint";

export component ModelPicker {
    in property <string> kind;
    in property <string> label;
    in property <length> picker-width: 320px;
    callback select-model(string);
    property <bool> open: false;
    width: root.picker-width;
    height: 46px;
    Rectangle {
        background: AppTheme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: open ? AppTheme.accent : AppTheme.border;
        Text {
            x: 14px;
            width: 62px;
            height: parent.height;
            text: root.label;
            color: AppTheme.muted;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        Rectangle { x: 82px; y: (parent.height - 8px) / 2; width: 8px; height: 8px; border-radius: 4px; background: AppTheme.accent; }
        Text {
            x: 100px;
            width: parent.width - 134px;
            height: parent.height;
            text: display-text();
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: 50px;
        width: root.width;
        height: root.popup-height();
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: max(self.height, 12px + root.option-count() * 42px);
                VerticalLayout {
                    width: parent.viewport-width;
                    height: parent.viewport-height;
                    padding: 6px;
                    spacing: 4px;
                    if root.option-count() == 0: IconButton {
                        width: root.width - 12px;
                        text: AppState.en ? "Add a model first" : "请先添加模型";
                        clicked => { root.open = false; popup.close(); AppState.navigate("models"); }
                    }
                    if root.kind == "image": VerticalLayout {
                        spacing: 4px;
                        for model in AppState.model-image-options: IconButton {
                            width: root.width - 12px;
                            text: model.name;
                            active: AppState.image-model == model.code;
                            clicked => {
                                root.select-model(model.code);
                                root.open = false;
                                popup.close();
                            }
                        }
                    }
                    if root.kind == "reasoning": VerticalLayout {
                        spacing: 4px;
                        for model in AppState.model-reasoning-options: IconButton {
                            width: root.width - 12px;
                            text: model.name;
                            active: AppState.reasoning-model == model.code;
                            clicked => {
                                root.select-model(model.code);
                                root.open = false;
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
    function option-count() -> int {
        return root.kind == "image" ? AppState.model-image-options.length : AppState.model-reasoning-options.length;
    }
    function popup-height() -> length {
        return min(320px, max(54px, 12px + root.option-count() * 42px));
    }
    function display-text() -> string {
        if root.kind == "image" {
            return AppState.image-model == "" ? (AppState.en ? "Not selected" : "未选择") : AppState.image-model-name;
        }
        return AppState.reasoning-model == "" ? (AppState.en ? "Not selected" : "未选择") : AppState.reasoning-model-name;
    }
}
