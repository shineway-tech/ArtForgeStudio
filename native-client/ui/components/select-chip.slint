import { AppState } from "../app-state.slint";
import { CountOption } from "count-option.slint";
import { DropdownIcon } from "dropdown-icon.slint";
import { TypeOption } from "type-option.slint";
import { AppTheme } from "../theme.slint";

export component SelectChip {
    in property <string> kind;
    property <bool> open: false;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: open ? AppTheme.accent : AppTheme.border;
        Text { x: 16px; width: parent.width - 46px; height: parent.height; text: label(); color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: -options-height() - 6px;
        width: options-width();
        height: options-height();
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 6px;
                spacing: 4px;
                if root.kind == "type": TypeOption { id: "character"; label: AppState.en ? "Character" : "角色"; close => { root.open = false; popup.close(); } }
                if root.kind == "type": TypeOption { id: "scene"; label: AppState.en ? "Scene" : "场景"; close => { root.open = false; popup.close(); } }
                if root.kind == "type": TypeOption { id: "ui"; label: "UI"; close => { root.open = false; popup.close(); } }
                if root.kind == "type": TypeOption { id: "effect"; label: AppState.en ? "Effect" : "特效"; close => { root.open = false; popup.close(); } }
                if root.kind == "count": CountOption { count: 1; close => { root.open = false; popup.close(); } }
                if root.kind == "count": CountOption { count: 2; close => { root.open = false; popup.close(); } }
                if root.kind == "count": CountOption { count: 4; close => { root.open = false; popup.close(); } }
            }
        }
    }
    function label() -> string {
        if root.kind == "count" { return "\{AppState.count}" + (AppState.en ? " img" : " 张"); }
        if AppState.asset-type == "character" { return AppState.en ? "Character" : "角色"; }
        if AppState.asset-type == "scene" { return AppState.en ? "Scene" : "场景"; }
        if AppState.asset-type == "ui" { return "UI"; }
        if AppState.asset-type == "effect" { return AppState.en ? "Effect" : "特效"; }
        if AppState.asset-type == "action-sequence" { return AppState.en ? "Action Sequence" : "动作序列"; }
        return AppState.en ? "Character" : "角色";
    }
    function options-height() -> length {
        return root.kind == "count" ? 138px : 218px;
    }
    function options-width() -> length {
        return root.kind == "count" ? 118px : 152px;
    }
}
