import { AppState } from "../app-state.slint";
import { NavGlyph } from "nav-glyph.slint";
import { AppTheme } from "../theme.slint";

export component NavItem {
    in property <string> icon;
    in property <string> label;
    in property <string> page;
    in property <bool> show-dot: false;
    width: 176px;
    height: 38px;
    Rectangle {
        background: AppState.page == root.page ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 7px;
        border-width: AppState.page == root.page ? 1px : 0px;
        border-color: AppTheme.accent;
        Rectangle {
            x: 9px;
            y: 8px;
            width: 22px;
            height: 22px;
            border-radius: 6px;
            background: AppTheme.panel-soft;
            NavGlyph {
                kind: root.icon;
                glyph-color: AppTheme.accent-dark;
                width: parent.width;
                height: parent.height;
            }
        }
        Text {
            x: 42px;
            width: parent.width - 52px;
            height: parent.height;
            text: root.label;
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
        }
        if root.show-dot: Rectangle {
            x: parent.width - 18px;
            y: 7px;
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: AppTheme.danger;
        }
        touch := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.navigate(root.page); } }
    }
}
