import { AppState } from "../app-state.slint";
import { AppTheme } from "../theme.slint";

export component StudioToolCard {
    in property <string> title;
    in property <string> subtitle;
    in property <string> page;
    in property <string> mode: "";
    height: 124px;
    Rectangle {
        width: root.width;
        height: root.height;
        background: touch.has-hover ? AppTheme.panel-soft : AppTheme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: touch.has-hover ? AppTheme.accent : AppTheme.border;
        Text { x: 18px; y: 18px; width: parent.width - 62px; text: root.title; color: AppTheme.text; font-size: 16px; font-weight: 500; overflow: elide; }
        Text { x: 18px; y: 48px; width: parent.width - 36px; text: root.subtitle; color: AppTheme.muted; font-size: 12px; font-weight: 400; wrap: word-wrap; }
        Text { x: parent.width - 36px; y: 16px; width: 18px; height: 24px; text: "→"; color: AppTheme.accent-dark; font-size: 18px; font-weight: 400; horizontal-alignment: center; vertical-alignment: center; }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.mode = root.mode == "" ? AppState.mode : root.mode;
                AppState.navigate(root.page);
            }
        }
    }
}
