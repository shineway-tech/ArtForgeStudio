import { AppState } from "../app-state.slint";
import { AppTheme } from "../theme.slint";

export component CategoryWorkspaceOption {
    in property <string> category;
    in property <string> label;
    callback picked();
    width: 176px;
    height: 32px;
    Rectangle {
        x: 8px;
        width: parent.width - 8px;
        height: parent.height;
        background: AppState.page == "generation" && AppState.asset-type == root.category ? AppTheme.panel-soft : (touch.has-hover ? AppTheme.panel-soft : transparent);
        border-radius: 7px;
        border-width: AppState.page == "generation" && AppState.asset-type == root.category ? 1px : 0px;
        border-color: AppTheme.accent;
        Rectangle {
            x: 14px;
            y: (parent.height - 16px) / 2;
            width: 16px;
            height: 16px;
            border-radius: 8px;
            border-width: 1px;
            border-color: AppState.asset-type == root.category ? AppTheme.accent : AppTheme.weak;
            background: transparent;
            if AppState.asset-type == root.category: Rectangle {
                x: 4px;
                y: 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: AppTheme.accent;
            }
        }
        Text {
            x: 42px;
            width: parent.width - 52px;
            height: parent.height;
            text: root.label;
            color: AppTheme.text;
            font-size: AppState.settings-font-size * 1px;
            font-weight: 400;
            vertical-alignment: center;
            overflow: elide;
        }
        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: pointer;
            clicked => {
                AppState.select-workspace-category(root.category);
                root.picked();
                AppState.navigate("generation");
            }
        }
    }
}
