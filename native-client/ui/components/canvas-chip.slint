import { AppState } from "../app-state.slint";
import { DropdownIcon } from "dropdown-icon.slint";
import { PillButton } from "pill-button.slint";
import { QualityButton } from "quality-button.slint";
import { RatioButton } from "ratio-button.slint";
import { AppTheme } from "../theme.slint";

export component CanvasChip {
    property <bool> open: false;
    height: 36px;
    Rectangle {
        background: AppTheme.panel-soft;
        border-radius: 18px;
        border-width: 1px;
        border-color: open ? AppTheme.accent : AppTheme.border;
        Text { x: 16px; width: parent.width - 46px; height: parent.height; text: AppState.ratio + " · " + AppState.quality; color: AppTheme.text; font-size: AppState.settings-font-size * 1px; font-weight: 400; vertical-alignment: center; overflow: elide; }
        DropdownIcon { x: parent.width - 32px; y: (parent.height - 12px) / 2; }
        TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { root.open = true; popup.show(); } }
    }
    popup := PopupWindow {
        x: 0px;
        y: -342px;
        width: 596px;
        height: 338px;
        close-policy: close-on-click-outside;
        Rectangle {
            visible: root.open;
            background: AppTheme.panel;
            border-radius: 12px;
            border-width: 1px;
            border-color: AppTheme.accent;
            VerticalLayout {
                padding: 14px;
                spacing: 14px;
                Text { text: AppState.en ? "Canvas" : "画布"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                GridLayout {
                    spacing: 12px;
                    Row {
                        RatioButton { width: 80px; id: "1:1"; label: "1:1"; }
                        RatioButton { width: 80px; id: "3:2"; label: "3:2"; }
                        RatioButton { width: 80px; id: "2:3"; label: "2:3"; }
                        RatioButton { width: 80px; id: "4:3"; label: "4:3"; }
                        RatioButton { width: 80px; id: "3:4"; label: "3:4"; }
                        RatioButton { width: 80px; id: "5:4"; label: "5:4"; }
                    }
                    Row {
                        RatioButton { width: 80px; id: "4:5"; label: "4:5"; }
                        RatioButton { width: 80px; id: "16:9"; label: "16:9"; }
                        RatioButton { width: 80px; id: "9:16"; label: "9:16"; }
                        RatioButton { width: 80px; id: "2:1"; label: "2:1"; }
                        RatioButton { width: 80px; id: "1:2"; label: "1:2"; }
                        RatioButton { width: 80px; id: "21:9"; label: "21:9"; }
                    }
                    Row {
                        RatioButton { width: 80px; id: "9:21"; label: "9:21"; }
                        PillButton { width: 80px; height: 40px; text: AppState.en ? "Close" : "收起"; clicked => { root.open = false; popup.close(); } }
                    }
                }
                Text { text: AppState.en ? "Resolution" : "选择分辨率"; color: AppTheme.muted; font-size: 13px; font-weight: 400; }
                HorizontalLayout {
                    spacing: 12px;
                    QualityButton { label: "1K"; }
                    QualityButton { label: AppState.en ? "HD 2K" : "高清 2K"; value: "2K"; }
                    QualityButton { label: AppState.en ? "Ultra 4K" : "超清 4K"; value: "4K"; }
                }
            }
        }
    }
}
