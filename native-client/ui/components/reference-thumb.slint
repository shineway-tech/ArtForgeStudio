import { AppState } from "../app-state.slint";
import { AppTheme } from "../theme.slint";
import { ReferenceItem } from "../types.slint";

export component ReferenceThumb {
    in property <ReferenceItem> item;
    width: 60px;
    height: 70px;
    Rectangle {
        background: transparent;
        clip: false;
        Image { x: 4px; y: 8px; width: 48px; height: 58px; source: root.item.image; image-fit: contain; }
        TouchArea { x: 0px; y: 8px; width: 52px; height: 58px; mouse-cursor: pointer; clicked => { AppState.open-reference(root.item.id); } }
        Rectangle {
            x: 38px; y: 0px; width: 20px; height: 20px; border-radius: 10px; background: AppTheme.danger;
            Text { width: parent.width; height: parent.height; text: "x"; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; font-size: 12px; }
            TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; clicked => { AppState.remove-reference(root.item.id); } }
        }
    }
}
