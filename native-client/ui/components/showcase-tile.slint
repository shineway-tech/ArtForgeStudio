export component ShowcaseTile inherits Rectangle {
    in property <image> source;
    in property <string> title;
    in property <string> subtitle;
    border-radius: 20px;
    clip: true;
    background: #1d1d1f;
    Image {
        x: hover.has-hover ? -12px : 0px;
        y: hover.has-hover ? -12px : 0px;
        width: parent.width + (hover.has-hover ? 24px : 0px);
        height: parent.height + (hover.has-hover ? 24px : 0px);
        source: root.source;
        image-fit: cover;
        animate x, y, width, height { duration: 180ms; }
    }
    Rectangle { y: parent.height - 92px; height: 92px; background: @linear-gradient(0deg, #000000b8, #00000000); }
    Text { x: 20px; y: parent.height - 62px; text: root.title; color: #ffffff; font-size: 24px; font-weight: 600; }
    Text { x: 20px; y: parent.height - 32px; text: root.subtitle; color: #ffffffe0; font-size: 16px; font-weight: 400; }
    hover := TouchArea { width: parent.width; height: parent.height; mouse-cursor: pointer; }
}
