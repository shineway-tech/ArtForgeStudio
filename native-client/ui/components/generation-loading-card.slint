import { AppState } from "../app-state.slint";
import { LoadingDots } from "loading-dots.slint";
import { AppTheme } from "../theme.slint";

export component GenerationLoadingCard {
    in property <length> card-width: 188px;
    in property <length> card-gap: 10px;
    width: root.card-width;
    height: root.card-width + root.card-gap;
    Rectangle {
        width: root.width;
        height: root.card-width;
        background: AppTheme.panel-soft;
        border-radius: 12px;
        border-width: 1px;
        border-color: AppTheme.border;
        LoadingDots {
            x: (parent.width - 64px) / 2;
            y: parent.height / 2 - 48px;
            width: 64px;
            height: 46px;
        }
        Text {
            x: 0px;
            y: parent.height / 2 + 6px;
            width: parent.width;
            height: 24px;
            text: AppState.en ? "Generating..." : "生成中...";
            color: AppTheme.accent-dark;
            font-size: 13px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        stop-button := Rectangle {
            x: parent.width - 38px;
            y: 10px;
            width: 28px;
            height: 28px;
            background: stop-touch.has-hover ? AppTheme.danger : AppTheme.panel.with-alpha(0.94);
            border-radius: 14px;
            border-width: 1px;
            border-color: AppTheme.danger.with-alpha(0.62);
            accessible-role: button;
            accessible-label: AppState.en ? "Stop generation" : "停止生成";

            Rectangle {
                x: (parent.width - 8px) / 2;
                y: (parent.height - 8px) / 2;
                width: 8px;
                height: 8px;
                border-radius: 2px;
                background: stop-touch.has-hover ? #ffffff : AppTheme.danger;
            }
            stop-touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                clicked => { AppState.stop-generation(); }
            }
        }
    }
}
