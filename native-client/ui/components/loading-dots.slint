import { AppTheme } from "../theme.slint";

export component LoadingDots {
    in-out property <int> step: 0;
    width: 42px;
    height: 42px;
    Timer {
        interval: 420ms;
        running: true;
        triggered => { root.step = Math.mod(root.step + 1, 3); }
    }
    Text {
        width: parent.width;
        height: parent.height;
        text: root.step == 0 ? "." : (root.step == 1 ? ".." : "...");
        color: AppTheme.accent;
        font-size: 18px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
