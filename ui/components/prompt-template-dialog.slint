import { Theme } from "../theme.slint";
import { AppState } from "../app-state.slint";
import { ToolButton } from "tool-button.slint";
import { RefImageChip } from "ref-image-chip.slint";
import { DialogField } from "dialog-field.slint";
import { CategoryField } from "category-field.slint";
import { DialogTextArea } from "dialog-text-area.slint";
import { FormatOption } from "format-option.slint";

export component PromptTemplateDialog {
    width: 100%;
    height: 100%;

    if AppState.prompt-template-dialog-open: Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000088;

        TouchArea {
            clicked => { AppState.prompt-template-show-categories = false; }
        }

        Rectangle {
            width: min(960px, max(680px, parent.width - 60px));
            height: min(680px, max(560px, parent.height - 60px));
            x: parent.width / 2 - self.width / 2;
            y: parent.height / 2 - self.height / 2;
            background: Theme.palette.bg-elevated;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.palette.border;
            clip: true;

            VerticalLayout {
                padding: 18px;
                spacing: 10px;

                HorizontalLayout {
                    height: 28px;
                    alignment: space-between;

                    Text {
                        text: AppState.prompt-template-title;
                        color: Theme.palette.fg;
                        font-family: Theme.typo.family;
                        font-size: Theme.typo.size-md;
                        font-weight: Theme.typo.weight-bold;
                        vertical-alignment: center;
                    }

                    ToolButton {
                        text: "关闭";
                        clicked => {
                            AppState.prompt-template-show-categories = false;
                            AppState.close-prompt-template-dialog();
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;

                    // 左栏：元数据 + 模式入口
                    Rectangle {
                        width: 320px;
                        horizontal-stretch: 0;
                        background: Theme.palette.bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.palette.border;
                        clip: true;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;

                            HorizontalLayout {
                                height: 30px;
                                spacing: 8px;
                                alignment: start;

                                ToolButton {
                                    text: "手写提示词";
                                    accent: AppState.prompt-template-mode == "manual";
                                    clicked => {
                                        AppState.prompt-template-mode = "manual";
                                    }
                                }

                                ToolButton {
                                    text: "反推参考图";
                                    accent: AppState.prompt-template-mode == "reverse";
                                    clicked => {
                                        AppState.prompt-template-mode = "reverse";
                                    }
                                }
                            }

                            DialogField {
                                label: "提示词名称";
                                placeholder: "例如：暗黑风格V5";
                                value <=> AppState.prompt-template-name;
                            }

                            CategoryField {}

                            HorizontalLayout {
                                height: 36px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "保存格式";
                                    color: Theme.palette.fg;
                                    font-family: Theme.typo.family;
                                    font-size: Theme.typo.size-xs;
                                    vertical-alignment: center;
                                }

                                FormatOption { id: "json"; label: "json"; }
                                FormatOption { id: "txt"; label: "txt"; }
                            }

                            // 反推模式专属：上传 + 分析
                            if AppState.prompt-template-mode == "reverse": VerticalLayout {
                                vertical-stretch: 1;
                                spacing: 8px;

                                HorizontalLayout {
                                    height: 36px;
                                    spacing: 8px;
                                    alignment: start;

                                    ToolButton {
                                        text: "上传风格参考图";
                                        clicked => {
                                            AppState.prompt-template-show-categories = false;
                                            AppState.add-reference-images();
                                        }
                                    }

                                    ToolButton {
                                        text: "分析图片生成风格";
                                        accent: true;
                                        clicked => {
                                            AppState.prompt-template-show-categories = false;
                                            AppState.analyze-prompt-template-images();
                                        }
                                    }
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                    background: Theme.palette.bg-elevated;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: Theme.palette.border;
                                    clip: true;

                                    if AppState.ws-ref-images.length == 0: Text {
                                        x: 12px;
                                        width: parent.width - 24px;
                                        height: parent.height;
                                        text: "上传参考图后点击\"分析图片生成风格\"，结果会填入右侧提示词内容";
                                        color: Theme.palette.fg-disabled;
                                        font-family: Theme.typo.family;
                                        font-size: Theme.typo.size-xs;
                                        vertical-alignment: center;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }

                                    if AppState.ws-ref-images.length > 0: Flickable {
                                        x: 8px;
                                        y: 8px;
                                        width: parent.width - 16px;
                                        height: parent.height - 16px;

                                        HorizontalLayout {
                                            spacing: 6px;
                                            alignment: start;

                                            for img[i] in AppState.ws-ref-images: RefImageChip {
                                                data: img;
                                                index: i;
                                            }
                                        }
                                    }
                                }

                                Text {
                                    text: "共 " + AppState.ws-ref-images.length + " 张参考图";
                                    color: Theme.palette.fg-muted;
                                    font-family: Theme.typo.family;
                                    font-size: Theme.typo.size-xs;
                                }
                            }

                            // 手写模式占位
                            if AppState.prompt-template-mode == "manual": Rectangle {
                                vertical-stretch: 1;
                                background: transparent;
                            }
                        }
                    }

                    // 右栏：提示词内容（可编辑）
                    Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.palette.bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.palette.border;
                        clip: true;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;

                            DialogTextArea {
                                label: AppState.prompt-template-mode == "reverse" ? "提示词内容（分析结果，可编辑）" : "提示词内容";
                                placeholder: AppState.prompt-template-mode == "reverse"
                                    ? "点击左侧\"分析图片生成风格\"自动填充..."
                                    : "输入提示词内容...";
                                value <=> AppState.prompt-template-content;
                                vertical-stretch: 1;
                            }

                            DialogTextArea {
                                height: 70px;
                                label: "反向提示词（仅 JSON 格式有效）";
                                placeholder: "可选：反向提示词";
                                disabled: AppState.prompt-template-format != "json";
                                value <=> AppState.prompt-template-negative;
                            }
                        }
                    }
                }

                if AppState.prompt-template-error != "": Rectangle {
                    height: 30px;
                    background: #ff4d4f22;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.palette.error;

                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text: AppState.prompt-template-error;
                        color: Theme.palette.error;
                        font-family: Theme.typo.family;
                        font-size: Theme.typo.size-xs;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                HorizontalLayout {
                    height: 52px;
                    spacing: 8px;
                    alignment: end;

                    ToolButton {
                        text: "Cancel";
                        clicked => {
                            AppState.prompt-template-show-categories = false;
                            AppState.close-prompt-template-dialog();
                        }
                    }

                    ToolButton {
                        text: "Save";
                        accent: true;
                        clicked => {
                            AppState.prompt-template-show-categories = false;
                            AppState.submit-prompt-template();
                        }
                    }
                }
            }
        }
    }
}
