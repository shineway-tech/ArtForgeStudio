import { Theme } from "../theme.slint";

export component GenerateButton {
    in property <bool> disabled: false;
    in property <bool> running: false;
    property <int> phase: 0;
    callback clicked();

    height: 54px;

    Rectangle {
        background: root.disabled
            ? Theme.palette.bg-hover
            : (touch.has-hover ? Theme.palette.accent-hover : Theme.palette.accent);
        border-radius: 12px;
        border-width: 0px;
        animate background { duration: 120ms; }

        // 底层：非执行中的"开始生成"
        Text {
            x: (parent.width - self.preferred-width) / 2;
            y: 0px;
            width: self.preferred-width;
            height: parent.height;
            text: "开始生成";
            color: root.disabled ? Theme.palette.fg-disabled : #ffffff;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-md;
            font-weight: Theme.typo.weight-bold;
            vertical-alignment: center;
            visible: !(root.running && !root.disabled);
        }

        // 执行中：居中"生成中" + 右侧三个轮流点亮的点
        if root.running && !root.disabled: HorizontalLayout {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            spacing: 3px;
            alignment: center;

            Text {
                text: "生成中";
                color: #ffffff;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-md;
                font-weight: Theme.typo.weight-bold;
                vertical-alignment: center;
            }

            Rectangle {
                width: 4px;
                height: 4px;
                y: parent.height / 2 - 2px;    
                border-radius: 2px;
                background: #ffffff;
                opacity: mod(root.phase, 3) == 0 ? 1.0 : 0.2;
                animate opacity { duration: 50ms; }
            }
            Rectangle {
                width: 4px;
                height: 4px;
                y: parent.height / 2 - 2px;    
                border-radius: 2px;
                background: #ffffff;
                opacity: mod(root.phase, 3) == 1 ? 1.0 : 0.2;
                animate opacity { duration: 50ms; }
            }
            Rectangle {
                width: 4px;
                height: 4px;
                y: parent.height / 2 - 2px;    
                border-radius: 2px;
                background: #ffffff;
                opacity: mod(root.phase, 3) == 2 ? 1.0 : 0.2;
                animate opacity { duration: 50ms; }
            }
        }

        phase-timer := Timer {
            interval: 150ms;
            running: root.running && !root.disabled;
            triggered => {
                root.phase = root.phase + 1;
                self.restart();
            }
        }

        touch := TouchArea {
            enabled: !root.disabled;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => { root.clicked(); }
        }
    }
}
