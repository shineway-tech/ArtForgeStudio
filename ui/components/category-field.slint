import { Theme } from "../theme.slint";
import { AppState } from "../app-state.slint";

export component CategoryField {
    height: AppState.prompt-template-show-categories
        ? min(172px, 58px + 4px + max(30px, AppState.ws-template-groups.length * 28px))
        : 58px;

    VerticalLayout {
        spacing: 5px;

        Text {
            height: 14px;
            text: "分类";
            color: Theme.palette.fg;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-xs;
        }

        Rectangle {
            height: 39px;
            background: Theme.palette.bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: input.has-focus || AppState.prompt-template-show-categories
                ? Theme.palette.accent
                : Theme.palette.border;
            animate border-color { duration: 120ms; }

            input := TextInput {
                x: 12px;
                width: parent.width - 52px;
                height: parent.height;
                color: Theme.palette.fg;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-sm;
                vertical-alignment: center;
                single-line: true;
                text <=> AppState.prompt-template-category;
            }

            if AppState.prompt-template-category == "" && !input.has-focus: Text {
                x: 12px;
                width: parent.width - 52px;
                height: parent.height;
                text: "例如：场景 / 角色 / 写实";
                color: Theme.palette.fg-disabled;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-sm;
                vertical-alignment: center;
            }

            Rectangle {
                x: parent.width - 38px;
                y: 5px;
                width: 30px;
                height: parent.height - 10px;
                background: category-toggle.has-hover ? Theme.palette.bg-hover : Theme.palette.bg-elevated;
                border-radius: 7px;
                border-width: 1px;
                border-color: AppState.prompt-template-show-categories ? Theme.palette.accent : Theme.palette.border;

                Image {
                    width: 12px;
                    height: 12px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("../assets/icons/square.svg");
                    colorize: Theme.palette.fg-disabled;
                }

                category-toggle := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        AppState.refresh-template-list();
                        AppState.prompt-template-show-categories = !AppState.prompt-template-show-categories;
                    }
                }
            }
        }

        if AppState.prompt-template-show-categories: Rectangle {
            height: min(110px, max(30px, AppState.ws-template-groups.length * 28px));
            background: Theme.palette.bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.palette.accent;
            clip: true;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                for group[i] in AppState.ws-template-groups: Rectangle {
                    height: 24px;
                    background: AppState.prompt-template-category == group.name || category-item.has-hover
                        ? Theme.palette.bg-hover
                        : transparent;
                    border-radius: 4px;

                    Text {
                        x: 8px;
                        width: parent.width - 16px;
                        height: parent.height;
                        text: group.name;
                        color: AppState.prompt-template-category == group.name
                            ? Theme.palette.accent-hover
                            : Theme.palette.fg;
                        font-family: Theme.typo.family;
                        font-size: Theme.typo.size-xs;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    category-item := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            AppState.prompt-template-category = group.name;
                            AppState.prompt-template-show-categories = false;
                        }
                    }
                }
            }
        }
    }
}
