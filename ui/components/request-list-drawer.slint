import { Theme } from "../theme.slint";
import { AppState, TaskItem } from "../app-state.slint";
import { PromptActionButton } from "prompt-action-button.slint";

component RequestFilterChip {
    in property <string> label;
    in property <int> count;
    in property <bool> active;
    callback clicked();

    height: 26px;
    min-width: 58px;
    horizontal-stretch: 1;

    Rectangle {
        background: root.active ? Theme.palette.accent : (touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg);
        border-radius: 7px;
        border-width: 1px;
        border-color: root.active ? Theme.palette.accent : Theme.palette.border;

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            spacing: 3px;
            alignment: center;

            Text {
                text: root.label;
                color: root.active ? #ffffff : Theme.palette.fg-muted;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                vertical-alignment: center;
            }

            Text {
                text: root.count + "";
                color: root.active ? #ffffffcc : Theme.palette.fg-disabled;
                font-family: Theme.typo.family-mono;
                font-size: Theme.typo.size-xs;
                vertical-alignment: center;
            }
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component RequestRow {
    in property <TaskItem> data;

    height: 92px;

    Rectangle {
        background: Theme.palette.bg;
        border-radius: 10px;
        border-width: 1px;
        border-color: status-color();
        clip: true;

        function status-color() -> color {
            if (root.data.status == "failed") { return Theme.palette.error; }
            if (root.data.status == "cancelled") { return Theme.palette.warning; }
            if (root.data.status == "completed") { return Theme.palette.success; }
            if (root.data.status == "running" || root.data.status == "validating" || root.data.status == "polling" || root.data.status == "saving") { return Theme.palette.accent; }
            return Theme.palette.border;
        }

        function status-label() -> string {
            if (root.data.status == "completed") { return "完成"; }
            if (root.data.status == "failed") { return "失败"; }
            if (root.data.status == "cancelled") { return "取消"; }
            if (root.data.status == "validating") { return "准备"; }
            if (root.data.status == "polling") { return "等待"; }
            if (root.data.status == "saving") { return "保存"; }
            if (root.data.status == "running") { return "进行"; }
            return root.data.status;
        }

        function model-prefix() -> string {
            if (root.data.kind == "prompt_opt" || root.data.kind == "analysis") { return "推理模型 · "; }
            return "model · ";
        }

        function detail-line() -> string {
            if (root.data.kind == "prompt_opt") {
                return root.data.prompt != "" ? root.data.prompt : root.data.created-at;
            }
            return root.data.output-path != "" ? root.data.output-path : root.data.created-at;
        }

        HorizontalLayout {
            padding: 8px;
            spacing: 8px;

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 3px;

                HorizontalLayout {
                    height: 18px;
                    spacing: 6px;

                    Rectangle {
                        width: 36px;
                        height: 18px;
                        background: status-color();
                        border-radius: 9px;

                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: status-label();
                            color: #ffffff;
                            font-family: Theme.typo.family;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: root.data.kind == "prompt_opt" ? "优化 · " + root.data.label : root.data.label;
                        color: Theme.palette.fg;
                        font-family: Theme.typo.family;
                        font-size: Theme.typo.size-xs;
                        font-weight: Theme.typo.weight-bold;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Text {
                    text: root.data.status == "completed"
                        ? "完成于 " + root.data.finished-at
                        : (root.data.error != "" ? root.data.error : root.data.last-log);
                    color: root.data.error != "" ? Theme.palette.error : Theme.palette.fg-muted;
                    font-family: Theme.typo.family;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    text: root.data.model != "" ? model-prefix() + root.data.model : model-prefix() + "-";
                    color: Theme.palette.fg-muted;
                    font-family: Theme.typo.family-mono;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    text: detail-line();
                    color: Theme.palette.fg-disabled;
                    font-family: Theme.typo.family;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle {
                width: 18px;
                height: 18px;
                background: close-touch.has-hover ? Theme.palette.bg-hover : transparent;
                border-radius: 9px;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "×";
                    color: close-touch.has-hover ? Theme.palette.error : Theme.palette.fg-disabled;
                    font-family: Theme.typo.family;
                    font-size: Theme.typo.size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                close-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { AppState.remove-task(root.data.id); }
                }
            }
        }
    }
}

export component RequestListDrawer {
    in property <string> mode;
    width: 318px;
    height: 100%;
    visible: AppState.request-list-open;

    property <string> filter: "all";
    function matches-page(t: TaskItem) -> bool {
        if (root.mode == "") { return true; }
        if (root.mode == "prompt_opt") { return t.kind == "prompt_opt" || t.mode == "prompt_opt"; }
        return t.mode == root.mode;
    }

    function matches-filter(t: TaskItem) -> bool {
        if (!matches-page(t)) { return false; }
        if (root.filter == "all") { return true; }
        if (root.filter == "running") { return t.status == "running" || t.status == "validating" || t.status == "uploading" || t.status == "submitted" || t.status == "polling" || t.status == "saving"; }
        if (root.filter == "completed") { return t.status == "completed"; }
        if (root.filter == "failed") { return t.status == "failed" || t.status == "cancelled"; }
        return true;
    }

    function total-count() -> int {
        return AppState.request-list-count-total;
    }

    function running-count() -> int {
        return AppState.request-list-count-running;
    }

    function completed-count() -> int {
        return AppState.request-list-count-completed;
    }

    function failed-count() -> int {
        return AppState.request-list-count-failed;
    }

    Rectangle {
        width: root.width;
        height: root.height;
        background: Theme.palette.bg-elevated;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.palette.border;
        drop-shadow-blur: 18px;
        drop-shadow-color: #00000055;

        VerticalLayout {
            padding: 12px;
            spacing: 10px;

            HorizontalLayout {
                height: 28px;
                spacing: 8px;

                Text {
                    text: "请求列表";
                    color: Theme.palette.fg;
                    font-family: Theme.typo.family;
                    font-size: Theme.typo.size-sm;
                    font-weight: Theme.typo.weight-bold;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: "共 " + root.total-count();
                    color: Theme.palette.fg-muted;
                    font-family: Theme.typo.family;
                    font-size: Theme.typo.size-xs;
                    vertical-alignment: center;
                }

                PromptActionButton {
                    text: "关闭";
                    width: 72px;
                    height: 26px;
                    clicked => { AppState.request-list-open = false; }
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 6px;

                PromptActionButton {
                    text: "清空全部";
                    clicked => { AppState.clear-tasks("all"); }
                }

                PromptActionButton {
                    text: "清空完成";
                    clicked => { AppState.clear-tasks("completed"); }
                }

                PromptActionButton {
                    text: "清空失败";
                    clicked => { AppState.clear-tasks("failed"); }
                }
            }

            HorizontalLayout {
                height: 28px;
                spacing: 6px;

                RequestFilterChip { label: "全部"; count: root.total-count(); active: root.filter == "all"; clicked => { root.filter = "all"; } }
                RequestFilterChip { label: "进行中"; count: root.running-count(); active: root.filter == "running"; clicked => { root.filter = "running"; } }
                RequestFilterChip { label: "已完成"; count: root.completed-count(); active: root.filter == "completed"; clicked => { root.filter = "completed"; } }
                RequestFilterChip { label: "失败"; count: root.failed-count(); active: root.filter == "failed"; clicked => { root.filter = "failed"; } }
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: request-list.preferred-height;

                request-list := VerticalLayout {
                    width: parent.width;
                    spacing: 8px;

                    for t[i] in AppState.tasks: RequestRow {
                        data: t;
                        visible: root.matches-filter(t);
                        height: root.matches-filter(t) ? self.preferred-height : 0px;
                    }
                }
            }

            if root.total-count() == 0: Text {
                text: root.mode == "" ? "暂无请求记录" : "当前分类暂无请求";
                color: Theme.palette.fg-disabled;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                horizontal-alignment: center;
            }
        }
    }
}
