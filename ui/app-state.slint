    in-out property <int> gallery-generating-scene-count: 0;
    in-out property <int> gallery-generating-character-count: 0;
    in-out property <int> gallery-generating-ui-count: 0;
    in-out property <int> gallery-generating-effect-count: 0;
    in-out property <int> gallery-generating-animation-scene-count: 0;
