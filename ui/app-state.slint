    in-out property <[ProviderModelOption]> ws-analysis-model-options: [];
    in-out property <bool> ws-skip-existing: false;
    in-out property <string> ws-last-output: "";
    in-out property <[RefImageItem]> ws-ref-images: [];
    in-out property <bool> ws-show-templates: false;
    in-out property <bool> ws-drop-highlight: false;
    in-out property <[string]> ws-template-files: [];
