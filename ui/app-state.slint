    in-out property <[WorkspaceSelectOption]> ws-time-of-day-options: [
        { id: "", label: "自然时间", hint: "" },
        { id: "dawn", label: "清晨", hint: "晨" },
        { id: "noon", label: "正午", hint: "昼" },
        { id: "dusk", label: "黄昏", hint: "昏" },
        { id: "blue_hour", label: "蓝调时刻", hint: "蓝" },
        { id: "night", label: "深夜", hint: "夜" },
    ];
    in-out property <[WorkspaceSelectOption]> ws-lighting-options: [
        { id: "", label: "自然光照", hint: "" },
        { id: "soft_natural", label: "柔和自然光", hint: "自然" },
        { id: "cinematic", label: "电影感", hint: "电影" },
        { id: "dream_glow", label: "梦幻发光", hint: "发光" },
        { id: "high_contrast", label: "高对比", hint: "对比" },
        { id: "volumetric", label: "体积光", hint: "光束" },
        { id: "neon", label: "霓虹灯", hint: "霓虹" },
    ];
    in-out property <string> ws-generation-provider-id: "";
    in-out property <string> ws-generation-model: "";
    // 视频工作台状态
    in-out property <string> ws-video-resolution: "720p";
    in-out property <int> ws-video-duration: 5;
    in-out property <bool> ws-video-enable-audio: false;
    in-out property <[WorkspaceSelectOption]> ws-video-resolution-options: [
        { id: "480p", label: "480p", hint: "标准" },
        { id: "720p", label: "720p", hint: "高清" },
        { id: "1080p", label: "1080p", hint: "超清" },
    ];
    in-out property <[WorkspaceSelectOption]> ws-generation-provider-options: [];
    in-out property <[ProviderModelOption]> ws-generation-model-options: [];
    in-out property <string> ws-analysis-provider-id: "";
    in-out property <string> ws-analysis-model: "";
