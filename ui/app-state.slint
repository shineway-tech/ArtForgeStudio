    in-out property <[WorkspaceSelectOption]> ws-color-mood-options: [
        { id: "", label: "自由风格", hint: "" },
        { id: "warm_healing", label: "温暖治愈", hint: "暖" },
        { id: "cold_oppressive", label: "冷峻压抑", hint: "冷" },
        { id: "high_saturation", label: "高饱和", hint: "艳" },
        { id: "low_saturation", label: "低饱和", hint: "淡" },
