// ArtAIT 应用状态 global。
// Rust 端推送、UI 端订阅。

import { Theme } from "theme.slint";

export struct FeatureItem {
    id: string,
    name: string,
    enabled: bool,
    visible: bool,
}

export struct ProviderInfo {
    has-provider: bool,
    instance-name: string,
    model: string,
}

export struct ProviderInstanceView {
    id: string,
    name: string,
    family: string,
    scopes: string,
    endpoint: string,
    models: string,
    api-style: string,
    has-secret: bool,
    show-in-main-ui: bool,
    has-generation-scope: bool,
    has-analysis-scope: bool,
    is-default-generation: bool,
    is-default-analysis: bool,
}

export struct TaskItem {
    id: string,
    label: string,
    status: string,
    progress: float,
    last-log: string,
    error: string,
    kind: string,
    output-path: string,
    provider-name: string,
    model: string,
    mode: string,
    prompt: string,
    thumb: image,
    has-thumb: bool,
    has-provider-task-id: bool,
    finished-at: string,
    created-at: string,
}

export struct ScriptFileItem {
    path: string,
    name: string,
}

export struct ScriptBlockItem {
    index: int,
    title: string,
    body: string,
}

export struct StoryboardPackageItem {
    index: int,
    label: string,
    shot-count: int,
    markdown: string,
}

export struct StoryboardShotItem {
    index: int,
    label: string,
    markdown: string,
    summary: string,
}

export struct StoryboardShotImageItem {
    package-index: int,
    shot-index: int,
    path: string,
    image: image,
}

export struct ScriptEpisodeItem {
    id: string,
    label: string,
    scenes: string,  // JSON: [{id, label, prompt}]
}

export struct ScriptSceneSummaryItem {
    id: string,
    episode: string,
    label: string,
    characters: string,
    action-preview: string,
    dialogue-count: int,
}

export struct ScriptCharacterSummaryItem {
    name: string,
    role: string,
    scene-count: int,
    dialogue-count: int,
    sample: string,
}

export struct AssetItem {
    id: string,
    path: string,
    name: string,
    domain: string,
    is-video: bool,
    selected: bool,
    bytes: int,
    prompt: string,
    quality: string,
    aspect-ratio: string,
    model: string,
    width: int,
    height: int,
    thumb: image,
}

export struct RefImageItem {
    path: string,
    name: string,
    thumb: image,
}

export struct PromptTemplateGroup {
    name: string,
    files: [string],
}

export struct WorkspaceSelectOption {
    id: string,
    label: string,
    hint: string,
}

export struct ProviderModelOption {
    provider-id: string,
    model: string,
    label: string,
    hint: string,
}

export struct OnboardingState {
    step: int,
    preset: string,
    feature-flags: [bool],
    input-dir: string,
    output-dir: string,
    prompt-dir: string,
    theme-id: string,
    legacy-detected: bool,
    legacy-hint: string,
    last-error: string,
}

export struct CharacterCardItem {
    id: string,
    name: string,
    status: string,
    view-count: int,
    variation-count: int,
    description: string,
    tags: string,
    has-thumb: bool,
    thumb: image,
}

export struct SceneCardItem {
    id: string,
    name: string,
    location: string,
    time_of_day: string,
    atmosphere: string,
    viewpoint_count: int,
    has_thumb: bool,
    thumb: image,
}

export struct ProjectItem {
    id: string,
    name: string,
    description: string,
    created-at: string,
    scene-count: int,
    project-type: string,
}

export global AppState {
    // 路由
    in-out property <string> current-page: "welcome";
    in-out property <string> current-theme-id: "dark";
    in-out property <bool> sidebar-collapsed: false;

    // 工作台模式：art=美术创作, film=影视创作
    in-out property <string> workspace-mode: "art";

    // 是否处于引导模式（true 时主路由被隐藏）
    in-out property <bool> in-onboarding: false;

    // 引导状态
    in-out property <OnboardingState> onboarding: {
        step: 1,
        preset: "general",
        feature-flags: [true, true, true, true, true, true, false, false, false, false, false],
        input-dir: "",
        output-dir: "",
        prompt-dir: "",
        theme-id: "dark",
        legacy-detected: false,
        legacy-hint: "",
        last-error: "",
    };

    // 功能开关 → 侧栏
    in-out property <[FeatureItem]> features: [];

    // provider 信息（顶栏）
    in-out property <ProviderInfo> generation: {
        has-provider: false,
        instance-name: "未配置",
        model: "—",
    };
    in-out property <ProviderInfo> analysis: {
        has-provider: false,
        instance-name: "未配置",
        model: "—",
    };

    // 项目
    in-out property <string> current-project-id: "";
    in-out property <string> current-project-name: "";
    in-out property <bool> has-project: false;
    in-out property <[ProjectItem]> projects: [];
    callback open-project(string);           // 打开已有项目
    callback open-create-project();          // 打开创建项目页
    callback create-project(string, string, string, string); // name, description, path, project_type
    callback close-project();                // 回到通配模式
    callback navigate-to-project();          // 导航到当前项目

    // provider 列表（设置页）
    in-out property <[ProviderInstanceView]> providers: [];

    // 设置页
    in-out property <string> settings-section: "basic";
    in-out property <string> settings-theme-id: "dark";
    in-out property <string> settings-font-family: "Sarasa UI SC";
    in-out property <int> settings-font-size: 14;
    in-out property <string> settings-input-dir: "";
    in-out property <string> settings-output-dir: "";
    in-out property <string> settings-prompt-dir: "";
    in-out property <string> default-project-path: "";
    in-out property <string> settings-upload-api-key: "";
    in-out property <string> settings-upload-api-url: "";
    in-out property <[string]> settings-font-list: [];

    // 添加/编辑 provider 对话框
    in-out property <bool> add-dialog-open: false;
    in-out property <bool> edit-dialog-open: false;
    in-out property <string> edit-instance-id: "";
    in-out property <string> add-name: "OpenAI 兼容";
    in-out property <string> add-endpoint: "https://api.openai.com/v1";
    in-out property <string> add-api-key: "";
    in-out property <string> add-node-kind: "both";
    in-out property <string> add-api-style: "newapi";
    // 每行一个模型，第一行作为默认模型。
    in-out property <string> add-generation-model: "gpt-image-2";
    in-out property <string> add-analysis-model: "gpt-5.5";
    in-out property <string> add-error: "";

    // 任务列表（顶栏 badge + 任务面板）
    in-out property <[TaskItem]> tasks: [];
    in-out property <string> tasks-filter: "all";
    // 最近一次已完成任务的状态："" | "success" | "failed"
    in-out property <string> ws-last-task-status: "";
    in-out property <bool> request-list-open: false;
    in-out property <string> request-list-mode: "";
    in-out property <int> request-list-count-total: 0;
    in-out property <int> request-list-count-running: 0;
    in-out property <int> request-list-count-completed: 0;
    in-out property <int> request-list-count-failed: 0;
    in-out property <int> tasks-count-running: 0;
    in-out property <int> tasks-count-completed: 0;
    in-out property <int> tasks-count-failed: 0;
    in-out property <int> tasks-count-prompt-opt: 0;
    in-out property <int> tasks-count-prompt-opt-running: 0;
    in-out property <int> tasks-count-prompt-opt-completed: 0;
    in-out property <int> tasks-count-prompt-opt-failed: 0;

    // 创作工作台共享状态
    in-out property <string> ws-prompt: "";
    in-out property <bool> prompt-history-open: false;
    in-out property <[string]> prompt-history: [];
    in-out property <string> ws-negative: "";
    in-out property <string> ws-aspect: "1:1";
    in-out property <string> ws-quality: "2K";
    in-out property <int> ws-count: 1;
    in-out property <string> ws-asset-purpose: "";
    in-out property <string> ws-color-mood: "";
    in-out property <string> ws-game-view: "";
    in-out property <string> ws-weather: "";
    in-out property <string> ws-time-of-day: "";
    in-out property <string> ws-lighting: "";
    in-out property <bool> ws-advanced-open: false;
    in-out property <bool> ws-prompt-preview-open: false;
    in-out property <string> ws-final-prompt-preview: "";
    in-out property <string> ws-open-select: "";
    in-out property <[WorkspaceSelectOption]> ws-quality-options: [
        { id: "1K", label: "1K", hint: "标准" },
        { id: "2K", label: "2K", hint: "高清" },
        { id: "4K", label: "4K", hint: "超清" },
    ];
    in-out property <[WorkspaceSelectOption]> ws-aspect-options: [
        { id: "1:1", label: "1:1", hint: "方图" },
        { id: "16:9", label: "16:9", hint: "横图" },
        { id: "9:16", label: "9:16", hint: "竖图" },
    ];
    in-out property <[WorkspaceSelectOption]> ws-count-options: [
        { id: "1", label: "1张", hint: "单张" },
        { id: "2", label: "2张", hint: "两张" },
        { id: "4", label: "4张", hint: "四张" },
