    in-out property <string> prompt-template-content: "";
    in-out property <string> prompt-template-negative: "";
    in-out property <string> prompt-template-error: "";

    // 图库（按 domain 过滤后的视图）
    in-out property <[AssetItem]> assets-all: [];
