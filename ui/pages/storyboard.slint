import { Theme } from "../theme.slint";
import { AppState, StoryboardPackageItem, StoryboardShotItem } from "../app-state.slint";
import { Button } from "../components/button.slint";
import { MarkdownView } from "../components/markdown-view.slint";

component FilmstripShot {
    in property <StoryboardShotItem> data;
    in property <bool> selected;
    in property <bool> has-image: false;
    in property <bool> generating: false;
    callback clicked();

    width: 108px;
    height: 72px;

    Rectangle {
        background: root.selected
            ? Theme.palette.bg-active
            : (touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg);
        border-radius: Theme.shape.radius-sm;
        border-width: root.selected ? 2px : Theme.shape.border-width;
        border-color: root.selected ? Theme.palette.accent : Theme.palette.border;
        animate background, border-color { duration: 120ms; }

        VerticalLayout {
            padding: 6px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 4px;

                Rectangle {
                    width: 20px;
                    height: 20px;
                    background: root.selected ? Theme.palette.accent : Theme.palette.bg-elevated;
                    border-radius: 4px;

                    Text {
                        text: root.data.index + 1;
                        color: root.selected ? #ffffff : Theme.palette.fg-muted;
                        font-family: Theme.typo.family-mono;
                        font-size: Theme.typo.size-xs;
                        font-weight: Theme.typo.weight-bold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Status dot
                if root.generating: Rectangle {
                    width: 6px;
                    height: 6px;
                    y: 7px;
                    background: Theme.palette.accent;
                    border-radius: 3px;
                }

                if root.has-image && !root.generating: Rectangle {
                    width: 6px;
                    height: 6px;
                    y: 7px;
                    background: Theme.palette.success;
                    border-radius: 3px;
                }

                if !root.has-image && !root.generating: Rectangle {
                    width: 6px;
                    height: 6px;
                    y: 7px;
                    background: Theme.palette.fg-disabled;
                    border-radius: 3px;
                }
            }

            Text {
                text: root.data.label;
                color: root.selected ? Theme.palette.fg : Theme.palette.fg-muted;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                font-weight: root.selected ? Theme.typo.weight-bold : Theme.typo.weight-regular;
                overflow: elide;
            }

            Text {
                text: root.data.summary;
                color: Theme.palette.fg-disabled;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                overflow: elide;
            }
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

component PackageTab {
    in property <StoryboardPackageItem> data;
    in property <int> index;
    in property <bool> selected;

    width: max(100px, label.preferred-width + 48px);
    height: 32px;

    Rectangle {
        background: root.selected
            ? Theme.palette.accent
            : (touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg);
        border-radius: Theme.shape.radius-sm;
        border-width: Theme.shape.border-width;
        border-color: root.selected ? Theme.palette.accent-hover : Theme.palette.border;

        label := Text {
            x: 0px;
            width: parent.width;
            height: parent.height;
            text: root.data.label + " · " + root.data.shot-count + "镜";
            color: root.selected ? #ffffff : Theme.palette.fg-muted;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-xs;
            font-weight: Theme.typo.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { AppState.sb-select(root.index); }
        }
    }
}

export component StoryboardPage {
    width: 100%;
    height: 100%;

    property <length> info-panel-width: min(380px, root.width * 0.30);
    property <length> preview-width: root.width - root.info-panel-width - 92px;
    property <bool> has-shots: AppState.sb-shots.length > 0;
    property <bool> single-fulltext-shot: AppState.sb-shots.length == 1 && AppState.sb-shots[0].label == "全文";

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.palette.bg;

        // === 空状态 ===
        if AppState.sb-packages.length == 0: Rectangle {
            x: 18px;
            y: 18px;
            width: parent.width - 36px;
            height: parent.height - 36px;
            background: Theme.palette.bg-elevated;
            border-radius: Theme.shape.radius-md;
            border-width: Theme.shape.border-width;
            border-color: Theme.palette.border;

            VerticalLayout {
                padding: Theme.spacing.xl;
                spacing: Theme.spacing.md;
                alignment: center;

                Text {
                    text: "分镜板";
                    color: Theme.palette.fg;
                    font-family: Theme.typo.family;
                    font-size: 24px;
                    font-weight: Theme.typo.weight-bold;
                    horizontal-alignment: center;
                }

                Text {
                    width: 520px;
                    text: "从剧本页拆分并发送分镜包后，这里会进入制作队列。你可以逐包检查镜头正文、补充画面要求，再生成分镜图。";
                    color: Theme.palette.fg-muted;
                    font-family: Theme.typo.family;
                    font-size: Theme.typo.size-md;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Button {
                    text: "返回剧本";
                    primary: true;
                    clicked => { AppState.navigate(AppState.has-project ? "project_script" : "animation_script"); }
                }
            }
        }

        // === 主界面 ===
        if AppState.sb-packages.length > 0: Rectangle {
            x: 18px;
            y: 10px;
            width: parent.width - 36px;
            height: parent.height - 20px;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: Theme.spacing.sm;

                // 顶栏：分镜包导航
                Rectangle {
                    height: 44px;
                    background: Theme.palette.bg-elevated;
                    border-radius: Theme.shape.radius-md;
                    border-width: Theme.shape.border-width;
                    border-color: Theme.palette.border;

                    HorizontalLayout {
                        padding-left: Theme.spacing.md;
                        padding-right: Theme.spacing.sm;
                        spacing: Theme.spacing.sm;
                        alignment: space-between;

                        Text {
                            text: "分镜板";
                            color: Theme.palette.fg;
                            font-family: Theme.typo.family;
                            font-size: Theme.typo.size-md;
                            font-weight: Theme.typo.weight-bold;
                            vertical-alignment: center;
                        }

                        // 分镜包 tabs
                        Flickable {
                            viewport-width: tabs.preferred-width;
                            interactive: true;
                            height: parent.height;

                            tabs := HorizontalLayout {
                                padding-top: 6px;
                                padding-bottom: 6px;
                                spacing: 6px;

                                for pkg[i] in AppState.sb-packages: PackageTab {
                                    data: pkg;
                                    index: i;
                                    selected: i == AppState.sb-selected;
                                }
                            }
                        }

                        Text {
                            text: AppState.sb-packages.length + " 包";
                            color: Theme.palette.fg-disabled;
                            font-family: Theme.typo.family-mono;
                            font-size: Theme.typo.size-xs;
                            vertical-alignment: center;
                        }
                    }
                }

                // 中部：画面 + 信息
                Rectangle {
                    height: parent.height - 44px - Theme.spacing.sm - 92px;
                    vertical-stretch: 1;

                    HorizontalLayout {
                        width: parent.width;
                        height: parent.height;
                        spacing: Theme.spacing.md;

                        // === 左侧：大图预览 ===
                        Rectangle {
                            width: root.preview-width;
                            height: parent.height;
                            background: #0a0a0a;
                            border-radius: Theme.shape.radius-md;
                            border-width: Theme.shape.border-width;
                            border-color: Theme.palette.border;
                            clip: true;

                            if AppState.sb-current-shot-image-path != "" && AppState.sb-generating-shot != AppState.sb-selected-shot: Image {
                                source: AppState.sb-current-shot-image;
                                width: parent.width;
                                height: parent.height;
                                image-fit: contain;
                            }

                            if AppState.sb-generating-shot == AppState.sb-selected-shot: VerticalLayout {
                                alignment: center;
                                spacing: Theme.spacing.md;

                                Rectangle {
                                    width: 56px;
                                    height: 56px;
                                    background: Theme.palette.bg;
                                    border-radius: 28px;
                                    border-width: 3px;
                                    border-color: Theme.palette.accent;
                                    opacity: 0.8;
                                }

                                Text {
                                    text: "正在生成当前镜头图...";
                                    color: Theme.palette.accent-hover;
                                    font-family: Theme.typo.family;
                                    font-size: Theme.typo.size-sm;
                                    font-weight: Theme.typo.weight-bold;
                                    horizontal-alignment: center;
                                }
                            }

                            if AppState.sb-current-shot-image-path == "" && AppState.sb-generating-shot != AppState.sb-selected-shot: VerticalLayout {
                                alignment: center;
                                spacing: Theme.spacing.sm;

                                Text {
                                    text: root.has-shots ? "点击右侧「生成画面」生成当前镜头图" : "暂无镜头数据";
                                    color: Theme.palette.fg-disabled;
                                    font-family: Theme.typo.family;
                                    font-size: Theme.typo.size-sm;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    width: 360px;
                                    text: root.single-fulltext-shot
                                        ? "当前内容只有\"全文\"一项。建议回剧本页重新拆分。"
                                        : "先生成一张，看看构图和角色表现，满意后再继续。";
                                    color: Theme.palette.fg-disabled;
                                    font-family: Theme.typo.family;
                                    font-size: Theme.typo.size-xs;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // === 右侧：镜头信息 + 操作 ===
                        Rectangle {
                            width: root.info-panel-width;
                            height: parent.height;
                            background: Theme.palette.bg-elevated;
                            border-radius: Theme.shape.radius-md;
                            border-width: Theme.shape.border-width;
                            border-color: Theme.palette.border;

                            Flickable {
                                width: parent.width;
                                height: parent.height;
                                viewport-height: info-content.preferred-height;

                                info-content := VerticalLayout {
                                    width: parent.width;
                                    padding: Theme.spacing.md;
                                    spacing: Theme.spacing.sm;

                                    if root.single-fulltext-shot: Rectangle {
                                        min-height: 52px;
                                        background: Theme.palette.bg-active;
                                        border-radius: Theme.shape.radius-md;
                                        border-width: Theme.shape.border-width;
                                        border-color: Theme.palette.accent;

                                        HorizontalLayout {
                                            padding-left: Theme.spacing.md;
                                            padding-right: Theme.spacing.md;
                                            padding-top: Theme.spacing.sm;
                                            padding-bottom: Theme.spacing.sm;
                                            spacing: Theme.spacing.sm;

                                            Text {
                                                horizontal-stretch: 1;
                                                text: "未拆出独立镜头 — 建议回剧本页重新拆分";
                                                color: Theme.palette.accent-hover;
                                                font-family: Theme.typo.family;
                                                font-size: Theme.typo.size-xs;
                                                wrap: word-wrap;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    // 镜头标签
                                    if root.has-shots: VerticalLayout {
                                        spacing: 2px;

                                        Text {
                                            text: "镜头 " + (AppState.sb-selected-shot + 1) + " / " + AppState.sb-shots.length;
                                            color: Theme.palette.fg;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-md;
                                            font-weight: Theme.typo.weight-bold;
                                        }

                                        Text {
                                            text: AppState.sb-shots[AppState.sb-selected-shot].label;
                                            color: Theme.palette.fg-muted;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-xs;
                                            overflow: elide;
                                        }
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: Theme.palette.border;
                                    }

                                    // 镜头正文预览
                                    if root.has-shots: VerticalLayout {
                                        spacing: 4px;

                                        Text {
                                            text: "镜头正文";
                                            color: Theme.palette.fg-muted;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-xs;
                                            font-weight: Theme.typo.weight-bold;
                                        }

                                        MarkdownView {
                                            height: 100px;
                                            text: AppState.sb-shots[AppState.sb-selected-shot].markdown;
                                            font-size: Theme.typo.size-xs;
                                        }
                                    }

                                    // 画面要求
                                    VerticalLayout {
                                        spacing: 4px;

                                        Text {
                                            text: "画面要求";
                                            color: Theme.palette.fg-muted;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-xs;
                                            font-weight: Theme.typo.weight-bold;
                                        }

                                        Rectangle {
                                            height: 72px;
                                            background: Theme.palette.bg;
                                            border-radius: Theme.shape.radius-sm;
                                            border-width: 1px;
                                            border-color: prompt-input.has-focus ? Theme.palette.accent : Theme.palette.border;

                                            prompt-input := TextInput {
                                                x: 8px;
                                                y: 8px;
                                                width: parent.width - 16px;
                                                height: parent.height - 16px;
                                                color: Theme.palette.fg;
                                                font-family: Theme.typo.family;
                                                font-size: Theme.typo.size-xs;
                                                wrap: word-wrap;
                                                single-line: false;
                                                text <=> AppState.sb-shot-prompt;
                                            }

                                            if AppState.sb-shot-prompt == "": Text {
                                                x: 8px;
                                                y: 8px;
                                                width: parent.width - 16px;
                                                text: "补全景别、机位、运动、光影、角色状态...";
                                                color: Theme.palette.fg-disabled;
                                                font-family: Theme.typo.family;
                                                font-size: Theme.typo.size-xs;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    // 导演备注
                                    VerticalLayout {
                                        spacing: 4px;

                                        Text {
                                            text: "导演备注";
                                            color: Theme.palette.fg-muted;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-xs;
                                            font-weight: Theme.typo.weight-bold;
                                        }

                                        Rectangle {
                                            height: 48px;
                                            background: Theme.palette.bg;
                                            border-radius: Theme.shape.radius-sm;
                                            border-width: 1px;
                                            border-color: note-input.has-focus ? Theme.palette.accent : Theme.palette.border;

                                            note-input := TextInput {
                                                x: 8px;
                                                y: 6px;
                                                width: parent.width - 16px;
                                                height: parent.height - 12px;
                                                color: Theme.palette.fg;
                                                font-family: Theme.typo.family;
                                                font-size: Theme.typo.size-xs;
                                                wrap: word-wrap;
                                                single-line: false;
                                                text <=> AppState.sb-shot-note;
                                            }

                                            if AppState.sb-shot-note == "": Text {
                                                x: 8px;
                                                y: 6px;
                                                width: parent.width - 16px;
                                                text: "景别、运动、焦段、表演节奏...";
                                                color: Theme.palette.fg-disabled;
                                                font-family: Theme.typo.family;
                                                font-size: Theme.typo.size-xs;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    // 参考图
                                    VerticalLayout {
                                        spacing: 4px;

                                        HorizontalLayout {
                                            spacing: Theme.spacing.sm;

                                            Text {
                                                horizontal-stretch: 1;
                                                text: "参考图 · " + AppState.sb-ref-images.length;
                                                color: Theme.palette.fg-muted;
                                                font-family: Theme.typo.family;
                                                font-size: Theme.typo.size-xs;
                                                font-weight: Theme.typo.weight-bold;
                                                vertical-alignment: center;
                                            }

                                            Button {
                                                text: "添加";
                                                height: 24px;
                                                clicked => { AppState.sb-add-reference-images(); }
                                            }

                                            if AppState.sb-ref-images.length > 0: Button {
                                                text: "清空";
                                                height: 24px;
                                                clicked => { AppState.sb-clear-reference-images(); }
                                            }
                                        }

                                        if AppState.sb-ref-images.length > 0: HorizontalLayout {
                                            spacing: 4px;

                                            for img[i] in AppState.sb-ref-images: Rectangle {
                                                width: 42px;
                                                height: 42px;
                                                background: Theme.palette.bg;
                                                border-radius: Theme.shape.radius-sm;
                                                border-width: 1px;
                                                border-color: Theme.palette.border;
                                                clip: true;

                                                Image {
                                                    source: img.thumb;
                                                    width: parent.width;
                                                    height: parent.height;
                                                    image-fit: cover;
                                                }

                                                TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { AppState.sb-remove-reference-image(i); }
                                                }
                                            }
                                        }
                                    }

                                    // 画幅比例
                                    VerticalLayout {
                                        spacing: 4px;

                                        Text {
                                            text: "画幅比例";
                                            color: Theme.palette.fg-muted;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-xs;
                                            font-weight: Theme.typo.weight-bold;
                                        }

                                        HorizontalLayout {
                                            spacing: 4px;

                                            for ratio in ["16:9", "9:16", "1:1"]: Rectangle {
                                                width: 52px;
                                                height: 28px;
                                                background: AppState.sb-aspect == ratio
                                                    ? Theme.palette.accent
                                                    : (touch-ratio.has-hover ? Theme.palette.bg-hover : Theme.palette.bg);
                                                border-radius: Theme.shape.radius-sm;
                                                border-width: 1px;
                                                border-color: AppState.sb-aspect == ratio ? Theme.palette.accent-hover : Theme.palette.border;

                                                Text {
                                                    text: ratio;
                                                    color: AppState.sb-aspect == ratio ? #ffffff : Theme.palette.fg-muted;
                                                    font-family: Theme.typo.family;
                                                    font-size: Theme.typo.size-xs;
                                                    font-weight: Theme.typo.weight-medium;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                touch-ratio := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { AppState.sb-aspect = ratio; }
                                                }
                                            }
                                        }
                                    }

                                    Rectangle { height: 4px; }

                                    // 生成按钮
                                    Button {
                                        text: "生成画面";
                                        height: 40px;
                                        primary: true;
                                        disabled: !AppState.generation.has-provider || AppState.sb-shot-prompt == "";
                                        clicked => { AppState.sb-generate(); }
                                    }
                                }
                            }
                        }
                    }
                }

                // === 底部：胶片条 ===
                if root.has-shots && !root.single-fulltext-shot: Rectangle {
                    height: 84px;
                    background: Theme.palette.bg-elevated;
                    border-radius: Theme.shape.radius-md;
                    border-width: Theme.shape.border-width;
                    border-color: Theme.palette.border;

                    HorizontalLayout {
                        padding: 6px;
                        spacing: 0px;

                        // 左箭头
                        Rectangle {
                            width: 28px;
                            height: parent.height;
                            background: transparent;

                            Image {
                                x: 4px;
                                y: (parent.height - 16px) / 2;
                                width: 16px;
                                height: 16px;
                                source: @image-url("../assets/icons/chevron-left.svg");
                                colorize: Theme.palette.fg-muted;
                            }

                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if AppState.sb-selected-shot > 0 {
                                        AppState.sb-select-shot(AppState.sb-selected-shot - 1);
                                    }
                                }
                            }
                        }

                        // 胶片条滚动区域
                        Flickable {
                            horizontal-stretch: 1;
                            viewport-width: filmstrip.preferred-width;

                            filmstrip := HorizontalLayout {
                                spacing: 4px;

                                for shot in AppState.sb-shots: FilmstripShot {
                                    data: shot;
                                    selected: shot.index == AppState.sb-selected-shot;
                                    generating: AppState.sb-generating-shot == shot.index;
                                    has-image: false;
                                    clicked => { AppState.sb-select-shot(shot.index); }
                                }
                            }
                        }

                        // 右箭头
                        Rectangle {
                            width: 28px;
                            height: parent.height;
                            background: transparent;

                            Image {
                                x: 8px;
                                y: (parent.height - 16px) / 2;
                                width: 16px;
                                height: 16px;
                                source: @image-url("../assets/icons/chevron-right.svg");
                                colorize: Theme.palette.fg-muted;
                            }

                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if AppState.sb-selected-shot < AppState.sb-shots.length - 1 {
                                        AppState.sb-select-shot(AppState.sb-selected-shot + 1);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
