import { Theme } from "../theme.slint";
import { AppState } from "../app-state.slint";
import { Button } from "../components/button.slint";
import { InlineSelect } from "../components/inline-select.slint";
import { MarkdownView } from "../components/markdown-view.slint";

component SectionLabel {
    in property <string> text;

    Text {
        text: root.text;
        color: Theme.palette.fg-muted;
        font-family: Theme.typo.family;
        font-size: Theme.typo.size-xs;
        font-weight: Theme.typo.weight-bold;
    }
}

component StatusPill {
    in property <string> text;
    in property <brush> color: Theme.palette.fg-muted;

    width: max(74px, label.preferred-width + 24px);
    height: 24px;

    Rectangle {
        background: Theme.palette.bg;
        border-radius: 12px;
        border-width: Theme.shape.border-width;
        border-color: Theme.palette.border;

        label := Text {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.text;
            color: root.color;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-xs;
            font-weight: Theme.typo.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component MetricText {
    in property <string> label;
    in property <string> value;

    width: max(72px, label-text.preferred-width + value-text.preferred-width + 28px);
    height: 26px;

    Rectangle {
        background: Theme.palette.bg;
        border-radius: Theme.shape.radius-sm;
        border-width: Theme.shape.border-width;
        border-color: Theme.palette.border;

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 4px;

            value-text := Text {
                text: root.value;
                color: Theme.palette.fg;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                font-weight: Theme.typo.weight-bold;
                vertical-alignment: center;
            }

            label-text := Text {
                text: root.label;
                color: Theme.palette.fg-disabled;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                vertical-alignment: center;
            }
        }
    }
}

component ViewButton {
    in property <string> id;
    in property <string> label;

    width: 78px;
    height: 28px;

    Rectangle {
        background: AppState.script-view-mode == root.id
            ? Theme.palette.accent
            : (touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg);
        border-radius: Theme.shape.radius-sm;
        border-width: Theme.shape.border-width;
        border-color: AppState.script-view-mode == root.id ? Theme.palette.accent-hover : Theme.palette.border;

        Text {
            text: root.label;
            color: AppState.script-view-mode == root.id ? #ffffff : Theme.palette.fg-muted;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-xs;
            font-weight: Theme.typo.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { AppState.script-view-mode = root.id; }
        }
    }
}

component EmptyPanel {
    in property <string> title;
    in property <string> body;
    in property <string> action-text;
    in property <bool> show-action: false;
    callback clicked();

    min-height: 220px;
    vertical-stretch: 1;
    horizontal-stretch: 1;

    Rectangle {
        width: parent.width;
        height: parent.height;
        vertical-stretch: 1;
        background: Theme.palette.bg;
        border-radius: Theme.shape.radius-md;
        border-width: Theme.shape.border-width;
        border-color: Theme.palette.border;

        VerticalLayout {
            padding: Theme.spacing.xl;
            spacing: Theme.spacing.sm;
            alignment: center;

            Text {
                text: root.title;
                color: Theme.palette.fg;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-md;
                font-weight: Theme.typo.weight-bold;
                horizontal-alignment: center;
            }

            Text {
                width: 320px;
                text: root.body;
                color: Theme.palette.fg-muted;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            if root.show-action: Button {
                text: root.action-text;
                primary: true;
                clicked => { root.clicked(); }
            }
        }
    }
}

component ScriptFileRow {
    in property <string> name;
    in property <string> path;
    in property <bool> selected;

    height: 34px;

    Rectangle {
        background: root.selected
            ? Theme.palette.bg-active
            : (touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg);
        border-radius: Theme.shape.radius-sm;
        border-width: root.selected ? Theme.shape.border-width : 0px;
        border-color: root.selected ? Theme.palette.accent : transparent;
        animate background, border-color { duration: 120ms; }

        HorizontalLayout {
            padding-left: Theme.spacing.sm;
            padding-right: Theme.spacing.sm;
            spacing: Theme.spacing.sm;

            Rectangle {
                width: 4px;
                height: parent.height - 14px;
                y: 7px;
                background: root.selected ? Theme.palette.accent : Theme.palette.border-strong;
                border-radius: 2px;
            }

            Text {
                horizontal-stretch: 1;
                text: root.name;
                color: root.selected ? Theme.palette.fg : Theme.palette.fg-muted;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                font-weight: root.selected ? Theme.typo.weight-bold : Theme.typo.weight-regular;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { AppState.script-select(root.path); }
        }
    }
}

component PipelineButton {
    in property <string> label;
    in property <string> stage;
    in property <bool> disabled: false;

    height: 28px;

    Rectangle {
        background: touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg;
        border-radius: Theme.shape.radius-sm;
        border-width: Theme.shape.border-width;
        border-color: Theme.palette.border;

        Text {
            x: 0px;
            width: parent.width;
            height: parent.height;
            text: root.label;
            color: root.disabled ? Theme.palette.fg-disabled : Theme.palette.fg-muted;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-xs;
            font-weight: Theme.typo.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            enabled: !root.disabled;
            clicked => { AppState.script-run-stage(root.stage); }
        }
    }
}

export component ScriptPage {
    width: 100%;
    height: 100%;

    property <length> library-width: 300px;
    property <length> editor-width: max(560px, root.width - root.library-width - 64px);

    Rectangle {
        width: root.width;
        height: root.height;
        background: Theme.palette.bg;

        Rectangle {
            x: 12px;
            y: 10px;
            width: parent.width - 24px;
            height: parent.height - 20px;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: Theme.spacing.sm;

                // 顶部状态栏
                Rectangle {
                    height: 44px;
                    background: Theme.palette.bg-elevated;
                    border-radius: Theme.shape.radius-md;
                    border-width: Theme.shape.border-width;
                    border-color: Theme.palette.border;

                    HorizontalLayout {
                        padding-left: Theme.spacing.lg;
                        padding-right: Theme.spacing.md;
                        spacing: Theme.spacing.md;
                        alignment: space-between;

                        VerticalLayout {
                            spacing: 0px;
                            horizontal-stretch: 1;

                            Text {
                                text: "剧本工作台";
                                color: Theme.palette.fg;
                                font-family: Theme.typo.family;
                                font-size: Theme.typo.size-md;
                                font-weight: Theme.typo.weight-bold;
                            }

                            Text {
                                text: AppState.current-project-name == "" ? "影视创作模式" : AppState.current-project-name;
                                color: Theme.palette.fg-muted;
                                font-family: Theme.typo.family;
                                font-size: Theme.typo.size-xs;
                                overflow: elide;
                            }
                        }

                        StatusPill {
                            text: AppState.script-files.length + " 脚本";
                            color: Theme.palette.accent-hover;
                        }

                        StatusPill {
                            text: AppState.script-parse-status == "ready" ? "已解析" : "待解析";
                            color: AppState.script-parse-status == "ready" ? Theme.palette.success : Theme.palette.fg-disabled;
                        }

                        StatusPill {
                            text: AppState.analysis.has-provider ? "推理可用" : "未配置推理";
                            color: AppState.analysis.has-provider ? Theme.palette.success : Theme.palette.error;
                        }
                    }
                }

                // 主体：剧本库 + 编辑区
                HorizontalLayout {
                    width: parent.width;
                    height: parent.height - 44px - Theme.spacing.sm;
                    vertical-stretch: 1;
                    spacing: Theme.spacing.md;

                    // === 左侧：剧本库 ===
                    Rectangle {
                        width: root.library-width;
                        height: parent.height;
                        vertical-stretch: 1;
                        horizontal-stretch: 0;
                        background: Theme.palette.bg-elevated;
                        border-radius: Theme.shape.radius-md;
                        border-width: Theme.shape.border-width;
                        border-color: Theme.palette.border;

                        VerticalLayout {
                            padding: Theme.spacing.md;
                            spacing: Theme.spacing.sm;

                            Text {
                                height: 32px;
                                text: "剧本库";
                                color: Theme.palette.fg;
                                font-family: Theme.typo.family;
                                font-size: Theme.typo.size-md;
                                font-weight: Theme.typo.weight-bold;
                                vertical-alignment: center;
                            }

                            // 创作入口按钮
                            HorizontalLayout {
                                spacing: Theme.spacing.xs;

                                Button {
                                    text: "AI 创作";
                                    height: 32px;
                                    horizontal-stretch: 1;
                                    primary: true;
                                    clicked => {
                                        AppState.script-theme = "";
                                        AppState.script-generate-dialog-open = true;
                                    }
                                }

                                Button {
                                    text: "导入剧本";
                                    height: 32px;
                                    horizontal-stretch: 1;
                                    clicked => {
                                        AppState.script-theme = "";
                                        AppState.script-import-dialog-open = true;
                                    }
                                }
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.palette.border;
                            }

                            if AppState.script-files.length == 0: Rectangle {
                                vertical-stretch: 1;
                                background: Theme.palette.bg;
                                border-radius: Theme.shape.radius-sm;
                                border-width: 1px;
                                border-color: Theme.palette.border;

                                VerticalLayout {
                                    padding: Theme.spacing.lg;
                                    alignment: center;
                                    spacing: Theme.spacing.sm;

                                    Text {
                                        text: "暂无剧本";
                                        color: Theme.palette.fg;
                                        font-family: Theme.typo.family;
                                        font-size: Theme.typo.size-sm;
                                        font-weight: Theme.typo.weight-bold;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        width: 240px;
                                        text: "点击上方按钮创建或导入剧本。";
                                        color: Theme.palette.fg-muted;
                                        font-family: Theme.typo.family;
                                        font-size: Theme.typo.size-xs;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            if AppState.script-files.length > 0: Flickable {
                                vertical-stretch: 1;
                                viewport-height: files.preferred-height;
                                interactive: true;

                                files := VerticalLayout {
                                    width: parent.width;
                                    spacing: 6px;

                                    for f in AppState.script-files: ScriptFileRow {
                                        name: f.name;
                                        path: f.path;
                                        selected: AppState.script-selected == f.path;
                                    }
                                }
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.palette.border;
                            }

                            HorizontalLayout {
                                height: 36px;
                                spacing: Theme.spacing.sm;

                                Button {
                                    text: "打开目录";
                                    height: 32px;
                                    horizontal-stretch: 1;
                                    clicked => { AppState.script-open-dir(); }
                                }

                                Button {
                                    text: "删除";
                                    height: 32px;
                                    horizontal-stretch: 1;
                                    disabled: AppState.script-selected == "";
                                    clicked => { AppState.script-delete-file(AppState.script-selected); }
                                }
                            }
                        }
                    }

                    // === 右侧：编辑器 ===
                    Rectangle {
                        width: root.editor-width;
                        height: parent.height;
                        vertical-stretch: 1;
                        horizontal-stretch: 0;
                        background: Theme.palette.bg-elevated;
                        border-radius: Theme.shape.radius-md;
                        border-width: Theme.shape.border-width;
                        border-color: Theme.palette.border;

                        VerticalLayout {
                            padding: Theme.spacing.md;
                            spacing: Theme.spacing.sm;

                            // 工具栏
                            HorizontalLayout {
                                height: 36px;
                                spacing: Theme.spacing.sm;
                                alignment: space-between;

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;

                                    Text {
                                        text: "当前剧本";
                                        color: Theme.palette.fg;
                                        font-family: Theme.typo.family;
                                        font-size: Theme.typo.size-md;
                                        font-weight: Theme.typo.weight-bold;
                                    }

                                    Text {
                                        text: AppState.script-parse-summary == ""
                                            ? (AppState.script-selected == "" ? "选择、导入或生成脚本后在此预览正文" : AppState.script-selected)
                                            : AppState.script-parse-summary;
                                        color: Theme.palette.fg-disabled;
                                        font-family: Theme.typo.family;
                                        font-size: Theme.typo.size-xs;
                                        overflow: elide;
                                    }
                                }

                                PipelineButton {
                                    label: "解析";
                                    stage: "parse";
                                    disabled: AppState.script-content == "";
                                }

                                PipelineButton {
                                    label: "场景校准";
                                    stage: "scene_calibrate";
                                    disabled: !AppState.analysis.has-provider || AppState.script-content == "";
                                }

                                PipelineButton {
                                    label: "角色入库";
                                    stage: "character";
                                    disabled: AppState.script-content == "";
                                }

                                PipelineButton {
                                    label: "分镜拆分";
                                    stage: "shot";
                                    disabled: AppState.script-content == "";
                                }

                                Text {
                                    text: "|";
                                    color: Theme.palette.border-strong;
                                    font-family: Theme.typo.family;
                                    vertical-alignment: center;
                                }

                                Button {
                                    text: "保存";
                                    height: 28px;
                                    disabled: AppState.script-content == "";
                                    clicked => { AppState.script-save-current(); }
                                }

                                Button {
                                    text: "发到分镜板";
                                    height: 28px;
                                    disabled: AppState.script-content == "";
                                    clicked => { AppState.script-send-to-storyboard(AppState.script-content); }
                                }
                            }

                            // 无内容时
                            if AppState.script-content == "": EmptyPanel {
                                title: "还没有打开剧本";
                                body: "从左侧选择历史剧本，或通过 AI 创作 / 导入剧本创建新内容。";
                                show-action: false;
                                clicked => { AppState.script-refresh(); }
                            }

                            // 统计指标
                            if AppState.script-content != "": HorizontalLayout {
                                height: 26px;
                                spacing: 6px;

                                MetricText {
                                    label: "集";
                                    value: AppState.script-episode-count;
                                }

                                MetricText {
                                    label: "场";
                                    value: AppState.script-parsed-scene-count;
                                }

                                MetricText {
                                    label: "角色";
                                    value: AppState.script-character-count;
                                }

                                MetricText {
                                    label: "对白";
                                    value: AppState.script-dialogue-count;
                                }

                                Text { horizontal-stretch: 1; text: ""; }
                            }

                            // 视图切换
                            if AppState.script-content != "": HorizontalLayout {
                                height: 30px;
                                spacing: Theme.spacing.sm;

                                ViewButton { id: "edit"; label: "编辑"; }
                                ViewButton { id: "preview"; label: "预览"; }
                                ViewButton { id: "structure"; label: "解析结果"; width: 92px; }

                                Text {
                                    horizontal-stretch: 1;
                                    text: AppState.script-selected == "" ? "未保存的新剧本" : AppState.script-selected;
                                    color: Theme.palette.fg-disabled;
                                    font-family: Theme.typo.family-mono;
                                    font-size: Theme.typo.size-xs;
                                    vertical-alignment: center;
                                    horizontal-alignment: right;
                                    overflow: elide;
                                }
                            }

                            // 编辑视图
                            if AppState.script-content != "" && AppState.script-view-mode == "edit": Rectangle {
                                vertical-stretch: 1;
                                background: Theme.palette.bg;
                                border-radius: Theme.shape.radius-md;
                                border-width: Theme.shape.border-width;
                                border-color: editor.has-focus ? Theme.palette.accent : Theme.palette.border;
                                clip: true;

                                editor := TextInput {
                                    x: Theme.spacing.md;
                                    y: Theme.spacing.md;
                                    width: parent.width - 2 * Theme.spacing.md;
                                    height: parent.height - 2 * Theme.spacing.md;
                                    color: Theme.palette.fg;
                                    font-family: Theme.typo.family-mono;
                                    font-size: Theme.typo.size-xs;
                                    wrap: word-wrap;
                                    single-line: false;
                                    text <=> AppState.script-content;
                                }
                            }

                            // 预览视图
                            if AppState.script-content != "" && AppState.script-view-mode == "preview": Rectangle {
                                vertical-stretch: 1;
                                background: Theme.palette.bg;
                                border-radius: Theme.shape.radius-md;
                                border-width: Theme.shape.border-width;
                                border-color: Theme.palette.border;
                                clip: true;

                                Flickable {
                                    x: Theme.spacing.md;
                                    y: Theme.spacing.md;
                                    width: parent.width - 2 * Theme.spacing.md;
                                    height: parent.height - 2 * Theme.spacing.md;
                                    viewport-height: block-list.preferred-height;

                                    block-list := VerticalLayout {
                                        width: parent.width;
                                        spacing: Theme.spacing.sm;

                                        for block in AppState.script-blocks: Rectangle {
                                            min-height: 72px;
                                            background: Theme.palette.bg-elevated;
                                            border-radius: Theme.shape.radius-sm;
                                            border-width: Theme.shape.border-width;
                                            border-color: Theme.palette.border;

                                            VerticalLayout {
                                                padding: Theme.spacing.sm;
                                                spacing: 6px;

                                                Text {
                                                    text: block.title;
                                                    color: Theme.palette.fg;
                                                    font-family: Theme.typo.family;
                                                    font-size: Theme.typo.size-sm;
                                                    font-weight: Theme.typo.weight-bold;
                                                    overflow: elide;
                                                }

                                                Text {
                                                    text: block.body;
                                                    color: Theme.palette.fg-muted;
                                                    font-family: Theme.typo.family-mono;
                                                    font-size: Theme.typo.size-xs;
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // 解析结果视图
                            if AppState.script-content != "" && AppState.script-view-mode == "structure": Rectangle {
                                vertical-stretch: 1;
                                background: Theme.palette.bg;
                                border-radius: Theme.shape.radius-md;
                                border-width: Theme.shape.border-width;
                                border-color: Theme.palette.border;
                                clip: true;

                                Flickable {
                                    x: Theme.spacing.md;
                                    y: Theme.spacing.md;
                                    width: parent.width - 2 * Theme.spacing.md;
                                    height: parent.height - 2 * Theme.spacing.md;
                                    viewport-height: structure-content.preferred-height;

                                    structure-content := VerticalLayout {
                                        width: parent.width;
                                        spacing: Theme.spacing.sm;

                                        SectionLabel { text: "场景解析 · " + AppState.script-scenes.length; }

                                        if AppState.script-scenes.length == 0: Text {
                                            text: AppState.script-parse-status == "error"
                                                ? AppState.script-parse-summary
                                                : "暂无场景结构。点击解析或保存后刷新。";
                                            color: Theme.palette.fg-muted;
                                            font-family: Theme.typo.family;
                                            font-size: Theme.typo.size-xs;
                                            wrap: word-wrap;
                                        }

                                        for scene in AppState.script-scenes: Rectangle {
                                            min-height: 86px;
                                            background: Theme.palette.bg-elevated;
                                            border-radius: Theme.shape.radius-sm;
                                            border-width: Theme.shape.border-width;
                                            border-color: Theme.palette.border;

                                            VerticalLayout {
                                                padding: Theme.spacing.sm;
                                                spacing: 4px;

                                                HorizontalLayout {
                                                    spacing: Theme.spacing.sm;

                                                    Text {
                                                        horizontal-stretch: 1;
                                                        text: scene.label;
                                                        color: Theme.palette.fg;
                                                        font-family: Theme.typo.family;
                                                        font-size: Theme.typo.size-sm;
                                                        font-weight: Theme.typo.weight-bold;
                                                        overflow: elide;
                                                    }

                                                    Text {
                                                        text: scene.dialogue-count + " 对白";
                                                        color: Theme.palette.accent-hover;
                                                        font-family: Theme.typo.family;
                                                        font-size: Theme.typo.size-xs;
                                                    }
                                                }

                                                Text {
                                                    text: scene.episode + (scene.characters == "" ? "" : " · " + scene.characters);
                                                    color: Theme.palette.fg-disabled;
                                                    font-family: Theme.typo.family;
                                                    font-size: Theme.typo.size-xs;
                                                    overflow: elide;
                                                }

                                                Text {
                                                    text: scene.action-preview;
                                                    color: Theme.palette.fg-muted;
                                                    font-family: Theme.typo.family;
                                                    font-size: Theme.typo.size-xs;
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }

                                        SectionLabel { text: "角色解析 · " + AppState.script-characters.length; }

                                        for character in AppState.script-characters: Rectangle {
                                            min-height: 66px;
                                            background: Theme.palette.bg-elevated;
                                            border-radius: Theme.shape.radius-sm;
                                            border-width: Theme.shape.border-width;
                                            border-color: Theme.palette.border;

                                            VerticalLayout {
                                                padding: Theme.spacing.sm;
                                                spacing: 3px;

                                                HorizontalLayout {
                                                    spacing: Theme.spacing.sm;

                                                    Text {
                                                        horizontal-stretch: 1;
                                                        text: character.name + " · " + character.role;
                                                        color: Theme.palette.fg;
                                                        font-family: Theme.typo.family;
                                                        font-size: Theme.typo.size-sm;
                                                        font-weight: Theme.typo.weight-bold;
                                                        overflow: elide;
                                                    }

                                                    Text {
                                                        text: character.scene-count + " 场 / " + character.dialogue-count + " 句";
                                                        color: Theme.palette.fg-disabled;
                                                        font-family: Theme.typo.family;
                                                        font-size: Theme.typo.size-xs;
                                                    }
                                                }

                                                Text {
                                                    text: character.sample == "" ? "暂无对白样本" : character.sample;
                                                    color: Theme.palette.fg-muted;
                                                    font-family: Theme.typo.family;
                                                    font-size: Theme.typo.size-xs;
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // 分镜包列表（底部）
                            if AppState.script-packages.length > 0: Rectangle {
                                height: 128px;
                                background: Theme.palette.bg;
                                border-radius: Theme.shape.radius-md;
                                border-width: Theme.shape.border-width;
                                border-color: Theme.palette.border;

                                VerticalLayout {
                                    padding: Theme.spacing.sm;
                                    spacing: 4px;

                                    SectionLabel { text: "已拆分分镜包 · " + AppState.script-packages.length; }

                                    Flickable {
                                        viewport-height: pkg-list.preferred-height;

                                        pkg-list := VerticalLayout {
                                            spacing: 3px;

                                            for pkg[i] in AppState.script-packages: Rectangle {
                                                height: 30px;
                                                background: touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg-elevated;
                                                border-radius: Theme.shape.radius-sm;

                                                HorizontalLayout {
                                                    padding-left: Theme.spacing.sm;
                                                    spacing: Theme.spacing.sm;

                                                    Text {
                                                        horizontal-stretch: 1;
                                                        text: pkg.label + " · " + pkg.shot-count + " 镜头";
                                                        color: Theme.palette.fg;
                                                        font-family: Theme.typo.family;
                                                        font-size: Theme.typo.size-xs;
                                                        vertical-alignment: center;
                                                        overflow: elide;
                                                    }

                                                    Button {
                                                        text: "发送";
                                                        clicked => { AppState.script-send-package(i); }
                                                    }
                                                }

                                                touch := TouchArea {}
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;
                    }
                }
            }
        }
    }
}
