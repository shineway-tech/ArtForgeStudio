import { Theme } from "../theme.slint";
import { AppState } from "../app-state.slint";

component ThemeCard {
    in property <string> id;
    in property <string> title;
    in property <string> subtitle;
    in property <color> bg-preview;
    in property <color> fg-preview;
    in property <color> accent-preview;

    height: 140px;

    Rectangle {
        background: AppState.onboarding.theme-id == root.id
            ? Theme.palette.bg-active
            : (touch.has-hover ? Theme.palette.bg-hover : Theme.palette.bg-elevated);
        border-radius: Theme.shape.radius-lg;
        border-width: AppState.onboarding.theme-id == root.id ? 2px : Theme.shape.border-width;
        border-color: AppState.onboarding.theme-id == root.id
            ? Theme.palette.accent
            : Theme.palette.border;
        animate background, border-color { duration: 150ms; }

        VerticalLayout {
            padding: Theme.spacing.md;
            spacing: Theme.spacing.sm;

            // 缩略预览
            Rectangle {
                background: root.bg-preview;
                border-radius: Theme.shape.radius-sm;
                height: 56px;
                border-width: 1px;
                border-color: Theme.palette.border;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 6px;
                    padding-bottom: 6px;
                    spacing: 6px;

                    Rectangle {
                        background: root.accent-preview;
                        border-radius: 3px;
                        width: 24px;
                        height: 12px;
                    }

                    Rectangle {
                        background: root.fg-preview;
                        border-radius: 2px;
                        width: 60px;
                        height: 6px;
                        y: 3px;
                    }
                }
            }

            Text {
                text: root.title;
                color: Theme.palette.fg;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-md;
                font-weight: Theme.typo.weight-bold;
            }

            Text {
                text: root.subtitle;
                color: Theme.palette.fg-muted;
                font-family: Theme.typo.family;
                font-size: Theme.typo.size-xs;
                wrap: word-wrap;
            }
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { AppState.onboarding-pick-theme(root.id); }
        }
    }
}

export component StepTheme {
    VerticalLayout {
        spacing: Theme.spacing.md;

        Text {
            text: "界面外观";
            color: Theme.palette.fg;
            font-family: Theme.typo.family;
            font-size: 24px;
            font-weight: Theme.typo.weight-bold;
        }

        Text {
            text: "选一个主题。之后可以在设置里随时切换。";
            color: Theme.palette.fg-muted;
            font-family: Theme.typo.family;
            font-size: Theme.typo.size-md;
        }

        GridLayout {
            spacing: Theme.spacing.md;

            ThemeCard {
                id: "dark";
                title: "深紫（推荐）";
                subtitle: "旧版默认深色主题";
                bg-preview: #06060e;
                fg-preview: #e4e4f4;
                accent-preview: #4f46e5;
                horizontal-stretch: 1;
            }

            ThemeCard {
                id: "ocean";
                title: "深海蓝";
                subtitle: "冷色低饱和工作台";
                bg-preview: #060b14;
                fg-preview: #e4ecf8;
                accent-preview: #0ea5e9;
                horizontal-stretch: 1;
            }

            ThemeCard {
                id: "forest";
                title: "森林绿";
                subtitle: "柔和绿色暗色主题";
                bg-preview: #060e0a;
                fg-preview: #e4f4ec;
                accent-preview: #22c55e;
                horizontal-stretch: 1;
            }

            ThemeCard {
                id: "cyber";
                title: "赛博紫";
                subtitle: "偏霓虹的暗色主题";
                bg-preview: #0a0410;
                fg-preview: #f4dcf8;
                accent-preview: #d946ef;
                horizontal-stretch: 1;
            }

            ThemeCard {
                id: "light";
                title: "素白";
                subtitle: "旧版白色主题";
                bg-preview: #fafafc;
                fg-preview: #1f2030;
                accent-preview: #4f46e5;
                horizontal-stretch: 1;
            }

            ThemeCard {
                id: "cream";
                title: "奶白";
                subtitle: "旧版暖色浅主题";
                bg-preview: #f2ebe0;
                fg-preview: #3a3025;
                accent-preview: #c96b73;
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            background: Theme.palette.bg-elevated;
            border-radius: Theme.shape.radius-md;
            border-width: 1px;
            border-color: Theme.palette.border;

            HorizontalLayout {
                padding: Theme.spacing.sm;
                spacing: Theme.spacing.sm;

                Image {
                    width: 16px;
                    height: 16px;
                    source: @image-url("../assets/icons/info.svg");
                    colorize: Theme.palette.accent;
                    vertical-alignment: center;
                }

                Text {
                    text: "用户自定义主题：在设置里选\"自定义\"，编辑 themes/user.toml 即时生效。";
                    color: Theme.palette.fg-muted;
                    font-family: Theme.typo.family;
                    font-size: Theme.typo.size-sm;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }
}
